---
---
<div class="space-y-5">
  <div id="prp-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-10 text-center cursor-pointer transition-colors">
    <input type="file" id="prp-file" accept=".pdf" class="hidden" />
    <div class="text-5xl mb-3">🔄</div>
    <p class="text-slate-200 font-semibold text-lg mb-1">Drop your PDF here</p>
    <p class="text-slate-500 text-sm mb-4">or click to browse — page previews load automatically</p>
    <span class="inline-block px-4 py-2 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Choose PDF</span>
  </div>

  <!-- Loading progress -->
  <div id="prp-loading" class="hidden">
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">⏳</div>
      <p class="text-slate-300 font-medium mb-1" id="prp-loading-msg">Generating page previews…</p>
      <p class="text-slate-500 text-xs mb-4">Rendering each page so you can see exactly what's on it</p>
      <div class="w-full bg-slate-800 rounded-full h-2 max-w-sm mx-auto">
        <div id="prp-loading-bar" class="bg-orange-500 h-2 rounded-full transition-all duration-200" style="width:0%"></div>
      </div>
    </div>
  </div>

  <!-- Main panel -->
  <div id="prp-panel" class="hidden space-y-4">
    <!-- File info bar -->
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="prp-name" class="text-slate-200 text-sm font-semibold truncate"></p>
        <p id="prp-info" class="text-slate-500 text-xs mt-0.5"></p>
      </div>
      <button id="prp-change" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-lg shrink-0 transition-colors">Change file</button>
    </div>

    <!-- Mode tabs -->
    <div class="flex gap-1 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-1">
      <button data-rmode="batch" class="prp-mode-btn flex-1 py-1.5 rounded-lg text-xs font-medium transition-colors bg-orange-600 text-white">Batch rotate</button>
      <button data-rmode="perpage" class="prp-mode-btn flex-1 py-1.5 rounded-lg text-xs font-medium transition-colors text-slate-400 hover:text-slate-200">Per-page control</button>
    </div>

    <!-- Batch mode -->
    <div id="prp-mode-batch" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="space-y-2">
          <label class="text-xs text-slate-400">Pages to rotate <span class="text-slate-600">(blank = all) or click below</span></label>
          <input id="prp-pages" type="text" placeholder="e.g. 1, 3, 5-8 — or leave blank" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-500 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-2">
          <label class="text-xs text-slate-400">Rotation angle</label>
          <select id="prp-angle" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500">
            <option value="90">90° clockwise</option>
            <option value="180">180° (flip)</option>
            <option value="270">90° counter-clockwise</option>
          </select>
        </div>
      </div>

      <!-- Thumbnail grid for visual selection -->
      <div>
        <p class="text-xs text-slate-500 mb-2">Or click page thumbnails to select:</p>
        <div id="prp-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
      </div>

      <!-- Quick actions -->
      <div class="space-y-2">
        <p class="text-xs text-slate-500">Quick select:</p>
        <div class="flex flex-wrap gap-2">
          <button data-quick="odd" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-white hover:border-orange-500/60 hover:bg-orange-500/10 rounded-lg transition-colors">Odd pages only</button>
          <button data-quick="even" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-white hover:border-orange-500/60 hover:bg-orange-500/10 rounded-lg transition-colors">Even pages only</button>
          <button data-quick="landscape" class="px-3 py-1.5 text-xs border border-orange-700/50 text-orange-400 hover:bg-orange-900/20 rounded-lg transition-colors">Auto: landscape → portrait</button>
          <button data-quick="clear" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-500 hover:text-slate-300 rounded-lg transition-colors">Clear selection</button>
        </div>
      </div>

      <button id="prp-rotate-batch" class="w-full px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors disabled:opacity-40" disabled>Rotate & Download</button>
    </div>

    <!-- Per-page mode -->
    <div id="prp-mode-perpage" class="hidden space-y-3">
      <p class="text-xs text-slate-500">Set a rotation angle for each page. Pages keeping their current rotation are left unchanged.</p>
      <div id="prp-page-list" class="space-y-1.5 max-h-72 overflow-y-auto pr-1"></div>
      <div class="flex gap-2 flex-wrap">
        <button data-setall="90" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg">Set all 90° CW</button>
        <button data-setall="180" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg">Set all 180°</button>
        <button data-setall="270" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg">Set all 90° CCW</button>
        <button data-setall="0" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg">Reset all</button>
      </div>
      <button id="prp-rotate-perpage" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Apply & Download</button>
    </div>
  </div>

  <div id="prp-status" class="hidden text-sm py-2"></div>
</div>

<style>
  .prp-card { transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s; }
  .prp-card.selected { border-color: rgb(249 115 22) !important; box-shadow: 0 0 0 2px rgb(249 115 22 / 0.2); }
  .prp-card:not(.selected):hover { border-color: rgb(249 115 22 / 0.7); }
  .prp-thumb-wrap { background: #fff; }
</style>

<script is:inline>
(function() {
  const PDFJS_CDN   = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
  const PDFLIB_CDN  = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';

  const drop = document.getElementById('prp-drop');
  const fileInput = document.getElementById('prp-file');
  const panel = document.getElementById('prp-panel');
  const loading = document.getElementById('prp-loading');
  const loadingMsg = document.getElementById('prp-loading-msg');
  const loadingBar = document.getElementById('prp-loading-bar');
  const status = document.getElementById('prp-status');
  const grid = document.getElementById('prp-grid');

  let currentFile = null, pageCount = 0, pageRotations = [], pdfBytes = null, currentMode = 'batch';
  let thumbs = [], selectedPages = new Set();

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500/80'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500/80'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500/80'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  // Mode tabs
  document.querySelectorAll('.prp-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentMode = btn.dataset.rmode;
      document.querySelectorAll('.prp-mode-btn').forEach(b => {
        b.classList.toggle('bg-orange-600', b.dataset.rmode === currentMode);
        b.classList.toggle('text-white', b.dataset.rmode === currentMode);
        b.classList.toggle('text-slate-400', b.dataset.rmode !== currentMode);
      });
      document.getElementById('prp-mode-batch').classList.toggle('hidden', currentMode !== 'batch');
      document.getElementById('prp-mode-perpage').classList.toggle('hidden', currentMode !== 'perpage');
    });
  });

  async function loadFile(file) {
    if (!file || (!file.type.includes('pdf') && !file.name.endsWith('.pdf'))) return;

    drop.classList.add('hidden');
    loading.classList.remove('hidden');
    status.classList.add('hidden');
    loadingBar.style.width = '0%';
    loadingMsg.textContent = 'Reading PDF…';

    try {
      pdfBytes = await file.arrayBuffer();
      currentFile = file;

      await loadScript(PDFJS_CDN);
      const pdfjsLib = window['pdfjs-dist/build/pdf'];
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

      const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes.slice(0) }).promise;
      pageCount = pdfDoc.numPages;
      thumbs = [];
      selectedPages.clear();

      // Load PDF.js for rotation info and generate thumbnails
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const pdfLib = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      pageRotations = Array.from({ length: pageCount }, (_, i) => {
        const page = pdfLib.getPage(i);
        return { add: 0, current: page.getRotation().angle };
      });

      // render thumbnails
      for (let i = 1; i <= pageCount; i++) {
        loadingMsg.textContent = `Generating previews… ${i} / ${pageCount}`;
        loadingBar.style.width = `${Math.round((i / pageCount) * 100)}%`;

        const page = await pdfDoc.getPage(i);
        const viewport = page.getViewport({ scale: 0.3 });
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(viewport.width);
        canvas.height = Math.round(viewport.height);
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        await page.render({ canvasContext: ctx, viewport }).promise;
        thumbs.push(canvas.toDataURL('image/jpeg', 0.82));
      }

      document.getElementById('prp-name').textContent = file.name;
      document.getElementById('prp-info').textContent = `${pageCount} pages · ${(file.size / 1024).toFixed(0)} KB`;
      loading.classList.add('hidden');
      panel.classList.remove('hidden');
      renderGrid();
      renderPageList();
    } catch(e) {
      loading.classList.add('hidden');
      drop.classList.remove('hidden');
      showStatus('Could not read PDF: ' + e.message, 'error');
    }
  }

  function renderGrid() {
    grid.innerHTML = Array.from({ length: pageCount }, (_, i) => {
      const selected = selectedPages.has(i + 1);
      const thumb = thumbs[i] || '';
      return `
        <button class="prp-card group relative cursor-pointer select-none rounded-2xl border-2 ${selected ? 'border-orange-600' : 'border-slate-700/60'} hover:border-orange-400/70 bg-[var(--bg-surface)] overflow-hidden"
                data-page="${i + 1}">
          <!-- thumbnail -->
          <div class="prp-thumb-wrap w-full flex items-center justify-center overflow-hidden">
            ${thumb
              ? `<img src="${thumb}" class="w-full h-auto block" alt="Page ${i + 1}" draggable="false" />`
              : `<div class="w-full flex items-center justify-center py-12 text-slate-500 text-xs">Page ${i + 1}</div>`
            }
          </div>
          <!-- label row -->
          <div class="flex items-center justify-between px-3 py-2 border-t ${selected ? 'border-orange-600 bg-orange-900/20' : 'border-slate-800'}">
            <span class="text-sm font-semibold ${selected ? 'text-orange-300' : 'text-slate-300'}">Page ${i + 1}</span>
            <span class="text-xs font-mono ${selected ? 'text-orange-400 bg-orange-600 text-white px-1.5 py-0.5 rounded' : 'text-slate-500'}">
              ${selected ? '✓' : ''}
            </span>
          </div>
        </button>`;
    }).join('');

    grid.querySelectorAll('.prp-card').forEach(card => {
      card.addEventListener('click', () => {
        const page = +card.dataset.page;
        if (selectedPages.has(page)) {
          selectedPages.delete(page);
        } else {
          selectedPages.add(page);
        }
        updateRangeFromSelection();
        renderGrid();
      });
    });
  }

  function updateRangeFromSelection() {
    if (selectedPages.size === 0) {
      document.getElementById('prp-pages').value = '';
      return;
    }
    const sorted = [...selectedPages].sort((a, b) => a - b);
    const ranges = [];
    let start = sorted[0], end = sorted[0];
    for (let i = 1; i < sorted.length; i++) {
      if (sorted[i] === end + 1) {
        end = sorted[i];
      } else {
        ranges.push(start === end ? `${start}` : `${start}-${end}`);
        start = end = sorted[i];
      }
    }
    ranges.push(start === end ? `${start}` : `${start}-${end}`);
    document.getElementById('prp-pages').value = ranges.join(', ');
  }

  function renderPageList() {
    const list = document.getElementById('prp-page-list');
    list.innerHTML = pageRotations.map((pr, i) => {
      const orientLabel = pr.current === 90 || pr.current === 270 ? 'landscape' : 'portrait';
      return `
        <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-lg px-3 py-2">
          <span class="text-slate-500 text-xs w-16 shrink-0">Page ${i+1}</span>
          <span class="text-xs text-slate-600 w-16 shrink-0">${orientLabel}</span>
          <select data-page="${i}" class="prp-per-select flex-1 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-2 py-1.5 text-slate-100 text-xs focus:outline-none focus:border-orange-500">
            <option value="0" ${pr.add === 0 ? 'selected' : ''}>No change</option>
            <option value="90" ${pr.add === 90 ? 'selected' : ''}>+90° clockwise</option>
            <option value="180" ${pr.add === 180 ? 'selected' : ''}>180° (flip)</option>
            <option value="270" ${pr.add === 270 ? 'selected' : ''}>90° counter-clockwise</option>
          </select>
        </div>`;
    }).join('');

    list.querySelectorAll('.prp-per-select').forEach(sel => {
      sel.addEventListener('change', () => {
        pageRotations[+sel.dataset.page].add = parseInt(sel.value);
      });
    });
  }

  // Quick selectors for batch mode
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-quick]');
    if (!btn || !pageCount) return;
    const action = btn.dataset.quick;
    selectedPages.clear();
    if (action === 'odd') {
      for (let i = 1; i <= pageCount; i += 2) selectedPages.add(i);
    } else if (action === 'even') {
      for (let i = 2; i <= pageCount; i += 2) selectedPages.add(i);
    } else if (action === 'landscape') {
      pageRotations.forEach((pr, i) => {
        if (pr.current === 0 || pr.current === 180) selectedPages.add(i + 1);
      });
    }
    if (action !== 'clear') {
      updateRangeFromSelection();
      renderGrid();
    }
  });

  // Batch rotate
  document.getElementById('prp-rotate-batch').addEventListener('click', async () => {
    if (!currentFile || selectedPages.size === 0) return;
    const angle = parseInt(document.getElementById('prp-angle').value) || 90;
    showStatus('Rotating pages…', 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      selectedPages.forEach(pageNum => {
        const page = src.getPage(pageNum - 1);
        page.rotate(angle);
      });
      const bytes = await src.save();
      downloadBytes(bytes, currentFile.name.replace('.pdf', '-rotated.pdf'));
      showStatus(`✅ Rotated ${selectedPages.size} page(s) successfully`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  // Per-page rotate
  document.getElementById('prp-rotate-perpage').addEventListener('click', async () => {
    if (!currentFile) return;
    const hasChanges = pageRotations.some(pr => pr.add !== 0);
    if (!hasChanges) { showStatus('No rotation changes selected', 'error'); return; }
    showStatus('Applying rotations…', 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      pageRotations.forEach((pr, i) => {
        if (pr.add !== 0) {
          const page = src.getPage(i);
          page.rotate(pr.add);
        }
      });
      const bytes = await src.save();
      downloadBytes(bytes, currentFile.name.replace('.pdf', '-rotated.pdf'));
      showStatus('✅ Rotations applied successfully', 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  // Set all rotations
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-setall]');
    if (!btn) return;
    const angle = parseInt(btn.dataset.setall);
    pageRotations.forEach(pr => pr.add = angle);
    renderPageList();
  });

  document.getElementById('prp-change').addEventListener('click', () => {
    currentFile = null; pageCount = 0; pdfBytes = null; thumbs = []; selectedPages.clear(); pageRotations = [];
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
    loading.classList.add('hidden');
    grid.innerHTML = '';
    document.getElementById('prp-pages').value = '';
  });

  // Set all buttons
  document.querySelectorAll('[data-setall]').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = parseInt(btn.dataset.setall);
      pageRotations.forEach(pr => pr.add = val);
      renderPageList();
    });
  });

  // Quick selectors (batch mode)
  document.querySelectorAll('[data-quick]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.quick;
      const pagesEl = document.getElementById('prp-pages');
      if (action === 'odd') {
        const odds = Array.from({ length: pageCount }, (_, i) => i + 1).filter(n => n % 2 !== 0);
        pagesEl.value = odds.join(', ');
      } else if (action === 'even') {
        const evens = Array.from({ length: pageCount }, (_, i) => i + 1).filter(n => n % 2 === 0);
        pagesEl.value = evens.join(', ');
      } else if (action === 'landscape') {
        // Find pages that are landscape (rotated 90 or 270, or width > height)
        const landscapePages = pageRotations
          .map((pr, i) => ({ idx: i, rot: pr.current }))
          .filter(({ rot }) => rot === 90 || rot === 270)
          .map(({ idx }) => idx + 1);
        if (landscapePages.length) {
          pagesEl.value = landscapePages.join(', ');
          document.getElementById('prp-angle').value = '90';
          showStatus(`${landscapePages.length} landscape page(s) selected — will rotate 90° to portrait`, 'info');
        } else {
          showStatus('No landscape pages detected (based on rotation metadata)', 'info');
        }
      } else {
        pagesEl.value = '';
      }
    });
  });

  // Batch rotate
  document.getElementById('prp-rotate-batch').addEventListener('click', async () => {
    if (!currentFile) return;
    const angle = parseInt(document.getElementById('prp-angle').value);
    const pagesStr = document.getElementById('prp-pages').value.trim();
    const targetPages = pagesStr ? parseRange(pagesStr, pageCount) : Array.from({ length: pageCount }, (_, i) => i + 1);
    if (!targetPages.length) { showStatus('Invalid page range.', 'error'); return; }
    showStatus('Rotating pages…', 'info');
    try {
      const { PDFDocument, degrees } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const pageSet = new Set(targetPages);
      for (let i = 1; i <= doc.getPageCount(); i++) {
        if (pageSet.has(i)) {
          const page = doc.getPage(i - 1);
          page.setRotation(degrees((page.getRotation().angle + angle) % 360));
        }
      }
      const out = await doc.save();
      downloadBytes(out, 'rotated.pdf');
      showStatus(`✅ Rotated ${targetPages.length} page(s) by ${angle}°`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  // Per-page rotate
  document.getElementById('prp-rotate-perpage').addEventListener('click', async () => {
    if (!currentFile) return;
    const anyChange = pageRotations.some(pr => pr.add !== 0);
    if (!anyChange) { showStatus('No rotations set — use the dropdowns to choose rotation for each page.', 'error'); return; }
    showStatus('Applying rotations…', 'info');
    try {
      const { PDFDocument, degrees } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      pageRotations.forEach((pr, i) => {
        if (pr.add !== 0) {
          const page = doc.getPage(i);
          page.setRotation(degrees((pr.current + pr.add) % 360));
        }
      });
      const out = await doc.save();
      downloadBytes(out, 'rotated.pdf');
      const changed = pageRotations.filter(pr => pr.add !== 0).length;
      showStatus(`✅ Rotated ${changed} page(s) successfully`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('prp-change').addEventListener('click', () => {
    currentFile = null; pageCount = 0; pdfBytes = null; pageRotations = [];
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function parseRange(str, max) {
    const nums = new Set();
    str.split(',').forEach(part => {
      part = part.trim();
      if (/^\d+$/.test(part)) { const n = parseInt(part); if (n >= 1 && n <= max) nums.add(n); }
      else if (/^\d+-\d+$/.test(part)) {
        const [a, b] = part.split('-').map(Number);
        for (let i = Math.min(a,b); i <= Math.min(Math.max(a,b), max); i++) nums.add(i);
      }
    });
    return [...nums].sort((a,b) => a-b);
  }

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
