---
---
<div class="space-y-5">
  <div id="pul-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pul-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🔓</div>
    <p class="text-slate-300 font-medium mb-1">Drop a password-protected PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Your file never leaves your device</p>
  </div>

  <div id="pul-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl">🔐</span>
      <div>
        <p id="pul-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="pul-info" class="text-slate-500 text-xs"></p>
      </div>
    </div>

    <div class="space-y-1">
      <label class="text-xs text-slate-400">PDF Password</label>
      <input type="password" id="pul-password" placeholder="Enter the PDF password…" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
    </div>

    <div class="flex gap-2">
      <button id="pul-unlock" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Remove Password & Download</button>
      <button id="pul-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear</button>
    </div>
  </div>

  <div id="pul-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('pul-drop');
  const fileInput = document.getElementById('pul-file');
  const panel = document.getElementById('pul-panel');
  const status = document.getElementById('pul-status');
  let currentFile = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    currentFile = file;
    document.getElementById('pul-name').textContent = file.name;
    document.getElementById('pul-info').textContent = `${(file.size / 1024).toFixed(1)} KB`;
    panel.classList.remove('hidden');
    drop.classList.add('hidden');
    status.classList.add('hidden');
    document.getElementById('pul-password').focus();
  }

  document.getElementById('pul-unlock').addEventListener('click', async () => {
    if (!currentFile) return;
    const password = document.getElementById('pul-password').value;
    showStatus('Unlocking PDF…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await currentFile.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { password });
      const output = await doc.save();
      const outName = currentFile.name.replace(/\.pdf$/i, '') + '-unlocked.pdf';
      downloadBytes(output, outName);
      showStatus('✅ Password removed — unlocked PDF downloaded.', 'success');
    } catch (e) {
      const msg = e.message || '';
      if (msg.toLowerCase().includes('password') || msg.toLowerCase().includes('incorrect') || msg.toLowerCase().includes('encrypted')) {
        showStatus('❌ Incorrect password. Please check and try again.', 'error');
      } else {
        showStatus('Error: ' + msg, 'error');
      }
    }
  });

  document.getElementById('pul-password').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('pul-unlock').click();
  });

  document.getElementById('pul-clear').addEventListener('click', () => {
    currentFile = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
    fileInput.value = '';
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
