  'least-frequent-words': {
    bg: '#be185d',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 20v-4M12 20V4M6 20v-2"/><path d="M2 20h20"/></svg>`,
