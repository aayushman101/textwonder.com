---
---
<div>
  <div id="mp-subjects" class="space-y-2 mb-3">
    <div class="grid grid-cols-12 gap-2 text-xs text-slate-500 px-1">
      <span class="col-span-4">Subject</span>
      <span class="col-span-3">Marks Obtained</span>
      <span class="col-span-3">Max Marks</span>
      <span class="col-span-2"></span>
    </div>
  </div>
  <div class="flex gap-2 mb-4">
    <button onclick="mpAdd()" class="px-3 py-2 rounded-lg text-sm font-medium text-white" style="background:#3b82f6">+ Add Subject</button>
    <button onclick="mpCalc()" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 bg-[var(--bg-base)] border border-slate-700 hover:text-white">Calculate</button>
  </div>

  <div id="mp-result" class="hidden space-y-3">
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-sm text-slate-400 mb-1">Overall Percentage</div>
      <div id="mp-overall" class="text-4xl font-bold" style="color:#3b82f6"></div>
      <div id="mp-grade" class="text-sm font-semibold mt-1"></div>
    </div>
    <div id="mp-breakdown" class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 space-y-2 text-sm"></div>
  </div>
</div>

<script is:inline>
(function(){
  let count=0;
  function row(i){
    return `<div id="mp-row-${i}" class="grid grid-cols-12 gap-2 items-center">
      <input class="col-span-4 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="Subject" id="mp-name-${i}" />
      <input type="number" class="col-span-3 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="Obtained" id="mp-got-${i}" />
      <input type="number" class="col-span-3 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="Max" id="mp-max-${i}" />
      <button onclick="mpRemove(${i})" class="col-span-2 text-slate-500 hover:text-red-400 text-xs">Remove</button>
    </div>`;
  }
  window.mpAdd=function(){count++;const c=document.createElement('div');c.innerHTML=row(count);document.getElementById('mp-subjects').appendChild(c.firstChild);};
  window.mpRemove=function(i){const el=document.getElementById('mp-row-'+i);if(el)el.remove();};
  window.mpCalc=function(){
    let totalGot=0,totalMax=0;
    const breakdown=[];
    for(let i=1;i<=count;i++){
      const got=parseFloat((document.getElementById('mp-got-'+i)||{}).value);
      const max=parseFloat((document.getElementById('mp-max-'+i)||{}).value);
      const name=(document.getElementById('mp-name-'+i)||{}).value||('Subject '+i);
      if(!isNaN(got)&&!isNaN(max)&&max>0){totalGot+=got;totalMax+=max;const pct=got/max*100;breakdown.push({name,got,max,pct});}
    }
    const res=document.getElementById('mp-result');
    if(!breakdown.length){res.classList.add('hidden');return;}
    const overall=totalGot/totalMax*100;
    let grade,color;
    if(overall>=90){grade='A+';color='#22c55e';}else if(overall>=80){grade='A';color='#22c55e';}else if(overall>=70){grade='B';color='#3b82f6';}else if(overall>=60){grade='C';color='#f59e0b';}else if(overall>=50){grade='D';color='#f59e0b';}else{grade='Fail';color='#ef4444';}
    document.getElementById('mp-overall').textContent=overall.toFixed(2)+'%';
    document.getElementById('mp-grade').textContent='Grade: '+grade;document.getElementById('mp-grade').style.color=color;
    document.getElementById('mp-breakdown').innerHTML=breakdown.map(s=>`<div class="flex justify-between"><span class="text-slate-400">${s.name}</span><span class="text-white">${s.got}/${s.max} <span class="text-slate-500 text-xs">(${s.pct.toFixed(1)}%)</span></span></div>`).join('');
    res.classList.remove('hidden');
  };
  mpAdd();mpAdd();mpAdd();
})();
</script>
