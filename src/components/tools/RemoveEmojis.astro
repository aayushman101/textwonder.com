---
const storageKey = 'tw-remove-emojis';
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <span id="re-input-count" class="text-xs text-slate-500">0 characters</span>
    </div>
    <textarea
      id="re-input"
      rows="7"
      placeholder="Paste your text with emojis here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="re-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      Remove Emojis
    </button>
    <button id="re-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Result</label>
      <div class="flex items-center gap-2">
        <span id="re-output-count" class="text-xs text-slate-500">0 characters</span>
        <button id="re-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
    </div>
    <textarea
      id="re-output"
      rows="7"
      readonly
      placeholder="Result will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<!-- Toast -->
<div id="re-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('re-input') as HTMLTextAreaElement;
  const output = document.getElementById('re-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('re-input-count')!;
  const outputCount = document.getElementById('re-output-count')!;
  const processBtn = document.getElementById('re-process')!;
  const clearBtn = document.getElementById('re-clear')!;
  const copyBtn = document.getElementById('re-copy')!;
  const toast = document.getElementById('re-toast')!;

  const STORAGE_KEY = 'tw-remove-emojis';

  function removeEmojis(text: string): string {
    return text
      .replace(/[\u{1F000}-\u{1FFFF}]/gu, '')
      .replace(/[\u{2600}-\u{27FF}]/gu, '')
      .replace(/[\u{2B00}-\u{2BFF}]/gu, '')
      .replace(/[\u{FE00}-\u{FEFF}]/gu, '')
      .replace(/[\u{1F900}-\u{1F9FF}]/gu, '')
      .replace(/[\u{1FA00}-\u{1FAFF}]/gu, '')
      .replace(/[\u{E0000}-\u{E007F}]/gu, '')
      .replace(/️/gu, '')
      .replace(/‍/gu, '');
  }

  function process() {
    const result = removeEmojis(input.value);
    output.value = result;
    outputCount.textContent = `${result.length} characters`;
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  function showToast() {
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  input.addEventListener('input', () => {
    inputCount.textContent = `${input.value.length} characters`;
    process();
  });

  processBtn.addEventListener('click', process);

  clearBtn.addEventListener('click', () => {
    input.value = '';
    output.value = '';
    inputCount.textContent = '0 characters';
    outputCount.textContent = '0 characters';
    localStorage.removeItem(STORAGE_KEY);
  });

  copyBtn.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value).then(showToast);
  });

  // Restore last input
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) {
    input.value = saved;
    inputCount.textContent = `${saved.length} characters`;
    process();
  }
</script>
