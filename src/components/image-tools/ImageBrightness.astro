---
---
<div class="max-w-2xl mx-auto space-y-6">
  <!-- Drop Zone -->
  <div id="ib-drop" class="border-2 border-dashed border-slate-600 rounded-2xl p-10 text-center cursor-pointer hover:border-rose-500 transition-colors">
    <div class="text-4xl mb-3">☀</div>
    <p class="text-slate-300 font-medium mb-1">Drop an image here or click to select</p>
    <p class="text-slate-500 text-sm">JPG, PNG, WebP supported</p>
    <input id="ib-input" type="file" accept="image/*" class="hidden" />
  </div>

  <!-- Editor -->
  <div id="ib-editor" class="hidden space-y-5">
    <!-- Preview -->
    <div class="rounded-xl overflow-hidden border border-slate-700 bg-slate-900">
      <canvas id="ib-canvas" class="w-full max-h-96 object-contain block"></canvas>
    </div>

    <!-- Sliders -->
    <div class="bg-slate-800/50 rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-white font-semibold text-sm">Adjustments</span>
        <button id="ib-reset" class="text-xs text-rose-400 hover:text-rose-300">Reset All</button>
      </div>

      <div class="space-y-1">
        <div class="flex justify-between text-sm"><span class="text-slate-300">Brightness</span><span id="ib-bv" class="text-rose-400 font-mono">100%</span></div>
        <input id="ib-brightness" type="range" min="0" max="300" value="100" class="w-full accent-rose-500" />
      </div>
      <div class="space-y-1">
        <div class="flex justify-between text-sm"><span class="text-slate-300">Contrast</span><span id="ib-cv" class="text-rose-400 font-mono">100%</span></div>
        <input id="ib-contrast" type="range" min="0" max="300" value="100" class="w-full accent-rose-500" />
      </div>
      <div class="space-y-1">
        <div class="flex justify-between text-sm"><span class="text-slate-300">Saturation</span><span id="ib-sv" class="text-rose-400 font-mono">100%</span></div>
        <input id="ib-saturation" type="range" min="0" max="300" value="100" class="w-full accent-rose-500" />
      </div>
      <div class="space-y-1">
        <div class="flex justify-between text-sm"><span class="text-slate-300">Sharpness</span><span id="ib-shv" class="text-rose-400 font-mono">0</span></div>
        <input id="ib-sharpness" type="range" min="0" max="5" value="0" step="1" class="w-full accent-rose-500" />
      </div>
    </div>

    <!-- Actions -->
    <div class="flex gap-3">
      <button id="ib-download-jpg" class="flex-1 py-3 rounded-xl font-semibold text-white transition-colors" style="background:#f43f5e">Download JPG</button>
      <button id="ib-download-png" class="px-5 py-3 rounded-xl border border-slate-600 text-slate-300 hover:border-rose-500 hover:text-white transition-colors">PNG</button>
      <button id="ib-new" class="px-4 py-3 rounded-xl border border-slate-600 text-slate-400 hover:border-slate-500 transition-colors text-sm">New Image</button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('ib-drop');
  const input = document.getElementById('ib-input');
  const editor = document.getElementById('ib-editor');
  const canvas = document.getElementById('ib-canvas');
  const ctx = canvas.getContext('2d');
  const resetBtn = document.getElementById('ib-reset');
  const newBtn = document.getElementById('ib-new');

  const sliders = {
    brightness: { el: document.getElementById('ib-brightness'), val: document.getElementById('ib-bv') },
    contrast:   { el: document.getElementById('ib-contrast'),   val: document.getElementById('ib-cv') },
    saturation: { el: document.getElementById('ib-saturation'), val: document.getElementById('ib-sv') },
    sharpness:  { el: document.getElementById('ib-sharpness'),  val: document.getElementById('ib-shv') },
  };

  let sourceImg = null;

  drop.addEventListener('click', () => input.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.style.borderColor='#f43f5e'; });
  drop.addEventListener('dragleave', () => drop.style.borderColor='');
  drop.addEventListener('drop', e => { e.preventDefault(); drop.style.borderColor=''; loadFile(e.dataTransfer.files[0]); });
  input.addEventListener('change', () => loadFile(input.files[0]));

  function loadFile(f) {
    if (!f || !f.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = e => {
      sourceImg = new Image();
      sourceImg.onload = () => {
        canvas.width = sourceImg.naturalWidth;
        canvas.height = sourceImg.naturalHeight;
        applyFilters();
        drop.classList.add('hidden');
        editor.classList.remove('hidden');
      };
      sourceImg.src = e.target.result;
    };
    reader.readAsDataURL(f);
  }

  function applyFilters() {
    if (!sourceImg) return;
    const b = sliders.brightness.el.value;
    const c = sliders.contrast.el.value;
    const s = sliders.saturation.el.value;
    sliders.brightness.val.textContent = b + '%';
    sliders.contrast.val.textContent = c + '%';
    sliders.saturation.val.textContent = s + '%';
    sliders.sharpness.val.textContent = sliders.sharpness.el.value;

    ctx.filter = `brightness(${b}%) contrast(${c}%) saturate(${s}%)`;
    ctx.drawImage(sourceImg, 0, 0);
    ctx.filter = 'none';

    const sh = +sliders.sharpness.el.value;
    if (sh > 0) applyUnsharp(sh);
  }

  function applyUnsharp(amount) {
    const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const d = imgData.data; const w = canvas.width; const h = canvas.height;
    const blurred = new Uint8ClampedArray(d);
    const r = 1;
    for (let y = r; y < h - r; y++) {
      for (let x = r; x < w - r; x++) {
        for (let c = 0; c < 3; c++) {
          let sum = 0, cnt = 0;
          for (let dy = -r; dy <= r; dy++) for (let dx = -r; dx <= r; dx++) {
            sum += d[((y+dy)*w+(x+dx))*4+c]; cnt++;
          }
          blurred[( y*w+x)*4+c] = sum/cnt;
        }
      }
    }
    const str = amount * 0.3;
    for (let i = 0; i < d.length; i += 4) {
      for (let c = 0; c < 3; c++) {
        d[i+c] = Math.min(255, Math.max(0, d[i+c] + str*(d[i+c]-blurred[i+c])));
      }
    }
    ctx.putImageData(imgData, 0, 0);
  }

  Object.values(sliders).forEach(s => s.el.addEventListener('input', applyFilters));

  resetBtn.addEventListener('click', () => {
    sliders.brightness.el.value = 100;
    sliders.contrast.el.value = 100;
    sliders.saturation.el.value = 100;
    sliders.sharpness.el.value = 0;
    applyFilters();
  });

  newBtn.addEventListener('click', () => {
    sourceImg = null; input.value = '';
    editor.classList.add('hidden'); drop.classList.remove('hidden');
  });

  document.getElementById('ib-download-jpg').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/jpeg', 0.93);
    a.download = 'adjusted.jpg'; a.click();
  });
  document.getElementById('ib-download-png').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png');
    a.download = 'adjusted.png'; a.click();
  });
})();
</script>
