---
---
<div class="space-y-5">
  <div id="pco-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pco-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🗜️</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Reduce file size by removing redundant data</p>
  </div>

  <div id="pco-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl">📄</span>
      <div>
        <p id="pco-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="pco-info" class="text-slate-500 text-xs"></p>
      </div>
    </div>

    <div class="space-y-2">
      <label class="text-xs text-slate-400">Compression level</label>
      <select id="pco-level" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500">
        <option value="normal" selected>Normal — remove unused objects</option>
        <option value="aggressive">Aggressive — also remove metadata</option>
      </select>
      <p class="text-xs text-slate-600">Note: client-side compression works best on PDFs with many unused objects. Image-heavy PDFs may see minimal reduction.</p>
    </div>

    <div class="flex gap-2">
      <button id="pco-compress" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Compress & Download</button>
      <button id="pco-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
    </div>
  </div>

  <div id="pco-status" class="hidden text-sm py-2"></div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('pco-drop');
  const fileInput = document.getElementById('pco-file');
  const panel = document.getElementById('pco-panel');
  const status = document.getElementById('pco-status');
  let currentFile = null, originalSize = 0;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await file.arrayBuffer();
      const pdf = await PDFDocument.load(bytes, { ignoreEncryption: true });
      currentFile = file;
      originalSize = file.size;
      document.getElementById('pco-name').textContent = file.name;
      document.getElementById('pco-info').textContent = `${pdf.getPageCount()} pages · ${(file.size/1024).toFixed(1)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
    } catch(e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('pco-compress').addEventListener('click', async () => {
    if (!currentFile) return;
    const aggressive = document.getElementById('pco-level').value === 'aggressive';
    showStatus('Compressing…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(await currentFile.arrayBuffer(), { ignoreEncryption: true });
      if (aggressive) {
        doc.setTitle('');
        doc.setAuthor('');
        doc.setSubject('');
        doc.setKeywords([]);
        doc.setProducer('');
        doc.setCreator('');
      }
      const out = await doc.save({ useObjectStreams: true, addDefaultPage: false, objectsPerTick: 50 });
      const savedBytes = originalSize - out.length;
      const pct = ((savedBytes / originalSize) * 100).toFixed(1);
      downloadBytes(out, 'compressed.pdf');
      if (savedBytes > 0) {
        showStatus(`✅ Compressed: ${(originalSize/1024).toFixed(1)} KB → ${(out.length/1024).toFixed(1)} KB (−${pct}%)`, 'success');
      } else {
        showStatus(`ℹ️ No further compression possible. Output: ${(out.length/1024).toFixed(1)} KB`, 'info');
      }
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pco-clear').addEventListener('click', () => {
    currentFile = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
