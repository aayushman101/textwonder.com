---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WonderHeader from '../../components/WonderHeader.astro';
import Footer from '../../components/Footer.astro';
import { CALC_TOOLS } from '../../data/calctools.js';
import ToolSearchBar from '../../components/ToolSearchBar.astro';

const brand = { name: 'CalcWonder', prefix: 'Calc', suffix: 'Wonder', rootPath: '/calc', accentColor: '#10b981', idPrefix: 'calc' };
---

<BaseLayout
  title="Free Online Calculators — Finance, Health & Education | CalcWonder"
  description="CalcWonder offers 8 free online calculators for finance, education, and everyday life. Age, EMI, SIP, GST, compound interest, and more. Instant, free, no signup."
  canonical="/calc"
>
  <WonderHeader brand={brand} tools={CALC_TOOLS} />

  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 pt-12 pb-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-950/50 border border-emerald-800/40 text-emerald-400 text-xs font-medium mb-5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Instant results — no signup required
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-3" style="font-family: 'Space Grotesk', sans-serif;">
        Calculators for every<br class="hidden sm:block" /> calculation
      </h1>
      <p class="text-slate-400 text-lg max-w-xl mx-auto mb-5">
        Free, instant calculators for finance, education, and everyday life.
      </p>
      <div class="inline-flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <span><strong class="text-emerald-400 font-semibold">8</strong> calculators</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-emerald-400 font-semibold">100%</strong> free</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-emerald-400 font-semibold">No</strong> signup</span>
      </div>
    </section>

    <!-- Tools Grid -->
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <ToolSearchBar accentColor="#10b981" placeholder="Search calculators…" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {CALC_TOOLS.map(tool => (
          <a
            href={`/calc/${tool.slug}`}
            data-tool-card
            data-name={tool.name}
            data-tagline={tool.tagline}
            class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-5 hover:border-emerald-500/50 hover:bg-[var(--bg-surface-hover)] transition-all"
          >
            <div class="flex items-start gap-4 mb-3">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 text-xl" style={`background:${tool.iconBg}`}>
                {tool.icon}
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-white font-semibold text-base group-hover:text-emerald-400 transition-colors">{tool.name}</h2>
                <p class="text-slate-400 text-sm leading-snug mt-0.5">{tool.tagline}</p>
              </div>
            </div>
            <div class="flex items-center text-xs font-medium transition-colors" style="color: rgba(16,185,129,0.6);" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(16,185,129,0.6)'">
              Open tool
              <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Sister Sites -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <a href="/" class="flex items-center justify-between bg-[var(--bg-surface)] border border-violet-800/30 rounded-xl p-4 hover:border-violet-500/50 transition-colors">
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Text tools</p>
            <p class="text-white font-semibold text-sm">Text<span class="text-violet-400">Wonder</span></p>
          </div>
          <span class="text-slate-500 text-sm">→</span>
        </a>
        <a href="/pdfwonder" class="flex items-center justify-between bg-[var(--bg-surface)] border border-orange-800/30 rounded-xl p-4 hover:border-orange-500/50 transition-colors">
          <div>
            <p class="text-xs text-slate-500 mb-0.5">PDF tools</p>
            <p class="text-white font-semibold text-sm">PDF<span class="text-orange-400">Wonder</span></p>
          </div>
          <span class="text-slate-500 text-sm">→</span>
        </a>
        <a href="/devwonder" class="flex items-center justify-between bg-[var(--bg-surface)] border border-sky-800/30 rounded-xl p-4 hover:border-sky-500/50 transition-colors">
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Dev tools</p>
            <p class="text-white font-semibold text-sm">Dev<span class="text-sky-400">Wonder</span></p>
          </div>
          <span class="text-slate-500 text-sm">→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
