---
---

<div class="space-y-4">
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Input Text</label>
    <textarea id="rcon-input" rows="6" placeholder="Type or paste text here..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"></textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Output (consonants removed)</label>
      <button id="rcon-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea id="rcon-output" rows="6" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y outline-none text-sm"></textarea>
  </div>
  <p class="text-xs text-slate-500">All letters except A, E, I, O, U are removed. Spaces, digits, and punctuation remain.</p>
</div>

<script>
function remove() {
  const text = document.getElementById('rcon-input').value;
  document.getElementById('rcon-output').value = text.replace(/[bcdfghjklmnpqrstvwxyzBCDFGHJKLMNPQRSTVWXYZ]/g, '');
}
document.getElementById('rcon-input').addEventListener('input', remove);
document.getElementById('rcon-copy').addEventListener('click', () => {
  const val = document.getElementById('rcon-output').value;
  if (!val) return;
  navigator.clipboard.writeText(val);
  const btn = document.getElementById('rcon-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = 'Copy', 1500);
});
</script>
