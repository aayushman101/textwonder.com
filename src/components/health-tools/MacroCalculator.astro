---
---
<div>
  <div class="flex gap-2 mb-4">
    <button id="mc-metric-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-white" style="background:#22c55e" onclick="mcUnit('metric')">Metric</button>
    <button id="mc-imperial-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700" onclick="mcUnit('imperial')">Imperial</button>
  </div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Gender</label>
      <div class="flex gap-3 pt-1">
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="mc-gender" value="male" checked class="accent-green-500" /><span class="text-white text-sm">Male</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="mc-gender" value="female" class="accent-green-500" /><span class="text-white text-sm">Female</span></label>
      </div>
    </div>
    <div><label class="block text-sm text-slate-400 mb-1">Age</label><input type="number" id="mc-age" placeholder="e.g. 28" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div id="mc-metric-inputs" class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (kg)</label><input type="number" id="mc-kg" placeholder="e.g. 75" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (cm)</label><input type="number" id="mc-cm" placeholder="e.g. 178" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div id="mc-imperial-inputs" class="hidden grid grid-cols-3 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (lbs)</label><input type="number" id="mc-lbs" placeholder="e.g. 165" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (ft)</label><input type="number" id="mc-ft" placeholder="5" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (in)</label><input type="number" id="mc-in" placeholder="10" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Activity Level</label>
      <select id="mc-activity" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500">
        <option value="1.2">Sedentary</option>
        <option value="1.375">Lightly active</option>
        <option value="1.55" selected>Moderately active</option>
        <option value="1.725">Very active</option>
        <option value="1.9">Extra active</option>
      </select>
    </div>
    <div><label class="block text-sm text-slate-400 mb-1">Goal</label>
      <select id="mc-goal" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500">
        <option value="-500">Lose fat (−500 kcal)</option>
        <option value="0" selected>Maintain weight</option>
        <option value="300">Gain muscle (+300 kcal)</option>
      </select>
    </div>
  </div>

  <div id="mc-result" class="hidden space-y-3">
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-sm text-slate-400 mb-1">Daily Calories</div>
      <div id="mc-cal" class="text-4xl font-bold" style="color:#22c55e"></div>
      <div class="text-slate-400 text-sm">kcal / day</div>
    </div>
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 space-y-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-blue-400"></div><span class="text-slate-300 text-sm">Protein</span></div>
        <div class="text-right"><span id="mc-protein" class="text-white font-semibold"></span><span class="text-slate-500 text-xs ml-1" id="mc-protein-pct"></span></div>
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-yellow-400"></div><span class="text-slate-300 text-sm">Carbohydrates</span></div>
        <div class="text-right"><span id="mc-carbs" class="text-white font-semibold"></span><span class="text-slate-500 text-xs ml-1" id="mc-carbs-pct"></span></div>
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-red-400"></div><span class="text-slate-300 text-sm">Fat</span></div>
        <div class="text-right"><span id="mc-fat" class="text-white font-semibold"></span><span class="text-slate-500 text-xs ml-1" id="mc-fat-pct"></span></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  let unitMode='metric';
  window.mcUnit=function(m){
    unitMode=m;
    document.getElementById('mc-metric-inputs').classList.toggle('hidden',m!=='metric');
    document.getElementById('mc-imperial-inputs').classList.toggle('hidden',m!=='imperial');
    const mb=document.getElementById('mc-metric-btn'),ib=document.getElementById('mc-imperial-btn');
    if(m==='metric'){mb.style.background='#22c55e';mb.classList.add('text-white');mb.classList.remove('text-slate-400');ib.style.background='';ib.classList.remove('text-white');ib.classList.add('text-slate-400');}
    else{ib.style.background='#22c55e';ib.classList.add('text-white');ib.classList.remove('text-slate-400');mb.style.background='';mb.classList.remove('text-white');mb.classList.add('text-slate-400');}
    calc();
  };
  function calc(){
    const gender=document.querySelector('input[name="mc-gender"]:checked').value;
    const age=parseFloat(document.getElementById('mc-age').value);
    const act=parseFloat(document.getElementById('mc-activity').value);
    const goalAdj=parseFloat(document.getElementById('mc-goal').value);
    let kg,cm;
    if(unitMode==='metric'){kg=parseFloat(document.getElementById('mc-kg').value);cm=parseFloat(document.getElementById('mc-cm').value);}
    else{const lbs=parseFloat(document.getElementById('mc-lbs').value);const ft=parseFloat(document.getElementById('mc-ft').value)||0;const inch=parseFloat(document.getElementById('mc-in').value)||0;kg=lbs*0.453592;cm=(ft*12+inch)*2.54;}
    const res=document.getElementById('mc-result');
    if(!age||!kg||!cm||age<=0||kg<=0||cm<=0){res.classList.add('hidden');return;}
    const bmr=(gender==='male')?(10*kg+6.25*cm-5*age+5):(10*kg+6.25*cm-5*age-161);
    const cal=Math.round(bmr*act+goalAdj);
    // Macros: protein 1.8g/kg, fat 25% cal, carbs rest
    const prot=Math.round(kg*1.8);
    const fatCal=Math.round(cal*0.25);
    const fat=Math.round(fatCal/9);
    const carbCal=cal-prot*4-fatCal;
    const carbs=Math.round(carbCal/4);
    document.getElementById('mc-cal').textContent=cal.toLocaleString();
    document.getElementById('mc-protein').textContent=prot+'g';
    document.getElementById('mc-protein-pct').textContent='('+Math.round(prot*4/cal*100)+'%)';
    document.getElementById('mc-carbs').textContent=Math.max(0,carbs)+'g';
    document.getElementById('mc-carbs-pct').textContent='('+Math.round(Math.max(0,carbs)*4/cal*100)+'%)';
    document.getElementById('mc-fat').textContent=fat+'g';
    document.getElementById('mc-fat-pct').textContent='('+Math.round(fat*9/cal*100)+'%)';
    res.classList.remove('hidden');
  }
  ['mc-age','mc-kg','mc-cm','mc-lbs','mc-ft','mc-in','mc-activity','mc-goal'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',calc);});
  document.querySelectorAll('input[name="mc-gender"]').forEach(r=>r.addEventListener('change',calc));
})();
</script>
