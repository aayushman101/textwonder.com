---
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <span id="tcc-input-count" class="text-xs text-slate-500">0 words</span>
    </div>
    <textarea
      id="tcc-input"
      rows="6"
      placeholder="Enter your title or headings here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="tcc-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      Convert to Title Case
    </button>
    <button id="tcc-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Title Case Result</label>
      <button id="tcc-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea
      id="tcc-output"
      rows="6"
      readonly
      placeholder="Result will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<div id="tcc-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('tcc-input') as HTMLTextAreaElement;
  const output = document.getElementById('tcc-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('tcc-input-count')!;
  const processBtn = document.getElementById('tcc-process')!;
  const clearBtn = document.getElementById('tcc-clear')!;
  const copyBtn = document.getElementById('tcc-copy')!;
  const toast = document.getElementById('tcc-toast')!;
  const STORAGE_KEY = 'tw-title-case-converter';

  const EXCEPTIONS = new Set(['a','an','the','and','but','or','nor','for','so','yet','at','by','in','of','on','to','up','as','if','vs','via']);

  function toTitleCase(text: string): string {
    return text.replace(/[^\n]+/g, line => {
      const words = line.split(/\b/);
      let wordIndex = 0;
      return words.map((token, i) => {
        if (!/[a-zA-Z]/.test(token)) return token;
        const isFirst = wordIndex === 0;
        const remaining = words.slice(i + 1).join('');
        const isLast = !/[a-zA-Z]/.test(remaining);
        wordIndex++;
        const lower = token.toLowerCase();
        if (isFirst || isLast || !EXCEPTIONS.has(lower)) {
          return lower.charAt(0).toUpperCase() + lower.slice(1);
        }
        return lower;
      }).join('');
    });
  }

  function process() {
    const result = toTitleCase(input.value);
    output.value = result;
    const words = input.value.trim() ? input.value.trim().split(/\s+/).length : 0;
    inputCount.textContent = `${words} word${words !== 1 ? 's' : ''}`;
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  function showToast() {
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  input.addEventListener('input', process);
  processBtn.addEventListener('click', process);
  clearBtn.addEventListener('click', () => {
    input.value = ''; output.value = '';
    inputCount.textContent = '0 words';
    localStorage.removeItem(STORAGE_KEY);
  });
  copyBtn.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value).then(showToast);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; process(); }
</script>
