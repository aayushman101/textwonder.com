---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { CATEGORIES, getToolsByCategory, getCategoryBySlug } from '../../data/tools.js';

export function getStaticPaths() {
  return CATEGORIES.map(cat => ({ params: { category: cat.slug }, props: { category: cat } }));
}

const { category } = Astro.props;
const tools = getToolsByCategory(category.slug);
---

<BaseLayout
  title={`${category.name} Tools — Free Online | TextWonder`}
  description={`${tools.length} free ${category.name.toLowerCase()} tools. ${category.description} No signup required.`}
  canonical={`/categories/${category.slug}`}
>
  <Header />

  <main class="max-w-6xl mx-auto px-4 py-10">
    <Breadcrumb items={[
      { label: 'Tools', href: '/tools' },
      { label: category.name },
    ]} />

    <div class="mt-6 mb-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-4xl">{category.icon}</span>
        <h1 class="text-3xl md:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;">
          {category.name} Tools
        </h1>
      </div>
      <p class="text-slate-400 text-lg">{category.description}</p>
      <p class="text-slate-500 text-sm mt-1">{tools.length} free tool{tools.length !== 1 ? 's' : ''} · No signup required</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => <ToolCard tool={tool} />)}
    </div>

    <div class="mt-12 text-center">
      <a href="/tools" class="inline-flex items-center gap-2 bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 hover:text-white font-medium px-5 py-2.5 rounded-xl transition-colors">
        View all categories
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>
