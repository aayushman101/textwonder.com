<div class="space-y-4">
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Your Text</label>
    <input
      id="ftg-input"
      type="text"
      placeholder="Type something here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    />
  </div>
  <div id="ftg-results" class="space-y-2"></div>
</div>

<script>
const styles = [
  { name: '𝗕𝗼𝗹𝗱', id: 'bold' },
  { name: '𝘐𝘵𝘢𝘭𝘪𝘤', id: 'italic' },
  { name: '𝑩𝒐𝒍𝒅 𝑰𝒕𝒂𝒍𝒊𝒄', id: 'boldItalic' },
  { name: '𝒮𝒸𝓇𝒾𝓅𝓉', id: 'script' },
  { name: '𝓢𝓬𝓻𝓲𝓹𝓽 𝓑𝓸𝓵𝓭', id: 'boldScript' },
  { name: '𝔊𝔬𝔱𝔥𝔦𝔠', id: 'fraktur' },
  { name: '𝕯𝖔𝖚𝖇𝖑𝖊 𝕾𝖙𝖗𝖚𝖈𝖐', id: 'doublestruck' },
  { name: '𝙼𝚘𝚗𝚘𝚜𝚙𝚊𝚌𝚎', id: 'mono' },
  { name: 'Ⓒⓘⓡⓒⓛⓔⓓ', id: 'circled' },
  { name: 'Ａｅｓｔｈｅｔｉｃ', id: 'fullwidth' },
  { name: 'ꜱᴍᴀʟʟ ᴄᴀᴘꜱ', id: 'smallcaps' },
  { name: 'S̶t̶r̶i̶k̶e̶', id: 'strike' },
  { name: 'U͟n͟d͟e͟r͟l͟i͟n͟e͟', id: 'underline' },
  { name: 'ᵘᵖᵖᵉʳ', id: 'super' },
  { name: 'ɐǝsʇɥǝʇıɔ', id: 'upsidedown' },
];

const maps = {
  bold: {U:'𝐀𝐁𝐂𝐃𝐄𝐅𝐆𝐇𝐈𝐉𝐊𝐋𝐌𝐍𝐎𝐏𝐐𝐑𝐒𝐓𝐔𝐕𝐖𝐗𝐘𝐙', L:'𝐚𝐛𝐜𝐝𝐞𝐟𝐠𝐡𝐢𝐣𝐤𝐥𝐦𝐧𝐨𝐩𝐪𝐫𝐬𝐭𝐮𝐯𝐰𝐱𝐲𝐳', D:'𝟎𝟏𝟐𝟑𝟒𝟓𝟔𝟕𝟖𝟗'},
  italic: {U:'𝐴𝐵𝐶𝐷𝐸𝐹𝐺𝐻𝐼𝐽𝐾𝐿𝑀𝑁𝑂𝑃𝑄𝑅𝑆𝑇𝑈𝑉𝑊𝑋𝑌𝑍', L:'𝑎𝑏𝑐𝑑𝑒𝑓𝑔ℎ𝑖𝑗𝑘𝑙𝑚𝑛𝑜𝑝𝑞𝑟𝑠𝑡𝑢𝑣𝑤𝑥𝑦𝑧'},
  boldItalic: {U:'𝑨𝑩𝑪𝑫𝑬𝑭𝑮𝑯𝑰𝑱𝑲𝑳𝑴𝑵𝑶𝑷𝑸𝑹𝑺𝑻𝑼𝑽𝑾𝑿𝒀𝒁', L:'𝒂𝒃𝒄𝒅𝒆𝒇𝒈𝒉𝒊𝒋𝒌𝒍𝒎𝒏𝒐𝒑𝒒𝒓𝒔𝒕𝒖𝒗𝒘𝒙𝒚𝒛'},
  script: {U:'𝒜ℬ𝒞𝒟ℰℱ𝒢ℋℐ𝒥𝒦ℒℳ𝒩𝒪𝒫𝒬ℛ𝒮𝒯𝒰𝒱𝒲𝒳𝒴𝒵', L:'𝒶𝒷𝒸𝒹ℯ𝒻ℊ𝒽𝒾𝒿𝓀𝓁𝓂𝓃ℴ𝓅𝓆𝓇𝓈𝓉𝓊𝓋𝓌𝓍𝓎𝓏'},
  boldScript: {U:'𝓐𝓑𝓒𝓓𝓔𝓕𝓖𝓗𝓘𝓙𝓚𝓛𝓜𝓝𝓞𝓟𝓠𝓡𝓢𝓣𝓤𝓥𝓦𝓧𝓨𝓩', L:'𝓪𝓫𝓬𝓭𝓮𝓯𝓰𝓱𝓲𝓳𝓴𝓵𝓶𝓷𝓸𝓹𝓺𝓻𝓼𝓽𝓾𝓿𝔀𝔁𝔂𝔃'},
  fraktur: {U:'𝔄𝔅ℭ𝔇𝔈𝔉𝔊ℌℑ𝔍𝔎𝔏𝔐𝔑𝔒𝔓𝔔ℜ𝔖𝔗𝔘𝔙𝔚𝔛𝔜ℨ', L:'𝔞𝔟𝔠𝔡𝔢𝔣𝔤𝔥𝔦𝔧𝔨𝔩𝔪𝔫𝔬𝔭𝔮𝔯𝔰𝔱𝔲𝔳𝔴𝔵𝔶𝔷'},
  doublestruck: {U:'𝔸𝔹ℂ𝔻𝔼𝔽𝔾ℍ𝕀𝕁𝕂𝕃𝕄ℕ𝕆ℙℚℝ𝕊𝕋𝕌𝕍𝕎𝕏𝕐ℤ', L:'𝕒𝕓𝕔𝕕𝕖𝕗𝕘𝕙𝕚𝕛𝕜𝕝𝕞𝕟𝕠𝕡𝕢𝕣𝕤𝕥𝕦𝕧𝕨𝕩𝕪𝕫', D:'𝟘𝟙𝟚𝟛𝟜𝟝𝟞𝟟𝟠𝟡'},
  mono: {U:'𝙰𝙱𝙲𝙳𝙴𝙵𝙶𝙷𝙸𝙹𝙺𝙻𝙼𝙽𝙾𝙿𝚀𝚁𝚂𝚃𝚄𝚅𝚆𝚇𝚈𝚉', L:'𝚊𝚋𝚌𝚍𝚎𝚏𝚐𝚑𝚒𝚓𝚔𝚕𝚖𝚗𝚘𝚙𝚚𝚛𝚜𝚝𝚞𝚟𝚠𝚡𝚢𝚣', D:'𝟶𝟷𝟸𝟹𝟺𝟻𝟼𝟽𝟾𝟿'},
  circled: {U:'ⒶⒷⒸⒹⒺⒻⒼⒽⒾⒿⓀⓁⓂⓃⓄⓅⓆⓇⓈⓉⓊⓋⓌⓍⓎⓏ', L:'ⓐⓑⓒⓓⓔⓕⓖⓗⓘⓙⓚⓛⓜⓝⓞⓟⓠⓡⓢⓣⓤⓥⓦⓧⓨⓩ', D:'⓪①②③④⑤⑥⑦⑧⑨'},
  fullwidth: {U:'ＡＢＣＤＥＦＧＨＩＪＫＬＭＮＯＰＱＲＳＴＵＶＷＸＹＺ', L:'ａｂｃｄｅｆｇｈｉｊｋｌｍｎｏｐｑｒｓｔｕｖｗｘｙｚ', D:'０１２３４５６７８９'},
  smallcaps: {L:'ᴀʙᴄᴅᴇꜰɢʜɪᴊᴋʟᴍɴᴏᴘQʀꜱᴛᴜᴠᴡxʏᴢ'},
  upsidedown: {
    map: {'a':'ɐ','b':'q','c':'ɔ','d':'p','e':'ǝ','f':'ɟ','g':'ɓ','h':'ɥ','i':'ᵻ','j':'ɾ','k':'ʞ','l':'l','m':'ɯ','n':'u','o':'o','p':'d','q':'b','r':'ɹ','s':'s','t':'ʇ','u':'n','v':'ʌ','w':'ʍ','x':'x','y':'ʎ','z':'z','A':'∀','B':'𐐒','C':'Ɔ','D':'◻','E':'Ǝ','F':'Ⅎ','G':'⅁','H':'H','I':'I','J':'ɾ','K':'⊻','L':'⅂','M':'W','N':'N','O':'O','P':'Ԁ','Q':'Q','R':'ɹ','S':'S','T':'⊥','U':'∩','V':'Λ','W':'M','X':'X','Y':'⅄','Z':'Z','0':'0','1':'Ɩ','2':'ᄅ','3':'Ɛ','4':'ㄣ','5':'ϛ','6':'9','7':'ㄥ','8':'8','9':'6'},
    reverse: true
  },
  super: {
    map: {'a':'ᵃ','b':'ᵇ','c':'ᶜ','d':'ᵈ','e':'ᵉ','f':'ᶠ','g':'ᵍ','h':'ʰ','i':'ⁱ','j':'ʲ','k':'ᵏ','l':'ˡ','m':'ᵐ','n':'ⁿ','o':'ᵒ','p':'ᵖ','q':'q','r':'ʳ','s':'ˢ','t':'ᵗ','u':'ᵘ','v':'ᵛ','w':'ʷ','x':'ˣ','y':'ʸ','z':'ᶻ','A':'ᴬ','B':'ᴮ','C':'ᶜ','D':'ᴰ','E':'ᴱ','F':'ᶠ','G':'ᴳ','H':'ᴴ','I':'ᴵ','J':'ᴶ','K':'ᴷ','L':'ᴸ','M':'ᴹ','N':'ᴺ','O':'ᴼ','P':'ᴾ','Q':'Q','R':'ᴿ','S':'ˢ','T':'ᵀ','U':'ᵁ','V':'ᵛ','W':'ᵂ','X':'ˣ','Y':'ʸ','Z':'ᶻ','0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹'}
  },
};

function convert(text, styleId) {
  const m = maps[styleId];
  if (!m) return text;
  if (m.map) {
    let result = [...text].map(ch => m.map[ch] || ch).join('');
    if (m.reverse) result = [...result].reverse().join('');
    return result;
  }
  const upper = m.U ? [...m.U] : null;
  const lower = m.L ? [...m.L] : null;
  const digits = m.D ? [...m.D] : null;
  return [...text].map(ch => {
    const c = ch.codePointAt(0);
    if (upper && c >= 65 && c <= 90) return upper[c - 65] || ch;
    if (lower && c >= 97 && c <= 122) return lower[c - 97] || ch;
    if (!upper && lower && c >= 65 && c <= 90) return (lower[c - 65] || ch).toUpperCase?.() || ch;
    if (digits && c >= 48 && c <= 57) return digits[c - 48] || ch;
    return ch;
  }).join('');
}

function addCombining(text, mark) {
  return [...text].map(ch => ch === ' ' ? ch : ch + mark).join('');
}

function getConverted(text, styleId) {
  if (styleId === 'strike') return addCombining(text, '̶');
  if (styleId === 'underline') return addCombining(text, '̲');
  return convert(text, styleId);
}

function copyText(el) {
  const text = el.dataset.text;
  navigator.clipboard.writeText(text).then(() => {
    const btn = el.querySelector('button');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = orig, 1500);
  });
}

function render(input) {
  const container = document.getElementById('ftg-results');
  if (!input.trim()) { container.innerHTML = ''; return; }
  container.innerHTML = styles.map(s => {
    const out = getConverted(input, s.id);
    return `<div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl px-4 py-3 cursor-pointer hover:border-violet-700 transition-colors" data-text="${out.replace(/"/g,'&quot;')}" onclick="copyText(this)">
      <span class="text-slate-400 text-xs w-28 shrink-0">${s.name}</span>
      <span class="text-slate-100 text-sm flex-1 break-all">${out}</span>
      <button class="text-xs bg-[var(--bg-surface-hover)] hover:bg-violet-700 text-slate-300 hover:text-white px-3 py-1 rounded-lg transition-colors shrink-0">Copy</button>
    </div>`;
  }).join('');
}

const input = document.getElementById('ftg-input');
input.addEventListener('input', () => render(input.value));
window.copyText = copyText;
</script>
