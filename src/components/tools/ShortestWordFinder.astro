---
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <button id="swf-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear</button>
    </div>
    <textarea
      id="swf-input"
      rows="8"
      placeholder="Paste your text here to find the shortest words..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="grid grid-cols-3 gap-3">
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="swf-total" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">Total Words</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="swf-short-count" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">1–3 Letter Words</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="swf-short-pct" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0%</div>
      <div class="text-slate-400 text-xs mt-1">% Short Words</div>
    </div>
  </div>

  <div id="swf-results-wrap" class="hidden space-y-3">
    <div>
      <p class="text-slate-400 text-xs font-medium mb-2">Shortest unique words (sorted by length):</p>
      <div class="bg-[var(--bg-base)] border border-slate-700 rounded-xl overflow-hidden">
        <div class="grid text-xs font-medium text-slate-400 border-b border-slate-800 px-4 py-2" style="grid-template-columns:2rem 1fr auto auto">
          <span>#</span><span>Word</span><span class="text-right pr-4">Count</span><span class="text-right">Len</span>
        </div>
        <div id="swf-list" class="max-h-64 overflow-y-auto divide-y divide-slate-800/50"></div>
      </div>
    </div>
  </div>

  <div id="swf-empty" class="text-center py-6 text-slate-500 text-sm hidden">Type or paste text above to find the shortest words.</div>
</div>

<script>
  const input = document.getElementById('swf-input') as HTMLTextAreaElement;
  const elTotal = document.getElementById('swf-total')!;
  const elShortCount = document.getElementById('swf-short-count')!;
  const elShortPct = document.getElementById('swf-short-pct')!;
  const elResultsWrap = document.getElementById('swf-results-wrap')!;
  const elList = document.getElementById('swf-list')!;
  const elEmpty = document.getElementById('swf-empty')!;
  const STORAGE_KEY = 'tw-shortest-word-finder';

  function update() {
    const rawWords = (input.value.match(/[a-zA-Z']+/g) || []).map(w => w.replace(/^'+|'+$/g, '').toLowerCase()).filter(w => w.length > 0);
    const total = rawWords.length;
    elTotal.textContent = total.toString();

    if (total === 0) {
      elShortCount.textContent = '0';
      elShortPct.textContent = '0%';
      elResultsWrap.classList.add('hidden');
      elEmpty.classList.remove('hidden');
      return;
    }

    const shortWords = rawWords.filter(w => w.length <= 3);
    const shortCount = shortWords.length;
    const shortPct = Math.round(shortCount / total * 100);

    elShortCount.textContent = shortCount.toString();
    elShortPct.textContent = shortPct + '%';

    const freq: Record<string,number> = {};
    for (const w of rawWords) freq[w] = (freq[w] || 0) + 1;
    const uniqueSorted = Object.keys(freq).sort((a, b) => a.length - b.length || a.localeCompare(b));

    elList.innerHTML = uniqueSorted.slice(0, 50).map((word, i) =>
      `<div class="grid items-center px-4 py-2 hover:bg-[var(--bg-surface-hover)] text-sm" style="grid-template-columns:2rem 1fr auto auto">
        <span class="text-slate-600 text-xs">${i + 1}</span>
        <span class="text-slate-200">${word.replace(/</g,'&lt;')}</span>
        <span class="text-slate-400 pr-4 text-right">${freq[word]}×</span>
        <span class="text-violet-400 font-bold text-right" style="font-family:'Space Grotesk',sans-serif;">${word.length}</span>
      </div>`
    ).join('');

    elResultsWrap.classList.remove('hidden');
    elEmpty.classList.add('hidden');
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  input.addEventListener('input', update);
  document.getElementById('swf-clear')!.addEventListener('click', () => {
    input.value = '';
    update();
    localStorage.removeItem(STORAGE_KEY);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; update(); }
</script>
