---
---
<div class="space-y-5">
  <div id="ib64-drop" class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center cursor-pointer hover:border-rose-500/60 transition-colors">
    <input id="ib64-file" type="file" accept="image/*" class="hidden" />
    <div class="text-3xl mb-2">🔢</div>
    <p class="text-slate-300 font-medium">Drop an image here or <span class="text-rose-400 underline cursor-pointer">click to browse</span></p>
    <p class="text-slate-500 text-xs mt-1">JPG, PNG, WebP, SVG, GIF — encoded in your browser</p>
  </div>

  <div id="ib64-panel" class="hidden space-y-4">
    <div class="flex gap-4 items-start">
      <img id="ib64-preview" src="" alt="Preview" class="w-20 h-20 rounded-lg object-contain border border-slate-700 shrink-0" />
      <div>
        <p id="ib64-info" class="text-xs text-slate-400"></p>
        <p id="ib64-b64-size" class="text-xs text-slate-500 mt-1"></p>
      </div>
    </div>

    <!-- Format selector -->
    <div class="flex gap-3">
      <label class="flex items-center gap-2 text-sm text-slate-300 cursor-pointer">
        <input type="radio" name="ib64-out" value="datauri" checked class="accent-rose-500" />
        Data URI (with prefix)
      </label>
      <label class="flex items-center gap-2 text-sm text-slate-300 cursor-pointer">
        <input type="radio" name="ib64-out" value="raw" class="accent-rose-500" />
        Raw Base64 only
      </label>
    </div>

    <div class="relative">
      <textarea id="ib64-output" rows="5" readonly
        class="w-full bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-300 rounded-xl px-4 py-3 text-xs font-mono resize-none focus:outline-none focus:border-rose-500"
        placeholder="Base64 output will appear here…"></textarea>
    </div>

    <div class="flex gap-3">
      <button id="ib64-copy" class="flex-1 py-2.5 bg-rose-600 hover:bg-rose-500 text-white rounded-lg font-semibold text-sm transition-colors">
        Copy to Clipboard
      </button>
      <button id="ib64-download" class="flex-1 py-2.5 bg-slate-700 hover:bg-slate-600 text-white rounded-lg font-semibold text-sm transition-colors">
        Download as .txt
      </button>
    </div>
    <p id="ib64-copied" class="text-xs text-emerald-400 text-center hidden">Copied!</p>
  </div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('ib64-drop');
  const fileInput = document.getElementById('ib64-file');
  const panel = document.getElementById('ib64-panel');
  const preview = document.getElementById('ib64-preview');
  const infoEl = document.getElementById('ib64-info');
  const sizeEl = document.getElementById('ib64-b64-size');
  const output = document.getElementById('ib64-output');
  const copyBtn = document.getElementById('ib64-copy');
  const dlBtn = document.getElementById('ib64-download');
  const copiedMsg = document.getElementById('ib64-copied');

  let dataUri = '', rawBase64 = '';

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-rose-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-rose-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-rose-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  function loadFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = e => {
      dataUri = e.target.result;
      rawBase64 = dataUri.split(',')[1] || '';
      preview.src = dataUri;
      infoEl.textContent = `${file.name} · ${(file.size / 1024).toFixed(1)} KB`;
      sizeEl.textContent = `Base64 string: ~${(rawBase64.length / 1024).toFixed(1)} KB`;
      renderOutput();
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
    };
    reader.readAsDataURL(file);
  }

  function renderOutput() {
    const mode = document.querySelector('input[name="ib64-out"]:checked')?.value || 'datauri';
    output.value = mode === 'datauri' ? dataUri : rawBase64;
  }

  document.querySelectorAll('input[name="ib64-out"]').forEach(r => r.addEventListener('change', renderOutput));

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(output.value).then(() => {
      copiedMsg.classList.remove('hidden');
      setTimeout(() => copiedMsg.classList.add('hidden'), 2000);
    });
  });

  dlBtn.addEventListener('click', () => {
    const blob = new Blob([output.value], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'image-base64.txt';
    a.click();
  });
})();
</script>
