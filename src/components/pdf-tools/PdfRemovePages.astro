---
---
<div class="space-y-5">
  <div id="rrp-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="rrp-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🗑️</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Click page numbers to mark them for removal</p>
  </div>

  <div id="rrp-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="rrp-name" class="text-slate-200 text-sm font-medium truncate"></p>
        <p id="rrp-info" class="text-slate-500 text-xs"></p>
      </div>
      <button id="rrp-change" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 px-3 py-1.5 rounded-lg shrink-0">Change</button>
    </div>

    <!-- Quick selectors -->
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-xs text-slate-500">Quick select:</span>
      <button data-qsel="first" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500 rounded-lg transition-colors">First page</button>
      <button data-qsel="last" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500 rounded-lg transition-colors">Last page</button>
      <button data-qsel="odd" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500 rounded-lg transition-colors">Odd pages</button>
      <button data-qsel="even" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500 rounded-lg transition-colors">Even pages</button>
      <button data-qsel="clear" class="px-3 py-1.5 text-xs border border-slate-700 text-slate-500 hover:text-slate-300 rounded-lg transition-colors">Clear all</button>
    </div>

    <!-- Page grid -->
    <div>
      <p class="text-xs text-slate-500 mb-2">Click a page to mark it for removal <span class="text-red-500/70">(red = will be removed)</span>:</p>
      <div id="rrp-grid" class="flex flex-wrap gap-2 max-h-64 overflow-y-auto p-1"></div>
    </div>

    <!-- Live summary -->
    <div id="rrp-summary" class="text-sm text-slate-400 py-1 min-h-[1.5rem]"></div>

    <button id="rrp-remove" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed" disabled>Remove Selected Pages</button>
  </div>

  <div id="rrp-status" class="hidden text-sm py-2"></div>
</div>

<style>
  .rrp-chip { user-select: none; transition: all 0.12s; }
  .rrp-chip.marked { background: rgb(239 68 68 / 0.18); border-color: rgb(239 68 68 / 0.6) !important; color: #f87171; }
  .rrp-chip:not(.marked):hover { border-color: rgb(148 163 184 / 0.5); color: #cbd5e1; }
</style>

<script is:inline>
(function() {
  const drop = document.getElementById('rrp-drop');
  const fileInput = document.getElementById('rrp-file');
  const panel = document.getElementById('rrp-panel');
  const status = document.getElementById('rrp-status');
  const grid = document.getElementById('rrp-grid');
  const summary = document.getElementById('rrp-summary');
  const removeBtn = document.getElementById('rrp-remove');
  let currentFile = null, pageCount = 0, pdfBytes = null;
  let pageStates = []; // true = marked for removal

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  async function loadFile(file) {
    if (!file || (!file.type.includes('pdf') && !file.name.endsWith('.pdf'))) return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      pdfBytes = await file.arrayBuffer();
      const pdf = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      pageCount = pdf.getPageCount();
      currentFile = file;
      pageStates = new Array(pageCount).fill(false);
      document.getElementById('rrp-name').textContent = file.name;
      document.getElementById('rrp-info').textContent = `${pageCount} pages · ${(file.size/1024).toFixed(0)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
      renderGrid();
    } catch(e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  function renderGrid() {
    grid.innerHTML = pageStates.map((marked, i) => `
      <button class="rrp-chip w-11 h-11 rounded-lg border border-slate-700 text-slate-500 text-xs font-mono flex items-center justify-center shrink-0 ${marked ? 'marked' : ''}" data-page="${i}">${i+1}</button>
    `).join('');
    grid.querySelectorAll('.rrp-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const idx = +chip.dataset.page;
        pageStates[idx] = !pageStates[idx];
        chip.classList.toggle('marked', pageStates[idx]);
        updateSummary();
      });
    });
    updateSummary();
  }

  function updateSummary() {
    const marked = pageStates.filter(Boolean).length;
    const remaining = pageCount - marked;
    if (marked === 0) {
      summary.textContent = 'No pages selected — click page numbers above to mark them for removal.';
      removeBtn.disabled = true;
    } else if (remaining === 0) {
      summary.textContent = `⚠️ Cannot remove all ${pageCount} pages — at least 1 must remain.`;
      removeBtn.disabled = true;
    } else {
      summary.textContent = `${marked} page${marked!==1?'s':''} will be removed · ${remaining} page${remaining!==1?'s':''} will remain`;
      removeBtn.disabled = false;
    }
  }

  document.querySelectorAll('[data-qsel]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!pageCount) return;
      const action = btn.dataset.qsel;
      if (action === 'first') { pageStates.fill(false); pageStates[0] = true; }
      else if (action === 'last') { pageStates.fill(false); pageStates[pageCount-1] = true; }
      else if (action === 'odd') pageStates = pageStates.map((_, i) => (i+1) % 2 !== 0);
      else if (action === 'even') pageStates = pageStates.map((_, i) => (i+1) % 2 === 0);
      else pageStates.fill(false);
      renderGrid();
    });
  });

  removeBtn.addEventListener('click', async () => {
    const keepIndices = pageStates.map((m,i) => m ? -1 : i).filter(i => i >= 0);
    const markedCount = pageStates.filter(Boolean).length;
    if (!markedCount) return;
    showStatus('Removing pages…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const out = await PDFDocument.create();
      const copied = await out.copyPages(src, keepIndices);
      copied.forEach(p => out.addPage(p));
      const bytes = await out.save();
      const baseName = currentFile.name.replace(/\.pdf$/i, '');
      downloadBytes(bytes, `${baseName}-edited.pdf`);
      showStatus(`✅ Removed ${markedCount} page(s) — ${keepIndices.length} page(s) remaining`, 'success');
      pageStates.fill(false);
      renderGrid();
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('rrp-change').addEventListener('click', () => {
    currentFile = null; pageCount = 0; pdfBytes = null; pageStates = [];
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
    grid.innerHTML = '';
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
