    bg: '#059669',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:13px;color:white;letter-spacing:-0.5px;line-height:1">A–Z</span>`,
  },
  'text-entropy': {
    bg: '#6d28d9',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 2l20 20"/><path d="M8.46 8.46A4.95 4.95 0 007 12c0 2.76 2.24 5 5 5 1.28 0 2.44-.49 3.32-1.29"/><path d="M12 7c2.76 0 5 2.24 5 5 0 .47-.06.92-.18 1.35"/></svg>`,
  },
  'character-frequency': {
    bg: '#0f766e',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21H3M21 21V7l-4-4H7L3 7v14"/><path d="M9 21v-9h6v9"/></svg>`,
  },
