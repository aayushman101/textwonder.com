const faqs = [
  { q: 'How do I resize an image without losing quality?', a: 'Downscaling (making an image smaller) has minimal quality loss. The key is to avoid upscaling — enlarging an image beyond its original dimensions causes pixelation because the browser has to invent pixels that do not exist. Always start from the highest resolution original you have.' },
  { q: 'What is the best size for social media images?', a: 'Common sizes: Instagram square 1080×1080px, Facebook cover 820×312px, Twitter/X post 1200×675px, LinkedIn post 1200×627px, YouTube thumbnail 1280×720px.' },
  { q: 'Does resizing change the file size?', a: 'Yes. A smaller image has fewer pixels, so the file size decreases proportionally. Halving both width and height reduces the pixel count to 25% of the original, and the file size drops accordingly.' },
  { q: 'Can I resize a PNG without losing transparency?', a: 'Yes. If you download the resized image as PNG, transparency is preserved. Downloading as JPEG will fill transparent areas with white.' },
  { q: 'Is there a limit to how much I can resize?', a: 'The tool supports any size from 1×1px up to 8000×8000px. Practical limits depend on the original image resolution and your device\'s available memory.' },
];
