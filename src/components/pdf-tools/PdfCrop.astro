---
---
<div class="space-y-5">
  <div id="pcr-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-10 text-center cursor-pointer transition-colors">
    <input type="file" id="pcr-file" accept=".pdf" class="hidden" />
    <div class="text-5xl mb-3">✂️</div>
    <p class="text-slate-200 font-semibold text-lg mb-1">Drop your PDF here</p>
    <p class="text-slate-500 text-sm mb-4">or click to browse — page previews load automatically</p>
    <span class="inline-block px-4 py-2 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Choose PDF</span>
  </div>

  <!-- Loading progress -->
  <div id="pcr-loading" class="hidden">
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">⏳</div>
      <p class="text-slate-300 font-medium mb-1" id="pcr-loading-msg">Generating page previews…</p>
      <p class="text-slate-500 text-xs mb-4">Rendering each page so you can see the crop effect</p>
      <div class="w-full bg-slate-800 rounded-full h-2 max-w-sm mx-auto">
        <div id="pcr-loading-bar" class="bg-orange-500 h-2 rounded-full transition-all duration-200" style="width:0%"></div>
      </div>
    </div>
  </div>

  <div id="pcr-panel" class="hidden space-y-4">
    <!-- File info bar -->
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="pcr-name" class="text-slate-200 text-sm font-semibold truncate"></p>
        <p id="pcr-info" class="text-slate-500 text-xs mt-0.5"></p>
      </div>
      <button id="pcr-change" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-lg shrink-0 transition-colors">Change file</button>
    </div>

    <!-- Thumbnail grid -->
    <div>
      <p class="text-xs text-slate-500 mb-2">Page previews (crop preview not available - margins shown below):</p>
      <div id="pcr-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
    </div>

    <p class="text-xs text-slate-500">Enter the amount to crop from each side in millimetres (mm). Set to 0 to leave that side unchanged.</p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Top (mm)</label>
        <input type="number" id="pcr-top" value="10" min="0" max="200" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Bottom (mm)</label>
        <input type="number" id="pcr-bottom" value="10" min="0" max="200" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Left (mm)</label>
        <input type="number" id="pcr-left" value="10" min="0" max="200" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Right (mm)</label>
        <input type="number" id="pcr-right" value="10" min="0" max="200" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
    </div>

    <div class="flex gap-2">
      <button id="pcr-crop" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Crop PDF &amp; Download</button>
      <button id="pcr-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear</button>
    </div>
  </div>

  <div id="pcr-status" class="hidden text-sm py-1"></div>
</div>

<style>
  .pcr-card { transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s; }
  .pcr-card:hover { border-color: rgb(249 115 22 / 0.7); }
  .pcr-thumb-wrap { background: #fff; }
</style>

<script is:inline>
(function () {
  const MM_TO_PT = 2.8346;
  const PDFJS_CDN   = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
  const PDFLIB_CDN  = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';

  const drop = document.getElementById('pcr-drop');
  const fileInput = document.getElementById('pcr-file');
  const panel = document.getElementById('pcr-panel');
  const loading = document.getElementById('pcr-loading');
  const loadingMsg = document.getElementById('pcr-loading-msg');
  const loadingBar = document.getElementById('pcr-loading-bar');
  const statusEl = document.getElementById('pcr-status');
  const grid = document.getElementById('pcr-grid');
  let currentFile = null, pdfBytes = null, thumbs = [];

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500/80'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500/80'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500/80'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;

    drop.classList.add('hidden');
    loading.classList.remove('hidden');
    statusEl.classList.add('hidden');
    loadingBar.style.width = '0%';
    loadingMsg.textContent = 'Reading PDF…';

    try {
      pdfBytes = await file.arrayBuffer();

      await loadScript(PDFJS_CDN);
      const pdfjsLib = window['pdfjs-dist/build/pdf'];
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

      const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes.slice(0) }).promise;
      const pageCount = pdfDoc.numPages;
      thumbs = [];

      // Generate thumbnails
      for (let i = 1; i <= pageCount; i++) {
        loadingMsg.textContent = `Generating previews… ${i} / ${pageCount}`;
        loadingBar.style.width = `${Math.round((i / pageCount) * 100)}%`;

        const page = await pdfDoc.getPage(i);
        const viewport = page.getViewport({ scale: 0.3 });
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(viewport.width);
        canvas.height = Math.round(viewport.height);
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        await page.render({ canvasContext: ctx, viewport }).promise;
        thumbs.push(canvas.toDataURL('image/jpeg', 0.82));
      }

      // Load PDF.js for metadata
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      currentFile = { file, doc };
      document.getElementById('pcr-name').textContent = file.name;
      document.getElementById('pcr-info').textContent = `${pageCount} pages · ${(file.size / 1024).toFixed(1)} KB`;
      loading.classList.add('hidden');
      panel.classList.remove('hidden');
      renderGrid(pageCount);
    } catch (e) {
      loading.classList.add('hidden');
      drop.classList.remove('hidden');
      showStatus('Could not read PDF: ' + e.message, 'error');
    }
  }

  function renderGrid(pageCount) {
    grid.innerHTML = Array.from({ length: pageCount }, (_, i) => {
      const thumb = thumbs[i] || '';
      return `
        <div class="pcr-card relative cursor-default select-none rounded-2xl border-2 border-slate-700/60 hover:border-orange-400/70 bg-[var(--bg-surface)] overflow-hidden">
          <div class="pcr-thumb-wrap w-full flex items-center justify-center overflow-hidden">
            ${thumb
              ? `<img src="${thumb}" class="w-full h-auto block" alt="Page ${i + 1}" draggable="false" />`
              : `<div class="w-full flex items-center justify-center py-12 text-slate-500 text-xs">Page ${i + 1}</div>`
            }
          </div>
          <div class="flex items-center justify-center px-3 py-2 border-t border-slate-800">
            <span class="text-sm font-semibold text-slate-300">Page ${i + 1}</span>
          </div>
        </div>`;
    }).join('');
  }

  document.getElementById('pcr-crop').addEventListener('click', async () => {
    if (!currentFile) return;
    const topMm = parseFloat(document.getElementById('pcr-top').value) || 0;
    const bottomMm = parseFloat(document.getElementById('pcr-bottom').value) || 0;
    const leftMm = parseFloat(document.getElementById('pcr-left').value) || 0;
    const rightMm = parseFloat(document.getElementById('pcr-right').value) || 0;

    if (topMm === 0 && bottomMm === 0 && leftMm === 0 && rightMm === 0) {
      showStatus('All margins are 0 — no crop applied. Enter a value for at least one side.', 'error');
      return;
    }

    showStatus('Cropping PDF…', 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const pages = doc.getPages();

      pages.forEach(page => {
        const { width, height } = page.getSize();
        const top = topMm * MM_TO_PT;
        const bottom = bottomMm * MM_TO_PT;
        const left = leftMm * MM_TO_PT;
        const right = rightMm * MM_TO_PT;
        const cropX = left;
        const cropY = bottom;
        const cropW = Math.max(1, width - left - right);
        const cropH = Math.max(1, height - top - bottom);
        page.setCropBox(cropX, cropY, cropW, cropH);
      });

      const outBytes = await doc.save();
      const outName = currentFile.file.name.replace(/\.pdf$/i, '') + '-cropped.pdf';
      downloadBytes(outBytes, outName);
      showStatus(`✅ Cropped ${pages.length} page${pages.length !== 1 ? 's' : ''} and downloaded.`, 'success');
    } catch (e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pcr-clear').addEventListener('click', () => {
    currentFile = null; pdfBytes = null; thumbs = [];
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    loading.classList.add('hidden');
    statusEl.classList.add('hidden');
    grid.innerHTML = '';
    fileInput.value = '';
  });

  function showStatus(msg, type) {
    statusEl.textContent = msg;
    statusEl.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    statusEl.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
