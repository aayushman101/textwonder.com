---
---
<div class="space-y-4">
  <textarea id="scc-input" rows="7" placeholder="Paste your text here…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2">
    <button id="scc-convert" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Convert</button>
    <button id="scc-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="scc-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span class="text-xs text-slate-500">Result</span>
      <button id="scc-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="scc-output" rows="7" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  function toSentenceCase(text) {
    return text.replace(/(^\s*|[.!?]\s+)([a-z])/g, (m, p1, p2) => p1 + p2.toUpperCase()).replace(/^([A-Z])(.*)/s, (m, p1, p2) => p1 + p2.toLowerCase())
      || text.replace(/(^|[.!?]\s+)(\w)/g, (m, p1, p2) => p1 + p2.toUpperCase());
  }
  function toSentenceCaseProper(text) {
    if (!text.trim()) return text;
    const lower = text.toLowerCase();
    return lower.replace(/(^|[.!?]\s+)\s*(\w)/g, (m, p1, p2) => p1 + p2.toUpperCase());
  }
  const input = document.getElementById('scc-input');
  const output = document.getElementById('scc-output');
  const wrap = document.getElementById('scc-output-wrap');
  const saved = localStorage.getItem('tw-sentence-case-converter');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-sentence-case-converter', input.value));
  document.getElementById('scc-convert').addEventListener('click', () => {
    const result = toSentenceCaseProper(input.value);
    output.value = result;
    wrap.classList.remove('hidden');
  });
  document.getElementById('scc-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); localStorage.removeItem('tw-sentence-case-converter'); });
  document.getElementById('scc-copy').addEventListener('click', () => { navigator.clipboard.writeText(output.value); });
</script>
