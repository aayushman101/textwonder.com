---
---
<div class="space-y-4">
  <textarea id="usg-input" rows="5" placeholder="My Awesome Blog Post Title!&#10;Another Great Article: Part 2&#10;H챕llo W철rld" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2 flex-wrap items-center">
    <button id="usg-convert" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Generate Slug</button>
    <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer">
      <input type="checkbox" id="usg-lower" checked class="accent-violet-500"> Lowercase
    </label>
    <button id="usg-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="usg-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span class="text-xs text-slate-500">Generated slugs</span>
      <button id="usg-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy all</button>
    </div>
    <textarea id="usg-output" rows="5" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  const ACCENT_MAP = {'횪':'a','찼':'a','창':'a','찾':'a','채':'a','책':'a','챈':'ae','챌':'c','챔':'e','챕':'e','챗':'e','챘':'e','챙':'i','챠':'i','챤':'i','챦':'i','챰':'n','챵':'o','처':'o','척':'o','천':'o','철':'o','첩':'o','첫':'u','첬':'u','청':'u','체':'u','첵':'y','첼':'y','횩':'ss'};
  function toSlug(str, lower) {
    let s = lower ? str.toLowerCase() : str;
    s = s.replace(/[횪찼창찾채책챈챌챔챕챗챘챙챠챤챦챰챵처척천철첩첫첬청체첵첼횩]/g, c => ACCENT_MAP[c] || c);
    s = s.replace(/[^a-zA-Z0-9\s\-]/g, '').replace(/[\s_]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
    return s;
  }
  const input = document.getElementById('usg-input');
  const output = document.getElementById('usg-output');
  const wrap = document.getElementById('usg-output-wrap');
  const lowerCb = document.getElementById('usg-lower');
  const saved = localStorage.getItem('tw-url-slug-generator');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-url-slug-generator', input.value));
  document.getElementById('usg-convert').addEventListener('click', () => {
    output.value = input.value.split('\n').map(l => l.trim() ? toSlug(l, lowerCb.checked) : '').join('\n');
    wrap.classList.remove('hidden');
  });
  document.getElementById('usg-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); localStorage.removeItem('tw-url-slug-generator'); });
  document.getElementById('usg-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
