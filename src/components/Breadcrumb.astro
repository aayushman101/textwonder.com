---
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-slate-500">
    <li>
      <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <>
        <li aria-hidden="true">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li>
          {item.href
            ? <a href={item.href} class="hover:text-violet-400 transition-colors">{item.label}</a>
            : <span class="text-slate-300" aria-current="page">{item.label}</span>
          }
        </li>
      </>
    ))}
  </ol>
</nav>
