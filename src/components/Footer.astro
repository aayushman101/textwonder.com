---
import { CATEGORIES, TOOLS } from '../data/tools.js';

const popularTools = TOOLS.filter(t => t.searchVolume === 'high' || t.searchVolume === 'very-high').slice(0, 6);
---

<footer class="border-t border-slate-800 bg-[var(--bg-base)] mt-16">
  <!-- Trust banner -->
  <div class="bg-[var(--bg-surface)] border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center gap-2 text-center sm:text-left">
      <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
      <p class="text-sm text-slate-400">
        <strong class="text-emerald-400">Privacy by design:</strong> All tools run entirely in your browser. We never store, transmit, or process your text on any server.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;">
          Text<span class="text-violet-500">Wonder</span>
        </a>
        <p class="text-slate-400 text-sm mt-2 leading-relaxed">
          Free online text tools. Fast, private, and completely browser-based. No signup ever.
        </p>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Categories</h3>
        <ul class="space-y-2">
          {CATEGORIES.map(cat => (
            <li>
              <a href={`/categories/${cat.slug}`} class="text-slate-400 hover:text-violet-400 text-sm transition-colors">
                {cat.icon} {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Tools -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Popular Tools</h3>
        <ul class="space-y-2">
          {popularTools.map(tool => (
            <li>
              <a href={`/tools/${tool.slug}`} class="text-slate-400 hover:text-violet-400 text-sm transition-colors">
                {tool.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Company</h3>
        <ul class="space-y-2">
          <li><a href="/tools" class="text-slate-400 hover:text-violet-400 text-sm transition-colors">All Tools</a></li>
          <li><a href="/blog" class="text-slate-400 hover:text-violet-400 text-sm transition-colors">Blog</a></li>
          <li><a href="/privacy-policy" class="text-slate-400 hover:text-violet-400 text-sm transition-colors">Privacy Policy</a></li>
        </ul>
        <h3 class="text-white font-semibold text-sm mt-5 mb-3">Our Other Sites</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://aaobanao.com" target="_blank" rel="noopener" class="text-slate-400 hover:text-violet-400 text-sm transition-colors">
              AaoBanao.com
            </a>
          </li>
          <li>
            <a href="https://toolswonder.com" target="_blank" rel="noopener" class="text-slate-400 hover:text-violet-400 text-sm transition-colors">
              ToolsWonder.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-slate-500 text-sm">© {new Date().getFullYear()} TextWonder. All rights reserved.</p>
      <p class="text-slate-500 text-sm">Made with care for people who work with text.</p>
    </div>
  </div>
</footer>
