---
---

<div class="space-y-4">
  <!-- Mode selector -->
  <div>
    <span class="text-slate-300 text-sm font-medium block mb-2">Reverse mode:</span>
    <div class="flex flex-wrap gap-2">
      <button id="rt-mode-char" class="px-4 py-2 rounded-xl text-sm font-medium bg-violet-700 text-white transition-colors">
        By Character
      </button>
      <button id="rt-mode-word" class="px-4 py-2 rounded-xl text-sm font-medium bg-[var(--bg-surface-hover)] text-slate-300 hover:bg-[var(--bg-surface-alt)] transition-colors">
        By Word
      </button>
      <button id="rt-mode-line" class="px-4 py-2 rounded-xl text-sm font-medium bg-[var(--bg-surface-hover)] text-slate-300 hover:bg-[var(--bg-surface-alt)] transition-colors">
        By Line
      </button>
    </div>
    <p id="rt-mode-desc" class="text-slate-500 text-xs mt-2">"Hello World" → "dlroW olleH"</p>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <span id="rt-input-count" class="text-xs text-slate-500">0 characters</span>
    </div>
    <textarea
      id="rt-input"
      rows="7"
      placeholder="Type or paste your text here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="rt-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      Reverse Text
    </button>
    <button id="rt-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Reversed Result</label>
      <button id="rt-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea
      id="rt-output"
      rows="7"
      readonly
      placeholder="Result will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<div id="rt-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('rt-input') as HTMLTextAreaElement;
  const output = document.getElementById('rt-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('rt-input-count')!;
  const modeDesc = document.getElementById('rt-mode-desc')!;
  const toast = document.getElementById('rt-toast')!;
  const STORAGE_KEY = 'tw-reverse-text';

  const modes = [
    { id: 'rt-mode-char', label: 'By Character', desc: '"Hello World" → "dlroW olleH"' },
    { id: 'rt-mode-word', label: 'By Word', desc: '"Hello World" → "World Hello"' },
    { id: 'rt-mode-line', label: 'By Line', desc: 'Reverses the order of lines in a multi-line block' },
  ];

  let currentMode = 'char';

  const ACTIVE = 'px-4 py-2 rounded-xl text-sm font-medium bg-violet-700 text-white transition-colors';
  const INACTIVE = 'px-4 py-2 rounded-xl text-sm font-medium bg-[var(--bg-surface-hover)] text-slate-300 hover:bg-[var(--bg-surface-alt)] transition-colors';

  function setMode(mode: string) {
    currentMode = mode;
    modes.forEach(m => {
      const btn = document.getElementById(m.id)!;
      btn.className = m.id === `rt-mode-${mode}` ? ACTIVE : INACTIVE;
      if (m.id === `rt-mode-${mode}`) modeDesc.textContent = m.desc;
    });
    process();
  }

  function reverseByChar(text: string): string {
    return [...text].reverse().join('');
  }
  function reverseByWord(text: string): string {
    return text.split(/(\s+)/).reverse().join('');
  }
  function reverseByLine(text: string): string {
    return text.split('\n').reverse().join('\n');
  }

  function process() {
    const text = input.value;
    let result = '';
    if (currentMode === 'char') result = reverseByChar(text);
    else if (currentMode === 'word') result = reverseByWord(text);
    else result = reverseByLine(text);
    output.value = result;
    inputCount.textContent = `${text.length} characters`;
    localStorage.setItem(STORAGE_KEY, text);
  }

  function showToast() { toast.style.opacity = '1'; setTimeout(() => { toast.style.opacity = '0'; }, 2000); }

  document.getElementById('rt-mode-char')!.addEventListener('click', () => setMode('char'));
  document.getElementById('rt-mode-word')!.addEventListener('click', () => setMode('word'));
  document.getElementById('rt-mode-line')!.addEventListener('click', () => setMode('line'));
  input.addEventListener('input', process);
  document.getElementById('rt-process')!.addEventListener('click', process);
  document.getElementById('rt-clear')!.addEventListener('click', () => {
    input.value = ''; output.value = ''; inputCount.textContent = '0 characters'; localStorage.removeItem(STORAGE_KEY);
  });
  document.getElementById('rt-copy')!.addEventListener('click', () => {
    if (!output.value) return; navigator.clipboard.writeText(output.value).then(showToast);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; process(); }
</script>
