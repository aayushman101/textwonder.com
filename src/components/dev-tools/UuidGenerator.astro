---
---
<div class="space-y-4">
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 items-end">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Count</label>
      <input id="uuid-count" type="number" value="1" min="1" max="100" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-cyan-500" />
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Case</label>
      <select id="uuid-case" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-cyan-500">
        <option value="lower">Lowercase</option>
        <option value="upper">Uppercase</option>
      </select>
    </div>
    <div class="col-span-2 flex gap-2">
      <button id="uuid-gen" class="flex-1 py-2.5 bg-cyan-600 hover:bg-cyan-500 text-white rounded-lg text-sm font-medium transition-colors">Generate</button>
      <button id="uuid-copy-all" class="flex-1 py-2.5 bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-300 rounded-lg text-sm transition-colors">Copy All</button>
    </div>
  </div>

  <div id="uuid-list" class="space-y-1.5 font-mono text-sm"></div>

  <div class="flex items-center gap-2 text-xs text-slate-600">
    <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
    Generated using <code>crypto.randomUUID()</code> — cryptographically secure
  </div>
</div>

<script is:inline>
(function() {
  let lastUuids = [];

  function gen() {
    const count = Math.min(100, Math.max(1, parseInt(document.getElementById('uuid-count').value) || 1));
    const upper = document.getElementById('uuid-case').value === 'upper';
    lastUuids = Array.from({length: count}, () => {
      const u = crypto.randomUUID();
      return upper ? u.toUpperCase() : u;
    });
    const list = document.getElementById('uuid-list');
    list.innerHTML = lastUuids.map(u => `
      <div class="flex items-center gap-2 bg-[var(--bg-base)] border border-slate-800 rounded-lg px-3 py-2 group hover:border-slate-700 transition-colors">
        <span class="flex-1 text-slate-200 text-xs select-all">${u}</span>
        <button class="uuid-copy-one text-slate-600 hover:text-cyan-400 transition-colors text-xs opacity-0 group-hover:opacity-100" data-val="${u}">Copy</button>
      </div>`).join('');
    document.querySelectorAll('.uuid-copy-one').forEach(btn => {
      btn.addEventListener('click', () => navigator.clipboard.writeText(btn.dataset.val));
    });
  }

  document.getElementById('uuid-gen').addEventListener('click', gen);
  document.getElementById('uuid-copy-all').addEventListener('click', () => { if (lastUuids.length) navigator.clipboard.writeText(lastUuids.join('\n')); });
  document.getElementById('uuid-case').addEventListener('change', () => { if (lastUuids.length) gen(); });

  gen();
})();
</script>
