---
---
<div class="space-y-5">
  <div id="ptt-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="ptt-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">📝</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Text-based PDFs only (not scanned images)</p>
  </div>

  <div id="ptt-status" class="hidden text-sm py-2 text-slate-400"></div>

  <div id="ptt-result" class="hidden space-y-3">
    <div class="flex items-center justify-between">
      <span id="ptt-stats" class="text-xs text-slate-500"></span>
      <div class="flex gap-2">
        <button id="ptt-copy" class="text-xs text-orange-400 hover:text-orange-300 transition-colors">Copy all</button>
        <button id="ptt-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear</button>
      </div>
    </div>
    <textarea id="ptt-output" rows="14" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-200 text-sm font-mono resize-y select-all leading-relaxed"></textarea>
  </div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('ptt-drop');
  const fileInput = document.getElementById('ptt-file');
  const statusEl = document.getElementById('ptt-status');
  const result = document.getElementById('ptt-result');
  const output = document.getElementById('ptt-output');
  const stats = document.getElementById('ptt-stats');

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); extractText(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => extractText(fileInput.files[0]));

  async function extractText(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading PDF.js…', false);
    await loadPdfJs();
    showStatus('Extracting text…', false);
    try {
      const pdfjsLib = window['pdfjs-dist/build/pdf'] || window.pdfjsLib;
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      let text = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const pageText = content.items.map(item => item.str).join(' ');
        text += `--- Page ${i} ---\n${pageText}\n\n`;
        showStatus(`Extracting page ${i} of ${pdf.numPages}…`, false);
      }
      output.value = text.trim();
      const wordCount = text.trim().split(/\s+/).filter(Boolean).length;
      stats.textContent = `${pdf.numPages} pages · ${wordCount.toLocaleString()} words · ${text.length.toLocaleString()} characters`;
      drop.classList.add('hidden');
      statusEl.classList.add('hidden');
      result.classList.remove('hidden');
    } catch(e) { showStatus('Error: ' + e.message + ' (Is this a text-based PDF?)', true); }
  }

  document.getElementById('ptt-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
  document.getElementById('ptt-clear').addEventListener('click', () => { output.value = ''; result.classList.add('hidden'); drop.classList.remove('hidden'); });

  function showStatus(msg, isError) {
    statusEl.textContent = msg;
    statusEl.className = 'text-sm py-2 ' + (isError ? 'text-red-400' : 'text-slate-400');
    statusEl.classList.remove('hidden');
  }

  function loadPdfJs() {
    if (window['pdfjs-dist/build/pdf'] || window.pdfjsLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
