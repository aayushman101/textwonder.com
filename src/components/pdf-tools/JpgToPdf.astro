---
---
<div class="space-y-5">
  <div id="jtp-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="jtp-file" accept="image/jpeg,image/png,image/webp" multiple class="hidden" />
    <div class="text-4xl mb-2">📷</div>
    <p class="text-slate-300 font-medium mb-1">Drop images here or click to select</p>
    <p class="text-slate-500 text-sm">JPG, PNG, WebP supported · each image becomes one PDF page</p>
  </div>

  <div id="jtp-list" class="hidden space-y-2"></div>

  <div id="jtp-actions" class="hidden flex gap-2">
    <button id="jtp-convert" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Convert to PDF</button>
    <button id="jtp-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear all</button>
  </div>

  <div id="jtp-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('jtp-drop');
  const fileInput = document.getElementById('jtp-file');
  const listEl = document.getElementById('jtp-list');
  const actionsEl = document.getElementById('jtp-actions');
  const status = document.getElementById('jtp-status');
  let images = [];

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); addImages([...e.dataTransfer.files]); });
  fileInput.addEventListener('change', () => { addImages([...fileInput.files]); fileInput.value = ''; });

  function addImages(files) {
    files.filter(f => f.type.startsWith('image/')).forEach(f => images.push(f));
    renderList();
  }

  function renderList() {
    if (!images.length) { listEl.classList.add('hidden'); actionsEl.classList.add('hidden'); return; }
    listEl.classList.remove('hidden'); actionsEl.classList.remove('hidden');
    listEl.innerHTML = images.map((f, i) => `
      <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-lg px-4 py-2.5">
        <span class="text-purple-400 text-lg">🖼️</span>
        <span class="text-slate-300 text-sm flex-1 truncate">${f.name}</span>
        <span class="text-slate-500 text-xs">${(f.size / 1024).toFixed(0)} KB</span>
        <button onclick="jtpRemove(${i})" class="text-slate-600 hover:text-red-400 transition-colors text-sm ml-1">✕</button>
      </div>`).join('');
  }

  window.jtpRemove = (i) => { images.splice(i, 1); renderList(); };

  document.getElementById('jtp-convert').addEventListener('click', async () => {
    if (!images.length) return;
    showStatus('Loading pdf-lib…', 'info');
    await loadPdfLib();
    showStatus('Building PDF…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.create();
      const A4_W = 595.28, A4_H = 841.89;

      for (const file of images) {
        const bytes = await file.arrayBuffer();
        let img;
        if (file.type === 'image/jpeg' || file.name.match(/\.jpe?g$/i)) {
          img = await doc.embedJpg(bytes);
        } else {
          img = await doc.embedPng(bytes);
        }
        const { width: iw, height: ih } = img;
        const scale = Math.min(A4_W / iw, A4_H / ih);
        const w = iw * scale, h = ih * scale;
        const page = doc.addPage([A4_W, A4_H]);
        page.drawImage(img, { x: (A4_W - w) / 2, y: (A4_H - h) / 2, width: w, height: h });
      }

      const pdfBytes = await doc.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'images.pdf'; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      showStatus(`✅ PDF created with ${images.length} page${images.length !== 1 ? 's' : ''} (${(pdfBytes.length / 1024).toFixed(0)} KB)`, 'success');
    } catch (err) {
      showStatus('Error: ' + err.message, 'error');
    }
  });

  document.getElementById('jtp-clear').addEventListener('click', () => {
    images = []; renderList(); status.classList.add('hidden');
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
