import BlogLayout from '../../layouts/BlogLayout.astro';

const faqs = [
  { q: 'Will text still be readable after converting to grayscale?', a: 'Yes. Text in the original PDF will appear as dark grey or black on a white or light grey background — perfectly readable. Only colour information is removed.' },
  { q: 'Does the output PDF have selectable text?', a: 'No — the tool renders each page as an image and embeds it in the PDF, so the output is image-based. Text will not be selectable or searchable. Keep the original PDF for text-based tasks.' },
  { q: 'How does converting to grayscale save money when printing?', a: 'Most printers charge significantly more per page for colour printing than black-and-white. Converting a colour PDF to grayscale before printing means your printer uses only black toner/ink, even if the source document was in colour.' },
  { q: 'What is the difference between grayscale and black-and-white?', a: 'Grayscale preserves shades of grey between pure black and pure white — photographs and gradients look natural. Pure black-and-white (1-bit monochrome) has no grey, only black or white pixels. The PDFWonder tool produces grayscale, which looks more natural.' },
  { q: 'Will the file size change after converting to grayscale?', a: 'The output is image-based and may be slightly larger than the original text-based PDF. Use the PDF Compressor tool afterward to reduce the file size.' },
  { q: 'Are my files uploaded anywhere?', a: 'No. All processing happens locally in your browser using PDF.js and pdf-lib. Your files never leave your device.' },
];
