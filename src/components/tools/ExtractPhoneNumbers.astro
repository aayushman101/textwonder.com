---
---

<div class="space-y-4">
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Input Text</label>
    <textarea id="epn-input" rows="7" placeholder="Paste any text containing phone numbers here..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"></textarea>
  </div>
  <div class="flex items-center gap-3">
    <button id="epn-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">Extract Phone Numbers</button>
    <button id="epn-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">Clear</button>
  </div>
  <div id="epn-stats" class="hidden">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-sm text-slate-400">Found: <strong id="epn-count" class="text-violet-400">0</strong> phone numbers</span>
      <button id="epn-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy All</button>
    </div>
    <textarea id="epn-output" rows="6" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y outline-none text-sm font-mono"></textarea>
  </div>
</div>

<script>
function extract() {
  const text = document.getElementById('epn-input').value;
  const pattern = /(?:\+?(\d{1,3})[\s.-]?)?(?:\((\d{1,4})\)[\s.-]?)?(\d{3,5})[\s.-]?(\d{3,5})[\s.-]?(\d{0,5})/g;
  const found = new Set();
  let match;
  while ((match = pattern.exec(text)) !== null) {
    const full = match[0].trim();
    if (/\d{7,}/.test(full.replace(/\D/g,''))) found.add(full);
  }
  const phones = [...found].filter(p => {
    const digits = p.replace(/\D/g,'');
    return digits.length >= 7 && digits.length <= 15;
  });
  const stats = document.getElementById('epn-stats');
  document.getElementById('epn-count').textContent = phones.length;
  document.getElementById('epn-output').value = phones.join('\n');
  stats.classList.toggle('hidden', phones.length === 0);
}

document.getElementById('epn-process').addEventListener('click', extract);
document.getElementById('epn-clear').addEventListener('click', () => {
  document.getElementById('epn-input').value = '';
  document.getElementById('epn-stats').classList.add('hidden');
});
document.getElementById('epn-copy').addEventListener('click', () => {
  const val = document.getElementById('epn-output').value;
  if (!val) return;
  navigator.clipboard.writeText(val);
  const btn = document.getElementById('epn-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = 'Copy All', 1500);
});
</script>
