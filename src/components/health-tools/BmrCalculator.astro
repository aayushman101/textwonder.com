---
---
<div>
  <div class="flex gap-2 mb-4">
    <button id="bmr-metric-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-white" style="background:#22c55e" onclick="bmrUnit('metric')">Metric</button>
    <button id="bmr-imperial-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700" onclick="bmrUnit('imperial')">Imperial</button>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm text-slate-400 mb-1">Gender</label>
      <div class="flex gap-3 pt-1">
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="bmr-gender" value="male" checked class="accent-green-500" /><span class="text-white text-sm">Male</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="bmr-gender" value="female" class="accent-green-500" /><span class="text-white text-sm">Female</span></label>
      </div>
    </div>
    <div><label class="block text-sm text-slate-400 mb-1">Age (years)</label><input type="number" id="bmr-age" placeholder="e.g. 25" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>

  <div id="bmr-metric-inputs" class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (kg)</label><input type="number" id="bmr-kg" placeholder="e.g. 70" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (cm)</label><input type="number" id="bmr-cm" placeholder="e.g. 175" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div id="bmr-imperial-inputs" class="hidden grid grid-cols-3 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (lbs)</label><input type="number" id="bmr-lbs" placeholder="e.g. 154" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (ft)</label><input type="number" id="bmr-ft" placeholder="5" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (in)</label><input type="number" id="bmr-in" placeholder="9" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>

  <div id="bmr-result" class="hidden space-y-3">
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-sm text-slate-400 mb-1">Your BMR (calories at rest)</div>
      <div id="bmr-value" class="text-4xl font-bold" style="color:#22c55e"></div>
      <div class="text-slate-400 text-sm">kcal/day</div>
    </div>
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700">
      <div class="text-sm text-slate-400 mb-3">TDEE by Activity Level</div>
      <div class="space-y-2" id="bmr-tdee-list"></div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  let unitMode = 'metric';
  window.bmrUnit = function(m) {
    unitMode = m;
    document.getElementById('bmr-metric-inputs').classList.toggle('hidden', m!=='metric');
    document.getElementById('bmr-imperial-inputs').classList.toggle('hidden', m!=='imperial');
    const mb=document.getElementById('bmr-metric-btn'), ib=document.getElementById('bmr-imperial-btn');
    if(m==='metric'){mb.style.background='#22c55e';mb.className='px-3 py-1.5 rounded-lg text-sm font-medium text-white';ib.style.background='';ib.className='px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700';}
    else{ib.style.background='#22c55e';ib.className='px-3 py-1.5 rounded-lg text-sm font-medium text-white';mb.style.background='';mb.className='px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700';}
    calc();
  };
  const activities = [
    {label:'Sedentary (desk job, no exercise)',mult:1.2},
    {label:'Lightly active (1–3 days/wk)',mult:1.375},
    {label:'Moderately active (3–5 days/wk)',mult:1.55},
    {label:'Very active (6–7 days/wk)',mult:1.725},
    {label:'Extra active (athlete/physical job)',mult:1.9},
  ];
  function calc() {
    const gender = document.querySelector('input[name="bmr-gender"]:checked').value;
    const age = parseFloat(document.getElementById('bmr-age').value);
    let kg, cm;
    if(unitMode==='metric') {
      kg=parseFloat(document.getElementById('bmr-kg').value);
      cm=parseFloat(document.getElementById('bmr-cm').value);
    } else {
      const lbs=parseFloat(document.getElementById('bmr-lbs').value);
      const ft=parseFloat(document.getElementById('bmr-ft').value)||0;
      const inch=parseFloat(document.getElementById('bmr-in').value)||0;
      kg=lbs*0.453592; cm=(ft*12+inch)*2.54;
    }
    const res=document.getElementById('bmr-result');
    if(!age||!kg||!cm||age<=0||kg<=0||cm<=0) { res.classList.add('hidden'); return; }
    let bmr;
    if(gender==='male') bmr=10*kg+6.25*cm-5*age+5;
    else bmr=10*kg+6.25*cm-5*age-161;
    document.getElementById('bmr-value').textContent = Math.round(bmr).toLocaleString();
    document.getElementById('bmr-tdee-list').innerHTML = activities.map(a =>
      `<div class="flex justify-between text-sm"><span class="text-slate-400">${a.label}</span><span class="text-white font-medium">${Math.round(bmr*a.mult).toLocaleString()} kcal</span></div>`
    ).join('');
    res.classList.remove('hidden');
  }
  ['bmr-age','bmr-kg','bmr-cm','bmr-lbs','bmr-ft','bmr-in'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',calc);});
  document.querySelectorAll('input[name="bmr-gender"]').forEach(r=>r.addEventListener('change',calc));
})();
</script>
