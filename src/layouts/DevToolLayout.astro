---
import BaseLayout from './BaseLayout.astro';
import DevHeader from '../components/DevHeader.astro';
import Footer from '../components/Footer.astro';

const { tool } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: tool.name,
  url: `https://textwonder.com/devwonder/${tool.slug}`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  description: tool.metaDescription,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  provider: { '@type': 'Organization', name: 'TextWonder', url: 'https://textwonder.com' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://textwonder.com' },
    { '@type': 'ListItem', position: 2, name: 'DevWonder', item: 'https://textwonder.com/devwonder' },
    { '@type': 'ListItem', position: 3, name: tool.name, item: `https://textwonder.com/devwonder/${tool.slug}` },
  ],
};

const faqSchema = (tool.faqs && tool.faqs.length > 0) ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: tool.faqs.map((f: { q: string; a: string }) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---

<BaseLayout
  title={tool.metaTitle}
  description={tool.metaDescription}
  canonical={`/devwonder/${tool.slug}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <DevHeader />

  <main class="max-w-4xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1 text-sm text-slate-500 mb-6">
      <a href="/devwonder" class="hover:text-cyan-400 transition-colors">DevWonder</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-slate-300">{tool.name}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-white mt-2 mb-2" style="font-family: 'Space Grotesk', sans-serif;">
      {tool.h1}
    </h1>
    <p class="text-slate-400 text-lg mb-8">{tool.tagline}</p>

    <!-- Tool UI -->
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-6 mb-10">
      <slot />
    </div>

    <!-- SEO Content -->
    <section class="mb-10 space-y-6">
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">About {tool.name}</h2>
        <p class="text-slate-400 leading-relaxed">{tool.descriptionLong}</p>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">Use Cases</h2>
        <p class="text-slate-400 leading-relaxed">{tool.useCases}</p>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">How It Works</h2>
        <p class="text-slate-400 leading-relaxed">{tool.howItWorks}</p>
      </div>
    </section>

    <!-- FAQ -->
    {tool.faqs && tool.faqs.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold text-white mb-4">FAQs</h2>
        <div class="space-y-2">
          {tool.faqs.map((faq: { q: string; a: string }) => (
            <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
                <span class="text-white font-medium text-sm">{faq.q}</span>
                <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-5 pb-4"><p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Related tools -->
    <section>
      <h2 class="text-xl font-semibold text-white mb-4">Related Dev Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        {tool.relatedTools.map((slug: string) => (
          <a href={`/devwonder/${slug}`} class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 hover:border-cyan-500/50 hover:bg-[var(--bg-surface-hover)] transition-all">
            <span class="text-white text-sm font-medium group-hover:text-cyan-400 transition-colors block">{slug.replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}</span>
            <svg class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 transition-colors mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
