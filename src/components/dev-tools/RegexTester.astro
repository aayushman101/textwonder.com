---
---
<div class="space-y-4">
  <div class="flex gap-3 items-start">
    <div class="flex-1 space-y-1">
      <label class="text-xs text-slate-500">Pattern</label>
      <div class="flex items-center bg-[var(--bg-base)] border border-slate-700 rounded-xl focus-within:border-cyan-500 overflow-hidden">
        <span class="pl-4 text-slate-500 font-mono text-lg select-none">/</span>
        <input id="rx-pattern" type="text" placeholder="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}" class="flex-1 bg-transparent px-2 py-3 text-slate-100 placeholder-slate-600 font-mono text-sm focus:outline-none" spellcheck="false" />
        <span class="pr-2 text-slate-500 font-mono text-lg select-none">/</span>
        <input id="rx-flags" type="text" value="gi" maxlength="6" class="w-12 bg-transparent py-3 text-cyan-400 font-mono text-sm focus:outline-none" placeholder="gi" spellcheck="false" />
      </div>
    </div>
  </div>

  <div class="space-y-1">
    <div class="flex items-center justify-between">
      <label class="text-xs text-slate-500">Test string</label>
      <span id="rx-count" class="text-xs text-cyan-400"></span>
    </div>
    <div id="rx-highlight" class="w-full min-h-32 bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-200 font-mono text-sm leading-relaxed whitespace-pre-wrap break-words focus:outline-none focus:border-cyan-500 cursor-text" contenteditable="true" spellcheck="false" data-placeholder="Type or paste your test string here…"></div>
  </div>

  <div id="rx-groups" class="hidden space-y-2">
    <p class="text-xs text-slate-500 uppercase tracking-wide">Capture Groups</p>
    <div id="rx-groups-list" class="space-y-1"></div>
  </div>

  <div id="rx-status" class="hidden text-sm py-1 text-red-400"></div>
</div>

<style>
  #rx-highlight:empty:before { content: attr(data-placeholder); color: #64748b; }
  #rx-highlight mark { background: rgba(6,182,212,0.3); color: inherit; border-radius: 2px; }
  #rx-highlight mark.rx-g0 { background: rgba(6,182,212,0.35); }
  #rx-highlight mark.rx-g1 { background: rgba(249,115,22,0.3); }
</style>

<script is:inline>
(function() {
  const patternEl = document.getElementById('rx-pattern');
  const flagsEl = document.getElementById('rx-flags');
  const highlight = document.getElementById('rx-highlight');
  const countEl = document.getElementById('rx-count');
  const status = document.getElementById('rx-status');
  const groupsDiv = document.getElementById('rx-groups');
  const groupsList = document.getElementById('rx-groups-list');

  function run() {
    const pat = patternEl.value;
    const text = highlight.innerText;
    status.classList.add('hidden');
    groupsDiv.classList.add('hidden');

    if (!pat) { highlight.innerHTML = escHtml(text); countEl.textContent = ''; return; }

    let re;
    try { re = new RegExp(pat, flagsEl.value.includes('g') ? flagsEl.value : flagsEl.value + 'g'); }
    catch(e) { status.textContent = '❌ ' + e.message; status.classList.remove('hidden'); countEl.textContent = ''; highlight.innerHTML = escHtml(text); return; }

    const matches = [...text.matchAll(re)];
    countEl.textContent = matches.length ? `${matches.length} match${matches.length>1?'es':''}` : 'no matches';

    // Highlight
    let result = '', lastIdx = 0;
    matches.forEach(m => {
      result += escHtml(text.slice(lastIdx, m.index));
      result += `<mark class="rx-g0">${escHtml(m[0])}</mark>`;
      lastIdx = m.index + m[0].length;
    });
    result += escHtml(text.slice(lastIdx));

    const sel = window.getSelection();
    const savedOffset = sel.rangeCount ? sel.getRangeAt(0).startOffset : null;
    highlight.innerHTML = result;

    // Show groups
    const hasGroups = matches.some(m => m.length > 1);
    if (hasGroups) {
      groupsList.innerHTML = matches.flatMap((m, mi) =>
        m.slice(1).map((g, gi) => `<div class="text-xs font-mono bg-[var(--bg-surface)] border border-slate-800 rounded-lg px-3 py-1.5"><span class="text-slate-500">Match ${mi+1}, Group ${gi+1}: </span><span class="text-orange-400">${g === undefined ? '<em class="text-slate-600">unmatched</em>' : escHtml(g)}</span></div>`)
      ).join('');
      groupsDiv.classList.remove('hidden');
    }
  }

  function escHtml(str) { return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  patternEl.addEventListener('input', run);
  flagsEl.addEventListener('input', run);
  highlight.addEventListener('input', run);
})();
</script>
