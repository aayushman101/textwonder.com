---
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <span id="uc-input-count" class="text-xs text-slate-500">0 characters</span>
    </div>
    <textarea
      id="uc-input"
      rows="8"
      placeholder="Type or paste your text here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="uc-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      CONVERT TO UPPERCASE
    </button>
    <button id="uc-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">UPPERCASE Result</label>
      <button id="uc-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea
      id="uc-output"
      rows="8"
      readonly
      placeholder="Result will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<div id="uc-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('uc-input') as HTMLTextAreaElement;
  const output = document.getElementById('uc-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('uc-input-count')!;
  const toast = document.getElementById('uc-toast')!;
  const STORAGE_KEY = 'tw-uppercase-converter';

  function process() {
    output.value = input.value.toUpperCase();
    inputCount.textContent = `${input.value.length} characters`;
    localStorage.setItem(STORAGE_KEY, input.value);
  }
  function showToast() { toast.style.opacity = '1'; setTimeout(() => { toast.style.opacity = '0'; }, 2000); }

  input.addEventListener('input', process);
  document.getElementById('uc-process')!.addEventListener('click', process);
  document.getElementById('uc-clear')!.addEventListener('click', () => {
    input.value = ''; output.value = ''; inputCount.textContent = '0 characters'; localStorage.removeItem(STORAGE_KEY);
  });
  document.getElementById('uc-copy')!.addEventListener('click', () => {
    if (!output.value) return; navigator.clipboard.writeText(output.value).then(showToast);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; process(); }
</script>
