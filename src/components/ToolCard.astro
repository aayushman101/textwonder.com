---
import { getCategoryBySlug } from '../data/tools.js';

const { tool } = Astro.props;
const category = getCategoryBySlug(tool.category);
---

<a
  href={`/tools/${tool.slug}`}
  class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-5 hover:border-violet-500/50 hover:bg-[var(--bg-surface-hover)] transition-all"
>
  <div class="flex items-start justify-between gap-2 mb-2">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-900/40 text-violet-300 border border-violet-800/50">
      {category?.icon} {category?.name}
    </span>
    <svg class="w-4 h-4 text-slate-600 group-hover:text-violet-400 transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
  </div>
  <h3 class="text-white font-semibold text-base mb-1 group-hover:text-violet-300 transition-colors">
    {tool.name}
  </h3>
  <p class="text-slate-400 text-sm leading-relaxed">{tool.tagline}</p>
</a>
