---
---
<div class="space-y-5">
  <div id="pwc-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pwc-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">📊</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Counts words, characters, sentences, and pages instantly</p>
  </div>

  <div id="pwc-results" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-indigo-400 text-2xl">📄</span>
      <div>
        <p id="pwc-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="pwc-size" class="text-slate-500 text-xs"></p>
      </div>
      <button id="pwc-clear" class="ml-auto text-slate-500 hover:text-slate-300 text-xs border border-slate-700 rounded-lg px-3 py-1 transition-colors">Clear</button>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-indigo-400" id="pwc-words">—</p>
        <p class="text-xs text-slate-500 mt-1">Words</p>
      </div>
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-orange-400" id="pwc-chars">—</p>
        <p class="text-xs text-slate-500 mt-1">Characters</p>
      </div>
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-emerald-400" id="pwc-sentences">—</p>
        <p class="text-xs text-slate-500 mt-1">Sentences</p>
      </div>
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-rose-400" id="pwc-pages">—</p>
        <p class="text-xs text-slate-500 mt-1">Pages</p>
      </div>
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-sky-400" id="pwc-readtime">—</p>
        <p class="text-xs text-slate-500 mt-1">Read time</p>
      </div>
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-violet-400" id="pwc-chars-no-space">—</p>
        <p class="text-xs text-slate-500 mt-1">Chars (no spaces)</p>
      </div>
    </div>
  </div>

  <div id="pwc-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('pwc-drop');
  const fileInput = document.getElementById('pwc-file');
  const results = document.getElementById('pwc-results');
  const status = document.getElementById('pwc-status');

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); handleFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => handleFile(fileInput.files[0]));

  document.getElementById('pwc-clear').addEventListener('click', () => {
    results.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  async function handleFile(file) {
    if (!file || file.type !== 'application/pdf') { showStatus('Please select a valid PDF file.', 'error'); return; }
    showStatus('Loading PDF.js…', 'info');
    await loadPdfJs();
    showStatus('Extracting text…', 'info');
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      const numPages = pdf.numPages;
      let fullText = '';

      for (let i = 1; i <= numPages; i++) {
        const page = await pdf.getPage(i);
        const textContent = await page.getTextContent();
        fullText += textContent.items.map(item => item.str).join(' ') + ' ';
      }

      const words = fullText.trim() ? fullText.trim().split(/\s+/).filter(w => w.length > 0).length : 0;
      const chars = fullText.replace(/\n/g, '').length;
      const charsNoSpace = fullText.replace(/\s/g, '').length;
      const sentences = (fullText.match(/[.!?]+/g) || []).length;
      const readMinutes = Math.ceil(words / 238);

      document.getElementById('pwc-name').textContent = file.name;
      document.getElementById('pwc-size').textContent = `${(file.size / 1024).toFixed(1)} KB`;
      document.getElementById('pwc-words').textContent = words.toLocaleString();
      document.getElementById('pwc-chars').textContent = chars.toLocaleString();
      document.getElementById('pwc-chars-no-space').textContent = charsNoSpace.toLocaleString();
      document.getElementById('pwc-sentences').textContent = sentences.toLocaleString();
      document.getElementById('pwc-pages').textContent = numPages.toLocaleString();
      document.getElementById('pwc-readtime').textContent = readMinutes < 1 ? '<1 min' : `${readMinutes} min`;

      drop.classList.add('hidden');
      results.classList.remove('hidden');
      status.classList.add('hidden');
    } catch (err) {
      showStatus('Error: ' + (err.message || 'Could not process PDF'), 'error');
    }
  }

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function loadPdfJs() {
    if (window.pdfjsLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      s.onload = () => {
        window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        resolve();
      };
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
