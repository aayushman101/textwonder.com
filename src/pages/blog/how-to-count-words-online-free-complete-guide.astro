const faqs = [
  { q: 'What is the difference between word count and character count?', a: 'Word count counts every word (separated by spaces). Character count includes every letter, digit, space, and punctuation mark. A 10-word sentence might be 50+ characters.' },
  { q: 'Do word counters include hyphenated words as one word or two?', a: 'Most word counters (including ours) treat hyphenated words as a single word. "New-school" = 1 word, not 2.' },
  { q: 'Why does my Word document show a different word count than TextWonder?', a: 'Different tools may count headers, footnotes, or text-in-graphics differently. Our counter counts only visible text words, which is the standard method.' },
  { q: 'Can word counters help me write better content?', a: 'Yes! Word counts help ensure you meet requirements (essays, articles, social posts). Tracking average word length helps identify overly complex sentences.' },
  { q: 'Is there a character limit for word counters?', a: 'Most online word counters handle large documents (10,000+ words). TextWonder handles unlimited text size.' },
];
