---
---
<div class="space-y-5">
  <!-- Upload -->
  <div id="irsz-drop" class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center cursor-pointer hover:border-rose-500/60 transition-colors">
    <input id="irsz-file" type="file" accept="image/*" class="hidden" />
    <div class="text-3xl mb-2">🖼️</div>
    <p class="text-slate-300 font-medium">Drop an image here or <span class="text-rose-400 underline cursor-pointer">click to browse</span></p>
    <p class="text-slate-500 text-xs mt-1">JPG, PNG, WebP, BMP — runs in your browser</p>
  </div>

  <!-- Preview + controls (hidden until file loaded) -->
  <div id="irsz-panel" class="hidden space-y-4">
    <div class="flex flex-col sm:flex-row gap-4">
      <!-- Preview -->
      <div class="shrink-0">
        <img id="irsz-preview" src="" alt="Preview" class="max-w-[200px] max-h-[160px] rounded-lg object-contain border border-slate-700" />
        <p id="irsz-orig-info" class="text-xs text-slate-500 mt-1 text-center"></p>
      </div>
      <!-- Controls -->
      <div class="flex-1 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-slate-400 mb-1">Width (px)</label>
            <input id="irsz-width" type="number" min="1" max="8000" class="w-full bg-[var(--bg-surface-hover)] border border-slate-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
          <div>
            <label class="block text-xs text-slate-400 mb-1">Height (px)</label>
            <input id="irsz-height" type="number" min="1" max="8000" class="w-full bg-[var(--bg-surface-hover)] border border-slate-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
        </div>
        <label class="flex items-center gap-2 text-sm text-slate-300 cursor-pointer select-none">
          <input id="irsz-lock" type="checkbox" checked class="w-4 h-4 accent-rose-500" />
          Lock aspect ratio
        </label>
        <div>
          <label class="block text-xs text-slate-400 mb-1">Quality (JPEG/WebP only)</label>
          <div class="flex items-center gap-3">
            <input id="irsz-quality" type="range" min="10" max="100" value="90" class="flex-1 accent-rose-500" />
            <span id="irsz-quality-val" class="text-sm text-rose-400 w-8 text-right">90</span>
          </div>
        </div>
        <button id="irsz-btn" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white rounded-lg font-semibold text-sm transition-colors">
          Resize & Download
        </button>
      </div>
    </div>
  </div>
</div>

<canvas id="irsz-canvas" class="hidden"></canvas>

<script is:inline>
(function () {
  const dropZone = document.getElementById('irsz-drop');
  const fileInput = document.getElementById('irsz-file');
  const panel = document.getElementById('irsz-panel');
  const preview = document.getElementById('irsz-preview');
  const origInfo = document.getElementById('irsz-orig-info');
  const wInput = document.getElementById('irsz-width');
  const hInput = document.getElementById('irsz-height');
  const lockCb = document.getElementById('irsz-lock');
  const qualitySlider = document.getElementById('irsz-quality');
  const qualityVal = document.getElementById('irsz-quality-val');
  const btn = document.getElementById('irsz-btn');
  const canvas = document.getElementById('irsz-canvas');

  let img = null;
  let origW = 0, origH = 0;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-rose-500'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-rose-500'));
  dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('border-rose-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  qualitySlider.addEventListener('input', () => { qualityVal.textContent = qualitySlider.value; });

  function loadFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    img = new Image();
    img.onload = () => {
      origW = img.naturalWidth;
      origH = img.naturalHeight;
      preview.src = url;
      wInput.value = origW;
      hInput.value = origH;
      origInfo.textContent = `${origW} × ${origH} px · ${(file.size / 1024).toFixed(0)} KB`;
      panel.classList.remove('hidden');
      dropZone.classList.add('hidden');
    };
    img.src = url;
  }

  wInput.addEventListener('input', () => {
    if (lockCb.checked && origW) hInput.value = Math.round(parseInt(wInput.value) * origH / origW) || '';
  });
  hInput.addEventListener('input', () => {
    if (lockCb.checked && origH) wInput.value = Math.round(parseInt(hInput.value) * origW / origH) || '';
  });

  btn.addEventListener('click', () => {
    if (!img) return;
    const w = parseInt(wInput.value) || origW;
    const h = parseInt(hInput.value) || origH;
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, w, h);
    const q = parseInt(qualitySlider.value) / 100;
    canvas.toBlob(blob => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `resized-${w}x${h}.jpg`;
      a.click();
    }, 'image/jpeg', q);
  });
})();
</script>
