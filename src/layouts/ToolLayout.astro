---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RelatedTools from '../components/RelatedTools.astro';
import ToolFAQ from '../components/ToolFAQ.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCategoryBySlug, getRelatedTools } from '../data/tools.js';

const { tool } = Astro.props;
const category = getCategoryBySlug(tool.category);
const related = getRelatedTools(tool.relatedTools);

const schemaMarkup = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: tool.name,
  url: `https://textwonder.com/tools/${tool.slug}`,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web',
  description: tool.metaDescription,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  provider: { '@type': 'Organization', name: 'TextWonder', url: 'https://textwonder.com' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://textwonder.com' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://textwonder.com/tools' },
    { '@type': 'ListItem', position: 3, name: category.name, item: `https://textwonder.com/categories/${tool.category}` },
    { '@type': 'ListItem', position: 4, name: tool.name, item: `https://textwonder.com/tools/${tool.slug}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: tool.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={tool.metaTitle}
  description={tool.metaDescription}
  canonical={`/tools/${tool.slug}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumb items={[
      { label: 'Tools', href: '/tools' },
      { label: category.name, href: `/categories/${tool.category}` },
      { label: tool.name },
    ]} />

    <h1 class="text-3xl md:text-4xl font-bold text-white mt-4 mb-2" style="font-family: 'Space Grotesk', sans-serif;">
      {tool.h1}
    </h1>
    <p class="text-slate-400 text-lg mb-8">{tool.tagline}</p>

    <!-- Tool UI injected here -->
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-6 mb-10">
      <slot />
    </div>

    <!-- SEO Content -->
    <section class="mb-10 space-y-6">
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">What is {tool.name}?</h2>
        <p class="text-slate-400 leading-relaxed">{tool.descriptionLong}</p>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">Common Use Cases</h2>
        <p class="text-slate-400 leading-relaxed">{tool.useCases}</p>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-white mb-2">How It Works</h2>
        <p class="text-slate-400 leading-relaxed">{tool.howItWorks}</p>
      </div>
    </section>

    <ToolFAQ faqs={tool.faqs} />

    {related.length > 0 && <RelatedTools tools={related} />}
  </main>

  <Footer />
</BaseLayout>
