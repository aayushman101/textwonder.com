---
---

<div class="space-y-4">
  <div>
    <label class="text-slate-300 text-sm font-medium block mb-1.5">Target keyword or phrase</label>
    <input
      id="kdc-keyword"
      type="text"
      placeholder="e.g. content marketing"
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-2.5 text-slate-100 placeholder-slate-600 outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    />
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Content to analyse</label>
      <button id="kdc-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear all</button>
    </div>
    <textarea
      id="kdc-input"
      rows="7"
      placeholder="Paste your article, blog post, or page content here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="kdc-total" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">Total Words</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="kdc-count" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">Keyword Occurrences</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-violet-600/40 ring-1 ring-violet-600/30 rounded-xl p-4 text-center">
      <div id="kdc-density" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0%</div>
      <div class="text-slate-400 text-xs mt-1">Keyword Density</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="kdc-status" class="text-lg font-bold text-slate-500" style="font-family:'Space Grotesk',sans-serif;">—</div>
      <div class="text-slate-400 text-xs mt-1">SEO Status</div>
    </div>
  </div>

  <div id="kdc-bar-wrap" class="hidden bg-[var(--bg-base)] border border-slate-800 rounded-xl px-4 py-3">
    <div class="flex justify-between text-xs text-slate-500 mb-1">
      <span>0%</span>
      <span class="text-emerald-400">Ideal: 1–2%</span>
      <span>5%+</span>
    </div>
    <div class="relative bg-[var(--bg-surface)] rounded-full h-3">
      <div class="absolute left-[20%] top-0 h-3 w-px bg-emerald-600/60"></div>
      <div class="absolute left-[40%] top-0 h-3 w-px bg-yellow-600/60"></div>
      <div class="absolute left-[60%] top-0 h-3 w-px bg-red-600/60"></div>
      <div id="kdc-bar" class="h-3 rounded-full transition-all" style="width:0%;background:#7c3aed"></div>
    </div>
    <p id="kdc-tip" class="text-xs text-slate-400 mt-2 leading-relaxed"></p>
  </div>
</div>

<script>
  const input = document.getElementById('kdc-input') as HTMLTextAreaElement;
  const kwInput = document.getElementById('kdc-keyword') as HTMLInputElement;
  const elTotal = document.getElementById('kdc-total')!;
  const elCount = document.getElementById('kdc-count')!;
  const elDensity = document.getElementById('kdc-density')!;
  const elStatus = document.getElementById('kdc-status')!;
  const elBarWrap = document.getElementById('kdc-bar-wrap')!;
  const elBar = document.getElementById('kdc-bar')!;
  const elTip = document.getElementById('kdc-tip')!;
  const STORAGE_KEY = 'tw-keyword-density-checker';

  function update() {
    const text = input.value;
    const kw = kwInput.value.trim().toLowerCase();
    const words = text.trim() ? text.trim().split(/\s+/) : [];
    const total = words.length;
    elTotal.textContent = total.toString();

    if (!kw || total === 0) {
      elCount.textContent = '0';
      elDensity.textContent = '0%';
      elStatus.textContent = '—';
      elStatus.className = 'text-lg font-bold text-slate-500';
      elBarWrap.classList.add('hidden');
      return;
    }

    const escaped = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const regex = new RegExp(escaped, 'gi');
    const matches = text.match(regex) || [];
    const count = matches.length;

    const kwWords = kw.split(/\s+/).length;
    const effectiveTotal = total - (count * (kwWords - 1));
    const density = effectiveTotal > 0 ? (count / effectiveTotal * 100) : 0;
    const densityStr = density.toFixed(2);

    let status = '';
    let statusClass = '';
    let tip = '';
    let barColor = '';
    const barW = Math.min(density / 5 * 100, 100);

    if (density === 0) {
      status = 'Absent'; statusClass = 'text-slate-500';
      tip = 'Your keyword doesn\'t appear in the content. Add it naturally to improve topical relevance.';
      barColor = '#475569';
    } else if (density < 0.5) {
      status = 'Too Low'; statusClass = 'text-yellow-400';
      tip = `Density of ${densityStr}% is below the ideal 1–2% range. Consider using your keyword more frequently in a natural way.`;
      barColor = '#ca8a04';
    } else if (density <= 2) {
      status = 'Ideal ✓'; statusClass = 'text-emerald-400';
      tip = `Density of ${densityStr}% is within the ideal 1–2% range. Good balance for SEO without risking keyword stuffing.`;
      barColor = '#059669';
    } else if (density <= 4) {
      status = 'High'; statusClass = 'text-yellow-400';
      tip = `Density of ${densityStr}% is above the ideal range. Consider reducing keyword repetition to avoid looking spammy.`;
      barColor = '#d97706';
    } else {
      status = 'Stuffing ⚠'; statusClass = 'text-red-400';
      tip = `Density of ${densityStr}% is very high — this may be penalised as keyword stuffing by search engines. Aim for 1–2%.`;
      barColor = '#dc2626';
    }

    elCount.textContent = count.toString();
    elDensity.textContent = densityStr + '%';
    elStatus.textContent = status;
    elStatus.className = `text-lg font-bold ${statusClass}`;
    elBar.style.width = barW + '%';
    (elBar as HTMLElement).style.background = barColor;
    elTip.textContent = tip;
    elBarWrap.classList.remove('hidden');

    localStorage.setItem(STORAGE_KEY, JSON.stringify({ text, kw: kwInput.value }));
  }

  input.addEventListener('input', update);
  kwInput.addEventListener('input', update);
  document.getElementById('kdc-clear')!.addEventListener('click', () => {
    input.value = '';
    kwInput.value = '';
    update();
    localStorage.removeItem(STORAGE_KEY);
  });

  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const { text, kw } = JSON.parse(saved);
      if (text) input.value = text;
      if (kw) kwInput.value = kw;
      update();
    }
  } catch {}
</script>
