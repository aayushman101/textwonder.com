---
import { TOOLS } from '../data/tools.js';

const toolsForSearch = TOOLS.map(t => ({ slug: t.slug, name: t.name, category: t.category }));

const wonderSections = [
  { label: 'PDF', suffix: 'Wonder', path: '/pdfwonder', color: '#f97316', shadow: 'rgba(249,115,22,0.45)' },
  { label: 'Dev', suffix: 'Wonder', path: '/devwonder', color: '#06b6d4', shadow: 'rgba(6,182,212,0.4)' },
  { label: 'Calc', suffix: 'Wonder', path: '/calc', color: '#10b981', shadow: 'rgba(16,185,129,0.4)' },
  { label: 'Unit', suffix: 'Wonder', path: '/unit', color: '#6366f1', shadow: 'rgba(99,102,241,0.4)' },
  { label: 'Health', suffix: 'Wonder', path: '/health', color: '#22c55e', shadow: 'rgba(34,197,94,0.4)' },
  { label: 'Student', suffix: 'Wonder', path: '/student', color: '#3b82f6', shadow: 'rgba(59,130,246,0.4)' },
  { label: 'Color', suffix: 'Wonder', path: '/color', color: '#ec4899', shadow: 'rgba(236,72,153,0.4)' },
  { label: 'Data', suffix: 'Wonder', path: '/data', color: '#f59e0b', shadow: 'rgba(245,158,11,0.4)' },
];
---

<header class="sticky top-0 z-50 bg-[var(--bg-base)]/95 backdrop-blur border-b border-slate-800">

  <!-- Mobile: 4-column grid of all Wonder sections (hidden on md+) -->
  <div class="md:hidden grid grid-cols-4 gap-1.5 px-3 py-2 border-b border-slate-800/60">
    {wonderSections.map(s => (
      <a href={s.path}
        class="flex flex-col items-center justify-center py-1.5 rounded-lg text-white font-semibold text-xs transition-colors"
        style={`background:${s.color}; box-shadow: 0 0 8px ${s.shadow}`}>
        <span class="leading-tight">{s.label}</span>
        <span class="text-[9px] opacity-80 font-normal">{s.suffix}</span>
      </a>
    ))}
  </div>

  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <span class="text-2xl font-bold text-white group-hover:text-violet-400 transition-colors" style="font-family: 'Space Grotesk', sans-serif;">
        Text<span class="text-violet-500">Wonder</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-4">
      <a href="/" class="text-slate-300 hover:text-white transition-colors text-sm font-medium">Home</a>
      <a href="/tools" class="text-slate-300 hover:text-white transition-colors text-sm font-medium">Tools</a>

      <!-- PDF + Dev as prominent pills -->
      <a href="/pdfwonder" class="flex items-center gap-1.5 text-white px-3 py-1.5 rounded-lg text-sm font-semibold transition-all" style="background:#f97316;box-shadow:0 0 12px rgba(249,115,22,0.45)">
        <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>
        PDF<span class="font-extrabold">Wonder</span>
      </a>
      <a href="/devwonder" class="flex items-center gap-1.5 text-white px-3 py-1.5 rounded-lg text-sm font-semibold transition-all" style="background:#06b6d4;box-shadow:0 0 12px rgba(6,182,212,0.4)">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3"/></svg>
        Dev<span class="font-extrabold">Wonder</span>
      </a>

      <!-- More dropdown -->
      <div class="relative" id="more-menu-wrapper">
        <button id="more-menu-btn" class="flex items-center gap-1 text-slate-300 hover:text-white text-sm font-medium transition-colors px-2 py-1.5 rounded-lg hover:bg-[var(--bg-surface-hover)]">
          More
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="more-menu-dropdown" class="hidden absolute right-0 top-full mt-2 w-64 bg-[var(--bg-surface)] border border-slate-700 rounded-xl shadow-2xl overflow-hidden z-50">
          <div class="p-2 grid grid-cols-2 gap-1.5">
            {wonderSections.slice(2).map(s => (
              <a href={s.path}
                class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-[var(--bg-surface-hover)] transition-colors group">
                <div class="w-2 h-2 rounded-full shrink-0" style={`background:${s.color}`}></div>
                <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">{s.label}<span class="font-bold" style={`color:${s.color}`}>{s.suffix}</span></span>
              </a>
            ))}
          </div>
          <div class="border-t border-slate-800 px-3 py-2">
            <a href="/" class="flex items-center gap-2 text-xs text-slate-500 hover:text-slate-300 transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              All TextWonder tools (61)
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button id="theme-toggle" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-[var(--bg-surface-hover)] transition-colors" aria-label="Toggle light/dark mode">
        <svg id="theme-icon-sun" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>

      <!-- Search -->
      <button id="search-open" class="flex items-center gap-2 bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-400 hover:text-white px-3 py-2 rounded-lg transition-colors text-sm" aria-label="Search tools">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="hidden sm:inline">Search tools…</span>
      </button>
    </div>
  </div>
</header>

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="search-backdrop"></div>
  <div class="relative max-w-lg mx-auto mt-20 mx-4">
    <div class="bg-[var(--bg-surface)] border border-slate-700 rounded-2xl shadow-2xl overflow-hidden">
      <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-700">
        <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="search-input" type="text" placeholder="Search tools…" class="flex-1 bg-transparent text-white placeholder-slate-500 outline-none text-base" autocomplete="off"/>
        <button id="search-close" class="text-slate-400 hover:text-white transition-colors text-sm">ESC</button>
      </div>
      <ul id="search-results" class="max-h-72 overflow-y-auto py-2"></ul>
    </div>
  </div>
</div>

<script define:vars={{ toolsForSearch }}>
(function() {
  // Search
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const openBtn = document.getElementById('search-open');
  const closeBtn = document.getElementById('search-close');
  const backdrop = document.getElementById('search-backdrop');

  function openModal() { modal.classList.remove('hidden'); setTimeout(() => input.focus(), 50); renderResults(''); }
  function closeModal() { modal.classList.add('hidden'); input.value = ''; }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeModal(); closeMoreMenu(); }
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openModal(); }
  });

  function renderResults(query) {
    const q = query.toLowerCase().trim();
    const filtered = q ? toolsForSearch.filter(t => t.name.toLowerCase().includes(q) || t.category.includes(q)) : toolsForSearch.slice(0, 8);
    results.innerHTML = filtered.length
      ? filtered.map(t => `<li><a href="/tools/${t.slug}" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[var(--bg-surface-hover)] transition-colors"><span class="text-white text-sm font-medium">${t.name}</span><span class="text-xs text-slate-500 ml-auto capitalize">${t.category.replace(/-/g, ' ')}</span></a></li>`).join('')
      : '<li class="px-4 py-4 text-slate-500 text-sm text-center">No tools found</li>';
  }
  input.addEventListener('input', e => renderResults(e.target.value));

  // Theme
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('theme-icon-sun');
  const iconMoon = document.getElementById('theme-icon-moon');
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('tw-theme', t);
    if (t === 'dark') { iconSun.classList.remove('hidden'); iconMoon.classList.add('hidden'); }
    else { iconSun.classList.add('hidden'); iconMoon.classList.remove('hidden'); }
  }
  applyTheme(document.documentElement.getAttribute('data-theme') || 'dark');
  themeToggle.addEventListener('click', () => applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'));

  // More dropdown
  const moreBtn = document.getElementById('more-menu-btn');
  const moreDropdown = document.getElementById('more-menu-dropdown');

  function closeMoreMenu() { moreDropdown && moreDropdown.classList.add('hidden'); }
  if (moreBtn && moreDropdown) {
    moreBtn.addEventListener('click', e => { e.stopPropagation(); moreDropdown.classList.toggle('hidden'); });
    document.addEventListener('click', e => { if (!moreBtn.contains(e.target) && !moreDropdown.contains(e.target)) closeMoreMenu(); });
  }
})();
</script>
