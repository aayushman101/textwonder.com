---
---
<div class="max-w-2xl mx-auto space-y-5">
  <!-- Mode -->
  <div class="flex gap-2">
    <button class="leave-mode-btn flex-1 py-2 rounded-lg text-sm font-semibold border transition-colors border-violet-500 text-white" style="background:#7c3aed" data-mode="office">Office</button>
    <button class="leave-mode-btn flex-1 py-2 rounded-lg text-sm font-semibold border transition-colors border-slate-600 text-slate-400" data-mode="school">School</button>
    <button class="leave-mode-btn flex-1 py-2 rounded-lg text-sm font-semibold border transition-colors border-slate-600 text-slate-400" data-mode="college">College</button>
  </div>

  <!-- Form -->
  <div class="bg-slate-800/50 rounded-xl p-5 border border-slate-700 space-y-3">
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-slate-400 text-xs mb-1 block">Your Name</label>
        <input id="la-name" type="text" placeholder="Full name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
      <div>
        <label class="text-slate-400 text-xs mb-1 block" id="la-desig-lbl">Designation</label>
        <input id="la-desig" type="text" placeholder="Software Engineer" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
      <div>
        <label class="text-slate-400 text-xs mb-1 block" id="la-to-lbl">To (Manager's Name)</label>
        <input id="la-to" type="text" placeholder="Name of recipient" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
      <div>
        <label class="text-slate-400 text-xs mb-1 block" id="la-org-lbl">Company / Organisation</label>
        <input id="la-org" type="text" placeholder="Organisation name" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
      <div>
        <label class="text-slate-400 text-xs mb-1 block">From Date</label>
        <input id="la-from" type="date" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
      <div>
        <label class="text-slate-400 text-xs mb-1 block">To Date</label>
        <input id="la-to-date" type="date" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500" />
      </div>
    </div>
    <div>
      <label class="text-slate-400 text-xs mb-1 block">Leave Type</label>
      <select id="la-type" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none">
        <option value="sick">Sick Leave</option>
        <option value="casual">Casual Leave</option>
        <option value="earned">Earned / Privilege Leave</option>
        <option value="personal">Personal Leave</option>
        <option value="custom">Other (custom reason)</option>
      </select>
    </div>
    <div id="la-reason-wrap">
      <label class="text-slate-400 text-xs mb-1 block">Reason (optional details)</label>
      <textarea id="la-reason" rows="2" placeholder="Additional details about your leave reason…" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-violet-500 resize-none"></textarea>
    </div>
    <button id="la-generate" class="w-full py-3 rounded-xl font-semibold text-white" style="background:#7c3aed">Generate Letter</button>
  </div>

  <!-- Output -->
  <div id="la-output" class="hidden">
    <div class="flex justify-between items-center mb-2">
      <span class="text-slate-300 text-sm font-medium">Preview (editable)</span>
      <button id="la-print" class="text-sm px-4 py-1.5 rounded-lg text-white font-semibold" style="background:#7c3aed">Print / Save as PDF</button>
    </div>
    <div id="la-preview" contenteditable="true" class="bg-white text-slate-900 rounded-xl p-6 text-sm leading-relaxed outline-none focus:ring-2 focus:ring-violet-500 min-h-48 font-serif whitespace-pre-wrap"></div>
  </div>
</div>

<script is:inline>
(function() {
  let mode = 'office';
  const modeLabels = {
    office: { desig: 'Designation / Role', to: "Manager's Name", org: 'Company Name' },
    school: { desig: 'Class / Grade', to: "Class Teacher's Name", org: 'School Name' },
    college: { desig: 'Course / Branch', to: "HOD / Principal's Name", org: 'College Name' },
  };

  document.querySelectorAll('.leave-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode;
      document.querySelectorAll('.leave-mode-btn').forEach(b => {
        b.style.background = ''; b.style.color = ''; b.style.borderColor = '#475569';
        b.className = b.className.replace('text-white','text-slate-400');
      });
      btn.style.background = '#7c3aed'; btn.style.borderColor = '#7c3aed';
      btn.className = btn.className.replace('text-slate-400','text-white');
      const lbl = modeLabels[mode];
      document.getElementById('la-desig-lbl').textContent = lbl.desig;
      document.getElementById('la-to-lbl').textContent = lbl.to;
      document.getElementById('la-org-lbl').textContent = lbl.org;
      document.getElementById('la-desig').placeholder = mode === 'office' ? 'Software Engineer' : mode === 'school' ? '10th A' : 'B.Tech CSE';
      document.getElementById('la-org').placeholder = mode === 'office' ? 'Acme Corp Pvt Ltd' : mode === 'school' ? 'DPS New Delhi' : 'IIT Delhi';
    });
  });

  function fmtDate(d) {
    if (!d) return '___';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function daysBetween(from, to) {
    if (!from || !to) return 1;
    const diff = (new Date(to) - new Date(from)) / (1000 * 60 * 60 * 24) + 1;
    return Math.max(1, diff);
  }

  const REASONS = {
    sick: 'I am suffering from a fever and have been advised rest by my doctor.',
    casual: 'I have some personal commitments that require my attention.',
    earned: 'I would like to avail my earned leave.',
    personal: 'Due to personal reasons, I am unable to attend work during this period.',
    custom: '',
  };

  document.getElementById('la-generate').addEventListener('click', () => {
    const name = document.getElementById('la-name').value || 'Your Name';
    const desig = document.getElementById('la-desig').value || '';
    const to = document.getElementById('la-to').value || 'The Manager';
    const org = document.getElementById('la-org').value || '';
    const fromDate = document.getElementById('la-from').value;
    const toDate = document.getElementById('la-to-date').value;
    const type = document.getElementById('la-type').value;
    const reason = document.getElementById('la-reason').value || REASONS[type];
    const days = daysBetween(fromDate, toDate);
    const today = fmtDate(new Date().toISOString().split('T')[0]);

    const leaveTypeName = { sick: 'Sick Leave', casual: 'Casual Leave', earned: 'Earned Leave', personal: 'Personal Leave', custom: 'Leave' }[type];
    const salutation = mode === 'school' ? 'Respected Sir/Ma\'am,' : 'Dear Sir/Ma\'am,';
    const subject = `Subject: Application for ${leaveTypeName} — ${fmtDate(fromDate)} to ${fmtDate(toDate)}`;

    const letter = `Date: ${today}

To,
${to}
${org ? org + '\n' : ''}
${salutation}

${subject}

I am writing to request ${days} day${days > 1 ? 's' : ''} of ${leaveTypeName.toLowerCase()} from ${fmtDate(fromDate)} to ${fmtDate(toDate)}.

${reason}

I assure you that I will complete all pending work before my leave and will be available on phone if needed during this period.

Kindly grant me leave for the requested period. I shall be grateful to you.

Thanking you,

Yours sincerely,
${name}${desig ? '\n' + desig : ''}${org ? '\n' + org : ''}`;

    document.getElementById('la-preview').textContent = letter;
    document.getElementById('la-output').classList.remove('hidden');
  });

  document.getElementById('la-print').addEventListener('click', () => {
    const content = document.getElementById('la-preview').innerText;
    const w = window.open('', '_blank');
    w.document.write(`<html><head><title>Leave Application</title><style>body{font-family:Georgia,serif;font-size:14px;line-height:1.8;margin:48px;color:#111;white-space:pre-wrap;}@media print{body{margin:24px;}}</style></head><body>${content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</body></html>`);
    w.document.close(); w.focus(); setTimeout(() => { w.print(); }, 300);
  });
})();
</script>
