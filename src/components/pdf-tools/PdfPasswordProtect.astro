---
---
<div class="space-y-5">
  <div id="ppp-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="ppp-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🔐</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">The file will be encrypted with AES-128 in your browser</p>
  </div>

  <div id="ppp-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-red-400 text-2xl">📄</span>
      <div>
        <p id="ppp-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="ppp-info" class="text-slate-500 text-xs"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">User password <span class="text-red-400">*</span></label>
        <input type="password" id="ppp-user-pw" placeholder="Password to open the PDF" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500 placeholder-slate-600" />
        <p class="text-xs text-slate-600">Required to open the document</p>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Owner password <span class="text-slate-600">(optional)</span></label>
        <input type="password" id="ppp-owner-pw" placeholder="Defaults to user password" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500 placeholder-slate-600" />
        <p class="text-xs text-slate-600">Controls editing permissions</p>
      </div>
    </div>

    <div class="bg-amber-950/30 border border-amber-800/40 rounded-xl px-4 py-3">
      <p class="text-amber-300 text-xs font-medium mb-1">⚠️ Important</p>
      <p class="text-amber-400/80 text-xs">Store your password safely. If you lose it, the PDF cannot be recovered. Your password is never sent to any server.</p>
    </div>

    <div class="flex gap-2">
      <button id="ppp-encrypt" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Encrypt & Download</button>
      <button id="ppp-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear</button>
    </div>
  </div>

  <div id="ppp-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('ppp-drop');
  const fileInput = document.getElementById('ppp-file');
  const panel = document.getElementById('ppp-panel');
  const status = document.getElementById('ppp-status');
  let currentFile = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
      currentFile = file;
      document.getElementById('ppp-name').textContent = file.name;
      document.getElementById('ppp-info').textContent = `${doc.getPageCount()} pages · ${(file.size / 1024).toFixed(1)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
    } catch (e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('ppp-encrypt').addEventListener('click', async () => {
    const userPw = document.getElementById('ppp-user-pw').value;
    const ownerPw = document.getElementById('ppp-owner-pw').value || userPw;
    if (!userPw) { showStatus('Please enter a user password.', 'error'); return; }
    if (!currentFile) return;
    showStatus('Encrypting…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(await currentFile.arrayBuffer(), { ignoreEncryption: true });
      const out = await doc.save({
        userPassword: userPw,
        ownerPassword: ownerPw,
        permissions: {
          printing: 'highResolution',
          copying: false,
          modifying: false,
          annotating: false,
          fillingForms: false,
          contentAccessibility: true,
          documentAssembly: false,
        },
      });
      downloadBytes(out, 'protected.pdf');
      showStatus('✅ PDF encrypted and downloaded successfully', 'success');
    } catch (e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('ppp-clear').addEventListener('click', () => {
    currentFile = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
    document.getElementById('ppp-user-pw').value = '';
    document.getElementById('ppp-owner-pw').value = '';
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
