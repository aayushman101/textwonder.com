---
import BlogLayout from '../../layouts/BlogLayout.astro';

const faqs = [
  { q: 'Does rotating an image reduce its quality?', a: 'Rotating by 90°, 180°, or 270° is geometrically lossless — no pixels are discarded. Saving as PNG preserves full quality. Saving as JPEG applies standard compression, which is a normal property of that format, not caused by the rotation.' },
  { q: 'Why is my phone photo sideways when I upload it?', a: 'Phone cameras save images in landscape orientation and store rotation metadata in the EXIF tags. Most browsers respect EXIF orientation automatically now, but some upload tools or platforms do not read EXIF and display the raw orientation.' },
  { q: 'Can I flip an image horizontally to create a mirror effect?', a: 'Yes. The Flip Horizontal button mirrors the image left-to-right, creating a mirror image. Flip Vertical flips it upside down.' },
  { q: 'Can I rotate by arbitrary angles like 30° or 45°?', a: 'Currently the tool supports 90° increments. Arbitrary rotation requires padding the canvas with background fill to avoid clipping the corners — this feature is not yet available.' },
  { q: 'Can I undo a rotation?', a: 'Click Reset to return the image to its original orientation at any time. Or rotate by 270° (3 × 90° clockwise) to undo a 90° clockwise rotation.' },
];
---

