<BlogLayout
  title="How to Scramble Words Online Free — Word Scrambler Tool"
  description="Scramble words and text online. Middle-letter scramble preserves first and last letters. Full scramble or word order scramble options. Free online word scrambler."
  canonical="/blog/how-to-scramble-words-online-free"
