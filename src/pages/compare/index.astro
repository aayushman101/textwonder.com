---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const comparisons = [
  {
    slug: 'word-counter-vs-character-counter',
    title: 'Word Counter vs Character Counter',
    description: 'Understand when word count matters (essays, blogs) vs when character count matters (Twitter, SMS, meta tags).',
    tools: ['Word Counter', 'Character Counter'],
  },
  {
    slug: 'uppercase-vs-title-case',
    title: 'Uppercase vs Title Case',
    description: 'When to use ALL CAPS vs Title Case for headings, titles, buttons, and content — with style guide guidance.',
    tools: ['Uppercase Converter', 'Title Case Converter'],
  },
  {
    slug: 'remove-duplicate-lines-vs-sort-lines',
    title: 'Remove Duplicate Lines vs Sort Lines',
    description: 'Two tools that solve different list-cleaning problems — and how combining them gives you the cleanest output.',
    tools: ['Remove Duplicate Lines', 'Sort Lines'],
  },
];
---

<BaseLayout
  title="Tool Comparisons — When to Use Which Text Tool | TextWonder"
  description="Side-by-side comparisons of similar text tools. Understand the differences between word count vs character count, uppercase vs title case, and more."
  canonical="/compare"
>
  <Header />

  <main class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-3" style="font-family: 'Space Grotesk', sans-serif;">Tool Comparisons</h1>
      <p class="text-slate-400 text-lg">Side-by-side breakdowns of similar tools — so you always know which one to reach for.</p>
    </header>

    <div class="space-y-4">
      {comparisons.map(c => (
        <a href={`/compare/${c.slug}`} class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-6 hover:border-violet-500/40 hover:bg-[var(--bg-surface-hover)] transition-all">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-white font-semibold text-lg mb-1 group-hover:text-violet-300 transition-colors">{c.title}</h2>
              <p class="text-slate-400 text-sm leading-relaxed mb-3">{c.description}</p>
              <div class="flex gap-2 flex-wrap">
                {c.tools.map(t => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-900/30 text-violet-300 border border-violet-800/40">{t}</span>
                ))}
              </div>
            </div>
            <svg class="w-5 h-5 text-slate-600 group-hover:text-violet-400 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
