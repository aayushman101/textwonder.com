---
---
<div class="space-y-4">

  <!-- Drop zone -->
  <div id="sc-drop" class="border-2 border-dashed border-slate-700 hover:border-rose-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="sc-file" accept="image/*" class="hidden" />
    <div class="text-4xl mb-2">🖨️</div>
    <p class="text-slate-300 font-medium mb-1">Drop a photo here or click to select</p>
    <p class="text-slate-500 text-sm">Converts any phone photo of a document into a clean scanned look</p>
  </div>

  <!-- Main panel -->
  <div id="sc-panel" class="hidden space-y-4">

    <!-- Before / After comparison with drag divider -->
    <div id="sc-compare" class="relative w-full rounded-xl overflow-hidden border border-slate-800 cursor-col-resize select-none bg-slate-900"
         style="touch-action: none;">
      <!-- "Before" layer — full width, always visible underneath -->
      <canvas id="sc-before" class="block w-full"></canvas>
      <!-- "After" layer — clipped to left half -->
      <div id="sc-after-clip" class="absolute inset-0 overflow-hidden" style="width: 50%">
        <canvas id="sc-after" class="block" style="position:absolute;top:0;left:0;"></canvas>
      </div>
      <!-- Drag handle line -->
      <div id="sc-handle" class="absolute top-0 bottom-0 pointer-events-none" style="left: 50%; transform: translateX(-50%); width: 3px; background: rgb(244 63 94);">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-rose-600 rounded-full flex items-center justify-center text-white text-xs shadow-xl border-2 border-white">⟺</div>
      </div>
      <!-- Labels -->
      <div class="absolute top-3 left-3 pointer-events-none">
        <span class="bg-black/60 text-white text-xs px-2 py-1 rounded-full">Original</span>
      </div>
      <div class="absolute top-3 right-3 pointer-events-none">
        <span class="bg-rose-600/90 text-white text-xs px-2 py-1 rounded-full">Scanned</span>
      </div>
    </div>

    <!-- Presets -->
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-xs text-slate-500">Preset:</span>
      <button class="sc-preset px-3 py-1.5 text-xs rounded-lg border transition-colors border-rose-600/60 bg-rose-900/20 text-rose-300" data-preset="document">📄 Document Clean</button>
      <button class="sc-preset px-3 py-1.5 text-xs rounded-lg border transition-colors border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500" data-preset="soft">📃 Soft Scan</button>
      <button class="sc-preset px-3 py-1.5 text-xs rounded-lg border transition-colors border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500" data-preset="photocopy">🖨️ Photocopy</button>
    </div>

    <!-- Sliders -->
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 space-y-4">
      <div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="text-slate-400">Brightness</span>
          <span id="sc-brightness-val" class="text-rose-400 font-mono tabular-nums w-8 text-right">+10</span>
        </div>
        <input type="range" id="sc-brightness" min="-50" max="80" value="10" class="w-full accent-rose-500 cursor-pointer" />
      </div>
      <div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="text-slate-400">Contrast</span>
          <span id="sc-contrast-val" class="text-rose-400 font-mono tabular-nums w-8 text-right">60</span>
        </div>
        <input type="range" id="sc-contrast" min="0" max="150" value="60" class="w-full accent-rose-500 cursor-pointer" />
      </div>
      <div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="text-slate-400">Background Clip</span>
          <span id="sc-clip-val" class="text-rose-400 font-mono tabular-nums w-8 text-right">2%</span>
        </div>
        <input type="range" id="sc-clip" min="0" max="8" value="2" step="0.5" class="w-full accent-rose-500 cursor-pointer" />
        <p class="text-slate-600 text-xs mt-1">Higher = more aggressive background whitening</p>
      </div>
      <label class="flex items-center gap-2.5 cursor-pointer">
        <input type="checkbox" id="sc-sharpen" checked class="accent-rose-500 w-3.5 h-3.5" />
        <span class="text-xs text-slate-400">Sharpen edges (makes text crisper)</span>
      </label>
    </div>

    <!-- Actions -->
    <div class="flex gap-3">
      <button id="sc-change" class="px-4 py-2.5 border border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500 rounded-lg text-sm transition-colors">Change image</button>
      <button id="sc-download" class="flex-1 py-2.5 bg-rose-600 hover:bg-rose-500 text-white rounded-lg text-sm font-semibold transition-colors">Download Scanned Image</button>
    </div>
    <p id="sc-status" class="hidden text-sm"></p>
  </div>
</div>

<script is:inline>
(function() {
  const dropZone   = document.getElementById('sc-drop');
  const fileInput  = document.getElementById('sc-file');
  const panel      = document.getElementById('sc-panel');
  const before     = document.getElementById('sc-before');
  const afterCanvas = document.getElementById('sc-after');
  const afterClip  = document.getElementById('sc-after-clip');
  const handle     = document.getElementById('sc-handle');
  const compare    = document.getElementById('sc-compare');

  const brightnessSlider = document.getElementById('sc-brightness');
  const contrastSlider   = document.getElementById('sc-contrast');
  const clipSlider       = document.getElementById('sc-clip');
  const sharpenCheck     = document.getElementById('sc-sharpen');

  let originalImg = null, W = 0, H = 0;
  let isDragging = false;
  let renderScheduled = false;

  // ── Drop / file ──────────────────────────────
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-rose-500/80'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-rose-500/80'));
  dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('border-rose-500/80'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  function loadFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => {
      originalImg = img;
      W = img.naturalWidth;
      H = img.naturalHeight;

      // Draw original on before canvas (shown on right half of compare)
      before.width = W; before.height = H;
      before.getContext('2d').drawImage(img, 0, 0);

      // Size after canvas same as before, absolute positioned
      afterCanvas.width = W; afterCanvas.height = H;
      afterCanvas.style.width = '100%';

      // Set compare container height to match image aspect ratio
      compare.style.aspectRatio = W + '/' + H;

      dropZone.classList.add('hidden');
      panel.classList.remove('hidden');
      processImage();
      URL.revokeObjectURL(url);
    };
    img.src = url;
  }

  // ── Process image ──────────────────────────────
  function processImage() {
    if (!originalImg) return;
    renderScheduled = false;

    const ctx = before.getContext('2d');
    const srcData = ctx.getImageData(0, 0, W, H);
    const src = srcData.data;

    // Step 1: Grayscale
    const gray = new Uint8Array(W * H);
    for (let i = 0, p = 0; i < gray.length; i++, p += 4) {
      gray[i] = Math.round(0.299 * src[p] + 0.587 * src[p + 1] + 0.114 * src[p + 2]);
    }

    // Step 2: Auto-levels using histogram percentile clipping
    const hist = new Uint32Array(256);
    for (let i = 0; i < gray.length; i++) hist[gray[i]]++;
    const total = gray.length;
    const clipFrac = parseFloat(clipSlider.value) / 100;
    let blackPt = 0, whitePt = 255, count = 0;
    for (let j = 0; j < 256; j++) {
      count += hist[j];
      if (count > total * clipFrac) { blackPt = j; break; }
    }
    count = 0;
    for (let j = 255; j >= 0; j--) {
      count += hist[j];
      if (count > total * clipFrac) { whitePt = j; break; }
    }
    const range = Math.max(1, whitePt - blackPt);

    // Step 3: Build LUT (levels → brightness → contrast)
    const brightness = parseInt(brightnessSlider.value, 10);
    const contrast   = parseInt(contrastSlider.value, 10);
    const cfactor    = (259 * (contrast + 255)) / (255 * (259 - contrast));
    const lut = new Uint8ClampedArray(256);
    for (let i = 0; i < 256; i++) {
      let v = (i - blackPt) * 255 / range;   // levels
      v = v + brightness;                      // brightness
      v = cfactor * (v - 128) + 128;           // contrast
      lut[i] = Math.max(0, Math.min(255, Math.round(v)));
    }

    // Step 4: Apply LUT
    const out = new Uint8ClampedArray(W * H * 4);
    for (let i = 0; i < gray.length; i++) {
      const v = lut[gray[i]];
      const p = i * 4;
      out[p] = out[p + 1] = out[p + 2] = v;
      out[p + 3] = 255;
    }

    // Step 5: Sharpen (unsharp mask with 2-pass box blur)
    if (sharpenCheck.checked) {
      const blurred = boxBlur(out, W, H);
      const amount  = 0.65;
      for (let p = 0; p < out.length; p += 4) {
        const v = Math.max(0, Math.min(255, out[p] + amount * (out[p] - blurred[p])));
        out[p] = out[p + 1] = out[p + 2] = v;
      }
    }

    const outCtx = afterCanvas.getContext('2d');
    outCtx.putImageData(new ImageData(out, W, H), 0, 0);
  }

  // Simple 2-pass box blur radius-1 (3x3 kernel)
  function boxBlur(data, w, h) {
    const tmp = new Uint8ClampedArray(data.length);
    const out = new Uint8ClampedArray(data.length);
    // Horizontal
    for (let y = 0; y < h; y++) {
      for (let x = 0; x < w; x++) {
        const x0 = Math.max(0, x - 1), x2 = Math.min(w - 1, x + 1);
        const v = Math.round((data[(y * w + x0) * 4] + data[(y * w + x) * 4] + data[(y * w + x2) * 4]) / 3);
        tmp[(y * w + x) * 4] = v;
      }
    }
    // Vertical
    for (let y = 0; y < h; y++) {
      for (let x = 0; x < w; x++) {
        const y0 = Math.max(0, y - 1), y2 = Math.min(h - 1, y + 1);
        const v = Math.round((tmp[(y0 * w + x) * 4] + tmp[(y * w + x) * 4] + tmp[(y2 * w + x) * 4]) / 3);
        const p = (y * w + x) * 4;
        out[p] = out[p + 1] = out[p + 2] = v;
        out[p + 3] = 255;
      }
    }
    return out;
  }

  // ── Sliders ──────────────────────────────────
  function scheduleRender() {
    if (renderScheduled) return;
    renderScheduled = true;
    requestAnimationFrame(processImage);
  }

  brightnessSlider.addEventListener('input', () => {
    document.getElementById('sc-brightness-val').textContent =
      (parseInt(brightnessSlider.value, 10) >= 0 ? '+' : '') + brightnessSlider.value;
    scheduleRender();
  });
  contrastSlider.addEventListener('input', () => {
    document.getElementById('sc-contrast-val').textContent = contrastSlider.value;
    scheduleRender();
  });
  clipSlider.addEventListener('input', () => {
    document.getElementById('sc-clip-val').textContent = clipSlider.value + '%';
    scheduleRender();
  });
  sharpenCheck.addEventListener('change', scheduleRender);

  // ── Presets ──────────────────────────────────
  const PRESETS = {
    document:  { brightness: 10,  contrast: 60,  clip: 2,   sharpen: true  },
    soft:      { brightness: 5,   contrast: 28,  clip: 1,   sharpen: false },
    photocopy: { brightness: 20,  contrast: 120, clip: 3.5, sharpen: true  },
  };

  document.querySelectorAll('.sc-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sc-preset').forEach(b => {
        b.className = 'sc-preset px-3 py-1.5 text-xs rounded-lg border transition-colors border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500';
      });
      btn.className = 'sc-preset px-3 py-1.5 text-xs rounded-lg border transition-colors border-rose-600/60 bg-rose-900/20 text-rose-300';

      const p = PRESETS[btn.dataset.preset];
      brightnessSlider.value = p.brightness;
      contrastSlider.value   = p.contrast;
      clipSlider.value       = p.clip;
      sharpenCheck.checked   = p.sharpen;
      document.getElementById('sc-brightness-val').textContent = (p.brightness >= 0 ? '+' : '') + p.brightness;
      document.getElementById('sc-contrast-val').textContent   = p.contrast;
      document.getElementById('sc-clip-val').textContent       = p.clip + '%';
      scheduleRender();
    });
  });

  // ── Before/After drag divider ──────────────────────────────────
  function setDivider(pct) {
    pct = Math.max(2, Math.min(98, pct));
    afterClip.style.width = pct + '%';
    handle.style.left = pct + '%';
  }

  function getPct(e) {
    const rect = compare.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    return ((clientX - rect.left) / rect.width) * 100;
  }

  compare.addEventListener('mousedown', e => { isDragging = true; setDivider(getPct(e)); e.preventDefault(); });
  compare.addEventListener('touchstart', e => { isDragging = true; setDivider(getPct(e)); }, { passive: true });
  window.addEventListener('mousemove', e => { if (isDragging) setDivider(getPct(e)); });
  window.addEventListener('touchmove', e => { if (isDragging) setDivider(getPct(e)); }, { passive: true });
  window.addEventListener('mouseup', () => isDragging = false);
  window.addEventListener('touchend', () => isDragging = false);

  // ── Download ──────────────────────────────────
  document.getElementById('sc-download').addEventListener('click', () => {
    afterCanvas.toBlob(blob => {
      const url = URL.createObjectURL(blob);
      const a   = document.createElement('a');
      a.href = url; a.download = 'scanned-document.jpg'; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }, 'image/jpeg', 0.92);
  });

  document.getElementById('sc-change').addEventListener('click', () => {
    originalImg = null;
    panel.classList.add('hidden');
    dropZone.classList.remove('hidden');
  });
})();
</script>
