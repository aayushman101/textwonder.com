---
---
<div>
  <!-- Unit toggle -->
  <div class="flex gap-2 mb-4">
    <button id="bmi-metric-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-white transition-colors" style="background:#22c55e" onclick="bmiUnit('metric')">Metric (kg/cm)</button>
    <button id="bmi-imperial-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700 transition-colors" onclick="bmiUnit('imperial')">Imperial (lbs/ft)</button>
  </div>

  <!-- Metric inputs -->
  <div id="bmi-metric" class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (kg)</label><input type="number" id="bmi-kg" placeholder="e.g. 70" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (cm)</label><input type="number" id="bmi-cm" placeholder="e.g. 175" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>

  <!-- Imperial inputs -->
  <div id="bmi-imperial" class="hidden grid grid-cols-3 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (lbs)</label><input type="number" id="bmi-lbs" placeholder="e.g. 154" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (ft)</label><input type="number" id="bmi-ft" placeholder="5" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (in)</label><input type="number" id="bmi-in" placeholder="9" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>

  <div id="bmi-result" class="hidden space-y-3">
    <div class="flex items-center gap-4 bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700">
      <div class="text-center min-w-[80px]">
        <div id="bmi-value" class="text-4xl font-bold" style="color:#22c55e"></div>
        <div class="text-xs text-slate-400 mt-1">BMI</div>
      </div>
      <div>
        <div id="bmi-category" class="text-lg font-semibold text-white"></div>
        <div id="bmi-range" class="text-sm text-slate-400 mt-1"></div>
      </div>
    </div>
    <!-- BMI scale bar -->
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700">
      <div class="text-xs text-slate-500 mb-2">BMI Scale</div>
      <div class="h-3 rounded-full overflow-hidden flex">
        <div class="flex-1" style="background:#3b82f6" title="Underweight"></div>
        <div class="flex-1" style="background:#22c55e" title="Normal"></div>
        <div class="flex-1" style="background:#f59e0b" title="Overweight"></div>
        <div class="flex-1" style="background:#ef4444" title="Obese"></div>
      </div>
      <div class="flex justify-between text-xs text-slate-500 mt-1">
        <span>Under</span><span>Normal</span><span>Over</span><span>Obese</span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  let mode = 'metric';
  window.bmiUnit = function(m) {
    mode = m;
    document.getElementById('bmi-metric').classList.toggle('hidden', m!=='metric');
    document.getElementById('bmi-imperial').classList.toggle('hidden', m!=='imperial');
    const mb = document.getElementById('bmi-metric-btn'), ib = document.getElementById('bmi-imperial-btn');
    if(m==='metric'){ mb.style.background='#22c55e'; mb.classList.remove('text-slate-400'); mb.classList.add('text-white'); ib.style.background=''; ib.classList.add('text-slate-400'); ib.classList.remove('text-white'); }
    else { ib.style.background='#22c55e'; ib.classList.remove('text-slate-400'); ib.classList.add('text-white'); mb.style.background=''; mb.classList.add('text-slate-400'); mb.classList.remove('text-white'); }
    calc();
  };

  function calc() {
    let kg, heightM;
    if(mode==='metric') {
      kg = parseFloat(document.getElementById('bmi-kg').value);
      const cm = parseFloat(document.getElementById('bmi-cm').value);
      if(!kg||!cm||kg<=0||cm<=0) { document.getElementById('bmi-result').classList.add('hidden'); return; }
      heightM = cm/100;
    } else {
      const lbs = parseFloat(document.getElementById('bmi-lbs').value);
      const ft = parseFloat(document.getElementById('bmi-ft').value)||0;
      const inch = parseFloat(document.getElementById('bmi-in').value)||0;
      const totalIn = ft*12+inch;
      if(!lbs||!totalIn||lbs<=0||totalIn<=0) { document.getElementById('bmi-result').classList.add('hidden'); return; }
      kg = lbs*0.453592; heightM = totalIn*0.0254;
    }
    const bmi = kg/(heightM*heightM);
    let cat, color;
    if(bmi<18.5){cat='Underweight';color='#3b82f6';}
    else if(bmi<25){cat='Normal weight';color='#22c55e';}
    else if(bmi<30){cat='Overweight';color='#f59e0b';}
    else{cat='Obese';color='#ef4444';}
    const minKg = 18.5*heightM*heightM, maxKg = 24.9*heightM*heightM;
    document.getElementById('bmi-value').textContent = bmi.toFixed(1);
    document.getElementById('bmi-value').style.color = color;
    document.getElementById('bmi-category').textContent = cat;
    document.getElementById('bmi-category').style.color = color;
    document.getElementById('bmi-range').textContent = `Healthy weight range: ${minKg.toFixed(1)}–${maxKg.toFixed(1)} kg`;
    document.getElementById('bmi-result').classList.remove('hidden');
  }
  ['bmi-kg','bmi-cm','bmi-lbs','bmi-ft','bmi-in'].forEach(id => { const el = document.getElementById(id); if(el) el.addEventListener('input', calc); });
})();
</script>
