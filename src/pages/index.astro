---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SECTIONS, getGlobalSearchIndex } from '../data/categories.js';

const toolsForSearch = getGlobalSearchIndex();
const totalTools = toolsForSearch.length;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TextWonder',
  alternateName: 'textwonder',
  url: 'https://textwonder.com',
  description: `textwonder — ${totalTools} free browser-based tools across 10 categories — text, PDF, developer, calculator, unit converter, health, student, color, and data tools. No signup required.`,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://textwonder.com/tools?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TextWonder',
  alternateName: ['textwonder', 'textwonder.com'],
  url: 'https://textwonder.com',
  logo: 'https://textwonder.com/favicon.svg',
};

const homepageFaqs = [
  { q: 'Are all the tools on TextWonder free?', a: 'Yes. Every tool across all 10 sections is completely free — no hidden charges, no premium tiers, no subscription, ever.' },
  { q: 'Is my data uploaded to a server?', a: 'Never. All tools run entirely in your browser using JavaScript. Your text, files, and data never leave your device.' },
  { q: 'What categories of tools are available?', a: `TextWonder has ${totalTools} tools across 10 categories: Text tools, PDF tools, Dev tools, calculators, unit converters, health tools, student utilities, color tools, data formatters, and document generators.` },
  { q: 'Do the tools work on mobile?', a: 'Yes. Every tool is fully responsive and works on smartphones and tablets without losing any functionality.' },
  { q: 'Do I need to install anything?', a: 'No. Everything runs directly in your browser. No app download, no browser extension, no dependencies.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homepageFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="TextWonder — Free Online Tools: Text, PDF, Dev, Calculator & More"
  description={`textwonder.com — ${totalTools} free browser-based tools for text, PDF, developer, calculator, unit converter, health, student, color & data tasks. No signup needed.`}
  canonical="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main>
    <!-- ── Hero with Interactive Search ──────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 pt-16 pb-8 text-center relative">
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[1.05] text-white mb-5">
        One platform,<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-500">every tool you need</span>
      </h1>
      <p class="text-slate-400 text-base md:text-lg max-w-xl mx-auto mb-8">
        Free, browser-based utilities across 10 categories. No signup, no ads, no data sent anywhere.
      </p>

      <!-- Large Hero Search Bar -->
      <div class="max-w-xl mx-auto relative mb-3" id="hero-search-wrapper">
        <div class="relative flex items-center bg-[var(--bg-surface)] border border-slate-800 rounded-2xl shadow-xl focus-within:border-violet-500 focus-within:ring-2 focus-within:ring-violet-500/20 transition-all overflow-hidden px-4 py-3.5">
          <svg class="w-5 h-5 text-slate-400 mr-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" id="hero-search-input" placeholder="Search 150+ free tools (e.g. pdf merger, emi, case)..." class="flex-1 bg-transparent text-white placeholder-slate-500 outline-none text-sm md:text-base" autocomplete="off" />
          <span class="hidden sm:inline text-[10px] text-slate-500 bg-[var(--bg-base)] border border-slate-800 px-2 py-0.5 rounded-md uppercase font-bold tracking-wider">/</span>
        </div>
        
        <!-- Search Dropdown -->
        <div id="hero-search-dropdown" class="hidden absolute left-0 right-0 top-full mt-2 bg-[var(--bg-surface)] border border-slate-800 rounded-xl shadow-2xl overflow-hidden z-40 max-h-80 overflow-y-auto text-left">
          <ul id="hero-search-results" class="py-2"></ul>
        </div>
      </div>

      <!-- Quick suggestions tags -->
      <div class="flex flex-wrap justify-center items-center gap-2 text-xs text-slate-500 mb-6">
        <span>Try searching:</span>
        <button class="popular-tag text-slate-400 hover:text-white transition-colors bg-[var(--bg-surface)] border border-slate-800/80 px-2.5 py-1 rounded-full cursor-pointer hover:border-slate-700" data-query="pdf merger">PDF Merger</button>
        <button class="popular-tag text-slate-400 hover:text-white transition-colors bg-[var(--bg-surface)] border border-slate-800/80 px-2.5 py-1 rounded-full cursor-pointer hover:border-slate-700" data-query="json">JSON Formatter</button>
        <button class="popular-tag text-slate-400 hover:text-white transition-colors bg-[var(--bg-surface)] border border-slate-800/80 px-2.5 py-1 rounded-full cursor-pointer hover:border-slate-700" data-query="word">Word Counter</button>
        <button class="popular-tag text-slate-400 hover:text-white transition-colors bg-[var(--bg-surface)] border border-slate-800/80 px-2.5 py-1 rounded-full cursor-pointer hover:border-slate-700" data-query="emi">EMI Calculator</button>
      </div>

      <div class="inline-flex flex-wrap justify-center gap-x-5 gap-y-1.5 text-xs text-slate-500">
        <span><strong class="text-white font-semibold">{totalTools}</strong> tools</span>
        <span class="text-slate-700">·</span>
        <span><strong class="text-white font-semibold">10</strong> categories</span>
        <span class="text-slate-700">·</span>
        <span><strong class="text-white font-semibold">100%</strong> browser-based</span>
        <span class="text-slate-700">·</span>
        <span><strong class="text-white font-semibold">0</strong> signups required</span>
      </div>
    </section>

    <!-- ── Category Grid Directory ────────────────────────────── -->
    <section class="max-w-5xl mx-auto px-4 pb-12">
      <h2 class="text-xs font-bold text-slate-500 uppercase tracking-widest text-center mb-6">Browse by Category</h2>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3" id="category-cards-grid">
        {SECTIONS.map((s, idx) => (
          <button 
            class="category-card-btn group text-left flex flex-col justify-between p-4 bg-[var(--bg-surface)] border border-slate-800/80 rounded-2xl hover:border-slate-700 transition-all cursor-pointer relative overflow-hidden active:scale-[0.98]"
            data-index={idx}
            style={`--brand-color:${s.color}; --tw-shadow-color:rgba(${s.accentRgb},0.15);`}>
            
            <div class="flex items-center justify-between w-full mb-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center text-lg transition-transform group-hover:scale-105 shrink-0" 
                style={`background:rgba(${s.accentRgb},0.08); border:1px solid rgba(${s.accentRgb},0.18)`}>
                {s.icon}
              </div>
              <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold shrink-0" 
                style={`background:rgba(${s.accentRgb},0.1); color:${s.color};`}>
                {s.count}
              </span>
            </div>
            
            <div>
              <h3 class="text-sm font-bold text-white transition-colors" style="font-family:'Space Grotesk',sans-serif;">
                {s.prefix}<span style={`color:${s.color}`}>{s.suffix}</span>
              </h3>
              <p class="text-slate-500 text-[10px] leading-snug mt-1 line-clamp-2 group-hover:text-slate-400 transition-colors">{s.tagline}</p>
            </div>
          </button>
        ))}
      </div>
    </section>

    <!-- ── Dynamic Category Explorer Dashboard ────────────────── -->
    <section class="max-w-5xl mx-auto px-4 pb-16" id="dashboard-section">
      <!-- Tabs header wrapper (scrollable on mobile) -->
      <div class="border-b border-slate-800/80 mb-6 flex items-center gap-1 overflow-x-auto pb-px scrollbar-none" id="dashboard-tab-bar">
        {SECTIONS.map((s, idx) => (
          <button
            class="dashboard-tab-btn flex items-center gap-1.5 px-4 py-3.5 border-b-2 border-transparent text-sm font-bold text-slate-400 hover:text-white hover:border-slate-800 transition-all shrink-0 cursor-pointer"
            data-index={idx}
            data-color={s.color}
            data-accent-rgb={s.accentRgb}>
            <span class="text-base">{s.icon}</span>
            <span>{s.prefix}{s.suffix}</span>
          </button>
        ))}
      </div>

      <!-- Tab Content Area -->
      <div class="bg-[var(--bg-surface)] border border-slate-800/80 rounded-3xl p-6 sm:p-8 relative overflow-hidden" id="tab-pane-container">
        {SECTIONS.map((s, idx) => (
          <div class="tab-pane hidden" data-index={idx}>
            <!-- Active Section Info Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-800/80 pb-6 mb-6">
              <div class="min-w-0">
                <div class="flex items-center gap-2.5 flex-wrap">
                  <h3 class="text-2xl font-bold" style="font-family:'Space Grotesk',sans-serif;">
                    <span style={`color:${s.color}`}>{s.prefix}</span><span class="text-white">{s.suffix}</span>
                  </h3>
                  <span class="text-xs px-2.5 py-0.5 rounded-full font-medium"
                    style={`background:rgba(${s.accentRgb},0.1);color:${s.color};border:1px solid rgba(${s.accentRgb},0.2)`}>
                    {s.count} Tools Available
                  </span>
                </div>
                <p class="text-slate-400 text-sm mt-1.5 leading-relaxed">{s.tagline}</p>
              </div>
              
              <a href={s.path}
                class="shrink-0 flex items-center justify-center gap-1.5 text-sm font-bold px-5 py-2.5 rounded-xl transition-all hover:brightness-110 active:scale-[0.98]"
                style={`color:#fff;background:${s.color};box-shadow: 0 4px 12px rgba(${s.accentRgb},0.2)`}>
                View stand-alone {s.prefix}{s.suffix} page
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>

            <!-- Active Category Tools Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id={`grid-${idx}`}>
              {s.toolsList.map((t, tIdx) => (
                <a href={t.path}
                  class={`tool-link-card block bg-[var(--bg-base)] border border-slate-800/80 rounded-2xl p-5 hover:border-slate-700 transition-all hover:-translate-y-0.5 hover:shadow-lg ${tIdx >= 6 ? 'hidden extra-tool' : ''}`}
                  style={`--brand-color:${s.color};`}>
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="text-white font-bold text-base transition-colors duration-200">{t.name}</h4>
                    <div class="w-6 h-6 rounded-md flex items-center justify-center text-xs opacity-60 shrink-0" style={`background:rgba(${s.accentRgb},0.08); color:${s.color}`}>
                      {s.icon}
                    </div>
                  </div>
                  <p class="text-slate-500 text-xs leading-snug line-clamp-2 mt-1">
                    Free browser-based {t.name.toLowerCase()} tool. Fast, private, and secure.
                  </p>
                  <div class="flex items-center text-[10px] font-bold mt-4 uppercase tracking-wider transition-colors" style={`color:${s.color};`}>
                    Launch Tool &rarr;
                  </div>
                </a>
              ))}
            </div>

            {/* Expander Button if tools count > 6 */}
            {s.count > 6 && (
              <div class="flex justify-center mt-8 pt-2">
                <button 
                  class="expand-tools-btn flex items-center gap-1.5 text-xs font-bold px-6 py-3 rounded-full border transition-all cursor-pointer active:scale-95 hover:brightness-110"
                  style={`color:${s.color};background:rgba(${s.accentRgb},0.05);border-color:rgba(${s.accentRgb},0.2);`}
                  data-expanded="false"
                  data-index={idx}>
                  <span class="btn-text">Show All {s.count} Tools</span>
                  <svg class="w-3.5 h-3.5 transition-transform arrow-icon" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- ── Privacy section ────────────────────────────────────── -->
    <section class="bg-[var(--bg-surface)] border-y border-slate-800 py-12">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="text-3xl mb-3">🔒</div>
        <h2 class="text-xl font-bold text-white mb-2" style="font-family:'Space Grotesk',sans-serif;">Privacy by design — across every tool</h2>
        <p class="text-slate-400 text-sm max-w-xl mx-auto mb-6 leading-relaxed">
          Every tool on TextWonder — whether it's a text cleaner, PDF editor, or calculator — runs entirely in your browser.
          No servers receive your input. No files are uploaded. When you close the tab, your data is gone.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-xl mx-auto">
          <div class="bg-[var(--bg-base)] rounded-xl p-3.5 border border-slate-800">
            <div class="text-emerald-400 font-bold text-sm mb-0.5">No Servers</div>
            <div class="text-slate-500 text-xs">All processing stays on your device</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3.5 border border-slate-800">
            <div class="text-emerald-400 font-bold text-sm mb-0.5">No Accounts</div>
            <div class="text-slate-500 text-xs">No signup, no email, no passwords</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3.5 border border-slate-800">
            <div class="text-emerald-400 font-bold text-sm mb-0.5">No Tracking</div>
            <div class="text-slate-500 text-xs">No ad pixels or behaviour tracking</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SEO content ────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family:'Space Grotesk',sans-serif;">
        {totalTools} Free Online Tools — All in One Place
      </h2>
      <div class="text-slate-400 space-y-4 leading-relaxed text-sm">
        <p>
          TextWonder is one platform for every tool you need — free, browser-based utilities covering 10 categories, from
          <a href="/tools" class="text-violet-400 hover:underline">text processing tools</a> and
          <a href="/pdfwonder" class="text-orange-400 hover:underline">PDF utilities</a> to
          <a href="/devwonder" class="text-cyan-400 hover:underline">developer tools</a>,
          <a href="/calc" class="text-emerald-400 hover:underline">financial calculators</a>,
          <a href="/unit" class="text-indigo-400 hover:underline">unit converters</a>,
          <a href="/health" class="text-green-400 hover:underline">health calculators</a>,
          <a href="/student" class="text-blue-400 hover:underline">student tools</a>,
          <a href="/color" class="text-pink-400 hover:underline">color & design tools</a>,
          <a href="/data" class="text-amber-400 hover:underline">data format converters</a>, and
          <a href="/categories/document-generators" class="text-teal-400 hover:underline">document generators</a>.
          Every single tool runs entirely in your browser — no server-side processing, no uploads, no account required.
        </p>
        <p>
          Whether you need to <a href="/tools/word-counter" class="text-violet-400 hover:underline">count words</a>,
          <a href="/pdfwonder/pdf-merger" class="text-orange-400 hover:underline">merge PDF files</a>,
          <a href="/devwonder/json-formatter" class="text-cyan-400 hover:underline">format JSON</a>,
          <a href="/calc/emi-calculator" class="text-emerald-400 hover:underline">calculate EMI</a>, or
          <a href="/color/contrast-checker" class="text-pink-400 hover:underline">check color contrast</a>,
          there's a dedicated, fast tool here built for exactly that task.
        </p>
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <h2 class="text-2xl font-bold text-white mb-6" style="font-family:'Space Grotesk',sans-serif;">Frequently Asked Questions</h2>
      <div class="space-y-2">
        {homepageFaqs.map(faq => (
          <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
              <span class="text-white font-medium text-sm">{faq.q}</span>
              <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4">
              <p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ toolsForSearch }}>
(function() {
  // Hero Search Input & Dropdown
  const searchInput = document.getElementById('hero-search-input');
  const searchDropdown = document.getElementById('hero-search-dropdown');
  const searchResults = document.getElementById('hero-search-results');
  
  function renderHeroSearch(query) {
    const q = query.toLowerCase().trim();
    if (!q) {
      searchDropdown.classList.add('hidden');
      return;
    }
    
    const filtered = toolsForSearch.filter(t => 
      t.name.toLowerCase().includes(q) || 
      t.category.toLowerCase().includes(q)
    );
    
    if (filtered.length > 0) {
      searchResults.innerHTML = filtered.slice(0, 10).map(t => `
        <li>
          <a href="${t.path}" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[var(--bg-surface-hover)] transition-colors">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs" style="background:${t.color}15; color:${t.color}; border: 1px solid ${t.color}25">
              ${t.icon || '⚙️'}
            </div>
            <span class="text-white text-sm font-semibold">${t.name}</span>
            <span class="text-[10px] px-2 py-0.5 rounded-full font-medium ml-auto" style="background:${t.color}15; color:${t.color}">
              ${t.category}
            </span>
          </a>
        </li>
      `).join('');
    } else {
      searchResults.innerHTML = `<li class="px-4 py-6 text-slate-500 text-sm text-center">No tools match your search</li>`;
    }
    
    searchDropdown.classList.remove('hidden');
  }

  searchInput.addEventListener('input', e => renderHeroSearch(e.target.value));

  // Close search dropdown on click outside
  document.addEventListener('click', e => {
    if (searchInput && !searchInput.contains(e.target) && searchDropdown && !searchDropdown.contains(e.target)) {
      searchDropdown.classList.add('hidden');
    }
  });

  // Popular search suggestions tags handler
  const popularTags = document.querySelectorAll('.popular-tag');
  popularTags.forEach(tag => {
    tag.addEventListener('click', () => {
      const query = tag.getAttribute('data-query');
      searchInput.value = query;
      renderHeroSearch(query);
      searchInput.focus();
    });
  });

  // Keyboard shortcut '/' to focus search
  document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // Dynamic Dashboard Tab System
  const tabs = document.querySelectorAll('.dashboard-tab-btn');
  const cards = document.querySelectorAll('.category-card-btn');
  const panes = document.querySelectorAll('.tab-pane');

  function switchTab(index) {
    // 1. Update tab buttons
    tabs.forEach((tab, i) => {
      const activeColor = tab.getAttribute('data-color');
      const accentRgb = tab.getAttribute('data-accent-rgb');
      const isSelected = i === index;
      
      if (isSelected) {
        tab.style.borderColor = activeColor;
        tab.style.color = '#fff';
        tab.style.background = `rgba(${accentRgb}, 0.04)`;
        panes[i].classList.remove('hidden');
      } else {
        tab.style.borderColor = 'transparent';
        tab.style.color = '';
        tab.style.background = '';
        panes[i].classList.add('hidden');
      }
    });

    // 2. Update category cards border and glow
    cards.forEach((card, i) => {
      const isSelected = i === index;
      if (isSelected) {
        card.style.borderColor = card.style.getPropertyValue('--brand-color');
        card.style.boxShadow = `0 0 16px ${card.style.getPropertyValue('--tw-shadow-color')}`;
        card.style.background = 'var(--bg-surface-hover)';
      } else {
        card.style.borderColor = '';
        card.style.boxShadow = '';
        card.style.background = '';
      }
    });

    // Collapse expanded tools if tab switches
    const expandBtn = panes[index].querySelector('.expand-tools-btn');
    if (expandBtn) {
      collapseTools(expandBtn, index);
    }
  }

  // Bind clicks on Category Cards to switch tab
  cards.forEach((card, i) => {
    card.addEventListener('click', () => {
      switchTab(i);
      // Smooth scroll to the dashboard section so tools are visible
      const dashboardSection = document.getElementById('dashboard-section');
      if (dashboardSection) {
        dashboardSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Bind clicks on Tab buttons to switch tab
  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => switchTab(i));
  });

  // Expander buttons handler
  const expandBtns = document.querySelectorAll('.expand-tools-btn');
  
  function expandTools(btn, paneIdx) {
    const pane = panes[paneIdx];
    const extraTools = pane.querySelectorAll('.extra-tool');
    const color = tabs[paneIdx].getAttribute('data-color');
    const accentRgb = tabs[paneIdx].getAttribute('data-accent-rgb');
    
    extraTools.forEach(tool => tool.classList.remove('hidden'));
    btn.setAttribute('data-expanded', 'true');
    btn.querySelector('.btn-text').textContent = 'Show Less';
    btn.querySelector('.arrow-icon').style.transform = 'rotate(180deg)';
    
    // Style expanded button slightly differently
    btn.style.background = color;
    btn.style.color = '#fff';
    btn.style.borderColor = color;
    btn.style.boxShadow = `0 4px 12px rgba(${accentRgb}, 0.25)`;
  }

  function collapseTools(btn, paneIdx) {
    const pane = panes[paneIdx];
    const extraTools = pane.querySelectorAll('.extra-tool');
    const color = tabs[paneIdx].getAttribute('data-color');
    const accentRgb = tabs[paneIdx].getAttribute('data-accent-rgb');
    const count = extraTools.length + 6;
    
    extraTools.forEach(tool => tool.classList.add('hidden'));
    btn.setAttribute('data-expanded', 'false');
    btn.querySelector('.btn-text').textContent = `Show All ${count} Tools`;
    btn.querySelector('.arrow-icon').style.transform = '';
    
    btn.style.background = `rgba(${accentRgb}, 0.05)`;
    btn.style.color = color;
    btn.style.borderColor = `rgba(${accentRgb}, 0.2)`;
    btn.style.boxShadow = '';
  }

  expandBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.getAttribute('data-index'));
      const isExpanded = btn.getAttribute('data-expanded') === 'true';
      if (isExpanded) {
        collapseTools(btn, idx);
        // Scroll back to dashboard top to prevent jumping
        document.getElementById('dashboard-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        expandTools(btn, idx);
      }
    });
  });

  // Initialize: default select first tab (TextWonder)
  switchTab(0);
})();
</script>
