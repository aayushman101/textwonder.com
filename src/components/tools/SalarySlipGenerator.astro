---
---
<style>
  @media print {
    body > *:not(#ssg-print-area) { display: none !important; }
    #ssg-print-area { display: block !important; position: fixed; inset: 0; background: #fff; padding: 40px; }
    .ssg-no-print { display: none !important; }
  }
</style>

<div class="space-y-6 ssg-no-print">
  <!-- Company details -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Company Details</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1 sm:col-span-2">
        <label class="text-xs text-slate-400">Company Name</label>
        <input id="ssg-company" type="text" placeholder="e.g. Acme Technologies Pvt. Ltd." class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1 sm:col-span-2">
        <label class="text-xs text-slate-400">Company Address</label>
        <input id="ssg-company-address" type="text" placeholder="e.g. 12, Tech Park, Whitefield, Bengaluru - 560066" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Employee details -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Employee Details</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Employee Name</label>
        <input id="ssg-employee" type="text" placeholder="e.g. Amit Kumar" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Employee ID</label>
        <input id="ssg-empid" type="text" placeholder="e.g. EMP-042" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Designation</label>
        <input id="ssg-designation" type="text" placeholder="e.g. Software Engineer" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Department</label>
        <input id="ssg-dept" type="text" placeholder="e.g. Engineering" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Salary Month</label>
        <input id="ssg-month" type="month" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Bank Account No. (optional)</label>
        <input id="ssg-bank" type="text" placeholder="e.g. XXXX XXXX 4521" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Earnings -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Earnings (₹)</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Basic Salary</label>
        <input id="ssg-basic" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">HRA</label>
        <input id="ssg-hra" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Travel Allowance</label>
        <input id="ssg-ta" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Other Allowances</label>
        <input id="ssg-other-earn" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Deductions -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Deductions (₹)</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Provident Fund (PF)</label>
        <input id="ssg-pf" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Professional Tax</label>
        <input id="ssg-pt" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">TDS</label>
        <input id="ssg-tds" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Other Deductions</label>
        <input id="ssg-other-ded" type="number" placeholder="0" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <button id="ssg-print" class="px-6 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Print / Save as PDF</button>
    <span id="ssg-net-display" class="text-slate-300 text-sm font-medium"></span>
  </div>
</div>

<div class="mt-6 border border-slate-700 rounded-xl p-1 ssg-no-print">
  <div id="ssg-preview" class="bg-white text-slate-900 rounded-lg p-6 font-sans text-sm leading-relaxed"></div>
</div>

<div id="ssg-print-area" style="display:none;" class="bg-white text-slate-900 font-sans text-sm leading-relaxed p-10"></div>

<script>
  function n(id: string): number { return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0; }
  function s(id: string): string { return (document.getElementById(id) as HTMLInputElement).value.trim(); }
  function fmt(monthStr: string) {
    if (!monthStr) return '';
    const [y, m] = monthStr.split('-');
    return new Date(+y, +m - 1, 1).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });
  }
  function fmtNum(x: number) { return x.toLocaleString('en-IN'); }

  function buildHTML() {
    const basic = n('ssg-basic'), hra = n('ssg-hra'), ta = n('ssg-ta'), otherEarn = n('ssg-other-earn');
    const pf = n('ssg-pf'), pt = n('ssg-pt'), tds = n('ssg-tds'), otherDed = n('ssg-other-ded');
    const gross = basic + hra + ta + otherEarn;
    const totalDed = pf + pt + tds + otherDed;
    const net = gross - totalDed;
    const month = s('ssg-month');
    const bank = s('ssg-bank');

    document.getElementById('ssg-net-display')!.textContent = gross ? `Net Pay: ₹${fmtNum(net)}` : '';

    const bankRow = bank ? `<tr style="background:#f5f5f5;"><td style="padding:6px 10px;border:1px solid #ddd;font-size:12px;"><strong>Bank Account</strong></td><td style="padding:6px 10px;border:1px solid #ddd;font-size:12px;">${bank}</td><td colspan="2" style="border:1px solid #ddd;"></td></tr>` : '';

    return `
      <div style="font-family:Arial,sans-serif;max-width:720px;margin:0 auto;border:1px solid #ccc;padding:0;">
        <div style="background:#1e3a5f;color:#fff;padding:16px 20px;">
          <h2 style="margin:0 0 2px;font-size:17px;">${s('ssg-company') || 'Company Name'}</h2>
          <p style="margin:0;font-size:11px;opacity:.8;">${s('ssg-company-address') || ''}</p>
        </div>
        <div style="background:#f0f4f8;padding:10px 20px;text-align:center;">
          <h3 style="margin:0;font-size:14px;color:#1e3a5f;letter-spacing:1px;text-transform:uppercase;">Salary Slip — ${fmt(month) || '—'}</h3>
        </div>
        <div style="padding:16px 20px;">
          <table style="width:100%;border-collapse:collapse;margin-bottom:16px;font-size:12px;">
            <tr>
              <td style="padding:6px 10px;border:1px solid #ddd;width:25%;"><strong>Employee Name</strong></td>
              <td style="padding:6px 10px;border:1px solid #ddd;width:25%;">${s('ssg-employee') || '—'}</td>
              <td style="padding:6px 10px;border:1px solid #ddd;width:25%;"><strong>Employee ID</strong></td>
              <td style="padding:6px 10px;border:1px solid #ddd;width:25%;">${s('ssg-empid') || '—'}</td>
            </tr>
            <tr style="background:#f5f5f5;">
              <td style="padding:6px 10px;border:1px solid #ddd;"><strong>Designation</strong></td>
              <td style="padding:6px 10px;border:1px solid #ddd;">${s('ssg-designation') || '—'}</td>
              <td style="padding:6px 10px;border:1px solid #ddd;"><strong>Department</strong></td>
              <td style="padding:6px 10px;border:1px solid #ddd;">${s('ssg-dept') || '—'}</td>
            </tr>
            ${bankRow}
          </table>

          <table style="width:100%;border-collapse:collapse;font-size:12px;">
            <thead>
              <tr style="background:#1e3a5f;color:#fff;">
                <th style="padding:8px 10px;text-align:left;border:1px solid #ccc;width:50%;">Earnings</th>
                <th style="padding:8px 10px;text-align:right;border:1px solid #ccc;width:50%;">Amount (₹)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td style="padding:6px 10px;border:1px solid #ddd;">Basic Salary</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(basic)}</td></tr>
              <tr style="background:#f9f9f9;"><td style="padding:6px 10px;border:1px solid #ddd;">House Rent Allowance (HRA)</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(hra)}</td></tr>
              <tr><td style="padding:6px 10px;border:1px solid #ddd;">Travel Allowance</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(ta)}</td></tr>
              <tr style="background:#f9f9f9;"><td style="padding:6px 10px;border:1px solid #ddd;">Other Allowances</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(otherEarn)}</td></tr>
              <tr style="font-weight:bold;background:#e8f0fe;">
                <td style="padding:8px 10px;border:1px solid #ddd;">Gross Earnings</td>
                <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;">₹ ${fmtNum(gross)}</td>
              </tr>
            </tbody>
          </table>

          <table style="width:100%;border-collapse:collapse;font-size:12px;margin-top:12px;">
            <thead>
              <tr style="background:#c0392b;color:#fff;">
                <th style="padding:8px 10px;text-align:left;border:1px solid #ccc;width:50%;">Deductions</th>
                <th style="padding:8px 10px;text-align:right;border:1px solid #ccc;width:50%;">Amount (₹)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td style="padding:6px 10px;border:1px solid #ddd;">Provident Fund (PF)</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(pf)}</td></tr>
              <tr style="background:#f9f9f9;"><td style="padding:6px 10px;border:1px solid #ddd;">Professional Tax</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(pt)}</td></tr>
              <tr><td style="padding:6px 10px;border:1px solid #ddd;">TDS</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(tds)}</td></tr>
              <tr style="background:#f9f9f9;"><td style="padding:6px 10px;border:1px solid #ddd;">Other Deductions</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">${fmtNum(otherDed)}</td></tr>
              <tr style="font-weight:bold;background:#fde8e8;">
                <td style="padding:8px 10px;border:1px solid #ddd;">Total Deductions</td>
                <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;">₹ ${fmtNum(totalDed)}</td>
              </tr>
            </tbody>
          </table>

          <div style="background:#1e3a5f;color:#fff;padding:12px 20px;margin-top:12px;display:flex;justify-content:space-between;align-items:center;border-radius:4px;">
            <span style="font-size:14px;font-weight:bold;">Net Pay</span>
            <span style="font-size:18px;font-weight:bold;">₹ ${fmtNum(net)}</span>
          </div>
          <p style="font-size:10px;color:#888;margin-top:12px;text-align:center;">This is a computer-generated salary slip and does not require a signature.</p>
        </div>
      </div>`;
  }

  function render() {
    const html = buildHTML();
    document.getElementById('ssg-preview')!.innerHTML = html;
    document.getElementById('ssg-print-area')!.innerHTML = html;
  }

  const thisMonth = new Date().toISOString().slice(0, 7);
  (document.getElementById('ssg-month') as HTMLInputElement).value = thisMonth;

  document.querySelectorAll('#ssg-company,#ssg-company-address,#ssg-employee,#ssg-empid,#ssg-designation,#ssg-dept,#ssg-month,#ssg-bank,#ssg-basic,#ssg-hra,#ssg-ta,#ssg-other-earn,#ssg-pf,#ssg-pt,#ssg-tds,#ssg-other-ded').forEach(el => el.addEventListener('input', render));
  document.getElementById('ssg-print')?.addEventListener('click', () => window.print());
  render();
</script>
