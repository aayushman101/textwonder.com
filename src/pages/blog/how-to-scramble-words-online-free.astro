const faqs = [
  { q: 'What is the middle-letter scramble?', a: 'Research shows readers can recognise words even when internal letters are scrambled, as long as the first and last letters remain in place. The middle scramble preserves the first and last letter of each word.' },
  { q: 'What is the full scramble option?', a: 'Full scramble randomises every letter of every word, including the first and last.' },
