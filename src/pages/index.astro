---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { TOOLS, CATEGORIES } from '../data/tools.js';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TextWonder',
  url: 'https://textwonder.com',
  description: 'Free online text utility tools — browser-based, private, no signup.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://textwonder.com/tools?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TextWonder',
  url: 'https://textwonder.com',
  logo: 'https://textwonder.com/favicon.svg',
};

const homepageFaqs = [
  { q: 'Are all the tools on TextWonder free?', a: 'Yes. Every tool on TextWonder is completely free to use with no hidden charges, premium tiers, or subscription required — ever.' },
  { q: 'Is my text stored or sent to a server?', a: 'Never. All tools process text entirely in your browser using JavaScript. Your text never leaves your device. We have no servers that receive or store your input.' },
  { q: 'What text tools are available?', a: 'TextWonder currently offers 41 tools across four categories: Text Cleaning, Text Conversion, Text Analysis (including readability scores, word frequency, n-gram analysis, entropy, and more), and Text Formatting.' },
  { q: 'Does TextWonder work on mobile devices?', a: 'Yes. All tools are fully responsive and work on smartphones and tablets. The interface adapts to smaller screens without losing any functionality.' },
  { q: 'Does it support languages other than English?', a: 'Yes. The tools work with Unicode text, supporting Hindi, Arabic, Chinese, Spanish, French, and most other languages.' },
];

type ToolVisual = { bg: string; iconHtml: string };

const toolIcons: Record<string, ToolVisual> = {
  'remove-emojis': {
    bg: '#7c3aed',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M4.93 4.93l14.14 14.14"/></svg>`,
  },
  'remove-duplicate-lines': {
    bg: '#3b82f6',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 6h16M4 10h11M4 14h8"/><path d="M17 17l2 2 4-4"/></svg>`,
  },
  'remove-extra-spaces': {
    bg: '#0d9488',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 6h16M4 10h12M4 14h8M9 18l3-3 3 3"/></svg>`,
  },
  'title-case-converter': {
    bg: '#f97316',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:19px;color:white;letter-spacing:-1px;line-height:1">Tt</span>`,
  },
  'uppercase-converter': {
    bg: '#ef4444',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:17px;color:white;letter-spacing:2px;line-height:1">AA</span>`,
  },
  'lowercase-converter': {
    bg: '#22c55e',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:17px;color:white;letter-spacing:2px;line-height:1">aa</span>`,
  },
  'word-counter': {
    bg: '#6366f1',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>`,
  },
  'character-counter': {
    bg: '#ec4899',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:18px;color:white;letter-spacing:-1px;line-height:1">Aa</span>`,
  },
  'sort-lines': {
    bg: '#0ea5e9',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/></svg>`,
  },
  'reverse-text': {
    bg: '#f59e0b',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>`,
  },
  'sentence-counter': {
    bg: '#8b5cf6',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h10"/><circle cx="19" cy="14" r="2"/></svg>`,
