---
---
<div class="space-y-4">
  <textarea id="trp-input" rows="4" placeholder="Enter text to repeat…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Repeat count</label>
      <input id="trp-count" type="number" value="5" min="1" max="1000" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
    </div>
    <div class="space-y-1 col-span-2 sm:col-span-2">
      <label class="text-xs text-slate-500">Separator</label>
      <select id="trp-sep" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500">
        <option value="newline">New line</option>
        <option value="space">Space</option>
        <option value="comma">Comma</option>
        <option value="pipe">Pipe ( | )</option>
        <option value="none">None</option>
        <option value="custom">Custom…</option>
      </select>
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500 invisible">Custom</label>
      <input id="trp-custom" type="text" placeholder="Custom sep" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-500 text-sm focus:outline-none focus:border-violet-500 hidden" />
    </div>
  </div>
  <div class="flex gap-2">
    <button id="trp-do" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Repeat</button>
    <button id="trp-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="trp-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span id="trp-stats" class="text-xs text-slate-500">Result</span>
      <button id="trp-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="trp-output" rows="8" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  const SEP_MAP = { newline: '\n', space: ' ', comma: ', ', pipe: ' | ', none: '' };
  const input = document.getElementById('trp-input');
  const output = document.getElementById('trp-output');
  const wrap = document.getElementById('trp-output-wrap');
  const stats = document.getElementById('trp-stats');
  const countEl = document.getElementById('trp-count');
  const sepEl = document.getElementById('trp-sep');
  const customEl = document.getElementById('trp-custom');
  sepEl.addEventListener('change', () => customEl.classList.toggle('hidden', sepEl.value !== 'custom'));
  document.getElementById('trp-do').addEventListener('click', () => {
    const text = input.value;
    const n = Math.min(Math.max(parseInt(countEl.value) || 1, 1), 1000);
    const sep = sepEl.value === 'custom' ? customEl.value : (SEP_MAP[sepEl.value] ?? '\n');
    let result = Array(n).fill(text).join(sep);
    if (result.length > 100000) result = result.slice(0, 100000) + '\n…(truncated)';
    output.value = result;
    stats.textContent = `${n}× repeated · ${result.length} chars total`;
    wrap.classList.remove('hidden');
  });
  document.getElementById('trp-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); });
  document.getElementById('trp-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
