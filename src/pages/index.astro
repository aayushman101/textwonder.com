---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { TOOLS } from '../data/tools.js';
import { PDF_TOOLS } from '../data/pdftools.js';
import { DEV_TOOLS } from '../data/devtools.js';
import { CALC_TOOLS } from '../data/calctools.js';
import { UNIT_TOOLS } from '../data/unittools.js';
import { HEALTH_TOOLS } from '../data/healthtools.js';
import { STUDENT_TOOLS } from '../data/studenttools.js';
import { COLOR_TOOLS } from '../data/colortools.js';
import { DATA_TOOLS } from '../data/datatools.js';

const allToolArrays = [TOOLS, PDF_TOOLS, DEV_TOOLS, CALC_TOOLS, UNIT_TOOLS, HEALTH_TOOLS, STUDENT_TOOLS, COLOR_TOOLS, DATA_TOOLS];
const totalTools = allToolArrays.reduce((sum, arr) => sum + arr.length, 0);

type FeaturedTool = { name: string; path: string };
type Section = {
  prefix: string; suffix: string;
  path: string; color: string; accentRgb: string;
  tagline: string; count: number;
  featured: FeaturedTool[];
};

const SECTIONS: Section[] = [
  {
    prefix: 'Text', suffix: 'Wonder',
    path: '/tools',
    color: '#7c3aed', accentRgb: '124,58,237',
    tagline: 'Case converters, word counters, text cleaners, diff checker, encoders, and more.',
    count: TOOLS.length,
    featured: [
      { name: 'Word Counter', path: '/tools/word-counter' },
      { name: 'Title Case Converter', path: '/tools/title-case-converter' },
      { name: 'Remove Duplicate Lines', path: '/tools/remove-duplicate-lines' },
      { name: 'Sort Lines', path: '/tools/sort-lines' },
      { name: 'Reading Time Calculator', path: '/tools/reading-time-calculator' },
      { name: 'Text Diff Checker', path: '/tools/text-diff-checker' },
    ],
  },
  {
    prefix: 'PDF', suffix: 'Wonder',
    path: '/pdfwonder',
    color: '#f97316', accentRgb: '249,115,22',
    tagline: 'Merge, split, compress, rotate, and watermark PDFs — no upload, no signup.',
    count: PDF_TOOLS.length,
    featured: PDF_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/pdfwonder/${t.slug}` })),
  },
  {
    prefix: 'Dev', suffix: 'Wonder',
    path: '/devwonder',
    color: '#06b6d4', accentRgb: '6,182,212',
    tagline: 'JSON formatter, regex tester, JWT decoder, hash generator, UUID, cron parser — all in browser.',
    count: DEV_TOOLS.length,
    featured: DEV_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/devwonder/${t.slug}` })),
  },
  {
    prefix: 'Calc', suffix: 'Wonder',
    path: '/calc',
    color: '#10b981', accentRgb: '16,185,129',
    tagline: 'EMI, SIP, GST, compound interest, discount, percentage — all financial calculators.',
    count: CALC_TOOLS.length,
    featured: CALC_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/calc/${t.slug}` })),
  },
  {
    prefix: 'Unit', suffix: 'Wonder',
    path: '/unit',
    color: '#6366f1', accentRgb: '99,102,241',
    tagline: 'Length, weight, temperature, speed, volume, time, area, data — instant unit conversions.',
    count: UNIT_TOOLS.length,
    featured: UNIT_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/unit/${t.slug}` })),
  },
  {
    prefix: 'Health', suffix: 'Wonder',
    path: '/health',
    color: '#22c55e', accentRgb: '34,197,94',
    tagline: 'BMI, BMR, calorie calculator, body fat, macro calculator, water intake — free health tools.',
    count: HEALTH_TOOLS.length,
    featured: HEALTH_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/health/${t.slug}` })),
  },
  {
    prefix: 'Student', suffix: 'Wonder',
    path: '/student',
    color: '#3b82f6', accentRgb: '59,130,246',
    tagline: 'CGPA, GPA, attendance tracker, exam countdown, Pomodoro timer — built for students.',
    count: STUDENT_TOOLS.length,
    featured: STUDENT_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/student/${t.slug}` })),
  },
  {
    prefix: 'Color', suffix: 'Wonder',
    path: '/color',
    color: '#ec4899', accentRgb: '236,72,153',
    tagline: 'HEX/RGB/HSL converter, contrast checker, gradient builder, palette generator — for designers.',
    count: COLOR_TOOLS.length,
    featured: COLOR_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/color/${t.slug}` })),
  },
  {
    prefix: 'Data', suffix: 'Wonder',
    path: '/data',
    color: '#f59e0b', accentRgb: '245,158,11',
    tagline: 'CSV↔JSON, JSON↔YAML, XML→JSON, TSV↔CSV converters and data formatters.',
    count: DATA_TOOLS.length,
    featured: DATA_TOOLS.slice(0, 6).map((t: any) => ({ name: t.name, path: `/data/${t.slug}` })),
  },
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TextWonder',
  url: 'https://textwonder.com',
  description: `${totalTools} free browser-based tools across 9 categories — text, PDF, developer, calculator, unit converter, health, student, color, and data tools.`,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://textwonder.com/tools?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TextWonder',
  url: 'https://textwonder.com',
  logo: 'https://textwonder.com/favicon.svg',
};

const homepageFaqs = [
  { q: 'Are all the tools on TextWonder free?', a: 'Yes. Every tool across all 9 sections is completely free — no hidden charges, no premium tiers, no subscription, ever.' },
  { q: 'Is my data uploaded to a server?', a: 'Never. All tools run entirely in your browser using JavaScript. Your text, files, and data never leave your device.' },
  { q: 'What categories of tools are available?', a: `TextWonder has ${totalTools} tools across 9 categories: TextWonder (61 text utilities), PDFWonder (PDF tools), DevWonder (developer tools), CalcWonder (financial calculators), UnitWonder (unit converters), HealthWonder (health calculators), StudentWonder (student tools), ColorWonder (color & design tools), and DataWonder (data format converters).` },
  { q: 'Do the tools work on mobile?', a: 'Yes. Every tool is fully responsive and works on smartphones and tablets without losing any functionality.' },
  { q: 'Do I need to install anything?', a: 'No. Everything runs directly in your browser. No app download, no browser extension, no dependencies.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homepageFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Free Online Tools — Text, PDF, Dev, Calculator, Color & More | TextWonder"
  description={`${totalTools} free browser-based tools across 9 categories: text utilities, PDF tools, developer tools, calculators, unit converters, health tools, student tools, color tools, and data converters. No signup needed.`}
  canonical="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 pt-12 pb-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-3" style="font-family:'Space Grotesk',sans-serif;">
        One platform,<br class="hidden sm:block" /> every tool you need
      </h1>
      <p class="text-slate-400 text-lg max-w-xl mx-auto mb-6">
        Free, browser-based utilities across 9 categories. No signup, no ads, no data sent anywhere.
      </p>
      <div class="inline-flex flex-wrap justify-center gap-x-5 gap-y-1.5 text-sm text-slate-500">
        <span><strong class="text-white font-semibold">{totalTools}</strong> tools</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-white font-semibold">9</strong> categories</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-white font-semibold">100%</strong> browser-based</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-white font-semibold">0</strong> signups required</span>
      </div>
    </section>

    <!-- ── Category sections ─────────────────────────────────── -->
    <section class="max-w-5xl mx-auto px-4 pb-6">
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-6">Browse by category</h2>

      <div class="space-y-0 divide-y divide-slate-800/60">
        {SECTIONS.map(s => (
          <div class="py-6 first:pt-0 last:pb-0">
            <!-- Section header -->
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-lg font-bold" style={`font-family:'Space Grotesk',sans-serif;`}>
                    <span style={`color:${s.color}`}>{s.prefix}</span><span class="text-white">{s.suffix}</span>
                  </h3>
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                    style={`background:rgba(${s.accentRgb},0.12);color:${s.color};border:1px solid rgba(${s.accentRgb},0.3)`}>
                    {s.count} tools
                  </span>
                </div>
                <p class="text-slate-500 text-sm mt-0.5 leading-snug">{s.tagline}</p>
              </div>
              <a href={s.path}
                class="shrink-0 hidden sm:flex items-center gap-1 text-sm font-semibold px-4 py-1.5 rounded-lg transition-all hover:opacity-90"
                style={`color:${s.color};background:rgba(${s.accentRgb},0.1);border:1px solid rgba(${s.accentRgb},0.25)`}>
                Explore all
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </a>
            </div>

            <!-- Featured tool chips -->
            <div class="flex flex-wrap gap-2 items-center">
              {s.featured.map(t => (
                <a href={t.path}
                  class="inline-flex items-center px-3 py-1.5 rounded-full text-sm text-slate-300 hover:text-white bg-[var(--bg-surface)] border border-slate-800 transition-all hover:shadow-sm"
                  style={`--tw-shadow-color:rgba(${s.accentRgb},0.2);`}
                  onmouseover={`this.style.borderColor='rgba(${s.accentRgb},0.5)';this.style.color='${s.color}'`}
                  onmouseout={`this.style.borderColor='';this.style.color=''`}>
                  {t.name}
                </a>
              ))}
              {s.count > 6 && (
                <a href={s.path}
                  class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium transition-colors"
                  style={`color:${s.color};background:rgba(${s.accentRgb},0.08);border:1px solid rgba(${s.accentRgb},0.2)`}>
                  +{s.count - 6} more →
                </a>
              )}
              <!-- mobile explore link -->
              <a href={s.path}
                class="sm:hidden inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-semibold transition-all"
                style={`color:${s.color};background:rgba(${s.accentRgb},0.1);border:1px solid rgba(${s.accentRgb},0.25)`}>
                Explore all
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Privacy section ────────────────────────────────────── -->
    <section class="bg-[var(--bg-surface)] border-y border-slate-800 py-10 mt-8">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="text-3xl mb-3">🔒</div>
        <h2 class="text-xl font-bold text-white mb-2" style="font-family:'Space Grotesk',sans-serif;">Privacy by design — across every tool</h2>
        <p class="text-slate-400 text-sm max-w-xl mx-auto mb-6 leading-relaxed">
          Every tool on TextWonder — whether it's a text cleaner, PDF editor, or calculator — runs entirely in your browser.
          No servers receive your input. No files are uploaded. When you close the tab, your data is gone.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-xl mx-auto">
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Servers</div>
            <div class="text-slate-500 text-xs">All processing stays on your device</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Accounts</div>
            <div class="text-slate-500 text-xs">No signup, no email, no passwords</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Tracking</div>
            <div class="text-slate-500 text-xs">No ad pixels or behaviour tracking</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SEO content ────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family:'Space Grotesk',sans-serif;">
        {totalTools} Free Online Tools — All in One Place
      </h2>
      <div class="text-slate-400 space-y-4 leading-relaxed text-sm">
        <p>
          TextWonder is a free, browser-based toolkit covering {SECTIONS.length} categories of everyday utilities — from
          <a href="/tools" class="text-violet-400 hover:underline">text processing tools</a> and
          <a href="/pdfwonder" class="text-orange-400 hover:underline">PDF utilities</a> to
          <a href="/devwonder" class="text-cyan-400 hover:underline">developer tools</a>,
          <a href="/calc" class="text-emerald-400 hover:underline">financial calculators</a>,
          <a href="/unit" class="text-indigo-400 hover:underline">unit converters</a>,
          <a href="/health" class="text-green-400 hover:underline">health calculators</a>,
          <a href="/student" class="text-blue-400 hover:underline">student tools</a>,
          <a href="/color" class="text-pink-400 hover:underline">color & design tools</a>, and
          <a href="/data" class="text-amber-400 hover:underline">data format converters</a>.
          Every single tool runs entirely in your browser — no server-side processing, no uploads, no account required.
        </p>
        <p>
          Whether you need to <a href="/tools/word-counter" class="text-violet-400 hover:underline">count words</a>,
          <a href="/pdfwonder/pdf-merger" class="text-orange-400 hover:underline">merge PDF files</a>,
          <a href="/devwonder/json-formatter" class="text-cyan-400 hover:underline">format JSON</a>,
          <a href="/calc/emi-calculator" class="text-emerald-400 hover:underline">calculate EMI</a>, or
          <a href="/color/contrast-checker" class="text-pink-400 hover:underline">check color contrast</a>,
          there's a dedicated, fast tool here built for exactly that task.
        </p>
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-4 pb-14">
      <h2 class="text-2xl font-bold text-white mb-6" style="font-family:'Space Grotesk',sans-serif;">Frequently Asked Questions</h2>
      <div class="space-y-2">
        {homepageFaqs.map(faq => (
          <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
              <span class="text-white font-medium text-sm">{faq.q}</span>
              <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4">
              <p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
