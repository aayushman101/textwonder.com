---
---
<style>
  @media print {
    body > *:not(#pig-print-area) { display: none !important; }
    #pig-print-area { display: block !important; position: fixed; inset: 0; background: #fff; padding: 40px; }
    .pig-no-print { display: none !important; }
  }
</style>

<div class="space-y-6 pig-no-print">
  <!-- Seller -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Seller / From</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1 sm:col-span-2">
        <label class="text-xs text-slate-400">Company / Seller Name</label>
        <input id="pig-seller-name" type="text" placeholder="e.g. Acme Exports Pvt. Ltd." class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1 sm:col-span-2">
        <label class="text-xs text-slate-400">Seller Address</label>
        <input id="pig-seller-address" type="text" placeholder="e.g. 12, MG Road, Mumbai - 400001" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">GSTIN (optional)</label>
        <input id="pig-seller-gstin" type="text" placeholder="e.g. 27ABCDE1234F1Z5" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Email / Phone (optional)</label>
        <input id="pig-seller-contact" type="text" placeholder="e.g. info@acme.com | +91 98765 43210" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Invoice meta -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Invoice Details</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Invoice No.</label>
        <input id="pig-inv-no" type="text" placeholder="e.g. PRO/2024/001" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Invoice Date</label>
        <input id="pig-date" type="date" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Valid Until (optional)</label>
        <input id="pig-valid" type="date" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Buyer -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Buyer / Bill To</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Buyer Name</label>
        <input id="pig-buyer-name" type="text" placeholder="e.g. Global Traders Ltd." class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Buyer GSTIN (optional)</label>
        <input id="pig-buyer-gstin" type="text" placeholder="e.g. 07ABCDE1234F1Z5" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
      <div class="space-y-1 sm:col-span-2">
        <label class="text-xs text-slate-400">Buyer Address</label>
        <input id="pig-buyer-address" type="text" placeholder="e.g. 5, Trade Tower, New Delhi - 110001" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <!-- Line items -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Line Items</p>
    <div id="pig-items" class="space-y-2"></div>
    <button id="pig-add-item" class="mt-3 px-4 py-1.5 border border-violet-500 text-violet-400 hover:bg-violet-500 hover:text-white rounded-lg text-xs font-medium transition-colors">+ Add Item</button>
  </div>

  <!-- Tax -->
  <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Tax</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">GST Rate (%)</label>
        <select id="pig-gst-rate" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500">
          <option value="0">0% (Exempt)</option>
          <option value="5">5%</option>
          <option value="12">12%</option>
          <option value="18" selected>18%</option>
          <option value="28">28%</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">GST Type</label>
        <select id="pig-gst-type" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500">
          <option value="cgst-sgst">CGST + SGST (Intrastate)</option>
          <option value="igst">IGST (Interstate)</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Notes (optional)</label>
        <input id="pig-notes" type="text" placeholder="e.g. Subject to realisation" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
      </div>
    </div>
  </div>

  <button id="pig-print" class="px-6 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Print / Save as PDF</button>
</div>

<div class="mt-6 border border-slate-700 rounded-xl p-1 pig-no-print">
  <div id="pig-preview" class="bg-white text-slate-900 rounded-lg p-6 font-sans text-sm leading-relaxed"></div>
</div>

<div id="pig-print-area" style="display:none;" class="bg-white text-slate-900 font-sans text-sm leading-relaxed p-10"></div>

<script>
  interface Item { desc: string; qty: number; rate: number; }

  let items: Item[] = [{ desc: '', qty: 1, rate: 0 }];

  function fmtNum(x: number) { return x.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  function s(id: string): string { return (document.getElementById(id) as HTMLInputElement).value.trim(); }
  function fmt(dateStr: string) {
    if (!dateStr) return '';
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function renderItemRows() {
    const container = document.getElementById('pig-items')!;
    container.innerHTML = items.map((item, i) => `
      <div class="flex gap-2 items-end pig-item-row" data-index="${i}">
        <div class="flex-1 space-y-1">
          ${i === 0 ? '<label class="text-xs text-slate-400">Description</label>' : ''}
          <input type="text" class="pig-desc w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" placeholder="e.g. Web Design Services" value="${item.desc.replace(/"/g, '&quot;')}" />
        </div>
        <div class="w-20 space-y-1">
          ${i === 0 ? '<label class="text-xs text-slate-400">Qty</label>' : ''}
          <input type="number" class="pig-qty w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" value="${item.qty}" min="1" />
        </div>
        <div class="w-28 space-y-1">
          ${i === 0 ? '<label class="text-xs text-slate-400">Rate (₹)</label>' : ''}
          <input type="number" class="pig-rate w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" value="${item.rate}" min="0" />
        </div>
        <div class="w-28 space-y-1">
          ${i === 0 ? '<label class="text-xs text-slate-400">Amount (₹)</label>' : ''}
          <div class="px-3 py-2 bg-[var(--bg-surface)] border border-slate-700 rounded-lg text-slate-300 text-sm">${fmtNum(item.qty * item.rate)}</div>
        </div>
        ${items.length > 1 ? `<button class="pig-del mb-0.5 text-slate-500 hover:text-red-400 text-lg leading-none" data-index="${i}">×</button>` : '<div class="w-5"></div>'}
      </div>`).join('');

    container.querySelectorAll('.pig-desc').forEach((el, i) => el.addEventListener('input', (e) => { items[i].desc = (e.target as HTMLInputElement).value; render(); }));
    container.querySelectorAll('.pig-qty').forEach((el, i) => el.addEventListener('input', (e) => { items[i].qty = parseFloat((e.target as HTMLInputElement).value) || 0; render(); }));
    container.querySelectorAll('.pig-rate').forEach((el, i) => el.addEventListener('input', (e) => { items[i].rate = parseFloat((e.target as HTMLInputElement).value) || 0; render(); }));
    container.querySelectorAll('.pig-del').forEach(btn => btn.addEventListener('click', (e) => {
      const idx = parseInt((e.currentTarget as HTMLElement).dataset.index!);
      items.splice(idx, 1);
      render();
    }));
  }

  function buildHTML() {
    const subtotal = items.reduce((s, it) => s + it.qty * it.rate, 0);
    const gstRate = parseFloat((document.getElementById('pig-gst-rate') as HTMLSelectElement).value);
    const gstType = (document.getElementById('pig-gst-type') as HTMLSelectElement).value;
    const gstAmt = subtotal * gstRate / 100;
    const total = subtotal + gstAmt;
    const valid = s('pig-valid');
    const notes = s('pig-notes');
    const sellerGstin = s('pig-seller-gstin');
    const buyerGstin = s('pig-buyer-gstin');
    const contact = s('pig-seller-contact');

    const taxRows = gstRate === 0 ? '' : gstType === 'igst'
      ? `<tr><td colspan="4" style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">IGST @ ${gstRate}%</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">₹ ${fmtNum(gstAmt)}</td></tr>`
      : `<tr><td colspan="4" style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">CGST @ ${gstRate/2}%</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">₹ ${fmtNum(gstAmt/2)}</td></tr>
         <tr><td colspan="4" style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">SGST @ ${gstRate/2}%</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right;font-size:12px;">₹ ${fmtNum(gstAmt/2)}</td></tr>`;

    return `
      <div style="font-family:Arial,sans-serif;max-width:740px;margin:0 auto;border:1px solid #ccc;">
        <div style="background:#1a1a2e;color:#fff;padding:20px 24px;display:flex;justify-content:space-between;align-items:flex-start;">
          <div>
            <h2 style="margin:0 0 4px;font-size:18px;">${s('pig-seller-name') || 'Company Name'}</h2>
            <p style="margin:0;font-size:11px;opacity:.8;">${s('pig-seller-address') || ''}</p>
            ${sellerGstin ? `<p style="margin:4px 0 0;font-size:11px;opacity:.7;">GSTIN: ${sellerGstin}</p>` : ''}
            ${contact ? `<p style="margin:2px 0 0;font-size:11px;opacity:.7;">${contact}</p>` : ''}
          </div>
          <div style="text-align:right;">
            <p style="margin:0;font-size:20px;font-weight:bold;letter-spacing:1px;text-transform:uppercase;">Proforma Invoice</p>
            <p style="margin:4px 0 0;font-size:13px;opacity:.85;">No: <strong>${s('pig-inv-no') || '—'}</strong></p>
            <p style="margin:2px 0 0;font-size:12px;opacity:.7;">Date: ${fmt(s('pig-date')) || '—'}</p>
            ${valid ? `<p style="margin:2px 0 0;font-size:11px;opacity:.7;">Valid Until: ${fmt(valid)}</p>` : ''}
          </div>
        </div>

        <div style="padding:16px 24px;background:#f8f9fa;border-bottom:1px solid #ddd;">
          <p style="margin:0 0 4px;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.5px;">Bill To</p>
          <p style="margin:0;font-size:14px;font-weight:bold;">${s('pig-buyer-name') || '—'}</p>
          <p style="margin:2px 0 0;font-size:12px;color:#555;">${s('pig-buyer-address') || ''}</p>
          ${buyerGstin ? `<p style="margin:2px 0 0;font-size:11px;color:#777;">GSTIN: ${buyerGstin}</p>` : ''}
        </div>

        <div style="padding:16px 24px;">
          <table style="width:100%;border-collapse:collapse;font-size:12px;">
            <thead>
              <tr style="background:#1a1a2e;color:#fff;">
                <th style="padding:8px 10px;text-align:left;border:1px solid #555;width:5%;">#</th>
                <th style="padding:8px 10px;text-align:left;border:1px solid #555;">Description</th>
                <th style="padding:8px 10px;text-align:right;border:1px solid #555;width:10%;">Qty</th>
                <th style="padding:8px 10px;text-align:right;border:1px solid #555;width:15%;">Rate (₹)</th>
                <th style="padding:8px 10px;text-align:right;border:1px solid #555;width:18%;">Amount (₹)</th>
              </tr>
            </thead>
            <tbody>
              ${items.map((item, i) => `
                <tr style="${i%2===1?'background:#f9f9f9;':''}">
                  <td style="padding:8px 10px;border:1px solid #ddd;color:#888;">${i+1}</td>
                  <td style="padding:8px 10px;border:1px solid #ddd;">${item.desc || '—'}</td>
                  <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;">${item.qty}</td>
                  <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;">₹ ${fmtNum(item.rate)}</td>
                  <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;">₹ ${fmtNum(item.qty * item.rate)}</td>
                </tr>`).join('')}
              <tr style="background:#f5f5f5;">
                <td colspan="4" style="padding:8px 10px;border:1px solid #ddd;text-align:right;font-size:12px;font-weight:bold;">Subtotal</td>
                <td style="padding:8px 10px;border:1px solid #ddd;text-align:right;font-weight:bold;">₹ ${fmtNum(subtotal)}</td>
              </tr>
              ${taxRows}
              <tr style="background:#1a1a2e;color:#fff;font-size:14px;font-weight:bold;">
                <td colspan="4" style="padding:10px 12px;border:1px solid #333;text-align:right;">Total</td>
                <td style="padding:10px 12px;border:1px solid #333;text-align:right;">₹ ${fmtNum(total)}</td>
              </tr>
            </tbody>
          </table>
          ${notes ? `<p style="margin-top:16px;font-size:11px;color:#777;"><strong>Notes:</strong> ${notes}</p>` : ''}
          <p style="margin-top:24px;font-size:10px;color:#aaa;text-align:center;">This is a Proforma Invoice and not a tax invoice. Goods/services will be dispatched upon receipt of payment.</p>
        </div>
      </div>`;
  }

  function render() {
    renderItemRows();
    const html = buildHTML();
    document.getElementById('pig-preview')!.innerHTML = html;
    document.getElementById('pig-print-area')!.innerHTML = html;
  }

  const today = new Date().toISOString().split('T')[0];
  (document.getElementById('pig-date') as HTMLInputElement).value = today;

  document.getElementById('pig-add-item')?.addEventListener('click', () => { items.push({ desc: '', qty: 1, rate: 0 }); render(); });
  document.getElementById('pig-print')?.addEventListener('click', () => window.print());

  ['pig-seller-name','pig-seller-address','pig-seller-gstin','pig-seller-contact','pig-inv-no','pig-date','pig-valid','pig-buyer-name','pig-buyer-address','pig-buyer-gstin','pig-notes'].forEach(id => document.getElementById(id)?.addEventListener('input', render));
  ['pig-gst-rate','pig-gst-type'].forEach(id => document.getElementById(id)?.addEventListener('change', render));

  render();
</script>
