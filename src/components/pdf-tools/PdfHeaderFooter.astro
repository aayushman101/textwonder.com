---
---
<div class="space-y-5">
  <div id="phf-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="phf-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">📋</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Header and footer text will be added to every page</p>
  </div>

  <div id="phf-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl">📄</span>
      <div>
        <p id="phf-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="phf-info" class="text-slate-500 text-xs"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Header text (leave blank to skip)</label>
        <input type="text" id="phf-header" placeholder="e.g. My Company — Confidential" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Footer text (leave blank to skip)</label>
        <input type="text" id="phf-footer" placeholder="e.g. www.example.com — © 2026" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Alignment</label>
        <select id="phf-align" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500">
          <option value="center" selected>Centre</option>
          <option value="left">Left</option>
          <option value="right">Right</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Font size (pt)</label>
        <input type="number" id="phf-size" value="10" min="6" max="24" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
    </div>

    <div class="flex gap-2">
      <button id="phf-add" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Add Header &amp; Footer &amp; Download</button>
      <button id="phf-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear</button>
    </div>
  </div>

  <div id="phf-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('phf-drop');
  const fileInput = document.getElementById('phf-file');
  const panel = document.getElementById('phf-panel');
  const statusEl = document.getElementById('phf-status');
  let currentFile = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
      currentFile = { file, doc };
      document.getElementById('phf-name').textContent = file.name;
      document.getElementById('phf-info').textContent = `${doc.getPageCount()} pages · ${(file.size / 1024).toFixed(1)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      statusEl.classList.add('hidden');
    } catch (e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('phf-add').addEventListener('click', async () => {
    if (!currentFile) return;
    const headerText = document.getElementById('phf-header').value.trim();
    const footerText = document.getElementById('phf-footer').value.trim();
    if (!headerText && !footerText) { showStatus('Enter at least a header or footer text.', 'error'); return; }

    showStatus('Adding header/footer…', 'info');
    try {
      const { PDFDocument, StandardFonts, rgb } = window.PDFLib;
      const doc = await PDFDocument.load(await currentFile.file.arrayBuffer(), { ignoreEncryption: true });
      const font = await doc.embedFont(StandardFonts.Helvetica);
      const pages = doc.getPages();
      const fontSize = parseInt(document.getElementById('phf-size').value, 10) || 10;
      const align = document.getElementById('phf-align').value;
      const color = rgb(0.3, 0.3, 0.3);
      const margin = 20;

      pages.forEach(page => {
        const { width, height } = page.getSize();
        function getX(text) {
          const w = font.widthOfTextAtSize(text, fontSize);
          if (align === 'left') return margin;
          if (align === 'right') return width - margin - w;
          return (width - w) / 2;
        }
        if (headerText) {
          page.drawText(headerText, { x: getX(headerText), y: height - margin - fontSize, size: fontSize, font, color });
        }
        if (footerText) {
          page.drawText(footerText, { x: getX(footerText), y: margin, size: fontSize, font, color });
        }
      });

      const outBytes = await doc.save();
      const outName = currentFile.file.name.replace(/\.pdf$/i, '') + '-with-header-footer.pdf';
      downloadBytes(outBytes, outName);
      showStatus(`✅ Header/footer added to ${pages.length} page${pages.length !== 1 ? 's' : ''}.`, 'success');
    } catch (e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('phf-clear').addEventListener('click', () => {
    currentFile = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    statusEl.classList.add('hidden');
    fileInput.value = '';
  });

  function showStatus(msg, type) {
    statusEl.textContent = msg;
    statusEl.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    statusEl.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
