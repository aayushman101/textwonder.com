---
---
<div class="space-y-4">
  <textarea id="btc-input" rows="5" placeholder="Type text to convert to binary, or paste binary (01001000 01101001) to decode…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2 flex-wrap">
    <button id="btc-encode" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Text → Binary</button>
    <button id="btc-decode" class="px-5 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg text-sm font-medium transition-colors">Binary → Text</button>
    <button id="btc-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="btc-error" class="hidden text-red-400 text-sm px-1"></div>
  <div id="btc-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span id="btc-label" class="text-xs text-slate-500">Result</span>
      <button id="btc-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="btc-output" rows="5" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all break-all leading-relaxed"></textarea>
  </div>
</div>
<script>
  function textToBinary(s) {
    return Array.from(new TextEncoder().encode(s)).map(b => b.toString(2).padStart(8,'0')).join(' ');
  }
  function binaryToText(s) {
    const bytes = s.trim().split(/\s+/);
    if (bytes.some(b => !/^[01]{8}$/.test(b))) throw new Error('Invalid binary — each group must be 8 bits (0s and 1s only).');
    return new TextDecoder().decode(new Uint8Array(bytes.map(b => parseInt(b, 2))));
  }
  const input = document.getElementById('btc-input');
  const output = document.getElementById('btc-output');
  const wrap = document.getElementById('btc-output-wrap');
  const err = document.getElementById('btc-error');
  const label = document.getElementById('btc-label');
  const saved = localStorage.getItem('tw-binary-text-converter');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-binary-text-converter', input.value));
  document.getElementById('btc-encode').addEventListener('click', () => { output.value = textToBinary(input.value); label.textContent = 'Binary output'; wrap.classList.remove('hidden'); err.classList.add('hidden'); });
  document.getElementById('btc-decode').addEventListener('click', () => {
    try { output.value = binaryToText(input.value); label.textContent = 'Decoded text'; wrap.classList.remove('hidden'); err.classList.add('hidden'); }
    catch(e) { err.textContent = e.message; err.classList.remove('hidden'); wrap.classList.add('hidden'); }
  });
  document.getElementById('btc-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); err.classList.add('hidden'); localStorage.removeItem('tw-binary-text-converter'); });
  document.getElementById('btc-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
