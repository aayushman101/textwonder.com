---
---
<div class="space-y-5">
  <div class="flex flex-col sm:flex-row gap-4 items-start">
    <div class="flex flex-col items-center gap-2">
      <label class="text-xs text-slate-500">Pick color</label>
      <input id="cc-picker" type="color" value="#7c3aed" class="w-16 h-16 rounded-xl border-2 border-slate-700 cursor-pointer bg-transparent p-1" />
    </div>
    <div class="flex-1 space-y-3">
      <div class="space-y-1">
        <label class="text-xs text-slate-500">HEX</label>
        <div class="flex gap-2">
          <input id="cc-hex" type="text" placeholder="#7c3aed" class="flex-1 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 font-mono text-sm focus:outline-none focus:border-cyan-500" />
          <button class="cc-copy px-3 py-2 text-xs bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-400 rounded-lg hover:text-cyan-400 transition-colors" data-target="cc-hex">Copy</button>
        </div>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-500">RGB</label>
        <div class="flex gap-2">
          <input id="cc-rgb" type="text" placeholder="rgb(124, 58, 237)" class="flex-1 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 font-mono text-sm focus:outline-none focus:border-cyan-500" />
          <button class="cc-copy px-3 py-2 text-xs bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-400 rounded-lg hover:text-cyan-400 transition-colors" data-target="cc-rgb">Copy</button>
        </div>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-500">HSL</label>
        <div class="flex gap-2">
          <input id="cc-hsl" type="text" placeholder="hsl(262, 83%, 58%)" class="flex-1 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 font-mono text-sm focus:outline-none focus:border-cyan-500" />
          <button class="cc-copy px-3 py-2 text-xs bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-400 rounded-lg hover:text-cyan-400 transition-colors" data-target="cc-hsl">Copy</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Preview -->
  <div id="cc-preview" class="rounded-xl h-16 border border-slate-800 transition-colors" style="background:#7c3aed"></div>

  <!-- CSS vars -->
  <div class="grid grid-cols-3 gap-2 text-xs text-center">
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-lg p-2">
      <p class="text-slate-500 mb-1">Tailwind approx.</p>
      <p id="cc-tw" class="text-slate-200 font-mono"></p>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-lg p-2">
      <p class="text-slate-500 mb-1">Brightness</p>
      <p id="cc-lum" class="text-slate-200 font-mono"></p>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-lg p-2">
      <p class="text-slate-500 mb-1">Contrast text</p>
      <p id="cc-contrast" class="text-slate-200 font-mono"></p>
    </div>
  </div>

  <div id="cc-status" class="hidden text-sm py-1 text-red-400"></div>
</div>

<script is:inline>
(function() {
  const picker = document.getElementById('cc-picker');
  const hexEl = document.getElementById('cc-hex');
  const rgbEl = document.getElementById('cc-rgb');
  const hslEl = document.getElementById('cc-hsl');
  const preview = document.getElementById('cc-preview');

  function hexToRgb(hex) {
    hex = hex.replace('#','');
    if (hex.length === 3) hex = hex.split('').map(c=>c+c).join('');
    const n = parseInt(hex, 16);
    return { r: (n>>16)&255, g: (n>>8)&255, b: n&255 };
  }
  function rgbToHsl(r,g,b) {
    r/=255; g/=255; b/=255;
    const max=Math.max(r,g,b), min=Math.min(r,g,b);
    let h,s,l=(max+min)/2;
    if(max===min){h=s=0;}
    else{const d=max-min;s=l>0.5?d/(2-max-min):d/(max+min);switch(max){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;default:h=(r-g)/d+4;}h/=6;}
    return {h:Math.round(h*360),s:Math.round(s*100),l:Math.round(l*100)};
  }
  function rgbFromString(str) {
    const m = str.match(/rgb\(\s*(\d+),\s*(\d+),\s*(\d+)\s*\)/i);
    return m ? {r:+m[1],g:+m[2],b:+m[3]} : null;
  }
  function hslFromString(str) {
    const m = str.match(/hsl\(\s*([\d.]+),\s*([\d.]+)%?,\s*([\d.]+)%?\s*\)/i);
    return m ? {h:+m[1],s:+m[2],l:+m[3]} : null;
  }
  function hslToRgb(h,s,l) {
    s/=100; l/=100;
    const k=n=>(n+h/30)%12;
    const a=s*Math.min(l,1-l);
    const f=n=>l-a*Math.max(-1,Math.min(k(n)-3,Math.min(9-k(n),1)));
    return {r:Math.round(f(0)*255),g:Math.round(f(8)*255),b:Math.round(f(4)*255)};
  }
  function rgbToHex(r,g,b) {
    return '#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
  }
  function luminance(r,g,b) {
    return (0.299*r+0.587*g+0.114*b)/255;
  }

  function update(r,g,b) {
    const hex = rgbToHex(r,g,b);
    const {h,s,l} = rgbToHsl(r,g,b);
    hexEl.value = hex;
    rgbEl.value = `rgb(${r}, ${g}, ${b})`;
    hslEl.value = `hsl(${h}, ${s}%, ${l}%)`;
    picker.value = hex;
    preview.style.background = hex;
    const lum = luminance(r,g,b);
    document.getElementById('cc-lum').textContent = (lum*100).toFixed(0)+'%';
    document.getElementById('cc-contrast').textContent = lum > 0.5 ? '#000000' : '#ffffff';
    document.getElementById('cc-tw').textContent = l > 80?'50':l>65?'100':l>55?'200':l>45?'300':l>35?'400':l>25?'500':l>18?'600':l>12?'700':l>7?'800':'900';
    document.getElementById('cc-status').classList.add('hidden');
  }

  picker.addEventListener('input', () => {
    const {r,g,b} = hexToRgb(picker.value);
    update(r,g,b);
  });

  hexEl.addEventListener('change', () => {
    const v = hexEl.value.trim();
    const hex = v.startsWith('#') ? v : '#'+v;
    if (!/^#[0-9a-f]{3}(?:[0-9a-f]{3})?$/i.test(hex)) { showErr('Invalid HEX'); return; }
    const {r,g,b} = hexToRgb(hex);
    update(r,g,b);
  });

  rgbEl.addEventListener('change', () => {
    const rgb = rgbFromString(rgbEl.value);
    if (!rgb) { showErr('Use format: rgb(255, 0, 0)'); return; }
    update(rgb.r, rgb.g, rgb.b);
  });

  hslEl.addEventListener('change', () => {
    const hsl = hslFromString(hslEl.value);
    if (!hsl) { showErr('Use format: hsl(262, 83%, 58%)'); return; }
    const {r,g,b} = hslToRgb(hsl.h, hsl.s, hsl.l);
    update(r,g,b);
  });

  document.querySelectorAll('.cc-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = document.getElementById(btn.dataset.target);
      if (el) navigator.clipboard.writeText(el.value);
    });
  });

  function showErr(msg) {
    const s = document.getElementById('cc-status');
    s.textContent = '❌ ' + msg;
    s.classList.remove('hidden');
  }

  // Init
  const {r,g,b} = hexToRgb('#7c3aed');
  update(r,g,b);
})();
</script>
