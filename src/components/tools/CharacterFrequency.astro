---
---

<div class="space-y-4">
  <div class="flex items-center gap-3 flex-wrap">
    <div class="flex gap-1">
      <button class="cfa-mode px-3 py-1 rounded-lg text-sm font-medium transition-colors bg-violet-700 text-white" data-mode="all">All Chars</button>
      <button class="cfa-mode px-3 py-1 rounded-lg text-sm font-medium transition-colors bg-[var(--bg-surface-hover)] text-slate-400" data-mode="letters">Letters</button>
      <button class="cfa-mode px-3 py-1 rounded-lg text-sm font-medium transition-colors bg-[var(--bg-surface-hover)] text-slate-400" data-mode="letters-digits">Letters + Digits</button>
    </div>
    <label class="flex items-center gap-2 cursor-pointer">
      <input id="cfa-case" type="checkbox" class="w-4 h-4 accent-violet-600" />
      <span class="text-slate-300 text-sm">Case-insensitive</span>
    </label>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <button id="cfa-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear</button>
    </div>
    <textarea
      id="cfa-input"
      rows="7"
      placeholder="Paste your text here to analyse character frequency..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div id="cfa-results-wrap" class="hidden">
    <div class="flex items-center justify-between mb-2">
      <p class="text-slate-400 text-xs font-medium">Character frequency</p>
      <span id="cfa-info" class="text-xs text-slate-500"></span>
    </div>
    <div class="space-y-1 max-h-72 overflow-y-auto" id="cfa-list"></div>
  </div>

  <div id="cfa-hint" class="text-center py-6 text-slate-500 text-sm">Type or paste text above to see character frequency.</div>
</div>

<script>
  const input = document.getElementById('cfa-input') as HTMLTextAreaElement;
  const elCase = document.getElementById('cfa-case') as HTMLInputElement;
  const elResultsWrap = document.getElementById('cfa-results-wrap')!;
  const elList = document.getElementById('cfa-list')!;
  const elInfo = document.getElementById('cfa-info')!;
  const elHint = document.getElementById('cfa-hint')!;
  const STORAGE_KEY = 'tw-character-frequency';

  let currentMode = 'all';
  const modeBtns = document.querySelectorAll<HTMLElement>('.cfa-mode');
  const ACTIVE = 'cfa-mode px-3 py-1 rounded-lg text-sm font-medium transition-colors bg-violet-700 text-white';
  const INACTIVE = 'cfa-mode px-3 py-1 rounded-lg text-sm font-medium transition-colors bg-[var(--bg-surface-hover)] text-slate-400';

  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentMode = btn.dataset.mode!;
      modeBtns.forEach(b => { b.className = b === btn ? ACTIVE : INACTIVE; });
      update();
    });
  });

  function update() {
    const rawText = elCase.checked ? input.value.toLowerCase() : input.value;
    const caseInsensitive = elCase.checked;
    elHint.classList.add('hidden');

    if (!rawText) {
      elResultsWrap.classList.add('hidden');
      elHint.classList.remove('hidden');
      return;
    }

    let chars = rawText.split('');
    if (currentMode === 'letters') {
      chars = chars.filter(c => /[a-zA-Z]/.test(c));
    } else if (currentMode === 'letters-digits') {
      chars = chars.filter(c => /[a-zA-Z0-9]/.test(c));
    }

    if (chars.length === 0) {
      elResultsWrap.classList.add('hidden');
      elHint.classList.remove('hidden');
      return;
    }

    const freq: Record<string,number> = {};
    for (const c of chars) freq[c] = (freq[c] || 0) + 1;
    const sorted = Object.entries(freq).sort((a,b) => b[1] - a[1]);
    const total = chars.length;
    const maxCount = sorted[0]?.[1] || 1;

    elInfo.textContent = `${sorted.length} unique chars · ${total.toLocaleString()} total`;

    elList.innerHTML = sorted.map(([char, count]) => {
      const pct = (count / total * 100).toFixed(2);
      const barW = Math.round(count / maxCount * 100);
      const label = char === ' ' ? '⎵ space' : char === '\n' ? '↵ newline' : char === '\t' ? '→ tab' : `"${char.replace(/</g,'&lt;')}"`;
      return `<div class="flex items-center gap-2 text-xs">
        <span class="text-slate-300 font-mono w-16 shrink-0">${label}</span>
        <div class="flex-1 bg-[var(--bg-surface)] rounded-full h-2 overflow-hidden">
          <div class="h-2 bg-violet-600 rounded-full" style="width:${barW}%"></div>
        </div>
        <span class="text-violet-400 font-bold w-10 text-right" style="font-family:'Space Grotesk',sans-serif;">${count}</span>
        <span class="text-slate-500 w-12 text-right">${pct}%</span>
      </div>`;
    }).join('');

    elResultsWrap.classList.remove('hidden');
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  input.addEventListener('input', update);
  elCase.addEventListener('change', update);
  document.getElementById('cfa-clear')!.addEventListener('click', () => {
    input.value = '';
    update();
    localStorage.removeItem(STORAGE_KEY);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; update(); }
</script>
