---
---
<div class="space-y-4">
  <div class="space-y-1">
    <label class="text-xs text-slate-500">Text to speak</label>
    <textarea id="tts-input" rows="8" placeholder="Type or paste your text here and click Speak..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 text-sm resize-y focus:outline-none focus:border-cyan-500 leading-relaxed"></textarea>
  </div>

  <div class="flex flex-wrap gap-3 items-end">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Voice</label>
      <select id="tts-voice" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-200 text-sm focus:outline-none focus:border-cyan-500 min-w-[160px]">
        <option value="">Default</option>
      </select>
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Rate</label>
      <select id="tts-rate" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-200 text-sm focus:outline-none focus:border-cyan-500">
        <option value="0.5">0.5× (Slow)</option>
        <option value="0.75">0.75×</option>
        <option value="1" selected>1× (Normal)</option>
        <option value="1.25">1.25×</option>
        <option value="1.5">1.5×</option>
        <option value="2">2× (Fast)</option>
      </select>
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Pitch</label>
      <select id="tts-pitch" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-200 text-sm focus:outline-none focus:border-cyan-500">
        <option value="0.5">Low</option>
        <option value="1" selected>Normal</option>
        <option value="1.5">High</option>
        <option value="2">Very High</option>
      </select>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <button id="tts-speak" class="px-5 py-2.5 bg-cyan-600 hover:bg-cyan-500 text-white rounded-lg text-sm font-medium transition-colors">▶ Speak</button>
    <button id="tts-pause" class="px-5 py-2.5 bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-300 rounded-lg text-sm transition-colors hidden">⏸ Pause</button>
    <button id="tts-resume" class="px-5 py-2.5 bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-300 rounded-lg text-sm transition-colors hidden">▶ Resume</button>
    <button id="tts-stop" class="px-5 py-2.5 bg-[var(--bg-surface-hover)] border border-slate-700 text-slate-400 rounded-lg text-sm transition-colors">■ Stop</button>
  </div>

  <div id="tts-status" class="text-sm py-1 text-slate-400"></div>

  <div id="tts-unsupported" class="hidden bg-yellow-900/30 border border-yellow-700 rounded-xl px-5 py-4">
    <p class="text-yellow-300 text-sm">Your browser does not support the Web Speech API. Try Chrome, Edge, or Safari.</p>
  </div>
</div>

<script is:inline>
(function () {
  const synth = window.speechSynthesis;
  if (!synth) {
    document.getElementById('tts-unsupported').classList.remove('hidden');
    document.getElementById('tts-speak').disabled = true;
    return;
  }

  const voiceSelect = document.getElementById('tts-voice');
  const status = document.getElementById('tts-status');

  function loadVoices() {
    const voices = synth.getVoices();
    voiceSelect.innerHTML = '<option value="">Default</option>';
    voices.forEach((v, i) => {
      const opt = document.createElement('option');
      opt.value = i;
      opt.textContent = `${v.name} (${v.lang})`;
      if (v.default) opt.selected = true;
      voiceSelect.appendChild(opt);
    });
  }

  loadVoices();
  if (speechSynthesis.onvoiceschanged !== undefined) {
    speechSynthesis.onvoiceschanged = loadVoices;
  }

  let utterance = null;

  function setStatus(msg) { status.textContent = msg; }

  function showPause() {
    document.getElementById('tts-speak').classList.add('hidden');
    document.getElementById('tts-pause').classList.remove('hidden');
    document.getElementById('tts-resume').classList.add('hidden');
  }
  function showResume() {
    document.getElementById('tts-pause').classList.add('hidden');
    document.getElementById('tts-resume').classList.remove('hidden');
  }
  function showSpeak() {
    document.getElementById('tts-speak').classList.remove('hidden');
    document.getElementById('tts-pause').classList.add('hidden');
    document.getElementById('tts-resume').classList.add('hidden');
  }

  document.getElementById('tts-speak').addEventListener('click', () => {
    const text = document.getElementById('tts-input').value.trim();
    if (!text) { setStatus('Enter some text first.'); return; }
    synth.cancel();
    utterance = new SpeechSynthesisUtterance(text);
    const voiceIdx = voiceSelect.value;
    if (voiceIdx !== '') utterance.voice = synth.getVoices()[parseInt(voiceIdx)];
    utterance.rate = parseFloat(document.getElementById('tts-rate').value);
    utterance.pitch = parseFloat(document.getElementById('tts-pitch').value);
    utterance.onstart = () => { setStatus('Speaking…'); showPause(); };
    utterance.onend = () => { setStatus('Done.'); showSpeak(); };
    utterance.onerror = (e) => { setStatus('Error: ' + e.error); showSpeak(); };
    synth.speak(utterance);
  });

  document.getElementById('tts-pause').addEventListener('click', () => {
    synth.pause();
    setStatus('Paused.');
    showResume();
  });

  document.getElementById('tts-resume').addEventListener('click', () => {
    synth.resume();
    setStatus('Speaking…');
    showPause();
  });

  document.getElementById('tts-stop').addEventListener('click', () => {
    synth.cancel();
    setStatus('Stopped.');
    showSpeak();
  });
})();
</script>
