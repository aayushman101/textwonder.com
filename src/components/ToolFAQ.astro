---
const { faqs } = Astro.props;
---

<section class="mt-10">
  <h2 class="text-xl font-semibold text-white mb-4">Frequently Asked Questions</h2>
  <div class="space-y-2">
    {faqs.map((faq, i) => (
      <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
          <span class="text-white font-medium text-sm">{faq.q}</span>
          <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4">
          <p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p>
        </div>
      </details>
    ))}
  </div>
</section>
