---
---
<div class="space-y-4">
  <textarea id="ued-input" rows="6" placeholder="Paste a URL or query string to encode/decode…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2 flex-wrap">
    <button id="ued-encode" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Encode URL</button>
    <button id="ued-decode" class="px-5 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg text-sm font-medium transition-colors">Decode URL</button>
    <button id="ued-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="ued-error" class="hidden text-red-400 text-sm px-1"></div>
  <div id="ued-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span id="ued-label" class="text-xs text-slate-500">Result</span>
      <button id="ued-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="ued-output" rows="6" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all break-all"></textarea>
  </div>
</div>
<script>
  const input = document.getElementById('ued-input');
  const output = document.getElementById('ued-output');
  const wrap = document.getElementById('ued-output-wrap');
  const err = document.getElementById('ued-error');
  const label = document.getElementById('ued-label');
  const saved = localStorage.getItem('tw-url-encoder-decoder');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-url-encoder-decoder', input.value));
  document.getElementById('ued-encode').addEventListener('click', () => {
    try { output.value = encodeURIComponent(input.value); label.textContent = 'Encoded URL'; wrap.classList.remove('hidden'); err.classList.add('hidden'); } catch(e) { err.textContent = e.message; err.classList.remove('hidden'); }
  });
  document.getElementById('ued-decode').addEventListener('click', () => {
    try { output.value = decodeURIComponent(input.value.trim()); label.textContent = 'Decoded URL'; wrap.classList.remove('hidden'); err.classList.add('hidden'); } catch(e) { err.textContent = 'Invalid URL-encoded input.'; err.classList.remove('hidden'); wrap.classList.add('hidden'); }
  });
  document.getElementById('ued-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); err.classList.add('hidden'); localStorage.removeItem('tw-url-encoder-decoder'); });
  document.getElementById('ued-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
