---
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <button id="emo-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear</button>
    </div>
    <textarea
      id="emo-input"
      rows="8"
      placeholder="Paste text with emojis here to count and list them... 😊 🎉 🚀"
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="grid grid-cols-3 gap-3">
    <div class="bg-[var(--bg-base)] border border-violet-600/40 ring-1 ring-violet-600/30 rounded-xl p-4 text-center">
      <div id="emo-total" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">Total Emojis</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="emo-unique" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0</div>
      <div class="text-slate-400 text-xs mt-1">Unique Emojis</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div id="emo-pct" class="text-2xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">0%</div>
      <div class="text-slate-400 text-xs mt-1">% of Total Chars</div>
    </div>
  </div>

  <div id="emo-list-wrap" class="hidden">
    <p class="text-slate-400 text-xs font-medium mb-2">Emoji frequency (sorted by count):</p>
    <div class="bg-[var(--bg-base)] border border-slate-700 rounded-xl overflow-hidden">
      <div class="grid text-xs font-medium text-slate-400 border-b border-slate-800 px-4 py-2" style="grid-template-columns:auto 1fr auto">
        <span class="pr-3">Emoji</span><span>Count</span><span class="text-right">%</span>
      </div>
      <div id="emo-list" class="max-h-64 overflow-y-auto divide-y divide-slate-800/50"></div>
    </div>
  </div>

  <div id="emo-empty" class="text-center py-6 text-slate-500 text-sm hidden">No emojis detected in the text.</div>
</div>

<script>
  const input = document.getElementById('emo-input') as HTMLTextAreaElement;
  const elTotal = document.getElementById('emo-total')!;
  const elUnique = document.getElementById('emo-unique')!;
  const elPct = document.getElementById('emo-pct')!;
  const elListWrap = document.getElementById('emo-list-wrap')!;
  const elList = document.getElementById('emo-list')!;
  const elEmpty = document.getElementById('emo-empty')!;
  const STORAGE_KEY = 'tw-emoji-counter';

  const EMOJI_REGEX = /\p{Emoji_Presentation}|\p{Extended_Pictographic}(?:️)?(?:‍(?:\p{Emoji_Presentation}|\p{Extended_Pictographic}))*|\p{Regional_Indicator}{2}/gu;

  function update() {
    const text = input.value;
    const emojis = text.match(EMOJI_REGEX) || [];
    const total = emojis.length;
    const charTotal = [...text].length;

    elTotal.textContent = total.toString();

    if (total === 0) {
      elUnique.textContent = '0';
      elPct.textContent = '0%';
      elListWrap.classList.add('hidden');
      if (text.length > 0) elEmpty.classList.remove('hidden');
      else elEmpty.classList.add('hidden');
      return;
    }

    const freq: Record<string,number> = {};
    for (const e of emojis) freq[e] = (freq[e] || 0) + 1;
    const sorted = Object.entries(freq).sort((a,b) => b[1] - a[1]);
    const uniqueCount = sorted.length;
    const pct = charTotal > 0 ? (total / charTotal * 100).toFixed(1) : '0';

    elUnique.textContent = uniqueCount.toString();
    elPct.textContent = pct + '%';

    elList.innerHTML = sorted.map(([emoji, count]) => {
      const barW = Math.round(count / sorted[0][1] * 100);
      const epct = (count / total * 100).toFixed(1);
      return `<div class="grid items-center px-4 py-2 hover:bg-[var(--bg-surface-hover)]" style="grid-template-columns:auto 1fr auto">
        <span class="text-2xl pr-3">${emoji}</span>
        <div>
          <div class="w-full bg-[var(--bg-surface)] rounded-full h-1.5 max-w-32">
            <div class="h-1.5 bg-violet-600/60 rounded-full" style="width:${barW}%"></div>
          </div>
          <span class="text-slate-400 text-xs">${count} time${count !== 1 ? 's' : ''}</span>
        </div>
        <span class="text-slate-500 text-xs text-right">${epct}%</span>
      </div>`;
    }).join('');

    elListWrap.classList.remove('hidden');
    elEmpty.classList.add('hidden');
    localStorage.setItem(STORAGE_KEY, text);
  }

  input.addEventListener('input', update);
  document.getElementById('emo-clear')!.addEventListener('click', () => {
    input.value = '';
    update();
    localStorage.removeItem(STORAGE_KEY);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; update(); }
</script>
