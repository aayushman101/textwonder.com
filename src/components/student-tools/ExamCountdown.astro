---
---
<div>
  <div class="flex gap-2 mb-4">
    <input type="text" id="ec2-name" placeholder="Exam name (e.g. Maths Final)" class="flex-1 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" />
    <input type="datetime-local" id="ec2-datetime" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" />
    <button onclick="ec2Add()" class="px-4 py-2 rounded-lg text-white text-sm font-medium whitespace-nowrap" style="background:#3b82f6">Add Exam</button>
  </div>

  <div id="ec2-list" class="space-y-3"></div>
  <p id="ec2-empty" class="text-slate-500 text-sm text-center py-6">No exams added yet. Add your first exam above.</p>
</div>

<script is:inline>
(function(){
  let exams=[];
  try{exams=JSON.parse(localStorage.getItem('ec2-exams')||'[]');}catch(e){exams=[];}
  let timerHandle=null;

  window.ec2Add=function(){
    const name=document.getElementById('ec2-name').value.trim();
    const dt=document.getElementById('ec2-datetime').value;
    if(!name||!dt)return;
    exams.push({id:Date.now(),name,dt});
    localStorage.setItem('ec2-exams',JSON.stringify(exams));
    document.getElementById('ec2-name').value='';
    document.getElementById('ec2-datetime').value='';
    render();
  };

  window.ec2Remove=function(id){
    exams=exams.filter(e=>e.id!==id);
    localStorage.setItem('ec2-exams',JSON.stringify(exams));
    render();
  };

  function pad(n){return String(n).padStart(2,'0');}

  function render(){
    const list=document.getElementById('ec2-list');
    const empty=document.getElementById('ec2-empty');
    if(!exams.length){list.innerHTML='';empty.classList.remove('hidden');return;}
    empty.classList.add('hidden');
    list.innerHTML=exams.map(e=>{
      const target=new Date(e.dt);
      const now=new Date();
      const diff=target-now;
      let timeStr='';
      if(diff<=0){timeStr='<span style="color:#22c55e">Exam time!</span>';}
      else{
        const d=Math.floor(diff/86400000);
        const h=Math.floor((diff%86400000)/3600000);
        const m=Math.floor((diff%3600000)/60000);
        const s=Math.floor((diff%60000)/1000);
        timeStr=`<span class="text-white">${d}d ${pad(h)}h ${pad(m)}m ${pad(s)}s</span>`;
      }
      return `<div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 flex items-center justify-between gap-4">
        <div>
          <div class="text-white font-semibold">${e.name}</div>
          <div class="text-slate-500 text-xs mt-0.5">${new Date(e.dt).toLocaleString()}</div>
        </div>
        <div class="text-right">
          <div class="text-sm font-mono ec2-countdown" data-id="${e.id}">${timeStr}</div>
          <button onclick="ec2Remove(${e.id})" class="text-xs text-slate-600 hover:text-red-400 mt-1">Remove</button>
        </div>
      </div>`;
    }).join('');
  }

  function tick(){
    document.querySelectorAll('.ec2-countdown').forEach(el=>{
      const id=parseInt(el.dataset.id);
      const exam=exams.find(e=>e.id===id);
      if(!exam)return;
      const diff=new Date(exam.dt)-new Date();
      if(diff<=0){el.innerHTML='<span style="color:#22c55e">Exam time!</span>';return;}
      const d=Math.floor(diff/86400000);
      const h=Math.floor((diff%86400000)/3600000);
      const m=Math.floor((diff%3600000)/60000);
      const s=Math.floor((diff%60000)/1000);
      el.innerHTML=`<span class="text-white">${d}d ${String(h).padStart(2,'0')}h ${String(m).padStart(2,'0')}m ${String(s).padStart(2,'0')}s</span>`;
    });
  }

  render();
  setInterval(tick,1000);
})();
</script>
