---
---

<div class="space-y-4">
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Your Script / Text</label>
      <div class="flex items-center gap-3">
        <span id="stc-word-count" class="text-xs text-slate-500">0 words</span>
        <button id="stc-clear" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear</button>
      </div>
    </div>
    <textarea
      id="stc-input"
      rows="8"
      placeholder="Paste your speech script, lecture notes, or any text to estimate speaking time..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="grid grid-cols-3 gap-3">
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div class="text-xs text-slate-500 mb-1 font-medium">Slow / Deliberate</div>
      <div class="text-xs text-slate-600 mb-2">100 WPM</div>
      <div id="stc-slow" class="text-xl font-bold text-slate-300" style="font-family:'Space Grotesk',sans-serif;">—</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-violet-600/40 rounded-xl p-4 text-center ring-1 ring-violet-600/30">
      <div class="text-xs text-violet-400 mb-1 font-medium">Conversational</div>
      <div class="text-xs text-slate-600 mb-2">130 WPM</div>
      <div id="stc-avg" class="text-xl font-bold text-violet-400" style="font-family:'Space Grotesk',sans-serif;">—</div>
    </div>
    <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl p-4 text-center">
      <div class="text-xs text-slate-500 mb-1 font-medium">Fast / Energetic</div>
      <div class="text-xs text-slate-600 mb-2">180 WPM</div>
      <div id="stc-fast" class="text-xl font-bold text-slate-300" style="font-family:'Space Grotesk',sans-serif;">—</div>
    </div>
  </div>

  <div class="bg-[var(--bg-base)] border border-slate-800 rounded-xl px-4 py-3">
    <p class="text-slate-500 text-xs leading-relaxed">
      Tip: Add 10–20% extra time for pauses, emphasis, and audience interaction not captured in the word count.
      Most effective public speakers aim for 120–150 WPM for clarity.
    </p>
  </div>
</div>

<script>
  const input = document.getElementById('stc-input') as HTMLTextAreaElement;
  const elWordCount = document.getElementById('stc-word-count')!;
  const elSlow = document.getElementById('stc-slow')!;
  const elAvg = document.getElementById('stc-avg')!;
  const elFast = document.getElementById('stc-fast')!;
  const STORAGE_KEY = 'tw-speaking-time-calculator';

  function formatTime(seconds: number): string {
    if (seconds < 60) return `${Math.ceil(seconds)}s`;
    const mins = Math.floor(seconds / 60);
    const secs = Math.round(seconds % 60);
    if (secs === 0) return `${mins} min`;
    return `${mins}m ${secs}s`;
  }

  function update() {
    const text = input.value.trim();
    const words = text ? text.split(/\s+/).length : 0;
    elWordCount.textContent = `${words.toLocaleString()} word${words !== 1 ? 's' : ''}`;

    if (words === 0) {
      elSlow.textContent = '—';
      elAvg.textContent = '—';
      elFast.textContent = '—';
      return;
    }

    elSlow.textContent = formatTime(words / 100 * 60);
    elAvg.textContent = formatTime(words / 130 * 60);
    elFast.textContent = formatTime(words / 180 * 60);

    localStorage.setItem(STORAGE_KEY, input.value);
  }

  input.addEventListener('input', update);
  document.getElementById('stc-clear')!.addEventListener('click', () => {
    input.value = '';
    update();
    localStorage.removeItem(STORAGE_KEY);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; update(); }
</script>
