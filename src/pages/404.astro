---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { TOOLS } from '../data/tools.js';

const popularTools = TOOLS.filter(t => t.searchVolume === 'very-high' || t.searchVolume === 'high').slice(0, 6);
---

<BaseLayout
  title="Page Not Found — TextWonder"
  description="The page you're looking for doesn't exist. Browse our free text tools instead."
  canonical="/404"
>
  <Header />

  <main class="min-h-[70vh] flex flex-col items-center justify-center px-4 py-20 text-center">
    <!-- Error code -->
    <p class="text-8xl font-bold text-violet-500 mb-2" style="font-family: 'Space Grotesk', sans-serif;">404</p>
    <h1 class="text-3xl font-bold text-white mb-3" style="font-family: 'Space Grotesk', sans-serif;">Page not found</h1>
    <p class="text-slate-400 max-w-md mb-10">
      The page you're looking for doesn't exist or may have been moved. Try one of our tools below.
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 justify-center mb-16">
      <a href="/" class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white rounded-lg font-medium transition-colors text-sm">
        Go to Homepage
      </a>
      <a href="/tools" class="px-5 py-2.5 bg-[var(--bg-surface)] hover:bg-slate-700 text-white rounded-lg font-medium transition-colors text-sm border border-slate-700">
        Browse All Tools
      </a>
    </div>

    <!-- Popular tools -->
    <div class="w-full max-w-3xl">
      <p class="text-slate-500 text-sm uppercase tracking-widest mb-5">Popular Tools</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {popularTools.map(tool => (
          <a
            href={`/tools/${tool.slug}`}
            class="bg-[var(--bg-surface)]/60 hover:bg-[var(--bg-surface)] border border-slate-700/50 hover:border-violet-500/40 rounded-xl px-4 py-3 text-left transition-all group"
          >
            <p class="text-white text-sm font-medium group-hover:text-violet-400 transition-colors">{tool.name}</p>
            <p class="text-slate-500 text-xs mt-0.5 line-clamp-1">{tool.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
