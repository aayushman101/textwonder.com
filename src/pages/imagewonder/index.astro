---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageHeader from '../../components/ImageHeader.astro';
import Footer from '../../components/Footer.astro';
import { IMAGE_TOOLS } from '../../data/imagetools.js';
import { TOOLS } from '../../data/tools.js';
import ToolSearchBar from '../../components/ToolSearchBar.astro';
import { DEV_TOOLS } from '../../data/devtools.js';
---

<BaseLayout
  title="Free Image Tools Online — Resize, Compress, Convert & More | ImageWonder"
  description="ImageWonder offers 10 free browser-based image tools. Resize, compress, convert, crop, watermark, pick colors, view metadata — all in your browser. No upload, no signup."
  canonical="/imagewonder"
>
  <ImageHeader />

  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 pt-12 pb-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-rose-950/50 border border-rose-800/40 text-rose-400 text-xs font-medium mb-5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        100% browser-based — your images never leave your device
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-3" style="font-family: 'Space Grotesk', sans-serif;">
        Image tools for your<br class="hidden sm:block" /> everyday workflow
      </h1>
      <p class="text-slate-400 text-lg max-w-xl mx-auto mb-5">
        Free, instant image utilities. Resize, compress, convert formats, crop, add watermarks, pick colors — all in your browser. No uploads, no signups.
      </p>
      <div class="inline-flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <span><strong class="text-rose-400 font-semibold">{IMAGE_TOOLS.length}</strong> image tools</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-rose-400 font-semibold">100%</strong> browser-based</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-rose-400 font-semibold">0</strong> signups required</span>
      </div>
    </section>

    <!-- Tools Grid -->
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <ToolSearchBar accentColor="#f43f5e" placeholder="Search image tools…" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {IMAGE_TOOLS.map(tool => (
          <a
            href={`/imagewonder/${tool.slug}`}
            data-tool-card
            data-name={tool.name}
            data-tagline={tool.tagline}
            class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-5 hover:border-rose-500/50 hover:bg-[var(--bg-surface-hover)] transition-all"
          >
            <div class="flex items-start gap-4 mb-3">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 font-bold text-white text-sm" style={`background:${tool.iconBg}`}>
                {tool.icon}
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-white font-semibold text-base group-hover:text-rose-400 transition-colors">{tool.name}</h2>
                <p class="text-slate-400 text-sm leading-snug mt-0.5">{tool.tagline}</p>
              </div>
            </div>
            <div class="flex items-center text-xs text-rose-400/60 group-hover:text-rose-400 transition-colors font-medium">
              Open tool
              <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Trust section -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-8 text-center">
        <div class="text-3xl mb-3">🛡️</div>
        <h2 class="text-xl font-bold text-white mb-2" style="font-family:'Space Grotesk',sans-serif;">Your images stay in your browser</h2>
        <p class="text-slate-400 text-sm leading-relaxed max-w-lg mx-auto">
          All image processing uses the HTML5 Canvas API running locally in your browser.
          No image, pixel, or metadata is ever transmitted to any server.
        </p>
      </div>
    </section>

    <!-- Cross-promo -->
    <section class="max-w-4xl mx-auto px-4 pb-16 grid sm:grid-cols-2 gap-4">
      <div class="flex items-center justify-between bg-[var(--bg-surface)] border border-violet-800/30 rounded-2xl p-5">
        <div>
          <p class="text-sm text-slate-400">Need text tools?</p>
          <p class="text-white font-semibold" style="font-family:'Space Grotesk',sans-serif;">Text<span class="text-violet-400">Wonder</span> — {TOOLS.length} utilities</p>
        </div>
        <a href="/" class="shrink-0 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Visit →</a>
      </div>
      <div class="flex items-center justify-between bg-[var(--bg-surface)] border border-cyan-800/30 rounded-2xl p-5">
        <div>
          <p class="text-sm text-slate-400">Need dev tools?</p>
          <p class="text-white font-semibold" style="font-family:'Space Grotesk',sans-serif;">Dev<span class="text-cyan-400">Wonder</span> — {DEV_TOOLS.length} utilities</p>
        </div>
        <a href="/devwonder" class="shrink-0 px-4 py-2 bg-cyan-700 hover:bg-cyan-600 text-white rounded-lg text-sm font-medium transition-colors">Visit →</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
