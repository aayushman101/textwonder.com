---
---
<div class="space-y-4">
  <textarea id="kbc-input" rows="7" placeholder="Hello World Example&#10;myVariableName&#10;snake_case_input" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2">
    <button id="kbc-convert" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Convert to kebab-case</button>
    <button id="kbc-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="kbc-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span class="text-xs text-slate-500">kebab-case result</span>
      <button id="kbc-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="kbc-output" rows="7" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  function toKebab(str) {
    return str
      .replace(/([a-z])([A-Z])/g, '$1-$2')
      .replace(/([A-Z]+)([A-Z][a-z])/g, '$1-$2')
      .replace(/[\s_]+/g, '-')
      .replace(/[^a-zA-Z0-9\-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '')
      .toLowerCase();
  }
  const input = document.getElementById('kbc-input');
  const output = document.getElementById('kbc-output');
  const wrap = document.getElementById('kbc-output-wrap');
  const saved = localStorage.getItem('tw-kebab-case-converter');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-kebab-case-converter', input.value));
  document.getElementById('kbc-convert').addEventListener('click', () => {
    output.value = input.value.split('\n').map(l => l.trim() ? toKebab(l) : '').join('\n');
    wrap.classList.remove('hidden');
  });
  document.getElementById('kbc-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); localStorage.removeItem('tw-kebab-case-converter'); });
  document.getElementById('kbc-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
