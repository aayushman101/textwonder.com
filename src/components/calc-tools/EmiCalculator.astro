---
---
<div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ec-principal">Loan Amount (₹)</label>
      <input type="number" id="ec-principal" placeholder="e.g. 500000" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ec-rate">Interest Rate (% p.a.)</label>
      <input type="number" id="ec-rate" placeholder="e.g. 8.5" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ec-tenure">Tenure (months)</label>
      <input type="number" id="ec-tenure" placeholder="e.g. 60" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
  </div>

  <div id="ec-result" class="hidden space-y-4">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
        <div class="text-xs text-slate-400 mb-1">Monthly EMI</div>
        <div id="ec-emi" class="text-xl font-bold" style="color:#10b981"></div>
      </div>
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
        <div class="text-xs text-slate-400 mb-1">Total Interest</div>
        <div id="ec-interest" class="text-xl font-bold text-white"></div>
      </div>
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
        <div class="text-xs text-slate-400 mb-1">Total Amount</div>
        <div id="ec-total" class="text-xl font-bold text-white"></div>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead><tr class="text-slate-400 border-b border-slate-700">
          <th class="text-left pb-2">Year</th>
          <th class="text-right pb-2">Principal Paid</th>
          <th class="text-right pb-2">Interest Paid</th>
          <th class="text-right pb-2">Balance</th>
        </tr></thead>
        <tbody id="ec-table" class="text-slate-300"></tbody>
      </table>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  function fmt(n) { return '₹' + Math.round(n).toLocaleString('en-IN'); }
  function calc() {
    const P = parseFloat(document.getElementById('ec-principal').value);
    const r = parseFloat(document.getElementById('ec-rate').value) / 100 / 12;
    const n = parseInt(document.getElementById('ec-tenure').value);
    const res = document.getElementById('ec-result');
    if(!P || !r || !n || P<=0 || r<=0 || n<=0) { res.classList.add('hidden'); return; }
    const emi = P * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);
    const totalAmt = emi * n;
    const totalInt = totalAmt - P;
    document.getElementById('ec-emi').textContent = fmt(emi);
    document.getElementById('ec-interest').textContent = fmt(totalInt);
    document.getElementById('ec-total').textContent = fmt(totalAmt);
    // Year-wise table
    let bal = P, tbody = '', month = 0;
    const years = Math.ceil(n/12);
    for(let y=1; y<=years; y++) {
      let yearPrincipal=0, yearInterest=0, months=Math.min(12, n-month);
      for(let m=0; m<months; m++) {
        const intPart = bal * r;
        const prinPart = emi - intPart;
        yearInterest+=intPart; yearPrincipal+=prinPart; bal-=prinPart; month++;
      }
      tbody += `<tr class="border-b border-slate-800"><td class="py-2">Year ${y}</td><td class="py-2 text-right">${fmt(yearPrincipal)}</td><td class="py-2 text-right">${fmt(yearInterest)}</td><td class="py-2 text-right">${fmt(Math.max(0,bal))}</td></tr>`;
    }
    document.getElementById('ec-table').innerHTML = tbody;
    res.classList.remove('hidden');
  }
  ['ec-principal','ec-rate','ec-tenure'].forEach(id => document.getElementById(id).addEventListener('input', calc));
})();
</script>
