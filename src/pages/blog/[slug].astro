---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { DYNAMIC_BLOG_POSTS } from '../../data/blogposts.js';

export function getStaticPaths() {
  return DYNAMIC_BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BlogLayout
  title={post.title}
  description={post.description}
  canonical={post.canonical}
  date={post.date}
  readTime={post.readTime}
  category={post.category}
  faqs={post.faqs}
>
  <p>
    Welcome to the ultimate guide on how to use the online <strong>{post.toolName}</strong>. 
    Whether you are a developer, writer, student, or working professional, having reliable, fast, and secure tools is crucial for productivity.
  </p>

  <h2>What is the {post.toolName}?</h2>
  <p>{post.descriptionLong}</p>

  <h2>Key Features & Common Use Cases</h2>
  <p>{post.useCases}</p>

  <h2>How it Works Under the Hood</h2>
  <p>{post.howItWorks}</p>

  <h2>Why {post.category} on TextWonder is Better Than Competitors</h2>
  <p>{post.competitorAnalysis}</p>

  <a href={post.toolUrl} class="tool-cta">
    <div class="cta-label">Free Tools</div>
    <div class="cta-title">Open {post.toolName} Tool →</div>
    <div class="cta-desc">Use the free, private, and instant version of {post.toolName} directly in your browser.</div>
  </a>

  <h2>Target Long-Tail Search Intent Keywords</h2>
  <ul>
    {post.keywords.map((kw) => (
      <li><strong>{kw}</strong></li>
    ))}
  </ul>

  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {post.faqs.map(f => (
      <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group mb-2">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
          <span class="text-white font-medium text-sm">{f.q}</span>
          <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-4"><p class="text-slate-400 text-sm leading-relaxed">{f.a}</p></div>
      </details>
    ))}
  </div>
</BlogLayout>
