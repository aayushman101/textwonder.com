---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is a word counter or character counter better for writing?', acceptedAnswer: { '@type': 'Answer', text: 'Word counter is better for judging content length and readability. Character counter is better for platform-specific limits (Twitter, SMS, meta tags). Both are available simultaneously on TextWonder.' } },
    { '@type': 'Question', name: 'Does word count include punctuation?', acceptedAnswer: { '@type': 'Answer', text: 'No. Punctuation marks attached to words (period, comma, apostrophe) are counted as part of the word. Standalone punctuation marks are usually not counted as words.' } },
    { '@type': 'Question', name: 'What is the Twitter character limit?', acceptedAnswer: { '@type': 'Answer', text: 'Twitter/X limits tweets to 280 characters. URLs always count as 23 characters regardless of actual length. Emojis count as 1–2 characters depending on the emoji.' } },
    { '@type': 'Question', name: 'Which is more accurate: word count or character count?', acceptedAnswer: { '@type': 'Answer', text: 'Character count is objectively more precise since it counts exact characters. Word count definitions vary slightly (how to handle hyphenated words, contractions, numbers). For most practical purposes, both give consistent results across tools.' } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://textwonder.com' },
    { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://textwonder.com/compare' },
    { '@type': 'ListItem', position: 3, name: 'Word Counter vs Character Counter', item: 'https://textwonder.com/compare/word-counter-vs-character-counter' },
  ],
};
---

<BaseLayout
  title="Word Counter vs Character Counter: Which Should You Use?"
  description="Word counter vs character counter — understand the key differences, when each matters, and which tool to use for essays, social media, SEO, and SMS."
  canonical="/compare/word-counter-vs-character-counter"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <main class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1 text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/compare" class="hover:text-violet-400 transition-colors">Compare</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-slate-400">Word Counter vs Character Counter</span>
    </nav>

    <header class="mb-10">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-900/40 text-violet-300 border border-violet-800/50 mb-4">Comparison</span>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', sans-serif;">Word Counter vs Character Counter: Which Should You Use?</h1>
      <p class="text-slate-400 text-lg leading-relaxed">Both measure text length — but they answer different questions. Here's exactly when to use each, side by side.</p>
    </header>

    <!-- Comparison Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <div class="bg-[var(--bg-surface)] border border-violet-800/40 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-violet-700 flex items-center justify-center text-white font-bold text-lg">W</div>
          <div>
            <div class="text-white font-semibold">Word Counter</div>
            <div class="text-slate-500 text-xs">Counts words (space-separated tokens)</div>
          </div>
        </div>
        <ul class="space-y-2 text-sm text-slate-400 mb-5">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Academic essays (500 words, 1000 words)</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Blog posts and SEO content length</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Publishing / journalism briefs</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Reading time estimation</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> NaNoWriMo word count goals</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Does not help with social media limits</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Not useful for SMS or form field limits</li>
        </ul>
        <a href="/tools/word-counter" class="block text-center bg-violet-700 hover:bg-violet-600 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors">
          Use Word Counter →
        </a>
      </div>

      <div class="bg-[var(--bg-surface)] border border-pink-800/40 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-pink-700 flex items-center justify-center text-white font-bold text-lg">C</div>
          <div>
            <div class="text-white font-semibold">Character Counter</div>
            <div class="text-slate-500 text-xs">Counts every letter, space, and symbol</div>
          </div>
        </div>
        <ul class="space-y-2 text-sm text-slate-400 mb-5">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Twitter/X: 280 characters per tweet</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> SMS: 160 characters per message</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Meta title: under 60 characters</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Meta description: under 155 characters</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Database column constraints (VARCHAR)</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Not useful for essay length requirements</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Doesn't reflect reading time</li>
        </ul>
        <a href="/tools/character-counter" class="block text-center bg-pink-700 hover:bg-pink-600 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors">
          Use Character Counter →
        </a>
      </div>
    </div>

    <!-- Quick Comparison Table -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-6" style="font-family: 'Space Grotesk', sans-serif;">Quick Reference: Which to Use When</h2>
      <div class="overflow-x-auto rounded-xl border border-slate-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="text-left px-5 py-3 text-slate-400 font-medium">Situation</th>
              <th class="text-center px-4 py-3 text-violet-400 font-medium">Word Count</th>
              <th class="text-center px-4 py-3 text-pink-400 font-medium">Character Count</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60">
            {[
              ['University essay (500-word limit)', '✓', ''],
              ['Twitter/X tweet (280 chars)', '', '✓'],
              ['SEO blog post (1,500+ words)', '✓', ''],
              ['SMS text message (160 chars)', '', '✓'],
              ['Meta title (60 chars)', '', '✓'],
              ['Meta description (155 chars)', '', '✓'],
              ['NaNoWriMo novel (50,000 words)', '✓', ''],
              ['Instagram bio (150 chars)', '', '✓'],
              ['Reading time estimate', '✓', ''],
              ['Database VARCHAR limit', '', '✓'],
              ['Magazine article (800 words)', '✓', ''],
              ['LinkedIn post (~210 char preview)', '', '✓'],
            ].map(([situation, w, c]) => (
              <tr>
                <td class="px-5 py-3 text-slate-300">{situation}</td>
                <td class="px-4 py-3 text-center text-emerald-400 font-bold">{w}</td>
                <td class="px-4 py-3 text-center text-emerald-400 font-bold">{c}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- The Best Answer -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', sans-serif;">The Best Answer: Use Both Simultaneously</h2>
      <p class="text-slate-400 leading-relaxed mb-4">
        The cleanest solution is a tool that shows both at the same time. TextWonder's <a href="/tools/word-counter" class="text-violet-400 hover:underline">Word Counter</a> displays word count, character count (with and without spaces), sentence count, paragraph count, and estimated reading time all at once, updating in real time as you type.
      </p>
      <p class="text-slate-400 leading-relaxed">
        There's no reason to choose one over the other — a good text analysis tool gives you both.
      </p>
    </section>

    <!-- Key Numbers Reference -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-6" style="font-family: 'Space Grotesk', sans-serif;">Common Character Limits to Know</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          ['Twitter/X tweet', '280 characters'],
          ['SMS message', '160 characters'],
          ['Google meta title', '~60 characters'],
          ['Google meta description', '~155 characters'],
          ['Instagram bio', '150 characters'],
          ['Instagram caption preview', '~125 characters'],
          ['LinkedIn post preview', '~210 characters'],
          ['Email subject line', '50–60 characters ideal'],
          ['YouTube title', '100 characters'],
          ['YouTube description', '5,000 characters'],
        ].map(([platform, limit]) => (
          <div class="flex items-center justify-between bg-[var(--bg-surface)] border border-slate-800 rounded-xl px-4 py-3">
            <span class="text-slate-300 text-sm">{platform}</span>
            <span class="text-violet-400 text-sm font-semibold">{limit}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-5" style="font-family: 'Space Grotesk', sans-serif;">Frequently Asked Questions</h2>
      <div class="space-y-2">
        {faqSchema.mainEntity.map(item => (
          <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
              <span class="text-white font-medium text-sm">{item.name}</span>
              <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-4"><p class="text-slate-400 text-sm leading-relaxed">{item.acceptedAnswer.text}</p></div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
