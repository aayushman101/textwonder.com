---
---
<div class="space-y-5">
  <div id="icmp-drop" class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center cursor-pointer hover:border-rose-500/60 transition-colors">
    <input id="icmp-file" type="file" accept="image/*" class="hidden" />
    <div class="text-3xl mb-2">📦</div>
    <p class="text-slate-300 font-medium">Drop an image here or <span class="text-rose-400 underline cursor-pointer">click to browse</span></p>
    <p class="text-slate-500 text-xs mt-1">JPG, PNG, WebP — compression runs in your browser</p>
  </div>

  <div id="icmp-panel" class="hidden space-y-4">
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-3 text-center">
      <div class="bg-[var(--bg-surface-hover)] rounded-xl p-3">
        <p class="text-xs text-slate-500 mb-1">Original size</p>
        <p id="icmp-orig-size" class="text-white font-bold text-sm">—</p>
      </div>
      <div class="bg-rose-950/40 border border-rose-800/30 rounded-xl p-3">
        <p class="text-xs text-slate-500 mb-1">Compressed</p>
        <p id="icmp-new-size" class="text-rose-400 font-bold text-sm">—</p>
      </div>
      <div class="bg-[var(--bg-surface-hover)] rounded-xl p-3">
        <p class="text-xs text-slate-500 mb-1">Savings</p>
        <p id="icmp-saving" class="text-emerald-400 font-bold text-sm">—</p>
      </div>
    </div>

    <!-- Preview -->
    <div class="grid grid-cols-2 gap-3">
      <div class="text-center">
        <p class="text-xs text-slate-500 mb-1">Original</p>
        <img id="icmp-orig-prev" src="" alt="Original" class="w-full max-h-40 object-contain rounded-lg border border-slate-700" />
      </div>
      <div class="text-center">
        <p class="text-xs text-slate-500 mb-1">Compressed</p>
        <img id="icmp-comp-prev" src="" alt="Compressed" class="w-full max-h-40 object-contain rounded-lg border border-slate-700" />
      </div>
    </div>

    <!-- Controls -->
    <div class="space-y-3">
      <div>
        <div class="flex justify-between text-xs text-slate-400 mb-1">
          <label>Quality</label>
          <span id="icmp-q-val" class="text-rose-400 font-medium">80%</span>
        </div>
        <input id="icmp-quality" type="range" min="10" max="100" value="80" class="w-full accent-rose-500" />
        <div class="flex justify-between text-xs text-slate-600 mt-1"><span>Smaller file</span><span>Better quality</span></div>
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Output format</label>
        <select id="icmp-format" class="bg-[var(--bg-surface-hover)] border border-slate-700 text-white rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:border-rose-500">
          <option value="image/jpeg">JPEG</option>
          <option value="image/webp">WebP</option>
          <option value="image/png">PNG (lossless)</option>
        </select>
      </div>
      <button id="icmp-btn" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white rounded-lg font-semibold text-sm transition-colors">
        Download Compressed Image
      </button>
    </div>
  </div>
</div>

<canvas id="icmp-canvas" class="hidden"></canvas>

<script is:inline>
(function () {
  const drop = document.getElementById('icmp-drop');
  const fileInput = document.getElementById('icmp-file');
  const panel = document.getElementById('icmp-panel');
  const origPrev = document.getElementById('icmp-orig-prev');
  const compPrev = document.getElementById('icmp-comp-prev');
  const origSizeEl = document.getElementById('icmp-orig-size');
  const newSizeEl = document.getElementById('icmp-new-size');
  const savingEl = document.getElementById('icmp-saving');
  const qualitySlider = document.getElementById('icmp-quality');
  const qValEl = document.getElementById('icmp-q-val');
  const formatSel = document.getElementById('icmp-format');
  const btn = document.getElementById('icmp-btn');
  const canvas = document.getElementById('icmp-canvas');

  let img = null, origFileSize = 0, origDataUrl = '';
  let compressedBlob = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-rose-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-rose-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-rose-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  function loadFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    origFileSize = file.size;
    origDataUrl = URL.createObjectURL(file);
    img = new Image();
    img.onload = () => {
      origPrev.src = origDataUrl;
      origSizeEl.textContent = fmt(origFileSize);
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      compress();
    };
    img.src = origDataUrl;
  }

  function fmt(bytes) {
    return bytes < 1024 * 1024 ? (bytes / 1024).toFixed(1) + ' KB' : (bytes / 1024 / 1024).toFixed(2) + ' MB';
  }

  function compress() {
    if (!img) return;
    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0);
    const q = parseInt(qualitySlider.value) / 100;
    const fmt2 = formatSel.value;
    canvas.toBlob(blob => {
      compressedBlob = blob;
      const url = URL.createObjectURL(blob);
      compPrev.src = url;
      newSizeEl.textContent = fmt(blob.size);
      const saved = Math.max(0, ((origFileSize - blob.size) / origFileSize * 100)).toFixed(0);
      savingEl.textContent = saved + '% smaller';
    }, fmt2, fmt2 === 'image/png' ? undefined : q);
  }

  qualitySlider.addEventListener('input', () => { qValEl.textContent = qualitySlider.value + '%'; compress(); });
  formatSel.addEventListener('change', compress);

  btn.addEventListener('click', () => {
    if (!compressedBlob) return;
    const ext = formatSel.value.split('/')[1];
    const a = document.createElement('a');
    a.href = URL.createObjectURL(compressedBlob);
    a.download = `compressed.${ext}`;
    a.click();
  });
})();
</script>
