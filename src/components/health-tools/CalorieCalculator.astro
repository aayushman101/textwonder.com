---
---
<div>
  <div class="flex gap-2 mb-4">
    <button id="cal-metric-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-white" style="background:#22c55e" onclick="calUnit('metric')">Metric</button>
    <button id="cal-imperial-btn" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 bg-[var(--bg-base)] border border-slate-700" onclick="calUnit('imperial')">Imperial</button>
  </div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm text-slate-400 mb-1">Gender</label>
      <div class="flex gap-3 pt-1">
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="cal-gender" value="male" checked class="accent-green-500" /><span class="text-white text-sm">Male</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="cal-gender" value="female" class="accent-green-500" /><span class="text-white text-sm">Female</span></label>
      </div>
    </div>
    <div><label class="block text-sm text-slate-400 mb-1">Age (years)</label><input type="number" id="cal-age" placeholder="e.g. 25" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div id="cal-metric-inputs" class="grid grid-cols-2 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (kg)</label><input type="number" id="cal-kg" placeholder="e.g. 70" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (cm)</label><input type="number" id="cal-cm" placeholder="e.g. 175" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div id="cal-imperial-inputs" class="hidden grid grid-cols-3 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Weight (lbs)</label><input type="number" id="cal-lbs" placeholder="e.g. 154" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (ft)</label><input type="number" id="cal-ft" placeholder="5" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Height (in)</label><input type="number" id="cal-in" placeholder="9" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500" /></div>
  </div>
  <div class="mb-4">
    <label class="block text-sm text-slate-400 mb-1">Activity Level</label>
    <select id="cal-activity" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-green-500">
      <option value="1.2">Sedentary (desk job, no exercise)</option>
      <option value="1.375">Lightly active (1–3 days/wk)</option>
      <option value="1.55" selected>Moderately active (3–5 days/wk)</option>
      <option value="1.725">Very active (6–7 days/wk)</option>
      <option value="1.9">Extra active (athlete/physical job)</option>
    </select>
  </div>

  <div id="cal-result" class="hidden space-y-3">
    <div class="grid grid-cols-1 gap-3">
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 flex justify-between items-center">
        <div><div class="text-sm text-slate-400">Weight Loss (−500 kcal/day)</div><div class="text-xs text-slate-500">~0.5 kg/week deficit</div></div>
        <div id="cal-loss" class="text-xl font-bold text-red-400"></div>
      </div>
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 flex justify-between items-center">
        <div><div class="text-sm text-slate-400">Maintenance (TDEE)</div><div class="text-xs text-slate-500">Total daily energy expenditure</div></div>
        <div id="cal-maintain" class="text-xl font-bold" style="color:#22c55e"></div>
      </div>
      <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 flex justify-between items-center">
        <div><div class="text-sm text-slate-400">Muscle Gain (+300 kcal/day)</div><div class="text-xs text-slate-500">Lean bulk surplus</div></div>
        <div id="cal-gain" class="text-xl font-bold text-blue-400"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  let unitMode='metric';
  window.calUnit=function(m){
    unitMode=m;
    document.getElementById('cal-metric-inputs').classList.toggle('hidden',m!=='metric');
    document.getElementById('cal-imperial-inputs').classList.toggle('hidden',m!=='imperial');
    const mb=document.getElementById('cal-metric-btn'),ib=document.getElementById('cal-imperial-btn');
    if(m==='metric'){mb.style.background='#22c55e';mb.classList.add('text-white');mb.classList.remove('text-slate-400');ib.style.background='';ib.classList.remove('text-white');ib.classList.add('text-slate-400');}
    else{ib.style.background='#22c55e';ib.classList.add('text-white');ib.classList.remove('text-slate-400');mb.style.background='';mb.classList.remove('text-white');mb.classList.add('text-slate-400');}
    calc();
  };
  function calc(){
    const gender=document.querySelector('input[name="cal-gender"]:checked').value;
    const age=parseFloat(document.getElementById('cal-age').value);
    const act=parseFloat(document.getElementById('cal-activity').value);
    let kg,cm;
    if(unitMode==='metric'){kg=parseFloat(document.getElementById('cal-kg').value);cm=parseFloat(document.getElementById('cal-cm').value);}
    else{const lbs=parseFloat(document.getElementById('cal-lbs').value);const ft=parseFloat(document.getElementById('cal-ft').value)||0;const inch=parseFloat(document.getElementById('cal-in').value)||0;kg=lbs*0.453592;cm=(ft*12+inch)*2.54;}
    const res=document.getElementById('cal-result');
    if(!age||!kg||!cm||age<=0||kg<=0||cm<=0){res.classList.add('hidden');return;}
    let bmr=(gender==='male')?(10*kg+6.25*cm-5*age+5):(10*kg+6.25*cm-5*age-161);
    const tdee=Math.round(bmr*act);
    document.getElementById('cal-loss').textContent=(tdee-500)+' kcal';
    document.getElementById('cal-maintain').textContent=tdee+' kcal';
    document.getElementById('cal-gain').textContent=(tdee+300)+' kcal';
    res.classList.remove('hidden');
  }
  ['cal-age','cal-kg','cal-cm','cal-lbs','cal-ft','cal-in','cal-activity'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',calc);});
  document.querySelectorAll('input[name="cal-gender"]').forEach(r=>r.addEventListener('change',calc));
})();
</script>
