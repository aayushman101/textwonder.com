---
---
<div class="max-w-2xl mx-auto space-y-5">
  <!-- Output -->
  <div class="bg-slate-800 rounded-xl p-4 border border-slate-700">
    <div class="flex items-center gap-3">
      <span id="pg-output" class="flex-1 font-mono text-lg text-white break-all select-all">Click Generate</span>
      <button id="pg-copy" class="shrink-0 px-3 py-1.5 bg-cyan-600 hover:bg-cyan-500 text-white text-sm rounded-lg transition-colors">Copy</button>
    </div>
    <div id="pg-strength" class="mt-2 flex gap-1">
      <div class="h-1 flex-1 rounded bg-slate-700" id="pg-s1"></div>
      <div class="h-1 flex-1 rounded bg-slate-700" id="pg-s2"></div>
      <div class="h-1 flex-1 rounded bg-slate-700" id="pg-s3"></div>
      <div class="h-1 flex-1 rounded bg-slate-700" id="pg-s4"></div>
    </div>
    <p id="pg-strength-label" class="text-xs text-slate-500 mt-1">—</p>
  </div>

  <!-- Options -->
  <div class="bg-slate-800/50 rounded-xl p-5 space-y-4 border border-slate-700">
    <div class="space-y-1">
      <div class="flex justify-between text-sm">
        <span class="text-slate-300">Length</span>
        <span id="pg-len-val" class="text-cyan-400 font-mono font-bold">16</span>
      </div>
      <input id="pg-length" type="range" min="4" max="128" value="16" class="w-full accent-cyan-500" />
    </div>

    <div class="grid grid-cols-2 gap-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="pg-upper" type="checkbox" checked class="w-4 h-4 accent-cyan-500" />
        <span class="text-slate-300 text-sm">Uppercase (A-Z)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="pg-lower" type="checkbox" checked class="w-4 h-4 accent-cyan-500" />
        <span class="text-slate-300 text-sm">Lowercase (a-z)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="pg-digits" type="checkbox" checked class="w-4 h-4 accent-cyan-500" />
        <span class="text-slate-300 text-sm">Numbers (0-9)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="pg-symbols" type="checkbox" checked class="w-4 h-4 accent-cyan-500" />
        <span class="text-slate-300 text-sm">Symbols (!@#$…)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer col-span-2">
        <input id="pg-noamb" type="checkbox" class="w-4 h-4 accent-cyan-500" />
        <span class="text-slate-300 text-sm">Exclude ambiguous characters (0, O, l, 1, I)</span>
      </label>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex gap-3">
    <button id="pg-generate" class="flex-1 py-3 rounded-xl font-semibold text-white text-base transition-colors" style="background:#06b6d4">Generate Password</button>
    <button id="pg-bulk" class="px-4 py-3 rounded-xl border border-slate-600 text-slate-300 hover:border-cyan-500 transition-colors text-sm">Generate 10</button>
  </div>

  <!-- Bulk output -->
  <div id="pg-bulk-list" class="hidden space-y-2">
    <p class="text-slate-400 text-sm font-medium">10 Passwords — click any to copy</p>
    <div id="pg-bulk-items" class="space-y-1.5"></div>
  </div>
</div>

<script is:inline>
(function() {
  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const DIGITS = '0123456789';
  const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';
  const AMBIGUOUS = /[0Ol1I]/g;

  const lenEl = document.getElementById('pg-length');
  const lenVal = document.getElementById('pg-len-val');
  const output = document.getElementById('pg-output');
  const copyBtn = document.getElementById('pg-copy');
  const genBtn = document.getElementById('pg-generate');
  const bulkBtn = document.getElementById('pg-bulk');
  const bulkList = document.getElementById('pg-bulk-list');
  const bulkItems = document.getElementById('pg-bulk-items');
  const strengthLabel = document.getElementById('pg-strength-label');
  const bars = [1,2,3,4].map(i => document.getElementById('pg-s'+i));

  lenEl.addEventListener('input', () => { lenVal.textContent = lenEl.value; generate(); });

  function getPool() {
    let pool = '';
    if (document.getElementById('pg-upper').checked) pool += UPPER;
    if (document.getElementById('pg-lower').checked) pool += LOWER;
    if (document.getElementById('pg-digits').checked) pool += DIGITS;
    if (document.getElementById('pg-symbols').checked) pool += SYMBOLS;
    if (document.getElementById('pg-noamb').checked) pool = pool.replace(AMBIGUOUS, '');
    return pool || LOWER;
  }

  function generate() {
    const pool = getPool();
    const len = +lenEl.value;
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    const pwd = Array.from(arr).map(v => pool[v % pool.length]).join('');
    output.textContent = pwd;
    updateStrength(pwd, pool.length);
    return pwd;
  }

  function updateStrength(pwd, poolSize) {
    const entropy = pwd.length * Math.log2(poolSize);
    let level, label, color;
    if (entropy < 40) { level = 1; label = 'Weak'; color = '#ef4444'; }
    else if (entropy < 60) { level = 2; label = 'Fair'; color = '#f97316'; }
    else if (entropy < 80) { level = 3; label = 'Strong'; color = '#22c55e'; }
    else { level = 4; label = 'Very Strong'; color = '#06b6d4'; }
    bars.forEach((b, i) => { b.style.background = i < level ? color : ''; });
    strengthLabel.textContent = label + ' — ' + Math.round(entropy) + ' bits of entropy';
    strengthLabel.style.color = color;
  }

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(output.textContent);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => copyBtn.textContent = 'Copy', 1500);
  });

  genBtn.addEventListener('click', () => { generate(); bulkList.classList.add('hidden'); });

  bulkBtn.addEventListener('click', () => {
    bulkItems.innerHTML = '';
    for (let i = 0; i < 10; i++) {
      const pwd = generate();
      const div = document.createElement('div');
      div.className = 'flex items-center gap-2 bg-slate-800 rounded-lg px-3 py-2 cursor-pointer hover:bg-slate-700 transition-colors';
      div.innerHTML = `<span class="flex-1 font-mono text-sm text-white">${pwd}</span><span class="text-xs text-slate-500">copy</span>`;
      div.addEventListener('click', () => {
        navigator.clipboard.writeText(pwd);
        div.querySelector('span:last-child').textContent = '✓';
        setTimeout(() => div.querySelector('span:last-child').textContent = 'copy', 1500);
      });
      bulkItems.appendChild(div);
    }
    bulkList.classList.remove('hidden');
  });

  generate();
})();
</script>
