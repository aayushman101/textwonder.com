---
---
<div>
  <div class="grid grid-cols-3 gap-4 mb-4">
    <div><label class="block text-sm text-slate-400 mb-1">Total Classes</label><input type="number" id="att-total" placeholder="e.g. 80" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Classes Attended</label><input type="number" id="att-attended" placeholder="e.g. 62" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" /></div>
    <div><label class="block text-sm text-slate-400 mb-1">Required % (default 75)</label><input type="number" id="att-req" placeholder="75" value="75" min="1" max="100" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" /></div>
  </div>

  <div id="att-result" class="hidden space-y-3">
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-sm text-slate-400 mb-1">Current Attendance</div>
      <div id="att-pct" class="text-4xl font-bold"></div>
    </div>
    <div id="att-msg" class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div id="att-msg-text" class="text-base font-semibold"></div>
      <div id="att-msg-sub" class="text-sm text-slate-400 mt-1"></div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  function calc(){
    const total=parseInt(document.getElementById('att-total').value);
    const attended=parseInt(document.getElementById('att-attended').value);
    const req=parseFloat(document.getElementById('att-req').value)||75;
    const res=document.getElementById('att-result');
    if(!total||!attended||total<=0||attended<0||attended>total){res.classList.add('hidden');return;}
    const pct=attended/total*100;
    const pctEl=document.getElementById('att-pct');
    pctEl.textContent=pct.toFixed(2)+'%';
    pctEl.style.color=pct>=req?'#22c55e':'#ef4444';
    const msg=document.getElementById('att-msg-text');
    const sub=document.getElementById('att-msg-sub');
    if(pct>=req){
      // How many can miss?
      let canMiss=0;
      while((attended/(total+canMiss+1))*100>=req)canMiss++;
      msg.textContent=`You can miss ${canMiss} more class${canMiss===1?'':'es'}`;
      msg.style.color='#22c55e';
      sub.textContent=`While staying above the ${req}% requirement`;
    } else {
      // How many must attend?
      let need=0;
      while(((attended+need)/(total+need))*100<req)need++;
      msg.textContent=`You need to attend ${need} more consecutive class${need===1?'':'es'}`;
      msg.style.color='#f59e0b';
      sub.textContent=`To reach the ${req}% attendance requirement`;
    }
    res.classList.remove('hidden');
  }
  ['att-total','att-attended','att-req'].forEach(id=>document.getElementById(id).addEventListener('input',calc));
})();
</script>
