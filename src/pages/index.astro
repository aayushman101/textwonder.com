    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:15px;color:white;letter-spacing:-1px;line-height:1">aeiou</span>`,
  },
  'number-counter': {
    bg: '#7c3aed',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:17px;color:white;letter-spacing:-1px;line-height:1">123</span>`,
  },
  'emoji-counter': {
    bg: '#d97706',
    iconHtml: `<span style="font-size:22px;line-height:1">😊</span>`,
  },
