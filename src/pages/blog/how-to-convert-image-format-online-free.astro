import BlogLayout from '../../layouts/BlogLayout.astro';

const faqs = [
  { q: 'What is the difference between JPG and PNG?', a: 'JPEG uses lossy compression — ideal for photos where minor quality loss is acceptable in exchange for much smaller file sizes. PNG uses lossless compression and supports transparency — ideal for logos, icons, and screenshots where sharp edges and text must stay crisp.' },
  { q: 'Should I use WebP instead of JPEG?', a: 'For web images, yes. WebP achieves 25–35% smaller file sizes than JPEG at the same visual quality, and supports both lossy and lossless compression as well as transparency. All modern browsers support it.' },
  { q: 'Will converting from JPEG to PNG improve quality?', a: 'No. Converting a JPEG to PNG will not recover any quality lost during the original JPEG compression. PNG will simply store the already-compressed pixel data losslessly, resulting in a larger file with the same visual quality.' },
  { q: 'What happens to transparency when converting PNG to JPEG?', a: 'JPEG does not support an alpha channel (transparency). Transparent areas are filled with white when converting PNG to JPEG. Use PNG or WebP if you need to preserve transparency.' },
  { q: 'What is BMP format used for?', a: 'BMP (Bitmap) is an uncompressed Windows format. Files are very large but universally compatible with older Windows software. It is rarely used for web or sharing — JPEG or PNG are always better alternatives.' },
];
---

