const faqs = [
  { q: 'What is Base64 image encoding?', a: 'Base64 is an encoding scheme that converts binary data (like image files) into a string of ASCII characters. This allows binary files to be embedded directly in text-based formats like HTML, CSS, JSON, and XML.' },
  { q: 'How much larger does a Base64 image get?', a: 'Base64 encoding increases file size by approximately 33%. A 100 KB image becomes about 133 KB as a Base64 string. For this reason, Base64 embedding is best reserved for small images under 50 KB.' },
  { q: 'Can I use a Base64 image directly in an img tag?', a: 'Yes. Set the src attribute to the full data URI: <img src="data:image/png;base64,iVBORw...">. The browser will render it without any network request.' },
  { q: 'Does Base64 encoding affect image quality?', a: 'No. Base64 is a pure encoding of the binary file — it does not compress or alter the image data. Decoding produces the exact original file.' },
  { q: 'Is it good practice to embed images as Base64 in production websites?', a: 'Only for very small images like icons under 5 KB. Large Base64 images bloat your HTML/CSS, cannot be cached separately, and delay rendering. Use a regular image URL for anything meaningful.' },
];
