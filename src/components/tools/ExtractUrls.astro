---
---
<div class="space-y-4">
  <textarea id="exu-input" rows="8" placeholder="Paste any text containing URLs or links…&#10;&#10;Visit https://example.com or check www.google.com for more info." class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-3 items-center flex-wrap">
    <button id="exu-do" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Extract URLs</button>
    <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer">
      <input type="checkbox" id="exu-dedup" checked class="accent-violet-500"> Remove duplicates
    </label>
    <button id="exu-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="exu-output-wrap" class="hidden space-y-3">
    <div id="exu-stats" class="text-xs text-slate-500"></div>
    <div id="exu-none" class="hidden text-slate-500 text-sm py-4 text-center">No URLs found.</div>
    <div id="exu-list" class="space-y-1"></div>
    <button id="exu-copy" class="hidden text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy all URLs</button>
  </div>
</div>
<script>
  const URL_RX = /https?:\/\/[^\s<>"'\])}]+|www\.[a-zA-Z0-9\-]+\.[a-zA-Z]{2,}[^\s<>"'\])}]*/g;
  function cleanUrl(u) { return u.replace(/[.,;:!?)'"\]>]+$/, ''); }
  const input = document.getElementById('exu-input');
  const wrap = document.getElementById('exu-output-wrap');
  const stats = document.getElementById('exu-stats');
  const listEl = document.getElementById('exu-list');
  const noneEl = document.getElementById('exu-none');
  const copyBtn = document.getElementById('exu-copy');
  const dedupCb = document.getElementById('exu-dedup');
  const saved = localStorage.getItem('tw-extract-urls');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-extract-urls', input.value));
  document.getElementById('exu-do').addEventListener('click', () => {
    const all = (input.value.match(URL_RX) || []).map(cleanUrl);
    const urls = dedupCb.checked ? [...new Set(all)] : all;
    wrap.classList.remove('hidden');
    if (urls.length === 0) { noneEl.classList.remove('hidden'); listEl.innerHTML=''; copyBtn.classList.add('hidden'); stats.textContent=''; return; }
    noneEl.classList.add('hidden');
    stats.textContent = `${urls.length} URL${urls.length!==1?'s':''} found`;
    listEl.innerHTML = urls.map(u => `<div class="flex items-center justify-between bg-[var(--bg-surface)] border border-slate-800 rounded-lg px-3 py-2 group"><span class="text-violet-300 text-sm font-mono truncate mr-2">${u}</span><button onclick="navigator.clipboard.writeText('${u.replace(/'/g,"&#39;")}')" class="shrink-0 text-xs text-slate-500 hover:text-violet-400 opacity-0 group-hover:opacity-100 transition-all">Copy</button></div>`).join('');
    copyBtn.classList.remove('hidden');
    copyBtn.onclick = () => navigator.clipboard.writeText(urls.join('\n'));
  });
  document.getElementById('exu-clear').addEventListener('click', () => { input.value=''; listEl.innerHTML=''; wrap.classList.add('hidden'); localStorage.removeItem('tw-extract-urls'); });
</script>
