---
---

<div class="space-y-4">
  <div class="flex flex-wrap items-center gap-3">
    <label class="text-slate-400 text-sm">Join with:</label>
    <select id="jl-sep-preset" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-1.5 text-slate-100 text-sm outline-none">
      <option value=", ">Comma + space</option>
      <option value=" ">Space</option>
      <option value="; ">Semicolon</option>
      <option value=" | ">Pipe</option>
      <option value="">Nothing (concatenate)</option>
      <option value="custom">Custom…</option>
    </select>
    <input id="jl-sep-custom" type="text" placeholder="separator" class="hidden bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-1.5 text-slate-100 text-sm outline-none w-32 focus:ring-2 focus:ring-violet-600" />
  </div>
  <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
    <input id="jl-skip-blank" type="checkbox" checked class="w-4 h-4 accent-violet-600" />
    Skip blank lines
  </label>
  <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
    <input id="jl-trim" type="checkbox" class="w-4 h-4 accent-violet-600" />
    Trim each line
  </label>
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Input Lines</label>
    <textarea id="jl-input" rows="7" placeholder="One value per line..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"></textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Joined Output</label>
      <button id="jl-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea id="jl-output" rows="4" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y outline-none text-sm font-mono"></textarea>
  </div>
</div>

<script>
function join() {
  const preset = document.getElementById('jl-sep-preset').value;
  const sep = preset === 'custom' ? document.getElementById('jl-sep-custom').value : preset;
  const skipBlank = document.getElementById('jl-skip-blank').checked;
  const trim = document.getElementById('jl-trim').checked;
  let lines = document.getElementById('jl-input').value.split('\n');
  if (trim) lines = lines.map(l => l.trim());
  if (skipBlank) lines = lines.filter(l => l.length > 0);
  document.getElementById('jl-output').value = lines.join(sep);
}

document.getElementById('jl-sep-preset').addEventListener('change', (e) => {
  document.getElementById('jl-sep-custom').classList.toggle('hidden', e.target.value !== 'custom');
  join();
});
['jl-input','jl-sep-custom'].forEach(id => document.getElementById(id).addEventListener('input', join));
['jl-skip-blank','jl-trim'].forEach(id => document.getElementById(id).addEventListener('change', join));
document.getElementById('jl-copy').addEventListener('click', () => {
  const val = document.getElementById('jl-output').value;
  if (!val) return;
  navigator.clipboard.writeText(val);
  const btn = document.getElementById('jl-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = 'Copy', 1500);
});
</script>
