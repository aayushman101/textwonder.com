---
---
<div class="space-y-4">
  <textarea id="aln-input" rows="8" placeholder="Paste your text here…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-3 flex-wrap items-end">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Start from</label>
      <input id="aln-start" type="number" value="1" min="0" class="w-24 bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Separator</label>
      <select id="aln-sep" class="bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500">
        <option value=". ">Period + space</option>
        <option value=": ">Colon + space</option>
        <option value="&#9;">Tab</option>
        <option value=" ">Space</option>
        <option value=") ">Parenthesis</option>
      </select>
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer mb-0.5">
      <input type="checkbox" id="aln-pad" checked class="accent-violet-500"> Pad numbers
    </label>
    <button id="aln-do" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Add Numbers</button>
    <button id="aln-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="aln-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span id="aln-stats" class="text-xs text-slate-500">Result</span>
      <button id="aln-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="aln-output" rows="8" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  const input = document.getElementById('aln-input');
  const output = document.getElementById('aln-output');
  const wrap = document.getElementById('aln-output-wrap');
  const stats = document.getElementById('aln-stats');
  const startEl = document.getElementById('aln-start');
  const sepEl = document.getElementById('aln-sep');
  const padCb = document.getElementById('aln-pad');
  const saved = localStorage.getItem('tw-add-line-numbers');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-add-line-numbers', input.value));
  document.getElementById('aln-do').addEventListener('click', () => {
    const lines = input.value.split('\n');
    const start = parseInt(startEl.value) || 1;
    const sep = sepEl.value;
    const pad = padCb.checked ? String(start + lines.length - 1).length : 0;
    output.value = lines.map((line, i) => `${String(start + i).padStart(pad, ' ')}${sep}${line}`).join('\n');
    stats.textContent = `${lines.length} lines numbered`;
    wrap.classList.remove('hidden');
  });
  document.getElementById('aln-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); localStorage.removeItem('tw-add-line-numbers'); });
  document.getElementById('aln-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
