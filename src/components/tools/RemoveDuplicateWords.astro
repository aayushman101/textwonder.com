---
---

<div class="space-y-4">
  <div class="flex flex-wrap gap-4">
    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
      <input id="rdw-case" type="checkbox" class="w-4 h-4 accent-violet-600" />
      Case-sensitive matching
    </label>
    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
      <input id="rdw-per-line" type="checkbox" class="w-4 h-4 accent-violet-600" />
      Per line (reset duplicate tracking each line)
    </label>
  </div>
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Input Text</label>
    <textarea id="rdw-input" rows="6" placeholder="Paste text with repeated words..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"></textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Output (duplicates removed) <span id="rdw-info" class="text-xs text-slate-500"></span></label>
      <button id="rdw-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea id="rdw-output" rows="6" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y outline-none text-sm"></textarea>
  </div>
</div>

<script>
function dedup(text, caseSens, perLine) {
  function dedupWords(str) {
    const seen = new Set();
    return str.split(/(\s+)/).filter(token => {
      if (/^\s+$/.test(token)) return true;
      const key = caseSens ? token : token.toLowerCase();
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    }).join('');
  }
  if (perLine) return text.split('\n').map(dedupWords).join('\n');
  return dedupWords(text);
}

function process() {
  const text = document.getElementById('rdw-input').value;
  const caseSens = document.getElementById('rdw-case').checked;
  const perLine = document.getElementById('rdw-per-line').checked;
  const result = dedup(text, caseSens, perLine);
  document.getElementById('rdw-output').value = result;
  const before = text.split(/\s+/).filter(Boolean).length;
  const after = result.split(/\s+/).filter(Boolean).length;
  document.getElementById('rdw-info').textContent = before > 0 ? `${before - after} duplicate(s) removed` : '';
}

document.getElementById('rdw-input').addEventListener('input', process);
['rdw-case','rdw-per-line'].forEach(id => document.getElementById(id).addEventListener('change', process));
document.getElementById('rdw-copy').addEventListener('click', () => {
  const val = document.getElementById('rdw-output').value;
  if (!val) return;
  navigator.clipboard.writeText(val);
  const btn = document.getElementById('rdw-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = 'Copy', 1500);
});
</script>
