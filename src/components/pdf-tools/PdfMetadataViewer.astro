---
---
<div class="space-y-5">
  <div id="pmv-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pmv-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🔍</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">View, edit, and export PDF metadata — or strip it for privacy</p>
  </div>

  <div id="pmv-panel" class="hidden space-y-4">
    <!-- File info bar -->
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="pmv-fname" class="text-slate-200 text-sm font-medium truncate"></p>
        <p id="pmv-finfo" class="text-slate-500 text-xs"></p>
      </div>
      <button id="pmv-change" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 px-3 py-1.5 rounded-lg shrink-0">Change</button>
    </div>

    <!-- Read-only info -->
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">File Information</h3>
        <div class="flex gap-2">
          <button id="pmv-copy-json" class="text-xs text-orange-400 hover:text-orange-300 border border-slate-700 hover:border-orange-700 px-2.5 py-1 rounded-lg transition-colors">Copy as JSON</button>
          <button id="pmv-strip-all" class="text-xs text-red-400 hover:text-red-300 border border-red-900/40 hover:border-red-700 px-2.5 py-1 rounded-lg transition-colors">Strip all metadata</button>
        </div>
      </div>
      <div id="pmv-readonly-fields" class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-0"></div>
    </div>

    <!-- Editable fields -->
    <div class="space-y-3">
      <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Edit Metadata</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Title</label>
          <input id="pmv-e-title" type="text" placeholder="Document title" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Author</label>
          <input id="pmv-e-author" type="text" placeholder="Author name" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Subject</label>
          <input id="pmv-e-subject" type="text" placeholder="Document subject" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Creator</label>
          <input id="pmv-e-creator" type="text" placeholder="Creating application" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="sm:col-span-2 space-y-1">
          <label class="text-xs text-slate-500">Keywords</label>
          <input id="pmv-e-keywords" type="text" placeholder="comma-separated keywords" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-600 text-sm focus:outline-none focus:border-orange-500" />
        </div>
      </div>
      <div class="flex gap-2">
        <button id="pmv-save" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Save & Download</button>
        <button id="pmv-clear-fields" class="px-4 py-2 border border-slate-700 text-slate-400 hover:text-slate-300 rounded-lg text-sm transition-colors">Clear fields</button>
      </div>
    </div>
  </div>

  <div id="pmv-status" class="hidden text-sm py-2"></div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('pmv-drop');
  const fileInput = document.getElementById('pmv-file');
  const panel = document.getElementById('pmv-panel');
  const status = document.getElementById('pmv-status');
  let currentFile = null, pdfBytes = null, cachedMeta = {};

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  async function loadFile(file) {
    if (!file || (!file.type.includes('pdf') && !file.name.endsWith('.pdf'))) return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      pdfBytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const pageCount = doc.getPageCount();
      currentFile = file;

      const firstPage = doc.getPage(0);
      const { width, height } = firstPage.getSize();
      const wMm = (width * 25.4 / 72).toFixed(0);
      const hMm = (height * 25.4 / 72).toFixed(0);

      cachedMeta = {
        title:    doc.getTitle()    || '',
        author:   doc.getAuthor()   || '',
        subject:  doc.getSubject()  || '',
        keywords: doc.getKeywords() || '',
        creator:  doc.getCreator()  || '',
        producer: doc.getProducer() || '',
        created:  doc.getCreationDate() ? doc.getCreationDate().toLocaleString() : '',
        modified: doc.getModificationDate() ? doc.getModificationDate().toLocaleString() : '',
        pages: pageCount,
        fileSize: file.size,
        pageDim: `${wMm} × ${hMm} mm`,
      };

      document.getElementById('pmv-fname').textContent = file.name;
      document.getElementById('pmv-finfo').textContent = `${pageCount} pages · ${(file.size/1024).toFixed(0)} KB`;

      const roFields = [
        { label: 'Pages', value: pageCount },
        { label: 'File size', value: (file.size/1024).toFixed(0) + ' KB' },
        { label: 'Page size', value: cachedMeta.pageDim },
        { label: 'Producer', value: cachedMeta.producer || '—' },
        { label: 'Created', value: cachedMeta.created || '—' },
        { label: 'Modified', value: cachedMeta.modified || '—' },
      ];
      document.getElementById('pmv-readonly-fields').innerHTML = roFields.map(f => `
        <div class="flex justify-between items-center gap-2 py-1.5 border-b border-slate-800/60">
          <span class="text-xs text-slate-500 shrink-0">${f.label}</span>
          <span class="text-xs text-slate-300 font-mono text-right truncate" title="${f.value}">${f.value}</span>
        </div>
      `).join('');

      document.getElementById('pmv-e-title').value   = cachedMeta.title;
      document.getElementById('pmv-e-author').value  = cachedMeta.author;
      document.getElementById('pmv-e-subject').value = cachedMeta.subject;
      document.getElementById('pmv-e-creator').value = cachedMeta.creator;
      document.getElementById('pmv-e-keywords').value = cachedMeta.keywords;

      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
    } catch(e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('pmv-copy-json').addEventListener('click', () => {
    const data = {
      title:    document.getElementById('pmv-e-title').value    || cachedMeta.title,
      author:   document.getElementById('pmv-e-author').value   || cachedMeta.author,
      subject:  document.getElementById('pmv-e-subject').value  || cachedMeta.subject,
      keywords: document.getElementById('pmv-e-keywords').value || cachedMeta.keywords,
      creator:  document.getElementById('pmv-e-creator').value  || cachedMeta.creator,
      producer: cachedMeta.producer,
      created:  cachedMeta.created,
      modified: cachedMeta.modified,
      pages:    cachedMeta.pages,
      pageSize: cachedMeta.pageDim,
      fileSize: cachedMeta.fileSize + ' bytes',
    };
    navigator.clipboard.writeText(JSON.stringify(data, null, 2)).then(() => {
      showStatus('✅ Metadata copied as JSON', 'success');
    }).catch(() => showStatus('Could not copy to clipboard', 'error'));
  });

  document.getElementById('pmv-strip-all').addEventListener('click', async () => {
    if (!confirm('Remove all metadata (title, author, subject, keywords, creator, producer)? The download will have no embedded identity information.')) return;
    showStatus('Stripping metadata…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      doc.setTitle(''); doc.setAuthor(''); doc.setSubject('');
      doc.setKeywords([]); doc.setCreator(''); doc.setProducer('');
      const out = await doc.save();
      const baseName = currentFile.name.replace(/\.pdf$/i, '');
      downloadBytes(out, `${baseName}-stripped.pdf`);
      ['pmv-e-title','pmv-e-author','pmv-e-subject','pmv-e-creator','pmv-e-keywords'].forEach(id => {
        document.getElementById(id).value = '';
      });
      showStatus('✅ All metadata stripped — PDF downloaded', 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pmv-save').addEventListener('click', async () => {
    if (!currentFile) return;
    showStatus('Saving…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const title   = document.getElementById('pmv-e-title').value.trim();
      const author  = document.getElementById('pmv-e-author').value.trim();
      const subject = document.getElementById('pmv-e-subject').value.trim();
      const creator = document.getElementById('pmv-e-creator').value.trim();
      const kw      = document.getElementById('pmv-e-keywords').value.trim();
      if (title)   doc.setTitle(title);
      if (author)  doc.setAuthor(author);
      if (subject) doc.setSubject(subject);
      if (creator) doc.setCreator(creator);
      if (kw)      doc.setKeywords(kw.split(',').map(k => k.trim()).filter(Boolean));
      const out = await doc.save();
      const baseName = currentFile.name.replace(/\.pdf$/i, '');
      downloadBytes(out, `${baseName}-meta.pdf`);
      showStatus('✅ Metadata saved — PDF downloaded', 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pmv-clear-fields').addEventListener('click', () => {
    ['pmv-e-title','pmv-e-author','pmv-e-subject','pmv-e-creator','pmv-e-keywords'].forEach(id => {
      document.getElementById(id).value = '';
    });
  });

  document.getElementById('pmv-change').addEventListener('click', () => {
    currentFile = null; pdfBytes = null; cachedMeta = {};
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
