---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: 'how-to-count-words-online',
    title: 'How to Count Words Online: The Complete Free Guide',
    description: 'Learn how to count words online for free. Discover why word count matters for SEO, essays, social media, and publishing.',
    date: '2025-06-15',
    readTime: '5 min read',
    category: 'Writing Tips',
  },
  {
    slug: 'title-case-guide',
    title: 'What Is Title Case? Rules, Examples & When to Use It',
    description: 'Master title case capitalization rules. Learn which words to capitalize and when to use title case vs sentence case.',
    date: '2025-06-12',
    readTime: '6 min read',
    category: 'Writing Tips',
  },
  {
    slug: 'word-count-vs-character-count',
    title: 'Word Count vs Character Count: Key Differences & When Each Matters',
    description: 'Word count and character count measure different things. Learn when to use each for social media, SMS, essays, and SEO.',
    date: '2025-06-08',
    readTime: '5 min read',
    category: 'Text Analysis',
  },
  {
    slug: 'remove-duplicate-lines-guide',
    title: 'How to Remove Duplicate Lines from Text: 3 Fast Methods',
    description: 'Remove duplicate lines from text files, lists, and CSV files. Covers online tools, Excel, Google Sheets, and terminal commands.',
    date: '2025-06-10',
    readTime: '4 min read',
    category: 'Text Cleaning',
  },
  {
    slug: 'text-case-converter-guide',
    title: 'How to Convert Text Case: Uppercase, Lowercase, Title Case & More',
    description: 'Learn how to convert text to any case type: uppercase, lowercase, title case, camelCase, snake_case, and kebab-case.',
    date: '2025-06-05',
    readTime: '5 min read',
    category: 'Text Conversion',
  },
  {
    slug: 'what-is-base64-encoding',
    title: 'What Is Base64 Encoding? A Plain-English Guide',
    description: 'Base64 explained simply. Learn what it is, why it exists, when it\'s used, and how to encode and decode Base64 online.',
    date: '2025-06-02',
    readTime: '6 min read',
    category: 'Developer Tools',
  },
  {
    slug: 'free-online-text-tools-for-writers',
    title: '10 Free Online Text Tools Every Writer Should Know',
    description: '10 essential free online text tools for writers and bloggers. Save hours every week with these browser-based utilities.',
    date: '2025-05-28',
    readTime: '7 min read',
    category: 'Productivity',
  },
  {
    slug: 'readability-score-guide',
    title: 'How to Check Your Writing\'s Readability Score',
    description: 'Learn how readability scores work, what Flesch-Kincaid grade level means, and how to improve your writing for wider audiences.',
    date: '2025-05-22',
    readTime: '6 min read',
    category: 'Writing Tips',
  },
  {
    slug: 'how-to-sort-text-lines',
    title: 'How to Sort Lines of Text Alphabetically: 4 Methods',
    description: 'Sort lines alphabetically, numerically, or randomly using free online tools, Excel, Google Sheets, and the command line.',
    date: '2025-05-18',
    readTime: '4 min read',
    category: 'Text Formatting',
  },
];

const categoryColors: Record<string, string> = {
  'Writing Tips': '#7c3aed',
  'Text Analysis': '#0891b2',
  'Text Cleaning': '#15803d',
  'Text Conversion': '#c2410c',
  'Developer Tools': '#0e7490',
  'Productivity': '#b45309',
  'Text Formatting': '#4338ca',
};

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'TextWonder Blog',
  description: 'Writing tips, text tool guides, and productivity articles from TextWonder.',
  url: 'https://textwonder.com/blog',
  publisher: { '@type': 'Organization', name: 'TextWonder', url: 'https://textwonder.com' },
};
---

<BaseLayout
  title="Blog — Writing Tips, Text Tool Guides & Productivity | TextWonder"
  description="Writing tips, text tool guides, and productivity articles. Learn word counting, readability, text case conversion, Base64, and more — all free."
  canonical="/blog"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <Header />

  <main class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-12">
      <div class="inline-flex items-center gap-2 bg-violet-900/30 border border-violet-800/40 rounded-full px-4 py-1.5 text-violet-300 text-sm font-medium mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        The TextWonder Blog
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-3" style="font-family: 'Space Grotesk', sans-serif;">
        Writing Tips & Text Tool Guides
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl">
        Practical guides on word counting, readability, text formatting, case conversion, and developer tools. All articles are free and written for writers, developers, and anyone who works with text.
      </p>
    </header>

    <!-- Article grid -->
    <div class="space-y-5">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`} class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-6 hover:border-violet-500/40 hover:bg-[var(--bg-surface-hover)] transition-all">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border"
                  style={`color: ${categoryColors[post.category] || '#7c3aed'}; background: ${categoryColors[post.category] || '#7c3aed'}15; border-color: ${categoryColors[post.category] || '#7c3aed'}30`}>
                  {post.category}
                </span>
                <span class="text-slate-600 text-xs">·</span>
                <span class="text-slate-500 text-xs">{post.readTime}</span>
                <span class="text-slate-600 text-xs">·</span>
                <time class="text-slate-500 text-xs" datetime={post.date}>{formatDate(post.date)}</time>
              </div>
              <h2 class="text-white font-semibold text-lg mb-1.5 group-hover:text-violet-300 transition-colors leading-snug">{post.title}</h2>
              <p class="text-slate-400 text-sm leading-relaxed line-clamp-2">{post.description}</p>
            </div>
            <svg class="w-5 h-5 text-slate-600 group-hover:text-violet-400 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">Ready to use the tools?</h2>
      <p class="text-slate-400 text-sm mb-5">61+ free browser-based text tools. No signup, no ads, works on all devices.</p>
      <a href="/tools" class="inline-flex items-center gap-2 bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
        Browse All Text Tools
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>
