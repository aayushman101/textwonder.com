  'longest-word-finder': {
    bg: '#0369a1',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 12h16M4 6l6 6-6 6M20 6l-6 6 6 6"/></svg>`,
  },
  'shortest-word-finder': {
    bg: '#15803d',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 8v8M8 12l4-4 4 4M8 12l4 4 4-4" stroke-width="0"/><path d="M12 4v16M9 7l3-3 3 3M9 17l3 3 3-3"/></svg>`,
  },
  'vocabulary-richness': {
    bg: '#6d28d9',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  'text-density': {
    bg: '#b45309',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8h10M7 12h10M7 16h6"/></svg>`,
  },
  'keyword-density-checker': {
    bg: '#1d4ed8',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M8 11h6M11 8v6"/></svg>`,
  },
  'stop-word-percentage': {
    bg: '#0891b2',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2z"/><path d="M8 12h8M12 8l-4 4 4 4"/></svg>`,
  },
  'repeated-phrase-detector': {
    bg: '#7c3aed',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 013.51 15"/></svg>`,
  },
  'n-gram-analyzer': {
    bg: '#0f766e',
    iconHtml: `<span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:15px;color:white;letter-spacing:-0.5px;line-height:1">N-g</span>`,
  },
  'lexical-diversity': {
    bg: '#4338ca',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12a4 4 0 018 0"/><path d="M9 9l1.5 1.5"/><path d="M15 9l-1.5 1.5"/></svg>`,
  },
  'readability-score': {
    bg: '#7c3aed',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
  },
  'grade-level-checker': {
    bg: '#b45309',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  },
  'palindrome-checker': {
    bg: '#0284c7',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14M5 12l4-4M5 12l4 4M19 12l-4-4M19 12l-4 4"/></svg>`,
