---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PDFHeader from '../../components/PDFHeader.astro';
import Footer from '../../components/Footer.astro';
import { PDF_TOOLS } from '../../data/pdftools.js';
import ToolSearchBar from '../../components/ToolSearchBar.astro';
---

<BaseLayout
  title="Free Online PDF Tools — Merge, Split, Convert & More | PDFWonder"
  description="PDFWonder offers 10 free browser-based PDF tools. Merge, split, rotate, compress, watermark and convert PDFs. No upload, no signup, 100% private."
  canonical="/pdfwonder"
>
  <PDFHeader />

  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 pt-12 pb-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange-950/50 border border-orange-800/40 text-orange-400 text-xs font-medium mb-5">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/></svg>
        100% browser-based — your files never leave your device
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-3" style="font-family: 'Space Grotesk', sans-serif;">
        PDF tools that respect<br class="hidden sm:block" /> your privacy
      </h1>
      <p class="text-slate-400 text-lg max-w-xl mx-auto mb-5">
        Free, browser-based PDF utilities. Merge, split, rotate, compress, watermark and more — no files uploaded anywhere.
      </p>
      <div class="inline-flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <span><strong class="text-orange-400 font-semibold">{PDF_TOOLS.length}</strong> PDF tools</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-orange-400 font-semibold">100%</strong> browser-based</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-orange-400 font-semibold">0</strong> files uploaded</span>
      </div>
    </section>

    <!-- Tools Grid -->
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <ToolSearchBar accentColor="#f97316" placeholder="Search PDF tools…" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {PDF_TOOLS.map(tool => (
          <a
            href={`/pdfwonder/${tool.slug}`}
            data-tool-card
            data-name={tool.name}
            data-tagline={tool.tagline}
            class="group block bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-5 hover:border-orange-500/50 hover:bg-[var(--bg-surface-hover)] transition-all"
          >
            <div class="flex items-start gap-4 mb-3">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 text-xl" style={`background:${tool.iconBg}`}>
                {tool.icon}
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-white font-semibold text-base group-hover:text-orange-400 transition-colors">{tool.name}</h2>
                <p class="text-slate-400 text-sm leading-snug mt-0.5">{tool.tagline}</p>
              </div>
            </div>
            <div class="flex items-center text-xs text-orange-400/60 group-hover:text-orange-400 transition-colors font-medium">
              Open tool
              <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Trust section -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-8 text-center">
        <div class="text-3xl mb-3">🔒</div>
        <h2 class="text-xl font-bold text-white mb-2" style="font-family:'Space Grotesk',sans-serif;">Your files stay on your device</h2>
        <p class="text-slate-400 text-sm leading-relaxed max-w-lg mx-auto">
          All PDF processing uses <strong class="text-slate-300">pdf-lib</strong> and <strong class="text-slate-300">PDF.js</strong> running entirely in your browser.
          No files are uploaded, stored, or transmitted. Even your internet can be off after the page loads.
        </p>
      </div>
    </section>

    <!-- Also try TextWonder -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between bg-[var(--bg-surface)] border border-violet-800/30 rounded-2xl p-5">
        <div>
          <p class="text-sm text-slate-400">Looking for text tools?</p>
          <p class="text-white font-semibold" style="font-family:'Space Grotesk',sans-serif;">Text<span class="text-violet-400">Wonder</span> — 61 free text utilities</p>
        </div>
        <a href="/" class="shrink-0 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">
          Visit TextWonder →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
