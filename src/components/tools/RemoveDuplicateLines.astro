---
---

<div class="space-y-4">
  <div class="flex flex-wrap gap-4 items-center">
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" id="rdl-case" class="accent-violet-600" />
      <span class="text-slate-300 text-sm">Case-insensitive matching</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" id="rdl-sort" class="accent-violet-600" />
      <span class="text-slate-300 text-sm">Sort output</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" id="rdl-blanks" class="accent-violet-600" />
      <span class="text-slate-300 text-sm">Remove blank lines</span>
    </label>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Lines</label>
      <span id="rdl-input-count" class="text-xs text-slate-500">0 lines</span>
    </div>
    <textarea
      id="rdl-input"
      rows="8"
      placeholder="Paste your list here, one item per line..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="rdl-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      Remove Duplicates
    </button>
    <button id="rdl-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Unique Lines</label>
      <div class="flex items-center gap-2">
        <span id="rdl-output-count" class="text-xs text-slate-500">0 lines</span>
        <button id="rdl-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
    </div>
    <textarea
      id="rdl-output"
      rows="8"
      readonly
      placeholder="Unique lines will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<div id="rdl-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('rdl-input') as HTMLTextAreaElement;
  const output = document.getElementById('rdl-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('rdl-input-count')!;
  const outputCount = document.getElementById('rdl-output-count')!;
  const caseCheck = document.getElementById('rdl-case') as HTMLInputElement;
  const sortCheck = document.getElementById('rdl-sort') as HTMLInputElement;
  const blanksCheck = document.getElementById('rdl-blanks') as HTMLInputElement;
  const processBtn = document.getElementById('rdl-process')!;
  const clearBtn = document.getElementById('rdl-clear')!;
  const copyBtn = document.getElementById('rdl-copy')!;
  const toast = document.getElementById('rdl-toast')!;
  const STORAGE_KEY = 'tw-remove-duplicate-lines';

  function process() {
    const caseInsensitive = caseCheck.checked;
    const shouldSort = sortCheck.checked;
    const removeBlanks = blanksCheck.checked;
    let lines = input.value.split('\n');
    if (removeBlanks) lines = lines.filter(l => l.trim());
    const seen = new Set<string>();
    const unique = lines.filter(line => {
      const key = caseInsensitive ? line.toLowerCase() : line;
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });
    if (shouldSort) unique.sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
    const result = unique.join('\n');
    output.value = result;
    const lineCount = result ? unique.length : 0;
    outputCount.textContent = `${lineCount} line${lineCount !== 1 ? 's' : ''}`;
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  function showToast() {
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  input.addEventListener('input', () => {
    const lines = input.value ? input.value.split('\n').length : 0;
    inputCount.textContent = `${lines} line${lines !== 1 ? 's' : ''}`;
    process();
  });
  [caseCheck, sortCheck, blanksCheck].forEach(el => el.addEventListener('change', process));
  processBtn.addEventListener('click', process);
  clearBtn.addEventListener('click', () => {
    input.value = ''; output.value = '';
    inputCount.textContent = '0 lines'; outputCount.textContent = '0 lines';
    localStorage.removeItem(STORAGE_KEY);
  });
  copyBtn.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value).then(showToast);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; const l = saved.split('\n').length; inputCount.textContent = `${l} lines`; process(); }
</script>
