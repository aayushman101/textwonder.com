const faqs = [
  { q: 'How does the tool detect blank pages?', a: 'It analyses the text content of each page using PDF.js. Pages with fewer characters of extractable text than your chosen threshold are classified as blank and removed. You can adjust the threshold slider to be more or less aggressive.' },
  { q: 'Will it remove pages that have only images?', a: 'Yes — if a page has no text layer (for example, a full-page scanned image or a diagram with no text), it is treated as blank. If you want to keep image-only pages, increase the threshold slider to zero so only completely empty pages are removed.' },
  { q: 'Does it work on scanned PDFs?', a: 'Scanned PDFs typically have no text layer at all, so all pages would be detected as blank. Run the scanned PDF through an OCR tool first to add a text layer, then use this tool to remove genuinely blank pages.' },
  { q: 'Can I undo if it removes the wrong pages?', a: 'Your original file is never modified — the tool creates a new PDF and downloads it. Simply run the tool again on the original file with a different threshold setting.' },
  { q: 'What if all pages are detected as blank?', a: 'If the threshold is set too high, or the PDF is scanned without a text layer, the tool will warn you rather than produce an empty PDF. Lower the threshold or use an OCR tool first.' },
  { q: 'Is my PDF uploaded anywhere?', a: 'No. All processing uses PDF.js and pdf-lib running entirely in your browser. Your file never leaves your device.' },
];
