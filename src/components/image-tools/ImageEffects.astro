---
---
<div class="max-w-2xl mx-auto space-y-6">
  <!-- Drop Zone -->
  <div id="ie-drop" class="border-2 border-dashed border-slate-600 rounded-2xl p-10 text-center cursor-pointer hover:border-rose-500 transition-colors">
    <div class="text-4xl mb-3">✨</div>
    <p class="text-slate-300 font-medium mb-1">Drop an image here or click to select</p>
    <p class="text-slate-500 text-sm">JPG, PNG, WebP supported</p>
    <input id="ie-input" type="file" accept="image/*" class="hidden" />
  </div>

  <!-- Editor -->
  <div id="ie-editor" class="hidden space-y-5">
    <!-- Filter Grid -->
    <div>
      <p class="text-slate-400 text-sm mb-3">Click a filter to apply it</p>
      <div id="ie-filters" class="grid grid-cols-3 sm:grid-cols-4 gap-3"></div>
    </div>

    <!-- Intensity slider for applicable filters -->
    <div id="ie-intensity-wrap" class="hidden bg-slate-800/50 rounded-xl p-4">
      <div class="flex justify-between text-sm mb-1">
        <span class="text-slate-300">Intensity</span>
        <span id="ie-intv" class="text-rose-400 font-mono">100%</span>
      </div>
      <input id="ie-intensity" type="range" min="0" max="100" value="100" class="w-full accent-rose-500" />
    </div>

    <!-- Preview -->
    <div class="rounded-xl overflow-hidden border border-slate-700 bg-slate-900">
      <canvas id="ie-canvas" class="w-full max-h-80 object-contain block"></canvas>
    </div>

    <!-- Actions -->
    <div class="flex gap-3">
      <button id="ie-download-jpg" class="flex-1 py-3 rounded-xl font-semibold text-white" style="background:#f43f5e">Download JPG</button>
      <button id="ie-download-png" class="px-5 py-3 rounded-xl border border-slate-600 text-slate-300 hover:border-rose-500 hover:text-white transition-colors">PNG</button>
      <button id="ie-new" class="px-4 py-3 rounded-xl border border-slate-600 text-slate-400 hover:border-slate-500 transition-colors text-sm">New</button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('ie-drop');
  const input = document.getElementById('ie-input');
  const editor = document.getElementById('ie-editor');
  const canvas = document.getElementById('ie-canvas');
  const ctx = canvas.getContext('2d');
  const filtersGrid = document.getElementById('ie-filters');
  const intensityWrap = document.getElementById('ie-intensity-wrap');
  const intensityEl = document.getElementById('ie-intensity');
  const intvEl = document.getElementById('ie-intv');

  const FILTERS = [
    { id: 'none',      name: 'Original',    hasIntensity: false },
    { id: 'grayscale', name: 'Grayscale',   hasIntensity: false },
    { id: 'sepia',     name: 'Sepia',       hasIntensity: true  },
    { id: 'invert',    name: 'Invert',      hasIntensity: false },
    { id: 'vintage',   name: 'Vintage',     hasIntensity: true  },
    { id: 'cool',      name: 'Cool',        hasIntensity: true  },
    { id: 'warm',      name: 'Warm',        hasIntensity: true  },
    { id: 'fade',      name: 'Fade',        hasIntensity: true  },
    { id: 'highcon',   name: 'High Contrast', hasIntensity: false },
    { id: 'blur',      name: 'Soft Blur',   hasIntensity: false },
    { id: 'sharpen',   name: 'Sharpen',     hasIntensity: false },
    { id: 'vignette',  name: 'Vignette',    hasIntensity: true  },
  ];

  let sourceImg = null;
  let activeFilter = 'none';
  let thumbCanvases = {};

  drop.addEventListener('click', () => input.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.style.borderColor = '#f43f5e'; });
  drop.addEventListener('dragleave', () => drop.style.borderColor = '');
  drop.addEventListener('drop', e => { e.preventDefault(); drop.style.borderColor = ''; loadFile(e.dataTransfer.files[0]); });
  input.addEventListener('change', () => loadFile(input.files[0]));

  function loadFile(f) {
    if (!f || !f.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = e => {
      sourceImg = new Image();
      sourceImg.onload = () => {
        canvas.width = sourceImg.naturalWidth;
        canvas.height = sourceImg.naturalHeight;
        buildFilterGrid();
        applyFilter('none');
        drop.classList.add('hidden');
        editor.classList.remove('hidden');
      };
      sourceImg.src = e.target.result;
    };
    reader.readAsDataURL(f);
  }

  function buildFilterGrid() {
    filtersGrid.innerHTML = '';
    thumbCanvases = {};
    FILTERS.forEach(f => {
      const tc = document.createElement('canvas');
      const THUMB = 80;
      tc.width = THUMB; tc.height = THUMB;
      const tc2 = tc.getContext('2d');
      const scale = Math.min(THUMB / sourceImg.naturalWidth, THUMB / sourceImg.naturalHeight);
      const tw = sourceImg.naturalWidth * scale, th = sourceImg.naturalHeight * scale;
      tc2.drawImage(sourceImg, (THUMB-tw)/2, (THUMB-th)/2, tw, th);
      applyFilterToCtx(tc2, THUMB, THUMB, f.id, 100);
      thumbCanvases[f.id] = tc;

      const div = document.createElement('div');
      div.className = 'cursor-pointer rounded-xl overflow-hidden border-2 transition-all ' + (f.id === 'none' ? 'border-rose-500' : 'border-transparent hover:border-slate-500');
      div.dataset.fid = f.id;
      div.innerHTML = `<div class="relative"><img src="${tc.toDataURL()}" class="w-full aspect-square object-cover" /><p class="text-center text-xs text-slate-300 py-1 bg-slate-900">${f.name}</p></div>`;
      div.addEventListener('click', () => {
        filtersGrid.querySelectorAll('[data-fid]').forEach(d => d.className = d.className.replace('border-rose-500', 'border-transparent'));
        div.className = div.className.replace('border-transparent', 'border-rose-500');
        activeFilter = f.id;
        const fObj = FILTERS.find(x => x.id === f.id);
        intensityWrap.classList.toggle('hidden', !fObj.hasIntensity);
        applyFilter(f.id);
      });
      filtersGrid.appendChild(div);
    });
  }

  function applyFilter(fid) {
    if (!sourceImg) return;
    ctx.drawImage(sourceImg, 0, 0);
    const intv = +intensityEl.value;
    applyFilterToCtx(ctx, canvas.width, canvas.height, fid, intv);
  }

  function applyFilterToCtx(c, w, h, fid, intv) {
    if (fid === 'none') return;
    if (fid === 'grayscale') { const d = getPixels(c,w,h); toGrayscale(d); c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'sepia') { const d = getPixels(c,w,h); toSepia(d, intv/100); c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'invert') { const d = getPixels(c,w,h); const px = d; for(let i=0;i<px.length;i+=4){px[i]=255-px[i];px[i+1]=255-px[i+1];px[i+2]=255-px[i+2];} c.putImageData(new ImageData(px,w,h),0,0); return; }
    if (fid === 'vintage') { const d = getPixels(c,w,h); toSepia(d,0.5*intv/100); vignette(d,w,h,0.5*intv/100); c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'cool') { const d = getPixels(c,w,h); const f=(intv/100)*30; for(let i=0;i<d.length;i+=4){d[i]=Math.max(0,d[i]-f);d[i+2]=Math.min(255,d[i+2]+f);} c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'warm') { const d = getPixels(c,w,h); const f=(intv/100)*30; for(let i=0;i<d.length;i+=4){d[i]=Math.min(255,d[i]+f);d[i+2]=Math.max(0,d[i+2]-f);} c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'fade') { const d = getPixels(c,w,h); const f=(intv/100)*80; for(let i=0;i<d.length;i+=4){d[i]=Math.min(255,d[i]+f);d[i+1]=Math.min(255,d[i+1]+f);d[i+2]=Math.min(255,d[i+2]+f);} c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'highcon') { c.filter = 'contrast(200%) brightness(90%)'; c.drawImage(c.canvas||{width:w,height:h}, 0,0); c.filter='none'; return; }
    if (fid === 'blur') { c.filter = 'blur(2px)'; c.drawImage(c.canvas||{width:w,height:h}, 0,0); c.filter='none'; return; }
    if (fid === 'sharpen') { const d = getPixels(c,w,h); unsharp(d,w,h,2); c.putImageData(new ImageData(d,w,h),0,0); return; }
    if (fid === 'vignette') { const d = getPixels(c,w,h); vignette(d,w,h,intv/100); c.putImageData(new ImageData(d,w,h),0,0); return; }
  }

  function getPixels(c,w,h) { return c.getImageData(0,0,w,h).data; }
  function toGrayscale(d) { for(let i=0;i<d.length;i+=4){const g=d[i]*0.299+d[i+1]*0.587+d[i+2]*0.114;d[i]=d[i+1]=d[i+2]=g;} }
  function toSepia(d,s) { for(let i=0;i<d.length;i+=4){const r=d[i],g=d[i+1],b=d[i+2];d[i]=Math.min(255,r*(1-0.607*s)+g*0.769*s+b*0.189*s);d[i+1]=Math.min(255,r*0.349*s+g*(1-0.314*s)+b*0.168*s);d[i+2]=Math.min(255,r*0.272*s+g*0.534*s+b*(1-0.869*s));} }
  function vignette(d,w,h,str) { const cx=w/2,cy=h/2,maxD=Math.sqrt(cx*cx+cy*cy); for(let y=0;y<h;y++){for(let x=0;x<w;x++){const dist=Math.sqrt((x-cx)**2+(y-cy)**2)/maxD;const factor=1-str*dist*dist;const i=(y*w+x)*4;d[i]=d[i]*factor;d[i+1]=d[i+1]*factor;d[i+2]=d[i+2]*factor;}} }
  function unsharp(d,w,h,amt) { const bl=new Uint8ClampedArray(d); for(let y=1;y<h-1;y++){for(let x=1;x<w-1;x++){for(let c=0;c<3;c++){let s=0;[[-1,0],[1,0],[0,-1],[0,1]].forEach(([dy,dx])=>{s+=d[((y+dy)*w+(x+dx))*4+c]});bl[(y*w+x)*4+c]=s/4;}}} for(let i=0;i<d.length;i+=4){for(let c=0;c<3;c++){d[i+c]=Math.min(255,Math.max(0,d[i+c]+amt*(d[i+c]-bl[i+c])));}} }

  intensityEl.addEventListener('input', () => { intvEl.textContent = intensityEl.value + '%'; if(sourceImg){ctx.drawImage(sourceImg,0,0); applyFilter(activeFilter);} });

  document.getElementById('ie-new').addEventListener('click', () => {
    sourceImg = null; input.value = '';
    editor.classList.add('hidden'); drop.classList.remove('hidden');
  });

  document.getElementById('ie-download-jpg').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/jpeg', 0.93);
    a.download = 'filtered.jpg'; a.click();
  });
  document.getElementById('ie-download-png').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png');
    a.download = 'filtered.png'; a.click();
  });
})();
</script>
