---
---

<div class="space-y-4">
  <div class="flex flex-wrap gap-4">
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" id="res-blanks" class="accent-violet-600" />
      <span class="text-slate-300 text-sm">Also remove blank lines</span>
    </label>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Input Text</label>
      <span id="res-input-count" class="text-xs text-slate-500">0 characters</span>
    </div>
    <textarea
      id="res-input"
      rows="8"
      placeholder="Paste text with extra spaces, tabs, or whitespace..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"
    ></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button id="res-process" class="bg-violet-700 hover:bg-violet-600 text-white font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
      Remove Extra Spaces
    </button>
    <button id="res-clear" class="bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 font-medium px-4 py-2.5 rounded-xl transition-colors text-sm">
      Clear
    </button>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Cleaned Text</label>
      <div class="flex items-center gap-2">
        <span id="res-output-count" class="text-xs text-slate-500">0 characters</span>
        <button id="res-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
    </div>
    <textarea
      id="res-output"
      rows="8"
      readonly
      placeholder="Result will appear here..."
      class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none text-sm"
    ></textarea>
  </div>
</div>

<div id="res-toast" class="fixed bottom-6 right-6 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium opacity-0 pointer-events-none transition-opacity z-50">
  Copied!
</div>

<script>
  const input = document.getElementById('res-input') as HTMLTextAreaElement;
  const output = document.getElementById('res-output') as HTMLTextAreaElement;
  const inputCount = document.getElementById('res-input-count')!;
  const outputCount = document.getElementById('res-output-count')!;
  const blanksCheck = document.getElementById('res-blanks') as HTMLInputElement;
  const processBtn = document.getElementById('res-process')!;
  const clearBtn = document.getElementById('res-clear')!;
  const copyBtn = document.getElementById('res-copy')!;
  const toast = document.getElementById('res-toast')!;
  const STORAGE_KEY = 'tw-remove-extra-spaces';

  function process() {
    let lines = input.value.split('\n').map(l => l.replace(/[ \t ]+/g, ' ').trim());
    if (blanksCheck.checked) lines = lines.filter(l => l.length > 0);
    const result = lines.join('\n');
    output.value = result;
    outputCount.textContent = `${result.length} characters`;
    localStorage.setItem(STORAGE_KEY, input.value);
  }

  function showToast() {
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  input.addEventListener('input', () => {
    inputCount.textContent = `${input.value.length} characters`;
    process();
  });
  blanksCheck.addEventListener('change', process);
  processBtn.addEventListener('click', process);
  clearBtn.addEventListener('click', () => {
    input.value = ''; output.value = '';
    inputCount.textContent = '0 characters'; outputCount.textContent = '0 characters';
    localStorage.removeItem(STORAGE_KEY);
  });
  copyBtn.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value).then(showToast);
  });

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) { input.value = saved; inputCount.textContent = `${saved.length} characters`; process(); }
</script>
