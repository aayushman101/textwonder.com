---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Should I remove duplicates before or after sorting?', acceptedAnswer: { '@type': 'Answer', text: 'Either works. Removing duplicates first then sorting gives you a clean sorted list. Sorting first then removing duplicates groups identical entries together, making it easier to spot what\'s being removed. The final result is the same.' } },
    { '@type': 'Question', name: 'Does removing duplicates change the order of lines?', acceptedAnswer: { '@type': 'Answer', text: 'It depends on the tool. TextWonder\'s Remove Duplicate Lines tool preserves the original order by default (keeps first occurrence). The Unix `sort -u` command sorts alphabetically while removing duplicates.' } },
    { '@type': 'Question', name: 'Can I sort and remove duplicates at the same time?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. On the command line: `sort -u input.txt` sorts alphabetically and removes duplicates in one step. In TextWonder, run Sort Lines first, then Remove Duplicate Lines — two quick steps.' } },
    { '@type': 'Question', name: 'Which tool should I use for cleaning a keyword list?', acceptedAnswer: { '@type': 'Answer', text: 'For cleaning keyword lists: first use Remove Duplicate Lines (to deduplicate), then Sort Lines (to organise alphabetically). Both tools are free on TextWonder.' } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://textwonder.com' },
    { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://textwonder.com/compare' },
    { '@type': 'ListItem', position: 3, name: 'Remove Duplicates vs Sort Lines', item: 'https://textwonder.com/compare/remove-duplicate-lines-vs-sort-lines' },
  ],
};
---

<BaseLayout
  title="Remove Duplicate Lines vs Sort Lines: Differences & When to Use Each"
  description="Remove Duplicate Lines vs Sort Lines — understand the difference, when to use each tool, and how to combine them for clean text lists. Free online tools."
  canonical="/compare/remove-duplicate-lines-vs-sort-lines"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <main class="max-w-4xl mx-auto px-4 py-12">
    <nav class="flex items-center gap-1 text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/compare" class="hover:text-violet-400 transition-colors">Compare</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-slate-400">Remove Duplicates vs Sort Lines</span>
    </nav>

    <header class="mb-10">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-900/40 text-violet-300 border border-violet-800/50 mb-4">Comparison</span>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', sans-serif;">Remove Duplicate Lines vs Sort Lines: What's the Difference?</h1>
      <p class="text-slate-400 text-lg leading-relaxed">Two of the most common text list operations — they solve different problems but work best together. Here's when to use each.</p>
    </header>

    <!-- Side-by-side cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <div class="bg-[var(--bg-surface)] border border-blue-800/40 rounded-2xl p-6">
        <div class="text-blue-400 text-xs font-semibold uppercase tracking-wider mb-3">Remove Duplicate Lines</div>
        <p class="text-slate-400 text-sm mb-4">Removes repeated entries. Keeps the first occurrence of each unique line. Order of remaining lines is preserved.</p>
        <div class="bg-[var(--bg-base)] rounded-xl p-4 text-xs font-mono mb-4 space-y-0.5">
          <div class="text-slate-400">apple</div>
          <div class="text-red-400 line-through">banana</div>
          <div class="text-slate-400">cherry</div>
          <div class="text-red-400 line-through">apple</div>
          <div class="text-slate-400">banana</div>
          <div class="text-slate-500 text-[10px] mt-1">→ apple, cherry, banana</div>
        </div>
        <div class="space-y-2 text-sm text-slate-400 mb-5">
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Deduplicating email lists</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Cleaning keyword lists</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Removing repeated log entries</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Deduplicating CSV rows</div>
          <div class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Does not change order of lines</div>
        </div>
        <a href="/tools/remove-duplicate-lines" class="block text-center bg-blue-700 hover:bg-blue-600 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors">
          Use Remove Duplicate Lines →
        </a>
      </div>

      <div class="bg-[var(--bg-surface)] border border-sky-800/40 rounded-2xl p-6">
        <div class="text-sky-400 text-xs font-semibold uppercase tracking-wider mb-3">Sort Lines</div>
        <p class="text-slate-400 text-sm mb-4">Reorders lines alphabetically, numerically, or in reverse. Does not remove anything — duplicates remain unless you also deduplicate.</p>
        <div class="bg-[var(--bg-base)] rounded-xl p-4 text-xs font-mono mb-4 space-y-0.5">
          <div class="text-slate-500">cherry</div>
          <div class="text-slate-500">apple</div>
          <div class="text-slate-500">banana</div>
          <div class="text-slate-500">apple</div>
          <div class="text-slate-500 text-[10px] mt-1">→ apple, apple, banana, cherry</div>
        </div>
        <div class="space-y-2 text-sm text-slate-400 mb-5">
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Alphabetising keyword lists</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Organising bibliography entries</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Sorting product/feature lists</div>
          <div class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Creating ordered navigation menus</div>
          <div class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Does not remove duplicates</div>
        </div>
        <a href="/tools/sort-lines" class="block text-center bg-sky-700 hover:bg-sky-600 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors">
          Use Sort Lines →
        </a>
      </div>
    </div>

    <!-- When to use together -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-5" style="font-family: 'Space Grotesk', sans-serif;">The Power Move: Use Both Together</h2>
      <p class="text-slate-400 leading-relaxed mb-5">
        For clean, organised lists, combine the two tools. The most common workflow for processing a keyword list, email list, or any collection of items:
      </p>
      <div class="space-y-3">
        {[
          { step: '1', icon: '📋', title: 'Paste your raw list', desc: 'Start with whatever you have — messy, duplicated, unsorted.' },
          { step: '2', icon: '🔁', title: 'Run Remove Duplicate Lines', desc: 'Eliminate all repeated entries. Keeps first occurrence, preserves original order.' },
          { step: '3', icon: '🔤', title: 'Run Sort Lines (A→Z)', desc: 'Now sort the deduplicated list alphabetically for easy scanning and management.' },
          { step: '4', icon: '✅', title: 'Copy the clean output', desc: 'Your list is now unique and sorted — ready to use.' },
        ].map(item => (
          <div class="flex items-start gap-4 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
            <div class="w-8 h-8 rounded-lg bg-violet-900/50 border border-violet-700/40 flex items-center justify-center text-violet-300 text-sm font-bold shrink-0">{item.step}</div>
            <div>
              <div class="text-white font-medium text-sm mb-0.5">{item.icon} {item.title}</div>
              <div class="text-slate-400 text-sm">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Decision Table -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-5" style="font-family: 'Space Grotesk', sans-serif;">Quick Decision Guide</h2>
      <div class="overflow-x-auto rounded-xl border border-slate-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="text-left px-5 py-3 text-slate-400 font-medium">Goal</th>
              <th class="text-center px-4 py-3 text-blue-400 font-medium">Remove Dupes</th>
              <th class="text-center px-4 py-3 text-sky-400 font-medium">Sort Lines</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60">
            {[
              ['I have duplicate entries to remove', '✓', ''],
              ['I want alphabetical order', '', '✓'],
              ['I want clean, unique, sorted list', '✓', '✓'],
              ['Cleaning an email list', '✓', ''],
              ['Creating a glossary', '', '✓'],
              ['Deduplicating SEO keywords', '✓', '✓'],
              ['Numbering items in order', '', '✓'],
              ['Removing duplicate log lines', '✓', ''],
            ].map(([goal, dupes, sort]) => (
              <tr>
                <td class="px-5 py-3 text-slate-300">{goal}</td>
                <td class="px-4 py-3 text-center text-emerald-400 font-bold">{dupes}</td>
                <td class="px-4 py-3 text-center text-emerald-400 font-bold">{sort}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-5" style="font-family: 'Space Grotesk', sans-serif;">Frequently Asked Questions</h2>
      <div class="space-y-2">
        {faqSchema.mainEntity.map(item => (
          <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
              <span class="text-white font-medium text-sm">{item.name}</span>
              <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-4"><p class="text-slate-400 text-sm leading-relaxed">{item.acceptedAnswer.text}</p></div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
