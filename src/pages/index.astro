<script define:vars={{ toolsForSearch }}>
(function() {
  // Hero Search Input & Dropdown
  const searchInput = document.getElementById('hero-search-input');
  const searchDropdown = document.getElementById('hero-search-dropdown');
  const searchResults = document.getElementById('hero-search-results');
  
  function renderHeroSearch(query) {
    const q = query.toLowerCase().trim();
    if (!q) {
      searchDropdown.classList.add('hidden');
      return;
    }
    
    const filtered = toolsForSearch.filter(t => 
      t.name.toLowerCase().includes(q) || 
      t.category.toLowerCase().includes(q)
    );
    
    if (filtered.length > 0) {
      searchResults.innerHTML = filtered.slice(0, 10).map(t => `
        <li>
          <a href="${t.path}" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[var(--bg-surface-hover)] transition-colors">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs" style="background:${t.color}15; color:${t.color}; border: 1px solid ${t.color}25">
              ${t.icon || '⚙️'}
            </div>
            <span class="text-white text-sm font-semibold">${t.name}</span>
            <span class="text-[10px] px-2 py-0.5 rounded-full font-medium ml-auto" style="background:${t.color}15; color:${t.color}">
              ${t.category}
            </span>
          </a>
        </li>
      `).join('');
    } else {
      searchResults.innerHTML = `<li class="px-4 py-6 text-slate-500 text-sm text-center">No tools match your search</li>`;
    }
    
    searchDropdown.classList.remove('hidden');
  }

  searchInput.addEventListener('input', e => renderHeroSearch(e.target.value));

  // Close search dropdown on click outside
  document.addEventListener('click', e => {
    if (searchInput && !searchInput.contains(e.target) && searchDropdown && !searchDropdown.contains(e.target)) {
      searchDropdown.classList.add('hidden');
    }
  });

  // Popular search suggestions tags handler
  const popularTags = document.querySelectorAll('.popular-tag');
  popularTags.forEach(tag => {
    tag.addEventListener('click', () => {
      const query = tag.getAttribute('data-query');
      searchInput.value = query;
      renderHeroSearch(query);
      searchInput.focus();
    });
  });

  // Keyboard shortcut '/' to focus search
  document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // Dynamic Dashboard Tab System
  const tabs = document.querySelectorAll('.dashboard-tab-btn');
  const cards = document.querySelectorAll('.category-card-btn');
  const panes = document.querySelectorAll('.tab-pane');

  function switchTab(index) {
    // 1. Update tab buttons
    tabs.forEach((tab, i) => {
      const activeColor = tab.getAttribute('data-color');
      const accentRgb = tab.getAttribute('data-accent-rgb');
      const isSelected = i === index;
      
      if (isSelected) {
        tab.style.borderColor = activeColor;
        tab.style.color = '#fff';
        tab.style.background = `rgba(${accentRgb}, 0.04)`;
        panes[i].classList.remove('hidden');
      } else {
        tab.style.borderColor = 'transparent';
        tab.style.color = '';
        tab.style.background = '';
        panes[i].classList.add('hidden');
      }
    });

    // 2. Update category cards border and glow
    cards.forEach((card, i) => {
      const isSelected = i === index;
      if (isSelected) {
        card.style.borderColor = card.style.getPropertyValue('--brand-color');
        card.style.boxShadow = `0 0 16px ${card.style.getPropertyValue('--tw-shadow-color')}`;
        card.style.background = 'var(--bg-surface-hover)';
      } else {
        card.style.borderColor = '';
        card.style.boxShadow = '';
        card.style.background = '';
      }
    });

    // Collapse expanded tools if tab switches
    const expandBtn = panes[index].querySelector('.expand-tools-btn');
    if (expandBtn) {
      collapseTools(expandBtn, index);
    }
  }

  // Bind clicks on Category Cards to switch tab
  cards.forEach((card, i) => {
    card.addEventListener('click', () => {
      switchTab(i);
      // Smooth scroll to the dashboard section so tools are visible
      const dashboardSection = document.getElementById('dashboard-section');
      if (dashboardSection) {
        dashboardSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Bind clicks on Tab buttons to switch tab
  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => switchTab(i));
  });

  // Expander buttons handler
  const expandBtns = document.querySelectorAll('.expand-tools-btn');
  
  function expandTools(btn, paneIdx) {
    const pane = panes[paneIdx];
    const extraTools = pane.querySelectorAll('.extra-tool');
    const color = tabs[paneIdx].getAttribute('data-color');
    const accentRgb = tabs[paneIdx].getAttribute('data-accent-rgb');
    
    extraTools.forEach(tool => tool.classList.remove('hidden'));
    btn.setAttribute('data-expanded', 'true');
    btn.querySelector('.btn-text').textContent = 'Show Less';
    btn.querySelector('.arrow-icon').style.transform = 'rotate(180deg)';
    
    // Style expanded button slightly differently
    btn.style.background = color;
    btn.style.color = '#fff';
    btn.style.borderColor = color;
    btn.style.boxShadow = `0 4px 12px rgba(${accentRgb}, 0.25)`;
  }

  function collapseTools(btn, paneIdx) {
    const pane = panes[paneIdx];
    const extraTools = pane.querySelectorAll('.extra-tool');
    const color = tabs[paneIdx].getAttribute('data-color');
    const accentRgb = tabs[paneIdx].getAttribute('data-accent-rgb');
    const count = extraTools.length + 6;
    
    extraTools.forEach(tool => tool.classList.add('hidden'));
    btn.setAttribute('data-expanded', 'false');
    btn.querySelector('.btn-text').textContent = `Show All ${count} Tools`;
    btn.querySelector('.arrow-icon').style.transform = '';
    
    btn.style.background = `rgba(${accentRgb}, 0.05)`;
    btn.style.color = color;
    btn.style.borderColor = `rgba(${accentRgb}, 0.2)`;
    btn.style.boxShadow = '';
  }

  expandBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.getAttribute('data-index'));
      const isExpanded = btn.getAttribute('data-expanded') === 'true';
      if (isExpanded) {
        collapseTools(btn, idx);
        // Scroll back to dashboard top to prevent jumping
        document.getElementById('dashboard-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        expandTools(btn, idx);
      }
    });
  });

  // Initialize: default select first tab (TextWonder)
  switchTab(0);
})();
</script>
