---
---

<div class="space-y-4">
  <div class="flex items-center gap-3 flex-wrap">
    <input id="fl-pattern" type="text" placeholder="Search pattern..." class="flex-1 min-w-48 bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-2.5 text-slate-100 placeholder-slate-600 outline-none focus:ring-2 focus:ring-violet-600 text-sm" />
    <select id="fl-mode" class="bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2.5 text-slate-100 text-sm outline-none">
      <option value="include">Keep matching lines</option>
      <option value="exclude">Remove matching lines</option>
    </select>
  </div>
  <div class="flex flex-wrap gap-4">
    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
      <input id="fl-case" type="checkbox" class="w-4 h-4 accent-violet-600" />
      Case-sensitive
    </label>
    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300">
      <input id="fl-regex" type="checkbox" class="w-4 h-4 accent-violet-600" />
      Regex mode
    </label>
  </div>
  <div>
    <label class="text-slate-300 text-sm font-medium mb-2 block">Input Text</label>
    <textarea id="fl-input" rows="7" placeholder="Paste lines of text here..." class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y outline-none focus:ring-2 focus:ring-violet-600 text-sm"></textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="text-slate-300 text-sm font-medium">Filtered Output <span id="fl-info" class="text-xs text-slate-500"></span></label>
      <button id="fl-copy" class="text-xs bg-[var(--bg-surface-hover)] hover:bg-[var(--bg-surface-alt)] text-slate-300 px-3 py-1 rounded-lg transition-colors">Copy</button>
    </div>
    <textarea id="fl-output" rows="7" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y outline-none text-sm"></textarea>
  </div>
</div>

<script>
function filter() {
  const pattern = document.getElementById('fl-pattern').value;
  const text = document.getElementById('fl-input').value;
  const mode = document.getElementById('fl-mode').value;
  const caseSens = document.getElementById('fl-case').checked;
  const regexMode = document.getElementById('fl-regex').checked;
  if (!pattern) { document.getElementById('fl-output').value = text; document.getElementById('fl-info').textContent = ''; return; }
  const lines = text.split('\n');
  let matched;
  try {
    if (regexMode) {
      const rx = new RegExp(pattern, caseSens ? '' : 'i');
      matched = lines.filter(l => mode === 'include' ? rx.test(l) : !rx.test(l));
    } else {
      const pat = caseSens ? pattern : pattern.toLowerCase();
      matched = lines.filter(l => {
        const hay = caseSens ? l : l.toLowerCase();
        return mode === 'include' ? hay.includes(pat) : !hay.includes(pat);
      });
    }
    document.getElementById('fl-output').value = matched.join('\n');
    document.getElementById('fl-info').textContent = `${matched.length} of ${lines.length} lines`;
  } catch(e) {
    document.getElementById('fl-info').textContent = 'Invalid regex';
  }
}
['fl-pattern','fl-input'].forEach(id => document.getElementById(id).addEventListener('input', filter));
['fl-mode','fl-case','fl-regex'].forEach(id => document.getElementById(id).addEventListener('change', filter));
document.getElementById('fl-copy').addEventListener('click', () => {
  const val = document.getElementById('fl-output').value;
  if (!val) return;
  navigator.clipboard.writeText(val);
  const btn = document.getElementById('fl-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = 'Copy', 1500);
});
</script>
