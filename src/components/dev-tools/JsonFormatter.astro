---
---
<div class="space-y-4">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 items-end">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Indent</label>
      <select id="jf-indent" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-cyan-500">
        <option value="2">2 spaces</option>
        <option value="4">4 spaces</option>
        <option value="	">Tab</option>
      </select>
    </div>
    <div class="flex gap-2">
      <button id="jf-format" class="flex-1 py-2 bg-cyan-600 hover:bg-cyan-500 text-white rounded-lg text-sm font-medium transition-colors">Format</button>
      <button id="jf-minify" class="flex-1 py-2 bg-[var(--bg-surface-hover)] hover:bg-slate-700 text-slate-300 rounded-lg text-sm font-medium transition-colors border border-slate-700">Minify</button>
      <button id="jf-validate" class="flex-1 py-2 bg-[var(--bg-surface-hover)] hover:bg-slate-700 text-slate-300 rounded-lg text-sm font-medium transition-colors border border-slate-700">Validate</button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Input JSON</label>
      <textarea id="jf-input" rows="14" placeholder='{"name":"Alice","age":30,"active":true}' class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-600 resize-y font-mono text-sm focus:outline-none focus:border-cyan-500 leading-relaxed"></textarea>
    </div>
    <div class="space-y-1">
      <div class="flex items-center justify-between">
        <label class="text-xs text-slate-500">Output</label>
        <button id="jf-copy" class="text-xs text-cyan-400 hover:text-cyan-300 transition-colors">Copy</button>
      </div>
      <textarea id="jf-output" rows="14" readonly class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-xl px-4 py-3 text-slate-200 resize-y font-mono text-sm focus:outline-none leading-relaxed"></textarea>
    </div>
  </div>

  <div id="jf-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function() {
  const input = document.getElementById('jf-input');
  const output = document.getElementById('jf-output');
  const status = document.getElementById('jf-status');

  document.getElementById('jf-format').addEventListener('click', () => {
    try {
      const indent = document.getElementById('jf-indent').value;
      const parsed = JSON.parse(input.value);
      output.value = JSON.stringify(parsed, null, indent === '\t' ? '\t' : parseInt(indent));
      showStatus('✅ Valid JSON — formatted successfully.', false);
    } catch(e) { output.value = ''; showStatus('❌ Invalid JSON: ' + e.message, true); }
  });

  document.getElementById('jf-minify').addEventListener('click', () => {
    try {
      output.value = JSON.stringify(JSON.parse(input.value));
      showStatus('✅ Minified successfully.', false);
    } catch(e) { output.value = ''; showStatus('❌ Invalid JSON: ' + e.message, true); }
  });

  document.getElementById('jf-validate').addEventListener('click', () => {
    try {
      JSON.parse(input.value);
      showStatus('✅ Valid JSON — no errors found.', false);
    } catch(e) { showStatus('❌ Invalid JSON: ' + e.message, true); }
  });

  document.getElementById('jf-copy').addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value);
  });

  function showStatus(msg, isError) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (isError ? 'text-red-400' : 'text-green-400');
    status.classList.remove('hidden');
  }
})();
</script>
