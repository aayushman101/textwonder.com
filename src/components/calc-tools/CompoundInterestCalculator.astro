---
---
<div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ci-principal">Principal (₹)</label>
      <input type="number" id="ci-principal" placeholder="e.g. 100000" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ci-rate">Annual Rate (%)</label>
      <input type="number" id="ci-rate" placeholder="e.g. 8" step="0.1" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ci-time">Time (years)</label>
      <input type="number" id="ci-time" placeholder="e.g. 5" step="0.5" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-1" for="ci-freq">Compounding</label>
      <select id="ci-freq" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500">
        <option value="365">Daily</option>
        <option value="12" selected>Monthly</option>
        <option value="4">Quarterly</option>
        <option value="1">Yearly</option>
      </select>
    </div>
  </div>

  <div id="ci-result" class="hidden grid grid-cols-2 gap-3">
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-xs text-slate-400 mb-1">Final Amount</div>
      <div id="ci-final" class="text-2xl font-bold" style="color:#10b981"></div>
    </div>
    <div class="bg-[var(--bg-base)] rounded-xl p-4 border border-slate-700 text-center">
      <div class="text-xs text-slate-400 mb-1">Total Interest</div>
      <div id="ci-interest" class="text-2xl font-bold text-white"></div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  function fmt(n) { return '₹' + n.toLocaleString('en-IN', {maximumFractionDigits:2}); }
  function calc() {
    const P = parseFloat(document.getElementById('ci-principal').value);
    const r = parseFloat(document.getElementById('ci-rate').value) / 100;
    const t = parseFloat(document.getElementById('ci-time').value);
    const n = parseInt(document.getElementById('ci-freq').value);
    const res = document.getElementById('ci-result');
    if(!P||!r||!t||P<=0||r<=0||t<=0) { res.classList.add('hidden'); return; }
    const A = P * Math.pow(1 + r/n, n*t);
    document.getElementById('ci-final').textContent = fmt(A);
    document.getElementById('ci-interest').textContent = fmt(A-P);
    res.classList.remove('hidden');
  }
  ['ci-principal','ci-rate','ci-time','ci-freq'].forEach(id => document.getElementById(id).addEventListener('input', calc));
})();
</script>
