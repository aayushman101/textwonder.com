---
---
<div class="space-y-5">
  <div id="pco-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pco-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🗜️</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Reduce file size by removing unused objects, metadata, and annotations</p>
  </div>

  <div id="pco-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="pco-name" class="text-slate-200 text-sm font-medium truncate"></p>
        <p id="pco-info" class="text-slate-500 text-xs"></p>
      </div>
      <button id="pco-change" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 px-3 py-1.5 rounded-lg shrink-0">Change</button>
    </div>

    <!-- Compression level -->
    <div class="space-y-2">
      <label class="text-xs text-slate-400 font-medium">Compression level</label>
      <div class="flex gap-2">
        <button data-level="normal" class="pco-level-btn flex-1 py-2.5 px-3 rounded-lg border text-sm font-medium transition-colors text-left bg-orange-600 border-orange-500 text-white">
          <span class="block">Normal</span>
          <span class="block text-xs font-normal opacity-75 mt-0.5">Removes unused PDF objects</span>
        </button>
        <button data-level="aggressive" class="pco-level-btn flex-1 py-2.5 px-3 rounded-lg border text-sm font-medium transition-colors text-left border-slate-700 text-slate-400 hover:text-slate-200">
          <span class="block">Aggressive</span>
          <span class="block text-xs font-normal opacity-75 mt-0.5">Also uses object streams</span>
        </button>
      </div>
    </div>

    <!-- Extra options -->
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-3 space-y-2.5">
      <label class="flex items-start gap-2.5 cursor-pointer">
        <input id="pco-strip-meta" type="checkbox" class="accent-orange-500 mt-0.5 shrink-0" />
        <div>
          <span class="text-sm text-slate-300">Strip all metadata</span>
          <span class="block text-xs text-slate-600">Removes author, title, creator — useful for privacy</span>
        </div>
      </label>
      <label class="flex items-start gap-2.5 cursor-pointer">
        <input id="pco-strip-annots" type="checkbox" class="accent-orange-500 mt-0.5 shrink-0" />
        <div>
          <span class="text-sm text-slate-300">Remove annotations</span>
          <span class="block text-xs text-slate-600">Strips comments and form field overlays</span>
        </div>
      </label>
    </div>

    <button id="pco-compress" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Compress & Download</button>

    <!-- Result card -->
    <div id="pco-result" class="hidden bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4 space-y-4">
      <div class="flex justify-between items-center">
        <div>
          <p class="text-xs text-slate-500 mb-0.5">Original</p>
          <p id="pco-orig-size" class="text-slate-300 text-sm font-medium"></p>
        </div>
        <div class="text-center">
          <p id="pco-saved-pct" class="text-2xl font-bold text-green-400"></p>
          <p id="pco-saved-bytes" class="text-xs text-slate-500"></p>
        </div>
        <div class="text-right">
          <p class="text-xs text-slate-500 mb-0.5">Compressed</p>
          <p id="pco-new-size" class="text-slate-300 text-sm font-medium"></p>
        </div>
      </div>
      <!-- Size bar -->
      <div class="space-y-1.5">
        <div class="relative h-4 bg-slate-800 rounded-full overflow-hidden">
          <div id="pco-bar" class="h-full bg-green-500 rounded-full transition-all duration-700" style="width:100%"></div>
          <div class="absolute inset-0 flex items-center justify-center text-xs text-white/70 font-medium" id="pco-bar-label"></div>
        </div>
        <div class="flex justify-between text-xs text-slate-600">
          <span>Compressed size</span>
          <span>Original size</span>
        </div>
      </div>
      <p id="pco-note" class="text-xs text-slate-500"></p>
    </div>
  </div>

  <div id="pco-status" class="hidden text-sm py-2"></div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('pco-drop');
  const fileInput = document.getElementById('pco-file');
  const panel = document.getElementById('pco-panel');
  const status = document.getElementById('pco-status');
  let currentFile = null, pdfBytes = null, currentLevel = 'normal';

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  document.querySelectorAll('.pco-level-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentLevel = btn.dataset.level;
      document.querySelectorAll('.pco-level-btn').forEach(b => {
        const active = b.dataset.level === currentLevel;
        b.classList.toggle('bg-orange-600', active);
        b.classList.toggle('border-orange-500', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('border-slate-700', !active);
        b.classList.toggle('text-slate-400', !active);
        if (!active) b.classList.remove('text-white');
      });
    });
  });

  async function loadFile(file) {
    if (!file || (!file.type.includes('pdf') && !file.name.endsWith('.pdf'))) return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      pdfBytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      currentFile = file;
      document.getElementById('pco-name').textContent = file.name;
      document.getElementById('pco-info').textContent = `${doc.getPageCount()} pages · ${fmtSize(file.size)}`;
      document.getElementById('pco-result').classList.add('hidden');
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
    } catch(e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('pco-compress').addEventListener('click', async () => {
    if (!currentFile) return;
    const origSize = pdfBytes.byteLength;
    showStatus('Compressing…', 'info');
    try {
      const { PDFDocument, PDFName } = window.PDFLib;
      const doc = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });

      if (document.getElementById('pco-strip-meta').checked) {
        doc.setTitle(''); doc.setAuthor(''); doc.setSubject('');
        doc.setKeywords([]); doc.setCreator(''); doc.setProducer('');
      }

      if (document.getElementById('pco-strip-annots').checked) {
        for (let i = 0; i < doc.getPageCount(); i++) {
          const page = doc.getPage(i);
          try { page.node.delete(PDFName.of('Annots')); } catch(_) {}
        }
      }

      const saveOpts = currentLevel === 'aggressive'
        ? { useObjectStreams: true, addDefaultPage: false, objectsPerTick: 50 }
        : { useObjectStreams: false, addDefaultPage: false };

      const out = await doc.save(saveOpts);
      const newSize = out.length;
      const saved = origSize - newSize;
      const pct = ((saved / origSize) * 100).toFixed(1);
      const ratio = Math.min(1, newSize / origSize);

      const baseName = currentFile.name.replace(/\.pdf$/i, '');
      downloadBytes(out, `${baseName}-compressed.pdf`);

      const resultEl = document.getElementById('pco-result');
      resultEl.classList.remove('hidden');
      document.getElementById('pco-orig-size').textContent = fmtSize(origSize);
      document.getElementById('pco-new-size').textContent = fmtSize(newSize);
      document.getElementById('pco-saved-pct').textContent = saved > 0 ? `−${pct}%` : '0%';
      document.getElementById('pco-saved-bytes').textContent = saved > 0 ? `saved ${fmtSize(saved)}` : 'no savings';
      document.getElementById('pco-bar').style.width = (ratio * 100).toFixed(1) + '%';
      document.getElementById('pco-bar').className = `h-full rounded-full transition-all duration-700 ${saved > 0 ? 'bg-green-500' : 'bg-slate-600'}`;
      document.getElementById('pco-bar-label').textContent = fmtSize(newSize);

      let note = '';
      if (saved <= 0) note = 'This PDF is already well-optimised — little or no unused data to remove.';
      else if (parseFloat(pct) < 5) note = 'Small savings. Most file size is image/font data which cannot be reduced client-side.';
      else note = `Removed ${fmtSize(saved)} of unused data (${pct}% reduction).`;
      document.getElementById('pco-note').textContent = note;

      showStatus(`✅ ${fmtSize(origSize)} → ${fmtSize(newSize)}`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pco-change').addEventListener('click', () => {
    currentFile = null; pdfBytes = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function fmtSize(bytes) {
    if (bytes >= 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    return (bytes / 1024).toFixed(0) + ' KB';
  }

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
