---
---
<div class="space-y-5">
  <div id="pmv-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="pmv-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🔍</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">View and optionally edit PDF metadata</p>
  </div>

  <div id="pmv-result" class="hidden space-y-4">
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
        <span class="text-sm font-medium text-slate-200">PDF Metadata</span>
        <button id="pmv-clear" class="text-xs text-slate-500 hover:text-slate-300">✕ Clear</button>
      </div>
      <div class="divide-y divide-slate-800" id="pmv-rows"></div>
    </div>

    <div class="space-y-3">
      <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Edit Metadata</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Title</label>
          <input id="pmv-e-title" type="text" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Author</label>
          <input id="pmv-e-author" type="text" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Subject</label>
          <input id="pmv-e-subject" type="text" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
        </div>
        <div class="space-y-1">
          <label class="text-xs text-slate-500">Keywords</label>
          <input id="pmv-e-keywords" type="text" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
        </div>
      </div>
      <button id="pmv-save" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Save & Download</button>
    </div>
  </div>

  <div id="pmv-status" class="hidden text-sm py-2"></div>
</div>

<script is:inline>
(function() {
  const drop = document.getElementById('pmv-drop');
  const fileInput = document.getElementById('pmv-file');
  const result = document.getElementById('pmv-result');
  const status = document.getElementById('pmv-status');
  let currentFile = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
      currentFile = file;

      const fields = [
        ['File name', file.name],
        ['File size', `${(file.size/1024).toFixed(1)} KB`],
        ['Pages', doc.getPageCount()],
        ['Title', doc.getTitle() || '—'],
        ['Author', doc.getAuthor() || '—'],
        ['Subject', doc.getSubject() || '—'],
        ['Keywords', doc.getKeywords() || '—'],
        ['Creator', doc.getCreator() || '—'],
        ['Producer', doc.getProducer() || '—'],
        ['Created', doc.getCreationDate()?.toLocaleDateString() || '—'],
        ['Modified', doc.getModificationDate()?.toLocaleDateString() || '—'],
      ];

      document.getElementById('pmv-rows').innerHTML = fields.map(([k, v]) => `
        <div class="flex items-start gap-4 px-4 py-3">
          <span class="text-slate-500 text-xs w-24 shrink-0 pt-0.5">${k}</span>
          <span class="text-slate-200 text-sm">${v}</span>
        </div>`).join('');

      document.getElementById('pmv-e-title').value = doc.getTitle() || '';
      document.getElementById('pmv-e-author').value = doc.getAuthor() || '';
      document.getElementById('pmv-e-subject').value = doc.getSubject() || '';
      document.getElementById('pmv-e-keywords').value = doc.getKeywords() || '';

      drop.classList.add('hidden');
      status.classList.add('hidden');
      result.classList.remove('hidden');
    } catch(e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('pmv-save').addEventListener('click', async () => {
    if (!currentFile) return;
    showStatus('Saving…', 'info');
    try {
      const { PDFDocument } = window.PDFLib;
      const doc = await PDFDocument.load(await currentFile.arrayBuffer(), { ignoreEncryption: true });
      doc.setTitle(document.getElementById('pmv-e-title').value);
      doc.setAuthor(document.getElementById('pmv-e-author').value);
      doc.setSubject(document.getElementById('pmv-e-subject').value);
      doc.setKeywords([document.getElementById('pmv-e-keywords').value]);
      const out = await doc.save();
      downloadBytes(out, 'updated-metadata.pdf');
      showStatus('✅ Metadata saved and PDF downloaded', 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('pmv-clear').addEventListener('click', () => {
    currentFile = null;
    result.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
