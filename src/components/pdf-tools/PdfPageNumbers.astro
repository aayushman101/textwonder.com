---
---
<div class="space-y-5">
  <div id="ppn-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-8 text-center cursor-pointer transition-colors">
    <input type="file" id="ppn-file" accept=".pdf" class="hidden" />
    <div class="text-4xl mb-2">🔢</div>
    <p class="text-slate-300 font-medium mb-1">Drop a PDF here or click to select</p>
    <p class="text-slate-500 text-sm">Page numbers will be added to the footer of every page</p>
  </div>

  <div id="ppn-panel" class="hidden space-y-4">
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl">📄</span>
      <div>
        <p id="ppn-name" class="text-slate-200 text-sm font-medium"></p>
        <p id="ppn-info" class="text-slate-500 text-xs"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Position</label>
        <select id="ppn-position" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500">
          <option value="center" selected>Bottom Centre</option>
          <option value="left">Bottom Left</option>
          <option value="right">Bottom Right</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Starting number</label>
        <input type="number" id="ppn-start" value="1" min="0" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Font size (pt)</label>
        <input type="number" id="ppn-size" value="11" min="6" max="24" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
      </div>
      <div class="space-y-1">
        <label class="text-xs text-slate-400">Format</label>
        <select id="ppn-format" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500">
          <option value="n" selected>1, 2, 3 …</option>
          <option value="xofy">Page 1 of N</option>
          <option value="dash">— 1 —</option>
        </select>
      </div>
    </div>

    <div class="flex gap-2">
      <button id="ppn-add" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Add Page Numbers & Download</button>
      <button id="ppn-clear" class="px-4 py-2 bg-[var(--bg-surface)] text-slate-400 rounded-lg text-sm border border-slate-700 transition-colors">Clear</button>
    </div>
  </div>

  <div id="ppn-status" class="hidden text-sm py-1"></div>
</div>

<script is:inline>
(function () {
  const drop = document.getElementById('ppn-drop');
  const fileInput = document.getElementById('ppn-file');
  const panel = document.getElementById('ppn-panel');
  const status = document.getElementById('ppn-status');
  let currentFile = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  async function loadFile(file) {
    if (!file || file.type !== 'application/pdf') return;
    showStatus('Loading…', 'info');
    await loadPdfLib();
    try {
      const { PDFDocument } = window.PDFLib;
      const bytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
      currentFile = { file, doc };
      document.getElementById('ppn-name').textContent = file.name;
      document.getElementById('ppn-info').textContent = `${doc.getPageCount()} pages · ${(file.size / 1024).toFixed(1)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
      status.classList.add('hidden');
    } catch (e) { showStatus('Could not read PDF: ' + e.message, 'error'); }
  }

  document.getElementById('ppn-add').addEventListener('click', async () => {
    if (!currentFile) return;
    showStatus('Adding page numbers…', 'info');
    try {
      const { PDFDocument, StandardFonts, rgb } = window.PDFLib;
      const doc = await PDFDocument.load(await currentFile.file.arrayBuffer(), { ignoreEncryption: true });
      const font = await doc.embedFont(StandardFonts.Helvetica);
      const pages = doc.getPages();
      const total = pages.length;
      const start = parseInt(document.getElementById('ppn-start').value, 10) || 1;
      const fontSize = parseInt(document.getElementById('ppn-size').value, 10) || 11;
      const position = document.getElementById('ppn-position').value;
      const format = document.getElementById('ppn-format').value;

      pages.forEach((page, idx) => {
        const { width } = page.getSize();
        const num = start + idx;
        let label;
        if (format === 'xofy') label = `Page ${num} of ${total}`;
        else if (format === 'dash') label = `— ${num} —`;
        else label = String(num);

        const textWidth = font.widthOfTextAtSize(label, fontSize);
        let x;
        if (position === 'left') x = 36;
        else if (position === 'right') x = width - 36 - textWidth;
        else x = (width - textWidth) / 2;

        page.drawText(label, { x, y: 20, size: fontSize, font, color: rgb(0.3, 0.3, 0.3) });
      });

      const out = await doc.save();
      downloadBytes(out, 'numbered.pdf');
      showStatus(`✅ Page numbers added to ${total} pages`, 'success');
    } catch (e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('ppn-clear').addEventListener('click', () => {
    currentFile = null;
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
  });

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-1 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function loadPdfLib() {
    if (window.PDFLib) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
