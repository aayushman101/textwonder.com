---
---
<div class="space-y-4">
  <textarea id="hee-input" rows="6" placeholder="Paste text with < > & \" or HTML entities like &lt; &amp; …" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
  <div class="flex gap-2 flex-wrap">
    <button id="hee-encode" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Encode → Entities</button>
    <button id="hee-decode" class="px-5 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg text-sm font-medium transition-colors">Decode ← Entities</button>
    <button id="hee-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="hee-output-wrap" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <span id="hee-label" class="text-xs text-slate-500">Result</span>
      <button id="hee-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="hee-output" rows="6" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm font-mono select-all"></textarea>
  </div>
</div>
<script>
  const MAP = {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'};
  const RMAP = Object.fromEntries(Object.entries(MAP).map(([k,v])=>[v,k]));
  function encode(s) { return s.replace(/[&<>"']/g, c => MAP[c]); }
  function decode(s) {
    const d = document.createElement('div');
    d.innerHTML = s;
    return d.textContent;
  }
  const input = document.getElementById('hee-input');
  const output = document.getElementById('hee-output');
  const wrap = document.getElementById('hee-output-wrap');
  const label = document.getElementById('hee-label');
  const saved = localStorage.getItem('tw-html-entity-encoder');
  if (saved) input.value = saved;
  input.addEventListener('input', () => localStorage.setItem('tw-html-entity-encoder', input.value));
  document.getElementById('hee-encode').addEventListener('click', () => { output.value = encode(input.value); label.textContent = 'HTML encoded'; wrap.classList.remove('hidden'); });
  document.getElementById('hee-decode').addEventListener('click', () => { output.value = decode(input.value); label.textContent = 'Decoded text'; wrap.classList.remove('hidden'); });
  document.getElementById('hee-clear').addEventListener('click', () => { input.value = ''; output.value = ''; wrap.classList.add('hidden'); localStorage.removeItem('tw-html-entity-encoder'); });
  document.getElementById('hee-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
</script>
