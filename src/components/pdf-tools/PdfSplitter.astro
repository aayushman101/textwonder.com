---
---
<div class="space-y-5">
  <div id="ps-drop" class="border-2 border-dashed border-slate-700 hover:border-orange-500/60 rounded-xl p-10 text-center cursor-pointer transition-colors">
    <input type="file" id="ps-file" accept=".pdf" class="hidden" />
    <div class="text-5xl mb-3">✂️</div>
    <p class="text-slate-200 font-semibold text-lg mb-1">Drop your PDF here</p>
    <p class="text-slate-500 text-sm mb-4">or click to browse — page previews load automatically</p>
    <span class="inline-block px-4 py-2 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Choose PDF</span>
  </div>

  <!-- Loading progress -->
  <div id="ps-loading" class="hidden">
    <div class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">⏳</div>
      <p class="text-slate-300 font-medium mb-1" id="ps-loading-msg">Generating page previews…</p>
      <p class="text-slate-500 text-xs mb-4">Rendering each page so you can see exactly what's on it</p>
      <div class="w-full bg-slate-800 rounded-full h-2 max-w-sm mx-auto">
        <div id="ps-loading-bar" class="bg-orange-500 h-2 rounded-full transition-all duration-200" style="width:0%"></div>
      </div>
    </div>
  </div>

  <!-- Main panel -->
  <div id="ps-panel" class="hidden space-y-4">
    <!-- File info bar -->
    <div class="flex items-center gap-3 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-4">
      <span class="text-orange-400 text-2xl shrink-0">📄</span>
      <div class="flex-1 min-w-0">
        <p id="ps-name" class="text-slate-200 text-sm font-semibold truncate"></p>
        <p id="ps-pages" class="text-slate-500 text-xs mt-0.5"></p>
      </div>
      <button id="ps-clear" class="text-xs text-slate-500 hover:text-slate-300 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-lg shrink-0 transition-colors">Change file</button>
    </div>

    <!-- Mode tabs -->
    <div class="flex gap-1 bg-[var(--bg-surface)] border border-slate-800 rounded-xl p-1">
      <button data-mode="extract" class="ps-mode-btn flex-1 py-1.5 rounded-lg text-xs font-medium transition-colors bg-orange-600 text-white">Extract pages</button>
      <button data-mode="every" class="ps-mode-btn flex-1 py-1.5 rounded-lg text-xs font-medium transition-colors text-slate-400 hover:text-slate-200">Split every N pages</button>
      <button data-mode="individual" class="ps-mode-btn flex-1 py-1.5 rounded-lg text-xs font-medium transition-colors text-slate-400 hover:text-slate-200">All pages separately</button>
    </div>

    <!-- Extract pages mode -->
    <div id="ps-mode-extract" class="space-y-3">
      <!-- Page range input -->
      <div class="space-y-2">
        <label class="text-xs text-slate-400">Pages to extract <span class="text-slate-600">(e.g. 1, 3, 5-8, 10) or click below</span></label>
        <input id="ps-range" type="text" placeholder="e.g. 1-3, 5, 7-9" class="w-full bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 placeholder-slate-500 text-sm focus:outline-none focus:border-orange-500" />
        <p id="ps-range-hint" class="text-xs text-slate-500"></p>
      </div>

      <!-- Thumbnail grid for visual selection -->
      <div>
        <p class="text-xs text-slate-500 mb-2">Or click page thumbnails to select:</p>
        <div id="ps-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
      </div>

      <button id="ps-split-extract" class="w-full px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors disabled:opacity-40" disabled>Extract Pages</button>
    </div>

    <!-- Every N pages mode -->
    <div id="ps-mode-every" class="hidden space-y-3">
      <div class="space-y-2">
        <label class="text-xs text-slate-400">Split every</label>
        <div class="flex items-center gap-2">
          <input id="ps-every-n" type="number" value="1" min="1" class="w-24 bg-[var(--bg-base)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-orange-500" />
          <span class="text-slate-400 text-sm">pages</span>
          <span id="ps-every-hint" class="text-xs text-slate-500 ml-2"></span>
        </div>
      </div>
      <button id="ps-split-every" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Split & Download Parts</button>
    </div>

    <!-- Individual pages mode -->
    <div id="ps-mode-individual" class="hidden space-y-3">
      <p class="text-sm text-slate-400">Each page will be saved as a separate PDF file, downloaded one by one.</p>
      <p id="ps-individual-hint" class="text-xs text-slate-500"></p>
      <button id="ps-split-individual" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg text-sm font-medium transition-colors">Download All Pages Separately</button>
    </div>
  </div>

  <div id="ps-status" class="hidden text-sm py-2"></div>
</div>

<style>
  .ps-card { transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s; }
  .ps-card.selected { border-color: rgb(249 115 22) !important; box-shadow: 0 0 0 2px rgb(249 115 22 / 0.2); }
  .ps-card:not(.selected):hover { border-color: rgb(249 115 22 / 0.7); }
  .ps-thumb-wrap { background: #fff; }
</style>

<script is:inline>
(function() {
  const PDFJS_CDN   = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
  const PDFLIB_CDN  = 'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js';

  const drop = document.getElementById('ps-drop');
  const fileInput = document.getElementById('ps-file');
  const panel = document.getElementById('ps-panel');
  const loading = document.getElementById('ps-loading');
  const loadingMsg = document.getElementById('ps-loading-msg');
  const loadingBar = document.getElementById('ps-loading-bar');
  const status = document.getElementById('ps-status');
  const grid = document.getElementById('ps-grid');

  let currentFile = null, pageCount = 0, currentMode = 'extract';
  let pdfBytes = null, thumbs = [], selectedPages = new Set();

  // Drop zone
  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-orange-500/80'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-orange-500/80'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-orange-500/80'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { loadFile(fileInput.files[0]); fileInput.value = ''; });

  // Mode tabs
  document.querySelectorAll('.ps-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentMode = btn.dataset.mode;
      document.querySelectorAll('.ps-mode-btn').forEach(b => {
        b.classList.toggle('bg-orange-600', b.dataset.mode === currentMode);
        b.classList.toggle('text-white', b.dataset.mode === currentMode);
        b.classList.toggle('text-slate-400', b.dataset.mode !== currentMode);
      });
      ['extract','every','individual'].forEach(m => {
        document.getElementById('ps-mode-' + m).classList.toggle('hidden', m !== currentMode);
      });
      updateHints();
    });
  });

  async function loadFile(file) {
    if (!file || (!file.type.includes('pdf') && !file.name.endsWith('.pdf'))) return;

    drop.classList.add('hidden');
    loading.classList.remove('hidden');
    status.classList.add('hidden');
    loadingBar.style.width = '0%';
    loadingMsg.textContent = 'Reading PDF…';

    try {
      pdfBytes = await file.arrayBuffer();
      currentFile = file;

      await loadScript(PDFJS_CDN);
      const pdfjsLib = window['pdfjs-dist/build/pdf'];
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

      const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes.slice(0) }).promise;
      pageCount = pdfDoc.numPages;
      thumbs = [];
      selectedPages.clear();

      // render thumbnails
      for (let i = 1; i <= pageCount; i++) {
        loadingMsg.textContent = `Generating previews… ${i} / ${pageCount}`;
        loadingBar.style.width = `${Math.round((i / pageCount) * 100)}%`;

        const page = await pdfDoc.getPage(i);
        const viewport = page.getViewport({ scale: 0.3 });
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(viewport.width);
        canvas.height = Math.round(viewport.height);
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        await page.render({ canvasContext: ctx, viewport }).promise;
        thumbs.push(canvas.toDataURL('image/jpeg', 0.82));
      }

      document.getElementById('ps-name').textContent = file.name;
      document.getElementById('ps-pages').textContent = `${pageCount} pages · ${(file.size / 1024).toFixed(0)} KB`;
      loading.classList.add('hidden');
      panel.classList.remove('hidden');
      renderGrid();
      updateHints();
    } catch(e) {
      loading.classList.add('hidden');
      drop.classList.remove('hidden');
      showStatus('Could not read PDF: ' + e.message, 'error');
    }
  }

  function renderGrid() {
    grid.innerHTML = Array.from({ length: pageCount }, (_, i) => {
      const selected = selectedPages.has(i + 1);
      const thumb = thumbs[i] || '';
      return `
        <button class="ps-card group relative cursor-pointer select-none rounded-2xl border-2 ${selected ? 'border-orange-600' : 'border-slate-700/60'} hover:border-orange-400/70 bg-[var(--bg-surface)] overflow-hidden"
                data-page="${i + 1}">
          <!-- thumbnail -->
          <div class="ps-thumb-wrap w-full flex items-center justify-center overflow-hidden">
            ${thumb
              ? `<img src="${thumb}" class="w-full h-auto block" alt="Page ${i + 1}" draggable="false" />`
              : `<div class="w-full flex items-center justify-center py-12 text-slate-500 text-xs">Page ${i + 1}</div>`
            }
          </div>
          <!-- label row -->
          <div class="flex items-center justify-between px-3 py-2 border-t ${selected ? 'border-orange-600 bg-orange-900/20' : 'border-slate-800'}">
            <span class="text-sm font-semibold ${selected ? 'text-orange-300' : 'text-slate-300'}">Page ${i + 1}</span>
            <span class="text-xs font-mono ${selected ? 'text-orange-400 bg-orange-600 text-white px-1.5 py-0.5 rounded' : 'text-slate-500'}">
              ${selected ? '✓' : ''}
            </span>
          </div>
        </button>`;
    }).join('');

    grid.querySelectorAll('.ps-card').forEach(card => {
      card.addEventListener('click', () => {
        const page = +card.dataset.page;
        if (selectedPages.has(page)) {
          selectedPages.delete(page);
        } else {
          selectedPages.add(page);
        }
        updateRangeFromSelection();
        renderGrid();
        updateHints();
      });
    });
  }

  function updateRangeFromSelection() {
    if (selectedPages.size === 0) {
      document.getElementById('ps-range').value = '';
      return;
    }
    const sorted = [...selectedPages].sort((a, b) => a - b);
    const ranges = [];
    let start = sorted[0], end = sorted[0];
    for (let i = 1; i < sorted.length; i++) {
      if (sorted[i] === end + 1) {
        end = sorted[i];
      } else {
        ranges.push(start === end ? `${start}` : `${start}-${end}`);
        start = end = sorted[i];
      }
    }
    ranges.push(start === end ? `${start}` : `${start}-${end}`);
    document.getElementById('ps-range').value = ranges.join(', ');
  }

  function updateHints() {
    const rangeEl = document.getElementById('ps-range');
    if (rangeEl && rangeEl.value) updateRangeHint();
    const everyN = parseInt(document.getElementById('ps-every-n')?.value) || 1;
    const chunks = Math.ceil(pageCount / everyN);
    const evHint = document.getElementById('ps-every-hint');
    if (evHint) evHint.textContent = pageCount ? `→ ${chunks} part${chunks !== 1 ? 's' : ''}` : '';
    const indHint = document.getElementById('ps-individual-hint');
    if (indHint) indHint.textContent = pageCount ? `${pageCount} files will be downloaded` : '';
  }

  function updateRangeHint() {
    const pages = parseRange(document.getElementById('ps-range').value, pageCount);
    document.getElementById('ps-range-hint').textContent = pages.length
      ? `${pages.length} page${pages.length !== 1 ? 's' : ''} selected`
      : document.getElementById('ps-range').value ? 'No valid pages in range' : '';
  }

  document.getElementById('ps-range')?.addEventListener('input', (e) => {
    selectedPages.clear();
    const pages = parseRange(e.target.value, pageCount);
    pages.forEach(p => selectedPages.add(p));
    renderGrid();
    updateRangeHint();
  });
  document.getElementById('ps-every-n')?.addEventListener('input', updateHints);

  // Extract mode
  document.getElementById('ps-split-extract').addEventListener('click', async () => {
    if (!currentFile) return;
    const pages = parseRange(document.getElementById('ps-range').value, pageCount);
    if (!pages.length) { showStatus('Enter valid page numbers or click pages (e.g. 1-3, 5).', 'error'); return; }
    showStatus('Extracting pages…', 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const out = await PDFDocument.create();
      const copied = await out.copyPages(src, pages.map(p => p - 1));
      copied.forEach(p => out.addPage(p));
      const bytes = await out.save();
      downloadBytes(bytes, `pages-${document.getElementById('ps-range').value.replace(/\s/g,'')}.pdf`);
      showStatus(`✅ Extracted ${pages.length} page(s) successfully`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  // Every N pages mode
  document.getElementById('ps-split-every').addEventListener('click', async () => {
    if (!currentFile) return;
    const n = Math.max(1, parseInt(document.getElementById('ps-every-n').value) || 1);
    const chunks = Math.ceil(pageCount / n);
    showStatus(`Splitting into ${chunks} parts…`, 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      for (let c = 0; c < chunks; c++) {
        const start = c * n;
        const end = Math.min(start + n, pageCount);
        const out = await PDFDocument.create();
        const indices = Array.from({ length: end - start }, (_, i) => start + i);
        const copied = await out.copyPages(src, indices);
        copied.forEach(p => out.addPage(p));
        const bytes = await out.save();
        downloadBytes(bytes, `part-${c+1}-pages-${start+1}-${end}.pdf`);
        await sleep(200);
      }
      showStatus(`✅ Split into ${chunks} part${chunks!==1?'s':''} — check your downloads`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  // Individual pages mode
  document.getElementById('ps-split-individual').addEventListener('click', async () => {
    if (!currentFile) return;
    if (pageCount > 30) {
      if (!confirm(`This will download ${pageCount} files. Continue?`)) return;
    }
    showStatus(`Downloading ${pageCount} pages…`, 'info');
    try {
      await loadScript(PDFLIB_CDN);
      const { PDFDocument } = window.PDFLib;
      const src = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      for (let i = 0; i < pageCount; i++) {
        const out = await PDFDocument.create();
        const [copied] = await out.copyPages(src, [i]);
        out.addPage(copied);
        const bytes = await out.save();
        downloadBytes(bytes, `page-${i+1}.pdf`);
        showStatus(`Downloading page ${i+1} of ${pageCount}…`, 'info');
        await sleep(300);
      }
      showStatus(`✅ Downloaded ${pageCount} pages`, 'success');
    } catch(e) { showStatus('Error: ' + e.message, 'error'); }
  });

  document.getElementById('ps-clear').addEventListener('click', () => {
    currentFile = null; pageCount = 0; pdfBytes = null; thumbs = []; selectedPages.clear();
    panel.classList.add('hidden');
    drop.classList.remove('hidden');
    status.classList.add('hidden');
    loading.classList.add('hidden');
    grid.innerHTML = '';
    document.getElementById('ps-range').value = '';
  });

  function parseRange(str, max) {
    const nums = new Set();
    str.split(',').forEach(part => {
      part = part.trim();
      if (/^\d+$/.test(part)) { const n = parseInt(part); if (n >= 1 && n <= max) nums.add(n); }
      else if (/^\d+-\d+$/.test(part)) {
        const [a, b] = part.split('-').map(Number);
        for (let i = Math.min(a,b); i <= Math.min(Math.max(a,b), max); i++) nums.add(i);
      }
    });
    return [...nums].sort((a,b) => a-b);
  }

  function updateRangeHint() {
    const pages = parseRange(document.getElementById('ps-range').value, pageCount);
    document.getElementById('ps-range-hint').textContent = pages.length
      ? `${pages.length} page${pages.length !== 1 ? 's' : ''} selected`
      : document.getElementById('ps-range').value ? 'No valid pages in range' : '';
  }

  function updateHints() {
    updateRangeHint();
    const everyN = parseInt(document.getElementById('ps-every-n')?.value) || 1;
    const chunks = Math.ceil(pageCount / everyN);
    const evHint = document.getElementById('ps-every-hint');
    if (evHint) evHint.textContent = pageCount ? `→ ${chunks} part${chunks !== 1 ? 's' : ''}` : '';
    const indHint = document.getElementById('ps-individual-hint');
    if (indHint) indHint.textContent = pageCount ? `${pageCount} files will be downloaded` : '';
  }

  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

  function showStatus(msg, type) {
    status.textContent = msg;
    status.className = 'text-sm py-2 ' + (type === 'error' ? 'text-red-400' : type === 'success' ? 'text-green-400' : 'text-slate-400');
    status.classList.remove('hidden');
  }

  function downloadBytes(bytes, name) {
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1500);
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }
})();
</script>
