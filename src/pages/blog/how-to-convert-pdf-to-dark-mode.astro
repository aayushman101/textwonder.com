---
import BlogLayout from '../../layouts/BlogLayout.astro';

const faqs = [
  { q: 'Does converting a PDF to dark mode affect text quality?', a: 'The dark mode conversion renders each page as an image, so the output is pixel-based rather than vector text. Text remains very readable at the 2x rendering resolution, but it will no longer be selectable or searchable in the output PDF. Keep the original for text-based tasks.' },
  { q: 'Why does dark mode invert my images and charts?', a: 'Colour inversion affects everything on the page — not just the white background. Photographs become negative images and coloured charts look unusual. Dark mode PDF conversion works best for text-heavy documents with minimal colour graphics.' },
  { q: 'Can I convert back from dark mode to light mode?', a: 'Yes. Run the dark mode converter on the already-dark PDF — applying the inversion twice restores the original colours.' },
  { q: 'Will this work on a scanned PDF?', a: 'Yes. Scanned PDFs are already image-based, so the conversion works the same way as any other PDF — the scanner output is re-rendered in inverted colours.' },
  { q: 'Is the dark mode PDF smaller in file size?', a: 'The output is image-based so it may be slightly larger than the original text-based PDF, depending on compression. Use the PDF Compressor afterward to reduce the size.' },
  { q: 'Are my files uploaded when I use the tool?', a: 'No. PDFWonder processes everything in your browser. No files are sent to any server.' },
];
---

<BlogLayout
  title="How to Convert a PDF to Dark Mode Free Online (Invert PDF Colours)"
