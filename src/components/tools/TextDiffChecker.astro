---
---
<div class="space-y-4">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Original text (A)</label>
      <textarea id="tdc-a" rows="8" placeholder="Paste original text here…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Modified text (B)</label>
      <textarea id="tdc-b" rows="8" placeholder="Paste modified text here…" class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 resize-y focus:outline-none focus:border-violet-500 text-sm font-mono"></textarea>
    </div>
  </div>
  <div class="flex gap-2">
    <button id="tdc-compare" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Compare</button>
    <button id="tdc-clear" class="px-4 py-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-surface-hover)] text-slate-400 rounded-lg text-sm transition-colors border border-slate-700">Clear</button>
  </div>
  <div id="tdc-output-wrap" class="hidden space-y-3">
    <div id="tdc-stats" class="flex gap-4 text-xs flex-wrap">
      <span class="text-green-400">+ <span id="tdc-added">0</span> added</span>
      <span class="text-red-400">− <span id="tdc-removed">0</span> removed</span>
      <span class="text-slate-500">= <span id="tdc-same">0</span> unchanged</span>
    </div>
    <div id="tdc-diff" class="bg-[var(--bg-surface)] border border-slate-700 rounded-xl p-4 text-sm font-mono overflow-x-auto max-h-96 overflow-y-auto space-y-0.5"></div>
  </div>
</div>
<script>
  function diffLines(a, b) {
    const aLines = a.split('\n'), bLines = b.split('\n');
    const m = aLines.length, n = bLines.length;
    const dp = Array.from({length:m+1}, () => new Array(n+1).fill(0));
    for (let i = m-1; i >= 0; i--) for (let j = n-1; j >= 0; j--) {
      if (aLines[i] === bLines[j]) dp[i][j] = dp[i+1][j+1]+1;
      else dp[i][j] = Math.max(dp[i+1][j], dp[i][j+1]);
    }
    const result = [];
    let i=0, j=0;
    while (i<m || j<n) {
      if (i<m && j<n && aLines[i]===bLines[j]) { result.push({type:'same',text:aLines[i]}); i++; j++; }
      else if (j<n && (i>=m || dp[i][j+1]>=dp[i+1][j])) { result.push({type:'add',text:bLines[j]}); j++; }
      else { result.push({type:'del',text:aLines[i]}); i++; }
    }
    return result;
  }
  const aEl = document.getElementById('tdc-a');
  const bEl = document.getElementById('tdc-b');
  const wrap = document.getElementById('tdc-output-wrap');
  const diffEl = document.getElementById('tdc-diff');
  document.getElementById('tdc-compare').addEventListener('click', () => {
    const diff = diffLines(aEl.value, bEl.value);
    let added=0, removed=0, same=0;
    diffEl.innerHTML = diff.map(d => {
      if (d.type==='add') { added++; return `<div class="text-green-400 bg-green-950/30 px-2 rounded">+ ${escHtml(d.text)}</div>`; }
      if (d.type==='del') { removed++; return `<div class="text-red-400 bg-red-950/30 px-2 rounded">− ${escHtml(d.text)}</div>`; }
      same++; return `<div class="text-slate-400 px-2">&nbsp; ${escHtml(d.text)}</div>`;
    }).join('');
    document.getElementById('tdc-added').textContent = added;
    document.getElementById('tdc-removed').textContent = removed;
    document.getElementById('tdc-same').textContent = same;
    wrap.classList.remove('hidden');
  });
  function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') || '&nbsp;'; }
  document.getElementById('tdc-clear').addEventListener('click', () => { aEl.value=''; bEl.value=''; diffEl.innerHTML=''; wrap.classList.add('hidden'); });
</script>
