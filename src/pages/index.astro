  'line-counter': {
    bg: '#2563eb',
    iconHtml: `<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8 6h13M8 10h13M8 14h13M8 18h13"/><path d="M3 6h.01M3 10h.01M3 14h.01M3 18h.01"/></svg>`,
