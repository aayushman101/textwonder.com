---
---
<div class="space-y-5">
  <div id="icnv-drop" class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center cursor-pointer hover:border-rose-500/60 transition-colors">
    <input id="icnv-file" type="file" accept="image/*" class="hidden" />
    <div class="text-3xl mb-2">⇄</div>
    <p class="text-slate-300 font-medium">Drop an image here or <span class="text-rose-400 underline cursor-pointer">click to browse</span></p>
    <p class="text-slate-500 text-xs mt-1">JPG, PNG, WebP, BMP — converted in your browser</p>
  </div>

  <div id="icnv-panel" class="hidden space-y-4">
    <div class="flex flex-col sm:flex-row gap-4 items-start">
      <img id="icnv-preview" src="" alt="Preview" class="max-w-[180px] max-h-[140px] rounded-lg object-contain border border-slate-700 shrink-0" />
      <div class="flex-1 space-y-3">
        <div>
          <p id="icnv-file-info" class="text-xs text-slate-500 mb-3"></p>
          <label class="block text-xs text-slate-400 mb-1">Convert to</label>
          <div class="grid grid-cols-2 gap-2">
            {['JPEG', 'PNG', 'WebP', 'BMP'].map(fmt => (
              <label class="flex items-center gap-2 bg-[var(--bg-surface-hover)] border border-slate-700 rounded-lg px-3 py-2 cursor-pointer hover:border-rose-500/50 transition-colors">
                <input type="radio" name="icnv-fmt" value={fmt.toLowerCase()} class="accent-rose-500" />
                <span class="text-white text-sm">{fmt}</span>
              </label>
            ))}
          </div>
        </div>
        <div id="icnv-quality-row" class="hidden">
          <div class="flex justify-between text-xs text-slate-400 mb-1">
            <label>Quality</label>
            <span id="icnv-q-val" class="text-rose-400">92%</span>
          </div>
          <input id="icnv-quality" type="range" min="10" max="100" value="92" class="w-full accent-rose-500" />
        </div>
        <button id="icnv-btn" class="w-full py-2.5 bg-rose-600 hover:bg-rose-500 text-white rounded-lg font-semibold text-sm transition-colors">
          Convert & Download
        </button>
      </div>
    </div>
  </div>
</div>

<canvas id="icnv-canvas" class="hidden"></canvas>

<script is:inline>
(function () {
  const drop = document.getElementById('icnv-drop');
  const fileInput = document.getElementById('icnv-file');
  const panel = document.getElementById('icnv-panel');
  const preview = document.getElementById('icnv-preview');
  const fileInfo = document.getElementById('icnv-file-info');
  const qualityRow = document.getElementById('icnv-quality-row');
  const qualitySlider = document.getElementById('icnv-quality');
  const qValEl = document.getElementById('icnv-q-val');
  const btn = document.getElementById('icnv-btn');
  const canvas = document.getElementById('icnv-canvas');
  let img = null;

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('border-rose-500'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('border-rose-500'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('border-rose-500'); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

  function loadFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    img = new Image();
    img.onload = () => {
      preview.src = url;
      fileInfo.textContent = `${file.name} — ${img.naturalWidth}×${img.naturalHeight}px · ${(file.size/1024).toFixed(0)} KB`;
      panel.classList.remove('hidden');
      drop.classList.add('hidden');
    };
    img.src = url;
  }

  document.querySelectorAll('input[name="icnv-fmt"]').forEach(r => {
    r.addEventListener('change', () => {
      const v = r.value;
      qualityRow.classList.toggle('hidden', v === 'png' || v === 'bmp');
    });
  });

  qualitySlider.addEventListener('input', () => { qValEl.textContent = qualitySlider.value + '%'; });

  btn.addEventListener('click', () => {
    if (!img) return;
    const fmtRadio = document.querySelector('input[name="icnv-fmt"]:checked');
    const fmt = fmtRadio ? fmtRadio.value : 'jpeg';
    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    const ctx = canvas.getContext('2d');
    if (fmt === 'jpeg') { ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, canvas.width, canvas.height); }
    ctx.drawImage(img, 0, 0);
    const mime = fmt === 'bmp' ? 'image/bmp' : `image/${fmt}`;
    const q = parseInt(qualitySlider.value) / 100;
    canvas.toBlob(blob => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `converted.${fmt === 'jpeg' ? 'jpg' : fmt}`;
      a.click();
    }, mime, (fmt === 'jpeg' || fmt === 'webp') ? q : undefined);
  });
})();
</script>
