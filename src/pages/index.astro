---

<BaseLayout
  title="Free Online Text Tools — Word Counter, Case Converter & More | TextWonder"
  description="TextWonder offers 41+ free browser-based text tools. Remove emojis, count words, convert case, sort lines and more. No signup, no ads, 100% private."
  canonical="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <Header />

  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 pt-12 pb-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-3" style="font-family: 'Space Grotesk', sans-serif;">
        Every text tool you need,<br class="hidden sm:block" /> in one place
      </h1>
      <p class="text-slate-400 text-lg max-w-xl mx-auto mb-5">
        Free, browser-based text utilities. No signup, no ads, no data sent anywhere.
      </p>
      <div class="inline-flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <span><strong class="text-violet-400 font-semibold">41</strong> tools</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-violet-400 font-semibold">100%</strong> browser-based</span>
        <span class="hidden sm:inline text-slate-700">·</span>
        <span><strong class="text-violet-400 font-semibold">0</strong> signups required</span>
      </div>
    </section>

    <!-- Category filters + Tools grid -->
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <!-- Filter pills -->
      <div class="flex flex-wrap gap-2 mb-7 justify-center" id="filter-tabs">
        <button
          class="filter-pill px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-violet-600 text-white"
          data-filter="all"
        >
          All
        </button>
        {CATEGORIES.map(cat => (
          <button
            class="filter-pill px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-[var(--bg-surface)] border border-slate-700 text-slate-400 hover:border-slate-500 hover:text-white"
            data-filter={cat.slug}
          >
            {cat.icon} {cat.name}
          </button>
        ))}
      </div>

      <!-- Tools grid -->
      <div id="tools-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {TOOLS.map(tool => {
          const visual = toolIcons[tool.slug];
          return (
            <a
              href={`/tools/${tool.slug}`}
              class="tool-card group bg-[var(--bg-surface)] border border-slate-800 rounded-2xl p-4 hover:border-violet-500/50 hover:shadow-xl hover:shadow-violet-900/10 transition-all"
              data-category={tool.category}
            >
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 shrink-0"
                style={`background-color: ${visual.bg}`}
              >
                <Fragment set:html={visual.iconHtml} />
              </div>
              <h3 class="text-white font-semibold text-sm mb-1 group-hover:text-violet-300 transition-colors leading-snug">{tool.name}</h3>
              <p class="text-slate-500 text-xs leading-relaxed line-clamp-2">{tool.tagline}</p>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Trust section -->
    <section class="bg-[var(--bg-surface)] border-y border-slate-800 py-10">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="text-3xl mb-3">&#x1F512;</div>
        <h2 class="text-xl font-bold text-white mb-2" style="font-family: 'Space Grotesk', sans-serif;">Privacy by Design</h2>
        <p class="text-slate-400 text-sm max-w-xl mx-auto mb-6 leading-relaxed">
          TextWonder has no servers that receive your text. Every tool runs as JavaScript in your browser. When you close the tab, your text is gone.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-xl mx-auto">
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Servers</div>
            <div class="text-slate-500 text-xs">Processing stays on your device</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Accounts</div>
            <div class="text-slate-500 text-xs">No signup, no email, no passwords</div>
          </div>
          <div class="bg-[var(--bg-base)] rounded-xl p-3 border border-slate-800">
            <div class="text-emerald-400 font-semibold text-sm mb-0.5">No Tracking</div>
            <div class="text-slate-500 text-xs">No ad pixels or behaviour tracking</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SEO content -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', sans-serif;">Free Online Text Tools for Everyone</h2>
      <div class="text-slate-400 space-y-4 leading-relaxed text-sm">
        <p>
          TextWonder is a free collection of browser-based text utility tools designed for writers, developers, SEO professionals, data analysts, and anyone who works with text regularly. Every tool runs entirely in your browser — no server-side processing, no data uploads, no account required.
        </p>
        <p>
          Whether you need to <a href="/tools/remove-emojis" class="text-violet-400 hover:underline">remove emojis from text</a>, <a href="/tools/word-counter" class="text-violet-400 hover:underline">count words and characters</a>, <a href="/tools/title-case-converter" class="text-violet-400 hover:underline">convert text to title case</a>, or <a href="/tools/sort-lines" class="text-violet-400 hover:underline">sort lines alphabetically</a>, TextWonder has a dedicated, fast tool purpose-built for that task.
        </p>
        <p>
          TextWonder currently offers 41 free tools across four categories — Text Cleaning, Text Conversion, Text Analysis, and Text Formatting — with many more planned. All tools are free with no premium tier and no ads.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-4xl mx-auto px-4 pb-14">
      <h2 class="text-2xl font-bold text-white mb-6" style="font-family: 'Space Grotesk', sans-serif;">Frequently Asked Questions</h2>
      <div class="space-y-2">
        {homepageFaqs.map(faq => (
          <details class="bg-[var(--bg-surface)] border border-slate-800 rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-[var(--bg-surface-hover)] rounded-xl transition-colors">
              <span class="text-white font-medium text-sm">{faq.q}</span>
              <svg class="w-4 h-4 text-slate-400 shrink-0 ml-2 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4">
              <p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.tool-card');

  const ACTIVE = 'filter-pill px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-violet-600 text-white';
  const INACTIVE = 'filter-pill px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-[var(--bg-surface)] border border-slate-700 text-slate-400 hover:border-slate-500 hover:text-white';

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter;

      pills.forEach(p => { p.className = INACTIVE; });
      pill.className = ACTIVE;

      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });
