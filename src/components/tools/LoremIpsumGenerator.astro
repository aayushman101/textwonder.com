---
---
<div class="space-y-4">
  <div class="flex gap-3 flex-wrap items-end">
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Amount</label>
      <input id="lig-count" type="number" value="3" min="1" max="100" class="w-24 bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500" />
    </div>
    <div class="space-y-1">
      <label class="text-xs text-slate-500">Unit</label>
      <select id="lig-unit" class="bg-[var(--bg-surface)] border border-slate-700 rounded-lg px-3 py-2 text-slate-100 text-sm focus:outline-none focus:border-violet-500">
        <option value="paragraphs">Paragraphs</option>
        <option value="sentences">Sentences</option>
        <option value="words">Words</option>
      </select>
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer mb-0.5">
      <input type="checkbox" id="lig-classic" checked class="accent-violet-500"> Start with "Lorem ipsum…"
    </label>
    <button id="lig-do" class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors">Generate</button>
  </div>
  <div class="space-y-2">
    <div class="flex items-center justify-between">
      <span id="lig-stats" class="text-xs text-slate-500">Generated text</span>
      <button id="lig-copy" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">Copy</button>
    </div>
    <textarea id="lig-output" rows="10" readonly class="w-full bg-[var(--bg-surface)] border border-slate-700 rounded-xl px-4 py-3 text-slate-100 resize-y text-sm select-all leading-relaxed"></textarea>
  </div>
</div>
<script>
  const SENTENCES = [
    'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
    'Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
    'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.',
    'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.',
    'Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia.',
    'Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit.',
    'Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet.',
    'Ut labore et dolore magnam aliquam quaerat voluptatem.',
    'Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse.',
    'Nam libero tempore, cum soluta nobis est eligendi optio cumque nihil impedit.',
    'Temporibus autem quibusdam et aut officiis debitis aut rerum necessitatibus.',
    'Itaque earum rerum hic tenetur a sapiente delectus, ut aut reiciendis.',
    'Quis nostrum exercitationem ullam corporis suscipit laboriosam.',
    'At vero eos et accusamus et iusto odio dignissimos ducimus blanditiis.',
    'Nam libero tempore, cum soluta nobis est eligendi optio cumque nihil impedit.',
    'Similique sunt in culpa qui officia deserunt mollitia animi, id est laborum.',
  ];
  const WORDS = 'lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua enim ad minim veniam quis nostrud exercitation ullamco laboris nisi aliquip ex ea commodo consequat duis aute irure in reprehenderit voluptate velit esse cillum eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident sunt culpa qui officia deserunt mollit anim id est'.split(' ');
  function getParagraph(i, classic) {
    const start = (i === 0 && classic) ? 0 : Math.floor(Math.random() * 4);
    const len = 3 + Math.floor(Math.random() * 5);
    const sents = [];
    for (let j = 0; j < len; j++) sents.push(SENTENCES[(start + j) % SENTENCES.length]);
    return sents.join(' ');
  }
  function generate(count, unit, classic) {
    if (unit === 'words') {
      const wordList = classic ? ['Lorem','ipsum','dolor','sit','amet',...Array.from({length:count-5},()=>WORDS[Math.floor(Math.random()*WORDS.length)])] : Array.from({length:count},()=>WORDS[Math.floor(Math.random()*WORDS.length)]);
      return wordList.slice(0,count).join(' ') + '.';
    }
    if (unit === 'sentences') {
      const out = [];
      for (let i = 0; i < count; i++) out.push((i===0&&classic) ? SENTENCES[0] : SENTENCES[Math.floor(Math.random()*SENTENCES.length)]);
      return out.join(' ');
    }
    return Array.from({length:count},(_,i)=>getParagraph(i,classic)).join('\n\n');
  }
  const output = document.getElementById('lig-output');
  const stats = document.getElementById('lig-stats');
  const countEl = document.getElementById('lig-count');
  const unitEl = document.getElementById('lig-unit');
  const classicCb = document.getElementById('lig-classic');
  function run() {
    const count = Math.min(Math.max(parseInt(countEl.value)||1,1),100);
    const result = generate(count, unitEl.value, classicCb.checked);
    output.value = result;
    const wc = result.trim().split(/\s+/).length;
    stats.textContent = `${wc} words · ${result.length} characters`;
  }
  document.getElementById('lig-do').addEventListener('click', run);
  document.getElementById('lig-copy').addEventListener('click', () => navigator.clipboard.writeText(output.value));
  run();
</script>
